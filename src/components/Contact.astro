---
import { site, socials } from '../data/site';
import Icon from './Icon.astro';
---
<section class="section" id="contato">
  <div class="container">
    <div class="cta" data-reveal>
      <div class="cta-glow" aria-hidden="true"></div>
      <p class="eyebrow">Contato</p>
      <h2 class="cta-title">Vamos construir algo juntos?</h2>
      <p class="cta-lead">
        Projeto novo, aula, mentoria ou só trocar ideia sobre código e jogos — minha caixa de
        entrada está aberta.
      </p>

      <div class="cta-actions">
        <a href={`mailto:${site.email}`} class="btn">
          <Icon name="email" size={18} /> {site.email}
        </a>
      </div>

      <div class="cta-socials">
        {
          socials.map((s) => (
            <a href={s.url} target="_blank" rel="noopener" aria-label={s.nome} title={s.nome}>
              <Icon name={s.icone} size={20} />
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    text-align: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) + 6px);
    padding: clamp(40px, 7vw, 72px) 24px;
    overflow: hidden;
  }
  .cta-glow {
    position: absolute;
    top: -40%;
    left: 50%;
    width: 600px;
    height: 400px;
    transform: translateX(-50%);
    background: radial-gradient(closest-side, var(--accent-glow), transparent);
    pointer-events: none;
  }
  .cta .eyebrow { justify-content: center; }
  .cta-title {
    font-size: clamp(1.9rem, 5vw, 3rem);
    margin-block: 14px 16px;
  }
  .cta-lead {
    color: var(--text-soft);
    max-width: 48ch;
    margin-inline: auto;
    font-size: 1.08rem;
  }
  .cta-actions {
    margin-top: 30px;
    display: flex;
    justify-content: center;
  }
  .cta-actions .btn { font-family: var(--font-mono); }
  .cta-socials {
    margin-top: 26px;
    display: flex;
    gap: 10px;
    justify-content: center;
  }
  .cta-socials a {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 11px;
    border: 1px solid var(--border);
    color: var(--text-soft);
    transition: all 0.2s var(--ease);
  }
  .cta-socials a:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-3px);
  }
</style>
