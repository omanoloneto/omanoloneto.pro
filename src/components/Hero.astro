---
import { site, socials } from '../data/site';
import Icon from './Icon.astro';
---
<section class="hero" id="conteudo">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow" data-reveal>Olá, eu sou {site.nome}</p>

      <h1 class="hero-title" data-reveal>
        {site.tagline}
      </h1>

      <p class="hero-desc" data-reveal>{site.descricao}</p>

      <div class="hero-actions" data-reveal>
        <a href="#projetos" class="btn">
          Ver projetos <Icon name="arrow" size={18} />
        </a>
        <a href="#contato" class="btn btn--ghost">Entrar em contato</a>
      </div>

      <div class="hero-socials" data-reveal>
        {
          socials.map((s) => (
            <a href={s.url} target="_blank" rel="noopener" aria-label={s.nome} title={s.nome}>
              <Icon name={s.icone} size={20} />
            </a>
          ))
        }
      </div>
    </div>

    <!-- Terminal decorativo -->
    <div class="hero-card" data-reveal aria-hidden="true">
      <div class="term">
        <div class="term-bar">
          <span></span><span></span><span></span>
          <em>~/dev/sobre.ts</em>
        </div>
        <pre class="term-body"><code><span class="c-kw">const</span> <span class="c-var">eu</span> = {'{'}
  <span class="c-prop">nome</span>: <span class="c-str">'{site.nome}'</span>,
  <span class="c-prop">faz</span>: [<span class="c-str">'jogos'</span>, <span class="c-str">'apps'</span>, <span class="c-str">'aulas'</span>],
  <span class="c-prop">stack</span>: [<span class="c-str">'Flutter'</span>, <span class="c-str">'Godot'</span>, <span class="c-str">'Unity'</span>],
  <span class="c-prop">cafe</span>: <span class="c-bool">true</span>,
{'}'};

<span class="c-var">eu</span>.<span class="c-fn">construir</span>(<span class="c-str">'algo incrível'</span>);
<span class="c-cmt">// → enviando... ✓</span></code></pre>
      </div>
    </div>
  </div>

  <a href="#sobre" class="scroll-hint" aria-label="Rolar para baixo">
    <span></span>
  </a>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 90px;
    position: relative;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(32px, 6vw, 72px);
    align-items: center;
  }
  .hero-title {
    font-size: clamp(2.3rem, 6vw, 4rem);
    margin-block: 16px 20px;
    background: linear-gradient(180deg, #fff 30%, #c4cedd);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-desc {
    color: var(--text-soft);
    font-size: 1.12rem;
    max-width: 50ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }
  .hero-socials {
    display: flex;
    gap: 8px;
    margin-top: 28px;
  }
  .hero-socials a {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border-radius: 10px;
    border: 1px solid var(--border);
    color: var(--text-soft);
    transition: all 0.2s var(--ease);
  }
  .hero-socials a:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  /* Terminal */
  .term {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    transform: perspective(1200px) rotateY(-6deg) rotateX(2deg);
    transition: transform 0.4s var(--ease);
  }
  .term:hover { transform: none; }
  .term-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 14px;
    background: var(--bg-soft);
    border-bottom: 1px solid var(--border);
  }
  .term-bar span {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #2c3647;
  }
  .term-bar span:nth-child(1) { background: #ff5f57; }
  .term-bar span:nth-child(2) { background: #febc2e; }
  .term-bar span:nth-child(3) { background: #28c840; }
  .term-bar em {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--text-dim);
    font-style: normal;
  }
  .term-body {
    margin: 0;
    padding: 20px;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    line-height: 1.8;
    overflow-x: auto;
    color: var(--text-soft);
  }
  .c-kw { color: #c084fc; }
  .c-var { color: var(--accent-2); }
  .c-prop { color: #f0b8a0; }
  .c-str { color: var(--accent); }
  .c-bool { color: #fbbf24; }
  .c-fn { color: #f0b8a0; }
  .c-cmt { color: var(--text-dim); font-style: italic; }

  .scroll-hint {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    width: 26px;
    height: 42px;
    border: 2px solid var(--border-strong);
    border-radius: 14px;
    display: grid;
    place-items: start center;
    padding-top: 8px;
  }
  .scroll-hint span {
    width: 4px;
    height: 8px;
    background: var(--accent);
    border-radius: 2px;
    animation: scrollDot 1.6s infinite;
  }
  @keyframes scrollDot {
    0% { opacity: 0; transform: translateY(0); }
    40% { opacity: 1; }
    80%, 100% { opacity: 0; transform: translateY(12px); }
  }

  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-card { order: -1; max-width: 460px; }
    .term { transform: none; }
    .scroll-hint { display: none; }
  }
</style>
