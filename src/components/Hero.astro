---
import { site, socials } from '../data/site';
import Icon from './Icon.astro';
---
<section class="hero" id="conteudo">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow" data-reveal>Manolo Neto · dev &amp; professor</p>

      <h1 class="hero-title" data-reveal>
        {site.tagline}
      </h1>

      <p class="hero-desc" data-reveal>{site.descricao}</p>

      <div class="hero-actions" data-reveal>
        <a href="#projetos" class="btn">
          Ver meus jogos <Icon name="arrow" size={18} />
        </a>
        <a href="/class/" class="btn btn--ghost">🎒 Sala de aula</a>
      </div>

      <div class="hero-socials" data-reveal>
        {
          socials.map((s) => (
            <a href={s.url} target="_blank" rel="noopener" aria-label={s.nome} title={s.nome}>
              <Icon name={s.icone} size={20} />
            </a>
          ))
        }
      </div>
    </div>

    <!-- Save slot: cartão de "continuar jogo" -->
    <div class="hero-card" data-reveal aria-hidden="true">
      <div class="save">
        <div class="save__top">— CONTINUAR? —</div>
        <div class="save__body">
          <div class="save__row save__slot">SLOT 01 <span class="save__cursor">▮</span></div>
          <div class="save__row save__nome">MANOLO NETO</div>
          <dl class="save__stats">
            <div><dt>CLASSE</dt><dd>DEV · PROFESSOR</dd></div>
            <div><dt>MISSÃO</dt><dd>FRANQUIA VMONSTERS</dd></div>
            <div><dt>ENGINES</dt><dd>UNITY · GODOT · FLUTTER</dd></div>
            <div><dt>PARTY</dt><dd>1 TURMA DE CRIANÇAS</dd></div>
          </dl>
          <div class="save__prog">
            <span class="save__prog-label">PROGRESSO</span>
            <span class="save__prog-bar"><i></i></span>
            <span class="save__prog-pct">87%*</span>
          </div>
          <p class="save__nota">*nunca chega em 100. sempre tem update.</p>
        </div>
        <div class="save__acoes">
          <a href="#projetos">▶ CONTINUAR</a>
          <a href="#contato">+ NOVO JOGO</a>
        </div>
      </div>
    </div>
  </div>

  <a href="#sobre" class="scroll-hint" aria-label="Rolar para baixo">
    <span></span>
  </a>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 90px;
    position: relative;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(32px, 6vw, 72px);
    align-items: center;
  }
  .hero-title {
    font-size: clamp(2.2rem, 5.6vw, 3.7rem);
    margin-block: 16px 20px;
    background: linear-gradient(180deg, #fff 30%, #c4cedd);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-desc {
    color: var(--text-soft);
    font-size: 1.12rem;
    max-width: 50ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }
  .hero-socials {
    display: flex;
    gap: 8px;
    margin-top: 28px;
  }
  .hero-socials a {
    width: 42px;
    height: 42px;
    display: grid;
    place-items: center;
    border-radius: 10px;
    border: 1px solid var(--border);
    color: var(--text-soft);
    transition: all 0.2s var(--ease);
  }
  .hero-socials a:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  /* ===== Save slot ===== */
  .save {
    font-family: var(--font-mono);
    background: var(--bg-card);
    border: 2px solid var(--border-strong);
    box-shadow: 0 0 0 4px var(--bg), 0 0 0 6px var(--border), var(--shadow);
    border-radius: 6px;
    overflow: hidden;
    max-width: 430px;
    margin-inline: auto;
  }
  .save__top {
    text-align: center;
    padding: 10px;
    font-size: 0.78rem;
    letter-spacing: 0.35em;
    color: var(--accent);
    border-bottom: 2px solid var(--border);
    background: var(--bg-soft);
  }
  .save__body { padding: 20px 22px 14px; }
  .save__slot {
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.2em;
  }
  .save__cursor { color: var(--accent); animation: pisca 1.1s steps(1) infinite; }
  @keyframes pisca { 50% { opacity: 0; } }
  .save__nome {
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text);
    margin: 4px 0 14px;
  }
  .save__stats { display: grid; gap: 7px; margin: 0; }
  .save__stats div { display: flex; gap: 10px; font-size: 0.78rem; }
  .save__stats dt { color: var(--text-dim); min-width: 72px; }
  .save__stats dd { color: var(--text-soft); margin: 0; }

  .save__prog {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 16px;
    font-size: 0.72rem;
  }
  .save__prog-label { color: var(--text-dim); letter-spacing: 0.1em; }
  .save__prog-bar {
    flex: 1;
    height: 10px;
    border: 1px solid var(--border-strong);
    padding: 1.5px;
    display: block;
  }
  .save__prog-bar i {
    display: block;
    height: 100%;
    width: 87%;
    background: repeating-linear-gradient(90deg, var(--accent) 0 6px, transparent 6px 8px);
  }
  .save__prog-pct { color: var(--accent); }
  .save__nota {
    margin-top: 8px;
    font-size: 0.68rem;
    color: var(--text-dim);
    font-style: italic;
  }
  .save__acoes {
    display: flex;
    border-top: 2px solid var(--border);
  }
  .save__acoes a {
    flex: 1;
    text-align: center;
    padding: 12px 8px;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    color: var(--text-soft);
    transition: background 0.15s, color 0.15s;
  }
  .save__acoes a:first-child { border-right: 2px solid var(--border); color: var(--accent); }
  .save__acoes a:hover { background: var(--bg-card-hover); color: var(--accent); }

  .scroll-hint {
    position: absolute;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%);
    width: 26px;
    height: 42px;
    border: 2px solid var(--border-strong);
    border-radius: 14px;
    display: grid;
    place-items: start center;
    padding-top: 8px;
  }
  .scroll-hint span {
    width: 4px;
    height: 8px;
    background: var(--accent);
    border-radius: 2px;
    animation: scrollDot 1.6s infinite;
  }
  @keyframes scrollDot {
    0% { opacity: 0; transform: translateY(0); }
    40% { opacity: 1; }
    80%, 100% { opacity: 0; transform: translateY(12px); }
  }

  @media (max-width: 860px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-card { order: -1; }
    .scroll-hint { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .save__cursor { animation: none; }
  }
</style>
