---
import Icon from './Icon.astro';

const itens = [
  {
    titulo: 'Jogos educativos',
    desc: 'Organizador da Área de Trabalho (hardware × software) e Trem de Palavras (sílabas). Feitos pras minhas turmas, abertos pra qualquer escola usar de graça.',
    url: '/class/',
    urlLabel: 'Jogar',
  },
  {
    titulo: 'Controle de Aula',
    desc: 'Extensão + app pro professor comandar os Chromebooks da turma pelo celular, pela rede local. Código aberto.',
    url: '/class/controle-de-aula/',
    urlLabel: 'Conhecer',
  },
  {
    titulo: 'Aulas e mentoria',
    desc: 'Programação e desenvolvimento de jogos, do zero ao primeiro projeto publicado. Pra crianças curiosas e adultos mudando de área.',
    url: '#contato',
    urlLabel: 'Falar comigo',
  },
];
---
<section class="section" id="ensino">
  <div class="container">
    <div class="teach-grid">
      <div class="teach-intro" data-reveal>
        <p class="eyebrow"><Icon name="teach" size={16} /> Professor</p>
        <h2 class="section-title">Minha sala de aula tem botão de jogar</h2>
        <p class="section-lead">
          Em vez de slide, jogo. As crianças aprendem tecnologia jogando no navegador — nos
          Chromebooks da escola ou em casa. Tudo que eu faço pras minhas turmas fica publicado
          aqui no site.
        </p>
        <a href="/class/" class="btn" style="margin-top:24px">
          🎒 Entrar na sala de aula <Icon name="arrow" size={18} />
        </a>
      </div>

      <div class="teach-cards">
        {
          itens.map((o) => (
            <a class="teach-card" data-reveal href={o.url}>
              <div class="teach-card__txt">
                <h3>{o.titulo}</h3>
                <p>{o.desc}</p>
              </div>
              <span class="teach-card__go">{o.urlLabel} →</span>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .teach-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: clamp(32px, 5vw, 60px);
    align-items: center;
  }
  .teach-cards { display: grid; gap: 14px; }
  .teach-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--radius-sm);
    padding: 20px 22px;
    transition: transform 0.25s var(--ease), background 0.25s, border-color 0.25s;
  }
  .teach-card:hover {
    transform: translateX(5px);
    background: var(--bg-card-hover);
    border-color: var(--border-strong);
    border-left-color: var(--accent);
  }
  .teach-card h3 { font-size: 1.1rem; margin-bottom: 6px; }
  .teach-card p { color: var(--text-soft); font-size: 0.95rem; }
  .teach-card__go {
    flex-shrink: 0;
    color: var(--accent);
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
  }

  @media (max-width: 800px) {
    .teach-grid { grid-template-columns: 1fr; }
    .teach-card { flex-direction: column; align-items: flex-start; }
  }
</style>
