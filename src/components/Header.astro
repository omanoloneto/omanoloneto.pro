---
import { site } from '../data/site';

const nav = [
  { label: 'Sobre', href: '#sobre' },
  { label: 'Projetos', href: '#projetos' },
  { label: 'Stack', href: '#skills' },
  { label: 'Ensino', href: '#ensino' },
  { label: 'Contato', href: '#contato' },
  { label: '🎒 Aulas', href: '/class/', destaque: true },
];
const iniciais = site.nome
  .split(' ')
  .map((p) => p[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
---
<header class="site-header" id="topo" data-header>
  <div class="container bar">
    <a href="#topo" class="brand" aria-label={site.nome}>
      <span class="brand-mark">{iniciais}</span>
      <span class="brand-name">{site.nome}</span>
    </a>

    <nav class="nav" aria-label="Navegação principal">
      {nav.map((item) => <a href={item.href} class:list={[{ 'nav-cta': item.destaque }]}>{item.label}</a>)}
    </nav>

    <button class="menu-toggle" aria-label="Abrir menu" aria-expanded="false" data-menu-toggle>
      <span></span><span></span><span></span>
    </button>
  </div>

  <nav class="mobile-nav" aria-label="Navegação mobile" data-mobile-nav hidden>
    {nav.map((item) => <a href={item.href} data-mobile-link>{item.label}</a>)}
  </nav>
</header>

<script>
  const header = document.querySelector('[data-header]');
  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 12);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  const toggle = document.querySelector('[data-menu-toggle]');
  const mobileNav = document.querySelector('[data-mobile-nav]');
  const close = () => {
    mobileNav?.setAttribute('hidden', '');
    toggle?.setAttribute('aria-expanded', 'false');
    header?.classList.remove('menu-open');
  };
  toggle?.addEventListener('click', () => {
    const open = mobileNav?.hasAttribute('hidden');
    if (open) {
      mobileNav?.removeAttribute('hidden');
      toggle.setAttribute('aria-expanded', 'true');
      header?.classList.add('menu-open');
    } else {
      close();
    }
  });
  document.querySelectorAll('[data-mobile-link]').forEach((a) => a.addEventListener('click', close));
</script>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    transition: background 0.3s, border-color 0.3s, backdrop-filter 0.3s;
    border-bottom: 1px solid transparent;
  }
  .site-header.is-scrolled,
  .site-header.menu-open {
    background: rgba(10, 14, 20, 0.8);
    backdrop-filter: blur(12px);
    border-bottom-color: var(--border);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    font-weight: 700;
    letter-spacing: -0.01em;
  }
  .brand-mark {
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 9px;
    background: linear-gradient(135deg, var(--accent), var(--accent-2));
    color: #04130d;
    font-size: 0.85rem;
    font-weight: 800;
  }
  .nav {
    display: flex;
    gap: 6px;
  }
  .nav a {
    padding: 8px 14px;
    border-radius: 8px;
    color: var(--text-soft);
    font-size: 0.92rem;
    font-weight: 500;
    transition: color 0.2s, background 0.2s;
  }
  .nav a:hover {
    color: var(--text);
    background: var(--bg-card);
  }
  .nav a.nav-cta {
    color: var(--accent);
    border: 1px solid var(--border-strong);
    margin-left: 6px;
  }
  .nav a.nav-cta:hover {
    border-color: var(--accent);
    background: var(--accent-glow);
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 8px;
  }
  .menu-toggle span {
    width: 24px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 8px 24px 20px;
    gap: 2px;
  }
  /* O media query abaixo liga display:flex — sem isto, a regra de autor
     venceria o [hidden] do navegador e o menu ficaria SEMPRE aberto. */
  .mobile-nav[hidden] { display: none !important; }
  .mobile-nav a {
    padding: 12px 8px;
    color: var(--text-soft);
    border-bottom: 1px solid var(--border);
    font-weight: 500;
  }
  .mobile-nav a:last-child { border-bottom: 0; }

  @media (max-width: 720px) {
    .nav { display: none; }
    .menu-toggle { display: flex; }
    .mobile-nav { display: flex; }
    .brand-name { display: none; }
  }
</style>
