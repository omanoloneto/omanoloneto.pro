---
import { site } from '../data/site';
const ano = new Date().getFullYear();
---
<footer class="footer">
  <div class="container foot-bar">
    <p>© {ano} {site.nome}. Feito à mão, sem template.</p>
    <a href="#topo" class="to-top">Voltar ao topo ↑</a>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    background: var(--bg-soft);
    padding-block: 26px;
  }
  .foot-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    color: var(--text-dim);
    font-size: 0.9rem;
  }
  .to-top { transition: color 0.2s; }
  .to-top:hover { color: var(--accent); }
  @media (max-width: 520px) {
    .foot-bar { flex-direction: column; gap: 8px; text-align: center; }
  }
</style>
