---
const grupos = [
  {
    titulo: 'Game Dev',
    itens: ['Unity / C#', 'Godot / GDScript', 'Flutter / Flame', 'Game Design', 'Pixel & 2D Art'],
  },
  {
    titulo: 'Desenvolvimento',
    itens: ['Dart', 'TypeScript', 'C#', 'Python', 'HTML / CSS'],
  },
  {
    titulo: 'Plataforma & Backend',
    itens: ['Firebase', 'Firestore', 'Android / iOS', 'CI/CD', 'Git'],
  },
  {
    titulo: 'Ensino',
    itens: ['Mentoria 1:1', 'Aulas práticas', 'Material didático', 'Code review'],
  },
];
---
<section class="section section--soft" id="skills">
  <div class="container">
    <div class="head" data-reveal>
      <p class="eyebrow">Stack & Skills</p>
      <h2 class="section-title">Ferramentas que uso no dia a dia</h2>
    </div>

    <div class="grid">
      {
        grupos.map((g) => (
          <div class="group" data-reveal>
            <h3 class="group-title">{g.titulo}</h3>
            <ul class="group-list">
              {g.itens.map((i) => <li class="chip">{i}</li>)}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section--soft {
    background: var(--bg-soft);
    border-block: 1px solid var(--border);
  }
  .head { margin-bottom: 36px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }
  .group {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
  }
  .group-title {
    font-size: 1.05rem;
    margin-bottom: 16px;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .group-title::before {
    content: '';
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
  }
  .group-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
  }
  .group .chip {
    background: var(--bg-soft);
    font-size: 0.82rem;
    padding: 6px 12px;
  }
  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
