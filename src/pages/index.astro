---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
import { site, socials } from '../data/site';

// Home: cartão de visitas tipográfico. A hierarquia faz o trabalho:
// nome → statement grande → uma linha de contexto → CTA → redes.
// Textos e links vêm de src/data/site.ts.
---

<Layout>
  <main class="cartao" id="conteudo">
    <div class="cartao__miolo">
      <p class="eyebrow" data-reveal>{site.nome} · {site.localizacao}</p>

      <h1 class="statement" data-reveal>
        <span class="statement__destaque">Faço jogos.</span><br />
        E ensino crianças a fazer os delas.
      </h1>

      <p class="contexto" data-reveal>{site.descricao}</p>

      <div class="acoes" data-reveal>
        <a href="/class/games/" class="btn">
          Sala de aula <Icon name="arrow" size={18} />
        </a>
      </div>

      <nav class="redes" aria-label="Redes e contato" data-reveal>
        {
          socials.map((s) => (
            <a class="redes__link" href={s.url} target="_blank" rel="noopener">
              <Icon name={s.icone} size={18} />
              <span>{s.nome}</span>
            </a>
          ))
        }
      </nav>
    </div>

    <p class="assinatura" data-reveal>© {site.nome}</p>
  </main>
</Layout>

<style>
  .cartao {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 48px 24px 28px;
    gap: clamp(28px, 6vh, 56px);
  }

  .cartao__miolo {
    width: min(92vw, 660px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* ===== Eyebrow (traço vem do .eyebrow::before do global.css) ===== */
  .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  /* ===== Statement ===== */
  .statement {
    margin-block: 22px 18px;
    font-size: clamp(2.3rem, 7.2vw, 4.1rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
    font-weight: 800;
    color: var(--text);
    text-wrap: balance;
  }
  .statement__destaque {
    color: var(--accent);
  }

  /* ===== Contexto ===== */
  .contexto {
    color: var(--text-soft);
    font-size: clamp(1rem, 2.6vw, 1.13rem);
    line-height: 1.65;
    max-width: 46ch;
  }

  /* ===== Ações ===== */
  .acoes {
    margin-top: 30px;
  }

  /* ===== Redes ===== */
  .redes {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 22px;
    margin-top: 34px;
  }
  .redes__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 0;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--text-dim);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .redes__link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .redes__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 3px;
    border-radius: 4px;
  }

  .assinatura {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--text-dim);
  }

  @media (max-width: 480px) {
    .acoes :global(.btn) {
      width: 100%;
      justify-content: center;
    }
    .redes {
      gap: 4px 18px;
    }
  }
</style>
