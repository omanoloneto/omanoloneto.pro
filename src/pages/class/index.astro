---
import Layout from '../../layouts/Layout.astro';

const title = 'Sala de Aula do Professor Manolo — jogos pra aprender brincando';
const description =
  'Jogos educativos gratuitos, em português, direto no navegador: hardware × software, montar palavras com sílabas e mais. Feitos por um professor pras próprias turmas.';

const jogos = [
  {
    url: '/class/games/desktop-organizer/',
    emoji: '🖥️',
    nome: 'Organizador da Área de Trabalho',
    linha: 'Hardware ou Software? Arraste cada ícone pra pasta certa!',
    tema: 'azul',
    tags: ['arrastar e soltar', '3 fases'],
  },
  {
    url: '/class/games/trem-de-palavras/',
    emoji: '🚂',
    nome: 'Trem de Palavras',
    linha: 'Monte palavras com os vagões de sílabas e faça o trem partir!',
    tema: 'verde',
    tags: ['sílabas', '7 níveis'],
  },
];
---

<Layout title={title} description={description}>
  <main class="sala" id="conteudo">
    <div class="ceu" aria-hidden="true">
      <span class="sol"></span>
      <span class="nuvem n1"></span>
      <span class="nuvem n2"></span>
      <span class="nuvem n3"></span>
      <span class="montes"></span>
    </div>

    <div class="conteudo">
      <header class="cab">
        <p class="cab__prof">a sala de aula do</p>
        <h1 class="cab__titulo">Professor Manolo</h1>
        <p class="cab__sub">🎮 Jogos pra aprender brincando — é só escolher e jogar!</p>
      </header>

      <section class="jogos" aria-label="Escolha seu jogo">
        {
          jogos.map((j) => (
            <a class:list={['jogo', 'jogo--' + j.tema]} href={j.url}>
              <span class="jogo__emoji" aria-hidden="true">{j.emoji}</span>
              <span class="jogo__info">
                <span class="jogo__nome">{j.nome}</span>
                <span class="jogo__linha">{j.linha}</span>
                <span class="jogo__tags">
                  {j.tags.map((t) => <i>{t}</i>)}
                </span>
              </span>
              <span class="jogo__play" aria-hidden="true">JOGAR ▶</span>
            </a>
          ))
        }

        <div class="jogo jogo--breve" aria-hidden="true">
          <span class="jogo__emoji">🎁</span>
          <span class="jogo__info">
            <span class="jogo__nome">Em breve…</span>
            <span class="jogo__linha">O professor está preparando o próximo jogo!</span>
          </span>
        </div>
      </section>

      <footer class="pe">
        <p class="pe__prof">
          👩‍🏫 Professor(a)? Os jogos são livres pra usar na sua escola.
          Conheça também o <a href="/class/controle-de-aula/">Controle de Aula</a> —
          comande os Chromebooks da turma pelo celular.
        </p>
        <a class="pe__site" href="/">← site do Manolo</a>
      </footer>
    </div>
  </main>
</Layout>

<style is:global>
  body.is-class { background: #6db3e8; overflow-x: hidden; }
  body.is-class::before { display: none !important; }
</style>

<script>
  document.body.classList.add('is-class');
</script>

<style>
  .sala {
    position: relative;
    min-height: 100svh;
    font-family: Verdana, Tahoma, 'Segoe UI', Geneva, sans-serif;
    color: #23303c;
    display: flex;
    flex-direction: column;
  }

  /* ===== Cenário ===== */
  .ceu {
    position: fixed;
    inset: 0;
    z-index: 0;
    background: linear-gradient(180deg, #4ba3e8 0%, #7ec8f0 50%, #c9ecff 100%);
  }
  .sol {
    position: absolute; top: 6%; right: 7%;
    width: 90px; height: 90px; border-radius: 50%;
    background: radial-gradient(circle, #ffe873 55%, #ffd23f 75%, rgba(255, 210, 63, 0) 100%);
    box-shadow: 0 0 50px 16px rgba(255, 220, 90, 0.55);
  }
  .nuvem {
    position: absolute;
    background: radial-gradient(closest-side, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0) 72%);
    border-radius: 50%;
  }
  .n1 { width: 240px; height: 90px; top: 8%; left: 6%; }
  .n2 { width: 180px; height: 70px; top: 18%; left: 55%; opacity: 0.9; }
  .n3 { width: 150px; height: 60px; top: 34%; left: 24%; opacity: 0.75; }
  .montes {
    position: absolute; left: -6%; right: -6%; bottom: 0; height: 34%;
    border-radius: 58% 46% 0 0 / 100% 88% 0 0;
    background: linear-gradient(180deg, #8fce58 0%, #5fa838 60%, #48862a 100%);
  }

  .conteudo {
    position: relative;
    z-index: 1;
    width: min(760px, 92vw);
    margin-inline: auto;
    padding: clamp(28px, 6vh, 64px) 0 28px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* ===== Cabeçalho ===== */
  .cab { text-align: center; color: #fff; margin-bottom: clamp(22px, 4vh, 40px); }
  .cab__prof {
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.35);
  }
  .cab__titulo {
    font-size: clamp(2.1rem, 6vw, 3.4rem);
    line-height: 1.05;
    margin: 2px 0 12px;
    text-shadow: 0 3px 0 rgba(35, 80, 30, 0.35), 0 6px 18px rgba(0, 0, 0, 0.3);
    letter-spacing: -0.01em;
  }
  .cab__sub {
    font-size: clamp(1rem, 2.6vw, 1.15rem);
    font-weight: 700;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.4);
  }

  /* ===== Cartões de jogo ===== */
  .jogos { display: grid; gap: 16px; }
  .jogo {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 18px 22px;
    border-radius: 20px;
    background: #fff;
    border: 3px solid rgba(0, 0, 0, 0.12);
    box-shadow: 0 6px 0 rgba(0, 0, 0, 0.14), 0 12px 26px rgba(0, 0, 0, 0.18);
    color: #23303c;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }
  a.jogo:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 0 rgba(0, 0, 0, 0.14), 0 18px 32px rgba(0, 0, 0, 0.22);
  }
  a.jogo:active { transform: translateY(0); box-shadow: 0 3px 0 rgba(0, 0, 0, 0.14); }
  a.jogo:focus-visible { outline: 4px solid #fff; outline-offset: 3px; }

  .jogo--azul { background: linear-gradient(135deg, #e8f4ff, #d3e9fc); border-color: #2f7fc0; }
  .jogo--verde { background: linear-gradient(135deg, #eefae4, #ddf3cd); border-color: #43a431; }
  .jogo--breve {
    background: rgba(255, 255, 255, 0.55);
    border-style: dashed;
    border-color: rgba(255, 255, 255, 0.9);
    box-shadow: none;
    color: #2c4a5e;
  }

  .jogo__emoji {
    font-size: clamp(2.6rem, 7vw, 3.6rem);
    line-height: 1;
    flex-shrink: 0;
    filter: drop-shadow(0 3px 3px rgba(0, 0, 0, 0.2));
  }
  .jogo__info { flex: 1; display: flex; flex-direction: column; gap: 4px; min-width: 0; }
  .jogo__nome { font-size: clamp(1.1rem, 3vw, 1.35rem); font-weight: 800; }
  .jogo__linha { font-size: clamp(0.86rem, 2.4vw, 0.98rem); color: #40566a; }
  .jogo__tags { display: flex; gap: 8px; margin-top: 4px; flex-wrap: wrap; }
  .jogo__tags i {
    font-style: normal;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.08);
  }
  .jogo__play {
    flex-shrink: 0;
    font-weight: 800;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    color: #fff;
    padding: 12px 18px;
    border-radius: 14px;
    background: linear-gradient(180deg, #6cc24a 0%, #43a431 55%, #2e8a28 100%);
    border: 2px solid #256b20;
    box-shadow: 0 4px 0 #1d5619;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.35);
  }
  a.jogo:hover .jogo__play { filter: brightness(1.08); }

  /* ===== Rodapé ===== */
  .pe {
    margin-top: auto;
    padding-top: clamp(26px, 5vh, 44px);
    text-align: center;
  }
  .pe__prof {
    font-size: 0.88rem;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.45);
    max-width: 54ch;
    margin-inline: auto;
    line-height: 1.6;
  }
  .pe__prof a {
    color: #ffe873;
    font-weight: 700;
    text-decoration: underline;
  }
  .pe__site {
    display: inline-block;
    margin-top: 14px;
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4);
  }
  .pe__site:hover { color: #fff; }

  @media (max-width: 560px) {
    .jogo { flex-direction: column; text-align: center; gap: 10px; }
    .jogo__info { align-items: center; }
    .jogo__play { width: 100%; text-align: center; }
  }
</style>
