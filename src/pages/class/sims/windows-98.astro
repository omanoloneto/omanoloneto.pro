        <tr><td>🐍 Cobrinha Espacial</td><td>800 KB</td><td>4 minutos</td><td><button type="button" class="bisel-alto pg-baixar" data-baixar="Cobrinha Espacial">Baixar</button></td></tr>
        <tr><td>🏎️ Corrida Maluca 98</td><td>2,5 MB</td><td>12 minutos</td><td><button type="button" class="bisel-alto pg-baixar" data-baixar="Corrida Maluca 98">Baixar</button></td></tr>
        <tr><td>🧙 A Masmorra do Mago</td><td>34 MB</td><td>quase 3 HORAS</td><td><button type="button" class="bisel-alto pg-baixar" data-baixar="A Masmorra do Mago">Baixar</button></td></tr>
        <tr><td>⚽ Super Futebol Estrela</td><td>300 MB</td><td>17 HORAS 😱</td><td><button type="button" class="bisel-alto pg-baixar" data-baixar="Super Futebol Estrela">Baixar</button></td></tr>
      </tbody>
    </table>
    <p><small>*Tempo com modem de 56k e NINGUÉM usando o telefone de casa. Se alguém atender, o download cai e começa TUDO DE NOVO.</small></p>
    <p class="pg-dica">💡 <b>Verdade de 1998:</b> a internet discada usava a linha do telefone. Pra baixar um jogo grandão, o computador ficava a noite INTEIRA ligado — e a família inteira torcendo pra ninguém ligar lá pra casa.</p>
    <p class="pg-nav">🏠 <a href="#" data-vai="www.portaldaturminha.com.br">Portal da Turminha</a> • 😂 <a href="#" data-vai="www.piadasdorecreio.com.br">Piadas do Recreio</a> • 🦖 <a href="#" data-vai="www.dinomania.com.br">DinoMania</a></p>
    <p class="pg-rodape">Baixa Tudo! © 1998 — 100% grátis, 0% rápido.</p>
  </div>`,
  },
  {
    url: '__erro__',
    titulo: 'A página não pode ser exibida',
    html: `
  <div class="pg pg--erro">
    <h1>A página não pode ser exibida</h1>
    <p>A página que você está procurando não está disponível no momento. O site pode estar com problemas… ou talvez esse endereço <b>nem exista</b>.</p>
    <hr class="pg-hr" />
    <p><b>Tente o seguinte:</b></p>
    <ul>
      <li>Confira se você digitou o endereço certinho, letra por letra.</li>
      <li>Clique no botão <b>⟳ Atualizar</b> pra tentar de novo.</li>
      <li>Clique em <b>🏠 Início</b> pra voltar pra página inicial.</li>
    </ul>
    <p class="pg-erro__tec">Não é possível localizar o servidor ou erro de DNS<br />Internet Explorer (de mentirinha)<br />Endereço digitado: <b data-url-erro></b></p>
    <p class="pg-dica">💡 <b>Curiosidade:</b> em 1998 a internet era pequenininha — a maioria dos endereços que você inventasse não existia mesmo. Hoje existem mais de UM BILHÃO de sites!</p>
  </div>`,
  },
];
---

<Layout title={title} description={description}>
  <main id="conteudo" class="w98" role="application" aria-label="Simulador do Windows 98">
    <!-- Ícones desenhados (sem marcas registradas de verdade — tudo genérico) -->
    <svg hidden aria-hidden="true">
      <symbol id="i-logo" viewBox="0 0 24 24">
        <g transform="skewY(-6) translate(0 3)">
          <rect x="2" y="2" width="9" height="9" fill="#f25022"></rect>
          <rect x="13" y="2" width="9" height="9" fill="#7fba00"></rect>
          <rect x="2" y="13" width="9" height="9" fill="#00a4ef"></rect>
          <rect x="13" y="13" width="9" height="9" fill="#ffb900"></rect>
        </g>
      </symbol>
      <symbol id="i-computador" viewBox="0 0 24 24">
        <rect x="3" y="3" width="18" height="13" rx="1" fill="#c0c0c0" stroke="#404040"></rect>
        <rect x="5" y="5" width="14" height="9" fill="#008080"></rect>
        <rect x="9" y="17" width="6" height="2" fill="#808080"></rect>
        <rect x="6" y="19" width="12" height="2.5" rx="0.5" fill="#c0c0c0" stroke="#404040" stroke-width="0.6"></rect>
      </symbol>
      <symbol id="i-pasta" viewBox="0 0 24 24">
        <path d="M2 6 L9 6 L11 8 L22 8 L22 20 L2 20 Z" fill="#ffd24a" stroke="#8a6d1a" stroke-width="1"></path>
        <path d="M2 10 L22 10 L22 20 L2 20 Z" fill="#ffe173"></path>
      </symbol>
      <symbol id="i-lixeira" viewBox="0 0 24 24">
        <path d="M7 8 L17 8 L16 21 L8 21 Z" fill="#d7d7d7" stroke="#555"></path>
        <path d="M9 10 L9.5 19 M12 10 L12 19 M15 10 L14.5 19" stroke="#888" stroke-width="1.2" fill="none"></path>
        <rect x="6" y="5.5" width="12" height="2.4" rx="1" fill="#bdbdbd" stroke="#555" stroke-width="0.8"></rect>
        <rect x="10" y="3.6" width="4" height="2" rx="0.8" fill="#bdbdbd" stroke="#555" stroke-width="0.8"></rect>
      </symbol>
      <symbol id="i-ie" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="9" fill="#2f7fd0"></circle>
        <text x="12" y="17" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="bold" fill="#fff">e</text>
        <path d="M2 10 Q12 4 23 9" stroke="#ffd24a" stroke-width="1.8" fill="none"></path>
      </symbol>
      <symbol id="i-bloco" viewBox="0 0 24 24">
        <rect x="5" y="3" width="14" height="18" fill="#fff" stroke="#555"></rect>
        <path d="M8 8 H16 M8 11 H16 M8 14 H13" stroke="#7a9ac9" stroke-width="1.2"></path>
      </symbol>
      <symbol id="i-disquete" viewBox="0 0 24 24">
        <path d="M4 4 H18 L20 6 V20 H4 Z" fill="#2b4fa0" stroke="#122a5c"></path>
        <rect x="8" y="4" width="8" height="6" fill="#cfd8ea"></rect>
        <rect x="13" y="5" width="2" height="4" fill="#2b4fa0"></rect>
        <rect x="7" y="13" width="10" height="7" fill="#e8e8e8"></rect>
      </symbol>
      <symbol id="i-ajuda" viewBox="0 0 24 24">
        <path d="M5 4 Q12 2 19 4 V20 Q12 18 5 20 Z" fill="#b48ae0" stroke="#5a3a9c"></path>
        <text x="12" y="16" text-anchor="middle" font-family="Georgia, serif" font-size="12" font-weight="bold" fill="#fff">?</text>
      </symbol>
      <symbol id="i-config" viewBox="0 0 24 24">
        <rect x="4" y="4" width="16" height="16" rx="2" fill="#c0c0c0" stroke="#404040"></rect>
        <path d="M7 9 H17 M7 13 H17 M7 17 H17" stroke="#808080" stroke-width="1.4"></path>
        <rect x="9" y="7.4" width="3" height="3.2" fill="#2f7fd0" stroke="#123"></rect>
        <rect x="13" y="11.4" width="3" height="3.2" fill="#e05a4e" stroke="#311"></rect>
        <rect x="8" y="15.4" width="3" height="3.2" fill="#7fba00" stroke="#131"></rect>
      </symbol>
      <symbol id="i-executar" viewBox="0 0 24 24">
        <rect x="3" y="5" width="18" height="14" fill="#000" stroke="#555"></rect>
        <text x="6" y="15.5" font-family="'Courier New', monospace" font-size="8" font-weight="bold" fill="#0f0">C:\&gt;_</text>
      </symbol>
      <symbol id="i-programas" viewBox="0 0 24 24">
        <rect x="3" y="6" width="13" height="11" fill="#fff" stroke="#404040"></rect>
        <rect x="3" y="6" width="13" height="3" fill="#000080"></rect>
        <rect x="8" y="10" width="13" height="11" fill="#fff" stroke="#404040"></rect>
        <rect x="8" y="10" width="13" height="3" fill="#1084d0"></rect>
      </symbol>
      <symbol id="i-doc" viewBox="0 0 24 24">
        <path d="M6 2 H15 L19 6 V22 H6 Z" fill="#fff" stroke="#555"></path>
        <path d="M15 2 L15 6 H19" fill="none" stroke="#555"></path>
        <path d="M9 10 H16 M9 13 H16 M9 16 H13" stroke="#7a9ac9" stroke-width="1.2"></path>
        <text x="9" y="8.6" font-family="Georgia, serif" font-size="6" font-weight="bold" fill="#2b4fa0">W</text>
      </symbol>
      <symbol id="i-txt" viewBox="0 0 24 24">
        <path d="M6 2 H15 L19 6 V22 H6 Z" fill="#fff" stroke="#555"></path>
        <path d="M15 2 L15 6 H19" fill="none" stroke="#555"></path>
        <path d="M9 9 H16 M9 12 H16 M9 15 H16 M9 18 H12" stroke="#999" stroke-width="1.2"></path>
      </symbol>
      <symbol id="i-imagem" viewBox="0 0 24 24">
        <rect x="3" y="4" width="18" height="16" fill="#fff" stroke="#555"></rect>
        <circle cx="9" cy="10" r="2.2" fill="#fd0" stroke="#f90"></circle>
        <path d="M4 18 L10 12 L14 16 L17 13 L20 16 V19 H4 Z" fill="#6db36d" stroke="#3a7a3a" stroke-width="0.8"></path>
      </symbol>
      <symbol id="i-musica" viewBox="0 0 24 24">
        <path d="M9 18.5 V6 L19 4 V16.5" fill="none" stroke="#2b4fa0" stroke-width="2"></path>
        <ellipse cx="6.8" cy="18.8" rx="2.6" ry="2" fill="#2b4fa0"></ellipse>
        <ellipse cx="16.8" cy="16.8" rx="2.6" ry="2" fill="#2b4fa0"></ellipse>
      </symbol>
      <symbol id="i-som" viewBox="0 0 24 24">
        <path d="M4 10 H8 L13 5 V19 L8 14 H4 Z" fill="#404040"></path>
        <path d="M16 9 Q19 12 16 15 M18 6 Q23 12 18 18" stroke="#404040" stroke-width="1.6" fill="none"></path>
      </symbol>
      <symbol id="i-som-mudo" viewBox="0 0 24 24">
        <path d="M4 10 H8 L13 5 V19 L8 14 H4 Z" fill="#404040"></path>
        <path d="M16 9 L22 15 M22 9 L16 15" stroke="#c22" stroke-width="2" fill="none"></path>
      </symbol>
    </svg>

    <!-- ===== Tela: boot ===== -->
    <div class="tela tela--boot" data-tela="boot">
      <div class="boot__arte">
        <svg class="boot__logo" aria-hidden="true"><use href="#i-logo"></use></svg>
        <p class="boot__nome">Windows<b>98</b></p>
        <p class="boot__sub">Simulador — Sala do Professor Manolo</p>
      </div>
      <div class="boot__barra" aria-hidden="true"><i></i></div>
    </div>

    <!-- ===== Tela: desktop ===== -->
    <div class="tela tela--desktop" data-tela="desktop" hidden>
      <div class="area" data-area>
        <div class="icones" role="group" aria-label="Ícones da área de trabalho">
          {
            iconesDesktop.map((i) => (
              <button class="icone" type="button" data-abre={i.id}>
                <span class="ico icone__img" aria-hidden="true">
                  <img src={'/class/sims/icons/' + i.icone + '.png'} alt="" onerror="this.remove()" />
                  <svg><use href={'#i-' + i.icone}></use></svg>
                </span>
                <span class="icone__nome">{i.rotulo}</span>
              </button>
            ))
          }
        </div>

        {
          janelas.map((j, n) => (
            <section
              class={'janela' + (j.classe ? ' ' + j.classe : '')}
              data-janela={j.id}
              data-nx={n}
              role="dialog"
              aria-labelledby={'jt-' + j.id}
              tabindex="-1"
              hidden
            >
              <header class="janela__barra" data-arrasta>
                <span class="ico janela__icone" aria-hidden="true">
                  <img src={'/class/sims/icons/' + j.icone + '.png'} alt="" onerror="this.remove()" />
                  <svg><use href={'#i-' + j.icone}></use></svg>
                </span>
                <span class="janela__titulo" id={'jt-' + j.id}>{j.titulo}</span>
                <span class="janela__acoes">
                  <button type="button" class="bisel-alto" data-min aria-label="Minimizar">▁</button>
                  <button type="button" class="bisel-alto" data-max aria-label="Maximizar">▢</button>
                  <button type="button" class="bisel-alto" data-fecha aria-label="Fechar">✕</button>
                </span>
              </header>
              {j.cru ? (
                <div class="janela__cru" set:html={j.html} />
              ) : (
                <div class="janela__corpo bisel-campo" set:html={j.html} />
              )}
            </section>
          ))
        }

        <!-- Internet Explorer: janela especial com navegador de mentirinha -->
        <section
          class="janela janela--ie"
          data-janela="internet-explorer"
          data-nx="1"
          role="dialog"
          aria-labelledby="jt-internet-explorer"
          tabindex="-1"
          hidden
        >
          <header class="janela__barra" data-arrasta>
            <span class="ico janela__icone" aria-hidden="true">
              <img src="/class/sims/icons/ie.png" alt="" onerror="this.remove()" />
              <svg><use href="#i-ie"></use></svg>
            </span>
            <span class="janela__titulo" id="jt-internet-explorer" data-ie-titulo>Internet Explorer</span>
            <span class="janela__acoes">
              <button type="button" class="bisel-alto" data-min aria-label="Minimizar">▁</button>
              <button type="button" class="bisel-alto" data-max aria-label="Maximizar">▢</button>
              <button type="button" class="bisel-alto" data-fecha aria-label="Fechar">✕</button>
            </span>
          </header>
          <div class="ie">
            <div class="ie__tools" role="toolbar" aria-label="Botões de navegação">
              <button type="button" class="ie__btn bisel-alto" data-ie-voltar disabled><span aria-hidden="true">◀</span> Voltar</button>
              <button type="button" class="ie__btn bisel-alto" data-ie-avancar disabled>Avançar <span aria-hidden="true">▶</span></button>
              <button type="button" class="ie__btn bisel-alto" data-ie-atualizar disabled><span aria-hidden="true">⟳</span> Atualizar</button>
              <button type="button" class="ie__btn bisel-alto" data-ie-inicio><span aria-hidden="true">🏠</span> Início</button>
            </div>
            <div class="ie__endereco">
              <label for="ie-url">Endereço</label>
              <input
                id="ie-url"
                class="bisel-campo"
                type="text"
                data-ie-url
                inputmode="url"
                autocomplete="off"
                autocapitalize="off"
                autocorrect="off"
                spellcheck="false"
                placeholder="www.algumsite.com.br"
              />
              <button type="button" class="ie__btn bisel-alto" data-ie-ir>Ir</button>
            </div>
            <div class="ie__pagina bisel-campo" data-ie-pagina tabindex="0" aria-label="Página da internet"></div>
            <div class="ie__status bisel-baixo" role="status" data-ie-status>Pronto</div>
          </div>
        </section>

        <!-- Mini-web de mentirinha: fontes das páginas (clonadas pelo JS) -->
        <div hidden data-ie-sites>
          {sites.map((s) => <div hidden data-site={s.url} data-titulo={s.titulo} set:html={s.html} />)}
        </div>
      </div>

      <nav class="menu bisel-alto" data-menu hidden aria-label="Menu Iniciar">
        <span class="menu__faixa" aria-hidden="true">Windows<b>98</b></span>
        <ul>
          {
            itensMenu.map((m) => (
              <li>
                <button type="button" data-abre={m.id}>
                  <span class="ico menu__ico" aria-hidden="true">
                    <img src={'/class/sims/icons/' + m.icone + '.png'} alt="" onerror="this.remove()" />
                    <svg><use href={'#i-' + m.icone}></use></svg>
                  </span>
                  {m.rotulo}
                </button>
              </li>
            ))
          }
          <li class="menu__sep" aria-hidden="true"></li>
          <li>
            <button type="button" data-desligar>
              <span class="ico menu__ico" aria-hidden="true">
                <img src="/class/sims/icons/computador.png" alt="" onerror="this.remove()" />
                <svg><use href="#i-computador"></use></svg>
              </span>
              Desligar…
            </button>
          </li>
        </ul>
      </nav>

      <footer class="barra bisel-alto">
        <button class="iniciar bisel-alto" type="button" data-iniciar aria-expanded="false" aria-haspopup="true">
          <svg aria-hidden="true"><use href="#i-logo"></use></svg>
          Iniciar
        </button>
        <div class="barra__tarefas" data-tarefas></div>
        <div class="bandeja bisel-baixo">
          <button class="bandeja__som" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
            <svg aria-hidden="true"><use data-mute-use href="#i-som"></use></svg>
          </button>
          <span data-relogio>--:--</span>
        </div>
      </footer>
    </div>

    <!-- ===== Tela: desligado ===== -->
    <div class="tela tela--desligado" data-tela="desligado" hidden>
      <p class="desligado__aguarde" data-aguarde hidden>O Windows está sendo desligado…</p>
      <p class="desligado__msg" data-msg-final hidden>Agora é seguro desligar o seu computador.</p>
      <button class="desligado__religar bisel-alto" type="button" data-religar hidden>🔌 Ligar de novo</button>
    </div>

    <p class="sr-only" data-anuncio aria-live="polite"></p>
  </main>

  <style is:global>
    body.is-game { background: #000; overflow: hidden; }
    body.is-game::before { display: none !important; }

    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
    }

    .w98 {
      position: fixed;
      inset: 0;
      font-family: Tahoma, 'MS Sans Serif', 'Segoe UI', Geneva, sans-serif;
      font-size: 13px;
      color: #000;
      user-select: none;
      -webkit-user-select: none;
      cursor: default;
    }

    /* ===== Bisel (o "3D" do Windows 98) ===== */
    .w98 .bisel-alto {
      border: 1px solid;
      border-color: #dfdfdf #404040 #404040 #dfdfdf;
      box-shadow: inset 1px 1px 0 #fff, inset -1px -1px 0 #808080;
      background: #c0c0c0;
    }
    .w98 .bisel-baixo {
      border: 1px solid;
      border-color: #404040 #dfdfdf #dfdfdf #404040;
      box-shadow: inset 1px 1px 0 #808080, inset -1px -1px 0 #fff;
      background: #c0c0c0;
    }
    .w98 .bisel-campo {
      border: 2px solid;
      border-color: #808080 #fff #fff #808080;
      background: #fff;
    }
    .w98 button { font-family: inherit; font-size: inherit; cursor: pointer; }

    /* Ícone com PNG opcional: se /class/sims/icons/<nome>.png existir, cobre o SVG;
       se faltar, o onerror remove o img e o SVG desenhado aparece. */
    .ico { position: relative; display: inline-block; flex-shrink: 0; }
    .ico svg { position: absolute; inset: 0; width: 100%; height: 100%; }
    .ico img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: contain; z-index: 1; }
    .w98 button:active {
      border-color: #404040 #dfdfdf #dfdfdf #404040;
      box-shadow: inset 1px 1px 0 #808080, inset -1px -1px 0 #fff;
    }

    /* ===== Telas ===== */
    .w98 .tela { position: fixed; inset: 0; }
    .w98 .tela[hidden] { display: none; }

    /* ---- Boot ---- */
    .tela--boot {
      background: #000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 40px;
      color: #fff;
    }
    .boot__arte { text-align: center; }
    .boot__logo { width: clamp(90px, 18vw, 150px); height: clamp(90px, 18vw, 150px); }
    .boot__nome { font-size: clamp(2rem, 7vw, 3.4rem); font-weight: 400; letter-spacing: -0.02em; margin-top: 8px; }
    .boot__nome b { font-weight: 800; }
    .boot__sub { color: #9a9aa0; font-size: 0.85rem; margin-top: 6px; }
    .boot__barra {
      width: min(70vw, 420px);
      height: 14px;
      border: 2px solid #555;
      overflow: hidden;
      position: relative;
    }
    .boot__barra i {
      position: absolute;
      top: 0; bottom: 0;
      width: 30%;
      background: repeating-linear-gradient(90deg, #1084d0 0 12px, #000080 12px 24px);
      animation: boot-anda 1.4s linear infinite;
    }
    @keyframes boot-anda {
      from { left: -30%; }
      to { left: 100%; }
    }

    /* ---- Desligado ---- */
    .tela--desligado {
      background: #000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 34px;
      padding: 24px;
      text-align: center;
    }
    .desligado__aguarde { color: #fff; font-size: clamp(1rem, 3vw, 1.5rem); }
    .desligado__msg {
      color: #ffa500;
      font-size: clamp(1.3rem, 4.5vw, 2.4rem);
      font-weight: 700;
      text-shadow: 0 2px 6px rgba(255, 165, 0, 0.25);
      max-width: 26ch;
      line-height: 1.35;
    }
    .desligado__religar { padding: 10px 26px; font-size: 1rem; font-weight: 700; }

    /* ===== Desktop ===== */
    .area {
      position: absolute;
      inset: 0 0 34px 0;
      background: #008080 url('/class/sims/wallpaper-98.jpg') center / cover no-repeat;
      /* clip (não hidden): focar uma janela meio pra fora da tela NÃO pode rolar a área */
      overflow: hidden;
      overflow: clip;
    }

    /* ---- Ícones ---- */
    .icones {
      position: absolute;
      inset: 8px;
      display: flex;
      flex-direction: column;
      flex-wrap: wrap;
      align-content: flex-start;
      gap: 10px;
      pointer-events: none; /* cliques no vazio passam pra área */
    }
    .icone {
      pointer-events: auto;
      width: 86px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      padding: 6px 2px;
      background: none;
      border: 1px solid transparent;
    }
    .w98 .icone:active { border-color: transparent; box-shadow: none; }
    .icone__img { width: 40px; height: 40px; filter: drop-shadow(1px 2px 2px rgba(0, 0, 0, 0.45)); }
    .icone__nome {
      color: #fff;
      font-size: 12px;
      line-height: 1.25;
      text-align: center;
      text-shadow: 1px 1px 0 #000, 0 0 4px rgba(0, 0, 0, 0.7);
      padding: 1px 3px;
    }
    .icone:hover .icone__nome { background: rgba(0, 0, 128, 0.55); }
    .icone:focus-visible { outline: 1px dotted #fff; }
    .icone:focus-visible .icone__nome { background: #000080; }

    /* ---- Janela ---- */
    .janela {
      position: absolute;
      left: 90px;
      top: 40px;
      width: min(430px, calc(100% - 16px));
