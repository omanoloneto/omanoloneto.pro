  <style is:global>
    /* ===== Skin Windows 98: só tokens — a estrutura vem de sim-os.css ===== */
    .sim.w98 {
      --sim-fonte: Tahoma, 'MS Sans Serif', 'Segoe UI', Geneva, sans-serif;
      --sim-fonte-tamanho: 13px;
      --sim-superficie: #c0c0c0;
      --sim-borda-clara: #dfdfdf;
      --sim-borda-escura: #404040;
      --sim-borda-media: #808080;
      --sim-realce: #fff;
      --sim-campo: #fff;
      --sim-desktop: #008080;
      --sim-wallpaper: url('/class/sims/wallpaper-98.jpg');
      --sim-titulo-grad-a: #000080;
      --sim-titulo-grad-b: #1084d0;
      --sim-titulo-texto: #fff;
      --sim-selecao: #000080;
      --sim-selecao-texto: #fff;
      --sim-barra-altura: 34px;
    }

    /* ===== Tema do shell: boot, faixa do menu, desligamento ===== */
    .tela--boot {
      background: #000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 40px;
      color: #fff;
    }
    .boot__arte { text-align: center; }
    .boot__logo { width: clamp(90px, 18vw, 150px); height: clamp(90px, 18vw, 150px); }
    .boot__nome { font-size: clamp(2rem, 7vw, 3.4rem); font-weight: 400; letter-spacing: -0.02em; margin-top: 8px; }
    .boot__nome b { font-weight: 800; }
    .boot__sub { color: #9a9aa0; font-size: 0.85rem; margin-top: 6px; }
    .boot__barra {
      width: min(70vw, 420px);
      height: 14px;
      border: 2px solid #555;
      overflow: hidden;
      position: relative;
    }
    .boot__barra i {
      position: absolute;
      top: 0; bottom: 0;
      width: 30%;
      background: repeating-linear-gradient(90deg, #1084d0 0 12px, #000080 12px 24px);
      animation: boot-anda 1.4s linear infinite;
    }
    @keyframes boot-anda {
      from { left: -30%; }
      to { left: 100%; }
    }

    .menu__faixa {
      flex-shrink: 0;
      width: 26px;
      background: linear-gradient(0deg, #1084d0, #000080 70%, #000);
      color: #c0c0c0;
      font-size: 15px;
      font-weight: 400;
      letter-spacing: 0.02em;
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      padding: 8px 3px;
      display: flex;
      align-items: center;
    }
    .menu__faixa b { color: #fff; font-weight: 800; }

    .tela--desligado {
      background: #000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 34px;
      padding: 24px;
      text-align: center;
    }
    .desligado__aguarde { color: #fff; font-size: clamp(1rem, 3vw, 1.5rem); }
    .desligado__msg {
      color: #ffa500;
      font-size: clamp(1.3rem, 4.5vw, 2.4rem);
      font-weight: 700;
      text-shadow: 0 2px 6px rgba(255, 165, 0, 0.25);
      max-width: 26ch;
      line-height: 1.35;
    }
    .desligado__religar { padding: 10px 26px; font-size: 1rem; font-weight: 700; }

    /* ===== Conteúdo autoral das janelas ===== */
    .w98 .dica {
      margin-top: 12px;
      padding: 8px 10px;
      background: #ffffd5;
      border: 1px solid #c9c37a;
      font-size: 12px;
    }

    /* folha de texto (WordPad / Bloco de Notas de fábrica) */
    .folha {
      background: #fff;
      border: 1px solid #999;
      padding: 12px 14px;
      font-family: 'Times New Roman', Times, serif;
      font-size: 14px;
      box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.12);
      margin-bottom: 10px;
    }
    .folha p { margin-bottom: 10px; }
    .folha p:last-child { margin-bottom: 0; }
