---
// Simulador do Windows 98 — SHELL da página. O comportamento vem do motor
// genérico (src/games/sim-os/*) e o conteúdo de src/data/windows-98.ts.
// Aqui ficam só: sprite SVG do tema, esqueleto com os ganchos [data-*],
// tokens de skin --sim-* e o CSS do conteúdo autoral (folha/paint/mini-web).
import Layout from '../../../layouts/Layout.astro';
import { dados } from '../../../data/windows-98';
import '../../../styles/sim-os.css';

const title = 'Simulador do Windows 98 — viaje até 1998 | Sala do Professor Manolo';
const description =
  'Um Windows 98 de mentirinha pra crianças explorarem: ligue o computador, abra as janelas, escreva no Bloco de Notas e descubra a internet discada. Grátis, em português, direto no navegador.';

// '</' escapado: conteúdo autoral não pode fechar o <script> do JSON sem querer
const dadosJson = JSON.stringify(dados).replaceAll('</', '<\\/');
---

<Layout title={title} description={description}>
  <main id="conteudo" class="sim w98" data-sim role="application" aria-label="Simulador do Windows 98">
    <!-- Ícones desenhados (sem marcas registradas de verdade — tudo genérico) -->
    <svg hidden aria-hidden="true">
      <symbol id="i-logo" viewBox="0 0 24 24">
        <g transform="skewY(-6) translate(0 3)">
          <rect x="2" y="2" width="9" height="9" fill="#f25022"></rect>
          <rect x="13" y="2" width="9" height="9" fill="#7fba00"></rect>
          <rect x="2" y="13" width="9" height="9" fill="#00a4ef"></rect>
          <rect x="13" y="13" width="9" height="9" fill="#ffb900"></rect>
        </g>
      </symbol>
      <symbol id="i-computador" viewBox="0 0 24 24">
        <rect x="3" y="3" width="18" height="13" rx="1" fill="#c0c0c0" stroke="#404040"></rect>
        <rect x="5" y="5" width="14" height="9" fill="#008080"></rect>
        <rect x="9" y="17" width="6" height="2" fill="#808080"></rect>
        <rect x="6" y="19" width="12" height="2.5" rx="0.5" fill="#c0c0c0" stroke="#404040" stroke-width="0.6"></rect>
      </symbol>
      <symbol id="i-pasta" viewBox="0 0 24 24">
        <path d="M2 6 L9 6 L11 8 L22 8 L22 20 L2 20 Z" fill="#ffd24a" stroke="#8a6d1a" stroke-width="1"></path>
        <path d="M2 10 L22 10 L22 20 L2 20 Z" fill="#ffe173"></path>
      </symbol>
      <symbol id="i-lixeira" viewBox="0 0 24 24">
        <path d="M7 8 L17 8 L16 21 L8 21 Z" fill="#d7d7d7" stroke="#555"></path>
        <path d="M9 10 L9.5 19 M12 10 L12 19 M15 10 L14.5 19" stroke="#888" stroke-width="1.2" fill="none"></path>
        <rect x="6" y="5.5" width="12" height="2.4" rx="1" fill="#bdbdbd" stroke="#555" stroke-width="0.8"></rect>
        <rect x="10" y="3.6" width="4" height="2" rx="0.8" fill="#bdbdbd" stroke="#555" stroke-width="0.8"></rect>
      </symbol>
      <symbol id="i-lixeira-cheia" viewBox="0 0 24 24">
        <path d="M8 6 L12 2.6 L15 5.4 L18 3.4 L18.6 6.6" fill="#fff" stroke="#555" stroke-width="1"></path>
        <path d="M9.5 5.8 L11.9 3.8 L13.6 5.4" fill="none" stroke="#7a9ac9" stroke-width="0.9"></path>
        <path d="M7 8 L17 8 L16 21 L8 21 Z" fill="#d7d7d7" stroke="#555"></path>
        <path d="M9 10 L9.5 19 M12 10 L12 19 M15 10 L14.5 19" stroke="#888" stroke-width="1.2" fill="none"></path>
        <rect x="6" y="5.5" width="12" height="2.4" rx="1" fill="#bdbdbd" stroke="#555" stroke-width="0.8"></rect>
      </symbol>
      <symbol id="i-ie" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="9" fill="#2f7fd0"></circle>
        <text x="12" y="17" text-anchor="middle" font-family="Georgia, serif" font-size="14" font-weight="bold" fill="#fff">e</text>
        <path d="M2 10 Q12 4 23 9" stroke="#ffd24a" stroke-width="1.8" fill="none"></path>
      </symbol>
      <symbol id="i-bloco" viewBox="0 0 24 24">
        <rect x="5" y="3" width="14" height="18" fill="#fff" stroke="#555"></rect>
        <path d="M8 8 H16 M8 11 H16 M8 14 H13" stroke="#7a9ac9" stroke-width="1.2"></path>
      </symbol>
      <symbol id="i-disquete" viewBox="0 0 24 24">
        <path d="M4 4 H18 L20 6 V20 H4 Z" fill="#2b4fa0" stroke="#122a5c"></path>
        <rect x="8" y="4" width="8" height="6" fill="#cfd8ea"></rect>
        <rect x="13" y="5" width="2" height="4" fill="#2b4fa0"></rect>
        <rect x="7" y="13" width="10" height="7" fill="#e8e8e8"></rect>
      </symbol>
      <symbol id="i-ajuda" viewBox="0 0 24 24">
        <path d="M5 4 Q12 2 19 4 V20 Q12 18 5 20 Z" fill="#b48ae0" stroke="#5a3a9c"></path>
        <text x="12" y="16" text-anchor="middle" font-family="Georgia, serif" font-size="12" font-weight="bold" fill="#fff">?</text>
      </symbol>
      <symbol id="i-config" viewBox="0 0 24 24">
        <rect x="4" y="4" width="16" height="16" rx="2" fill="#c0c0c0" stroke="#404040"></rect>
        <path d="M7 9 H17 M7 13 H17 M7 17 H17" stroke="#808080" stroke-width="1.4"></path>
        <rect x="9" y="7.4" width="3" height="3.2" fill="#2f7fd0" stroke="#123"></rect>
        <rect x="13" y="11.4" width="3" height="3.2" fill="#e05a4e" stroke="#311"></rect>
        <rect x="8" y="15.4" width="3" height="3.2" fill="#7fba00" stroke="#131"></rect>
      </symbol>
      <symbol id="i-executar" viewBox="0 0 24 24">
        <rect x="3" y="5" width="18" height="14" fill="#000" stroke="#555"></rect>
        <text x="6" y="15.5" font-family="'Courier New', monospace" font-size="8" font-weight="bold" fill="#0f0">C:\&gt;_</text>
      </symbol>
      <symbol id="i-programas" viewBox="0 0 24 24">
        <rect x="3" y="6" width="13" height="11" fill="#fff" stroke="#404040"></rect>
        <rect x="3" y="6" width="13" height="3" fill="#000080"></rect>
        <rect x="8" y="10" width="13" height="11" fill="#fff" stroke="#404040"></rect>
        <rect x="8" y="10" width="13" height="3" fill="#1084d0"></rect>
      </symbol>
      <symbol id="i-doc" viewBox="0 0 24 24">
        <path d="M6 2 H15 L19 6 V22 H6 Z" fill="#fff" stroke="#555"></path>
        <path d="M15 2 L15 6 H19" fill="none" stroke="#555"></path>
        <path d="M9 10 H16 M9 13 H16 M9 16 H13" stroke="#7a9ac9" stroke-width="1.2"></path>
        <text x="9" y="8.6" font-family="Georgia, serif" font-size="6" font-weight="bold" fill="#2b4fa0">W</text>
      </symbol>
      <symbol id="i-txt" viewBox="0 0 24 24">
        <path d="M6 2 H15 L19 6 V22 H6 Z" fill="#fff" stroke="#555"></path>
        <path d="M15 2 L15 6 H19" fill="none" stroke="#555"></path>
        <path d="M9 9 H16 M9 12 H16 M9 15 H16 M9 18 H12" stroke="#999" stroke-width="1.2"></path>
      </symbol>
      <symbol id="i-imagem" viewBox="0 0 24 24">
        <rect x="3" y="4" width="18" height="16" fill="#fff" stroke="#555"></rect>
        <circle cx="9" cy="10" r="2.2" fill="#fd0" stroke="#f90"></circle>
        <path d="M4 18 L10 12 L14 16 L17 13 L20 16 V19 H4 Z" fill="#6db36d" stroke="#3a7a3a" stroke-width="0.8"></path>
      </symbol>
      <symbol id="i-musica" viewBox="0 0 24 24">
        <path d="M9 18.5 V6 L19 4 V16.5" fill="none" stroke="#2b4fa0" stroke-width="2"></path>
        <ellipse cx="6.8" cy="18.8" rx="2.6" ry="2" fill="#2b4fa0"></ellipse>
        <ellipse cx="16.8" cy="16.8" rx="2.6" ry="2" fill="#2b4fa0"></ellipse>
      </symbol>
      <symbol id="i-som" viewBox="0 0 24 24">
        <path d="M4 10 H8 L13 5 V19 L8 14 H4 Z" fill="#404040"></path>
        <path d="M16 9 Q19 12 16 15 M18 6 Q23 12 18 18" stroke="#404040" stroke-width="1.6" fill="none"></path>
      </symbol>
      <symbol id="i-som-mudo" viewBox="0 0 24 24">
        <path d="M4 10 H8 L13 5 V19 L8 14 H4 Z" fill="#404040"></path>
        <path d="M16 9 L22 15 M22 9 L16 15" stroke="#c22" stroke-width="2" fill="none"></path>
      </symbol>
    </svg>

    <!-- ===== Tela: boot ===== -->
    <div class="tela tela--boot" data-tela="boot">
      <div class="boot__arte">
        <svg class="boot__logo" aria-hidden="true"><use href="#i-logo"></use></svg>
        <p class="boot__nome">Windows<b>98</b></p>
        <p class="boot__sub">Simulador — Sala do Professor Manolo</p>
      </div>
      <div class="boot__barra" aria-hidden="true"><i></i></div>
    </div>

    <!-- ===== Tela: desktop (o motor preenche ícones, menu, janelas e taskbar) ===== -->
    <div class="tela tela--desktop" data-tela="desktop" hidden>
      <div class="area" data-area>
        <div class="icones" role="group" aria-label="Ícones da área de trabalho" data-icones></div>
      </div>

      <nav class="menu bisel-alto" data-menu hidden aria-label="Menu Iniciar">
        <span class="menu__faixa" aria-hidden="true">Windows<b>98</b></span>
        <ul data-menu-itens></ul>
      </nav>

      <footer class="barra bisel-alto">
        <button class="iniciar bisel-alto" type="button" data-iniciar aria-expanded="false" aria-haspopup="true">
          <svg aria-hidden="true"><use href="#i-logo"></use></svg>
          Iniciar
        </button>
        <div class="barra__tarefas" data-tarefas></div>
        <div class="bandeja bisel-baixo">
          <button class="bandeja__som" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
            <svg aria-hidden="true"><use data-mute-use href="#i-som"></use></svg>
          </button>
          <span data-relogio>--:--</span>
        </div>
      </footer>
    </div>

    <!-- ===== Tela: desligado ===== -->
    <div class="tela tela--desligado" data-tela="desligado" hidden>
      <p class="desligado__aguarde" data-aguarde hidden>O Windows está sendo desligado…</p>
      <p class="desligado__msg" data-msg-final hidden>Agora é seguro desligar o seu computador.</p>
      <button class="desligado__religar bisel-alto" type="button" data-religar hidden>🔌 Ligar de novo</button>
    </div>

    <p class="sr-only" data-anuncio aria-live="polite"></p>
  </main>

  <script type="application/json" data-dados set:html={dadosJson}></script>

  <style is:global>
    /* ===== Skin Windows 98: só tokens — a estrutura vem de sim-os.css ===== */
    .sim.w98 {
      --sim-fonte: Tahoma, 'MS Sans Serif', 'Segoe UI', Geneva, sans-serif;
      --sim-fonte-tamanho: 13px;
      --sim-superficie: #c0c0c0;
      --sim-borda-clara: #dfdfdf;
      --sim-borda-escura: #404040;
      --sim-borda-media: #808080;
      --sim-realce: #fff;
      --sim-campo: #fff;
      --sim-desktop: #008080;
      --sim-wallpaper: url('/class/sims/wallpaper-98.jpg');
      --sim-titulo-grad-a: #000080;
      --sim-titulo-grad-b: #1084d0;
      --sim-titulo-texto: #fff;
      --sim-selecao: #000080;
      --sim-selecao-texto: #fff;
      --sim-barra-altura: 34px;
    }

    /* ===== Tema do shell: boot, faixa do menu, desligamento ===== */
    .tela--boot {
      background: #000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 40px;
      color: #fff;
    }
    .boot__arte { text-align: center; }
    .boot__logo { width: clamp(90px, 18vw, 150px); height: clamp(90px, 18vw, 150px); }
    .boot__nome { font-size: clamp(2rem, 7vw, 3.4rem); font-weight: 400; letter-spacing: -0.02em; margin-top: 8px; }
    .boot__nome b { font-weight: 800; }
    .boot__sub { color: #9a9aa0; font-size: 0.85rem; margin-top: 6px; }
    .boot__barra {
      width: min(70vw, 420px);
      height: 14px;
      border: 2px solid #555;
      overflow: hidden;
      position: relative;
    }
    .boot__barra i {
      position: absolute;
      top: 0; bottom: 0;
      width: 30%;
      background: repeating-linear-gradient(90deg, #1084d0 0 12px, #000080 12px 24px);
      animation: boot-anda 1.4s linear infinite;
    }
    @keyframes boot-anda {
      from { left: -30%; }
      to { left: 100%; }
    }

    .menu__faixa {
      flex-shrink: 0;
      width: 26px;
      background: linear-gradient(0deg, #1084d0, #000080 70%, #000);
      color: #c0c0c0;
      font-size: 15px;
      font-weight: 400;
      letter-spacing: 0.02em;
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      padding: 8px 3px;
      display: flex;
      align-items: center;
    }
    .menu__faixa b { color: #fff; font-weight: 800; }

    .tela--desligado {
      background: #000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 34px;
      padding: 24px;
      text-align: center;
    }
    .desligado__aguarde { color: #fff; font-size: clamp(1rem, 3vw, 1.5rem); }
    .desligado__msg {
      color: #ffa500;
      font-size: clamp(1.3rem, 4.5vw, 2.4rem);
      font-weight: 700;
      text-shadow: 0 2px 6px rgba(255, 165, 0, 0.25);
      max-width: 26ch;
      line-height: 1.35;
    }
    .desligado__religar { padding: 10px 26px; font-size: 1rem; font-weight: 700; }

    /* ===== Conteúdo autoral das janelas ===== */
    .w98 .dica {
      margin-top: 12px;
      padding: 8px 10px;
      background: #ffffd5;
      border: 1px solid #c9c37a;
      font-size: 12px;
    }

    /* folha de texto (WordPad / Bloco de Notas de fábrica) */
    .folha {
      background: #fff;
      border: 1px solid #999;
      padding: 12px 14px;
      font-family: 'Times New Roman', Times, serif;
      font-size: 14px;
      box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.12);
      margin-bottom: 10px;
    }
    .folha p { margin-bottom: 10px; }
    .folha p:last-child { margin-bottom: 0; }
    .folha--txt { font-family: 'Courier New', monospace; font-size: 12.5px; }
    .folha__titulo { text-align: center; font-weight: 700; font-size: 15px; }
    .folha__sub { text-align: center; font-size: 12px; color: #555; }

    /* Paint (desenho estático) */
    .janela--paint { width: min(480px, calc(100% - 16px)); }
    .paint { margin-bottom: 10px; }
    .paint__paleta { display: flex; gap: 3px; padding: 4px; background: #c0c0c0; border: 1px solid #808080; }
    .paint__paleta i { width: 16px; height: 16px; border: 1px solid; border-color: #404040 #dfdfdf #dfdfdf #404040; }
    .paint__tela { border: 2px solid; border-color: #808080 #fff #fff #808080; background: #fff; }
    .paint__tela svg { display: block; width: 100%; height: auto; }

    /* ---- Páginas da mini-web (vibe 1998) ---- */
    .ie__pagina { background: #fff; }
    .pg { padding: 14px 16px 20px; line-height: 1.55; font-size: 13px; }
    .pg h1 { font-family: 'Comic Sans MS', 'Chalkboard SE', cursive; text-align: center; font-size: 1.7rem; margin: 8px 0 4px; }
    .pg h2 { font-size: 1.05rem; margin: 14px 0 6px; }
    .pg ul { padding-left: 22px; margin: 8px 0; }
    .pg li { margin-bottom: 6px; }
    .pg a { color: #0000ee; text-decoration: underline; cursor: pointer; }
    .pg-centro { text-align: center; }
    .pg-hr { border: 0; border-top: 1px solid #999; border-bottom: 1px solid #fff; margin: 12px 0; }
    .pg-rodape { text-align: center; font-size: 11px; color: #666; margin-top: 16px; }
    .pg-nav { text-align: center; margin-top: 14px; font-size: 12px; }
    .pg-dica { margin-top: 12px; padding: 8px 10px; background: #ffffd5; border: 1px solid #c9c37a; font-size: 12px; }
    .pg-marquee { overflow: hidden; background: #000080; color: #ff0; font-weight: 700; padding: 3px 0; margin: -14px -16px 10px; }
    .pg-marquee span { display: inline-block; white-space: nowrap; padding-left: 100%; animation: pg-marquee 14s linear infinite; }
    @keyframes pg-marquee { to { transform: translateX(-100%); } }
    .pg-odometro { display: inline-block; margin-top: 4px; padding: 2px 12px; background: #000; color: #3f3; font: 700 1.2rem 'Courier New', monospace; letter-spacing: 4px; border: 2px solid; border-color: #404040 #dfdfdf #dfdfdf #404040; }
    .pg-obras { text-align: center; margin: 12px 0; }
    .pg-obras__faixa { display: block; height: 10px; background: repeating-linear-gradient(45deg, #ffd200 0 12px, #111 12px 24px); margin: 6px 0; }
    .pg--home { background: #fdf6ff radial-gradient(#e7d0f5 1.5px, transparent 1.6px); background-size: 20px 20px; }
    .pg--home h1 { color: #d4008f; text-shadow: 2px 2px 0 #ffd200; }
    .pg--piadas { background: #fffbe6 repeating-linear-gradient(0deg, transparent 0 26px, #ffe9a8 26px 27px); }
    .pg--piadas h1 { color: #e05a00; }
    .pg-piada { margin: 10px 0; padding: 8px 12px; background: #fff; border: 2px dashed #e0a000; }
    .pg-piada .pg-resposta { margin-top: 2px; color: #007700; font-weight: 700; }
    .pg--dinos { background: #eaf7ea; }
    .pg--dinos h1 { color: #1b7a1b; text-shadow: 2px 2px 0 #bfe8bf; }
    .pg-enquete { margin: 10px 0; padding: 10px 12px; background: #fff; border: 2px solid #1b7a1b; }
    .pg-enquete label { display: block; margin: 4px 0; }
    .pg--baixa { background: #eef3ff; }
    .pg--baixa h1 { color: #2b4fa0; text-shadow: 2px 2px 0 #cfd8ea; }
    .pg-tabela { width: 100%; border-collapse: collapse; font-size: 12px; margin: 10px 0; background: #fff; }
    .pg-tabela th, .pg-tabela td { border: 1px solid #8ea3c9; padding: 5px 8px; text-align: left; }
    .pg-tabela th { background: #2b4fa0; color: #fff; }
    .pg-baixar { padding: 2px 10px; font-size: 12px; }
    .pg--erro { font-family: Arial, Helvetica, sans-serif; }
    .pg--erro h1 { font-family: inherit; text-align: left; font-size: 1.25rem; margin-bottom: 10px; }
    .pg-erro__tec { margin-top: 14px; font-size: 12px; color: #666; }

    @media (prefers-reduced-motion: reduce) {
      .boot__barra i { animation: none; width: 60%; left: 20%; }
      .pg-marquee span { animation: none; padding-left: 0; }
    }
  </style>

  <script>
    import { iniciarSim } from '../../../games/sim-os/main';
    import { criarNavegador } from '../../../games/sim-os/apps/navegador';
    import { criarBlocoDeNotas } from '../../../games/sim-os/apps/bloco-de-notas';
    import { criarExplorador } from '../../../games/sim-os/apps/explorador';
    import { criarLixeira } from '../../../games/sim-os/apps/lixeira';
    import { criarTocador } from '../../../games/sim-os/apps/tocador';

    iniciarSim({
      apps: {
        navegador: criarNavegador,
        'bloco-de-notas': criarBlocoDeNotas,
        explorador: criarExplorador,
        lixeira: criarLixeira,
        tocador: criarTocador,
      },
    });
  </script>
</Layout>
