  </style>

  <script>
    const $ = (s) => document.querySelector(s);
    const $$ = (s) => [...document.querySelectorAll(s)];

    const areaEl = $('[data-area]');
    const menuEl = $('[data-menu]');
    const iniciarBtn = $('[data-iniciar]');
    const tarefasEl = $('[data-tarefas]');
    const anuncioEl = $('[data-anuncio]');
    const aguardeEl = $('[data-aguarde]');
    const msgFinalEl = $('[data-msg-final]');
    const religarBtn = $('[data-religar]');

    const semMov = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const estado = {
      tela: 'boot',
      zTopo: 10,
      abertas: {}, // id -> { min, abridor }
      menuAberto: false,
      bootTimer: 0,
      desligarTimer: 0,
      mudo: false,
    };

    function anunciar(msg) {
      anuncioEl.textContent = '';
      requestAnimationFrame(() => { anuncioEl.textContent = msg; });
    }

    // ===== Áudio (Web Audio, sem arquivos — acorde próprio, não o som real) =====
    let actx = null;
    function initAudio() {
      if (actx) return;
      const AC = window.AudioContext || window.webkitAudioContext;
      if (AC) actx = new AC();
    }
    function tom(freq, inicio, dur, tipo, vol) {
      if (!actx || actx.state !== 'running') return;
      const o = actx.createOscillator();
      const g = actx.createGain();
      o.type = tipo; o.frequency.value = freq;
      o.connect(g); g.connect(actx.destination);
      const t = actx.currentTime + inicio;
      g.gain.setValueAtTime(0.0001, t);
      g.gain.linearRampToValueAtTime(vol, t + 0.03);
      g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      o.start(t); o.stop(t + dur + 0.05);
    }
    function somLigar() {
      if (estado.mudo) return;
      [392, 523, 659].forEach((f, i) => tom(f, i * 0.09, 0.8, 'triangle', 0.15));
    }
    function somClique() { if (estado.mudo) return; tom(880, 0, 0.04, 'square', 0.05); }
    // Primeiro gesto em qualquer lugar libera o áudio
    document.addEventListener('pointerdown', () => {
      initAudio();
      if (actx && actx.state === 'suspended') actx.resume();
    }, { once: true, capture: true });

    // ===== Mudo (alto-falante da bandeja) =====
    const muteBtn = $('[data-mute]');
    const muteUse = $('[data-mute-use]');
    function aplicarMudo() {
      muteBtn.setAttribute('aria-pressed', String(estado.mudo));
      muteUse.setAttribute('href', estado.mudo ? '#i-som-mudo' : '#i-som');
      muteBtn.setAttribute('aria-label', estado.mudo ? 'Ligar o som' : 'Desligar o som');
    }
    (function initMudo() {
      estado.mudo = localStorage.getItem('win98:mudo') === '1';
      aplicarMudo();
    })();
    muteBtn.addEventListener('click', () => {
      estado.mudo = !estado.mudo;
      localStorage.setItem('win98:mudo', estado.mudo ? '1' : '0');
      aplicarMudo();
    });

    // ===== Telas =====
    function trocarTela(nome) {
      estado.tela = nome;
      $$('.tela').forEach((t) => { t.hidden = t.dataset.tela !== nome; });
    }

    function ligar() {
      clearTimeout(estado.bootTimer);
      clearTimeout(estado.desligarTimer);
      fecharTodas();
      alternarMenu(false);
      pararMelodia(true);
      // religou = internet "desconectou": histórico zera e a discagem toca de novo
      ieEstado.hist = [];
      ieEstado.idx = -1;
      ieEstado.token++;
      ieEstado.discou = false;
      ieBotoes();
      ieStatusEl.textContent = 'Pronto';
      trocarTela('boot');
      estado.bootTimer = setTimeout(entrarNoDesktop, semMov ? 800 : 3000);
    }

    function entrarNoDesktop() {
      trocarTela('desktop');
      somLigar();
      anunciar('Computador ligado. Você está na área de trabalho do Windows 98. Use Tab pra passear pelos ícones e Enter pra abrir.');
      const primeiro = $('.icone');
      if (primeiro) primeiro.focus({ preventScroll: true });
    }

    function desligar() {
      alternarMenu(false);
      trocarTela('desligado');
      aguardeEl.hidden = false;
      msgFinalEl.hidden = true;
      religarBtn.hidden = true;
      anunciar('O Windows está sendo desligado.');
      estado.desligarTimer = setTimeout(() => {
        aguardeEl.hidden = true;
        msgFinalEl.hidden = false;
        religarBtn.hidden = false;
        religarBtn.focus();
        anunciar('Agora é seguro desligar o seu computador. Aperte o botão pra ligar de novo.');
      }, semMov ? 300 : 1400);
    }
    religarBtn.addEventListener('click', ligar);

    // ===== Janelas =====
    function janelaEl(id) { return document.querySelector('[data-janela="' + id + '"]'); }
    function tituloDe(sec) { return sec.querySelector('.janela__titulo').textContent; }

    function abrirJanela(id, abridor) {
      const sec = janelaEl(id);
      if (!sec) return;
      somClique();
      if (estado.abertas[id]) {
        if (estado.abertas[id].min) restaurar(id);
        focarJanela(id);
        sec.focus({ preventScroll: true });
        return;
      }
      estado.abertas[id] = { min: false, abridor: abridor || null };
      sec.hidden = false;
      posicionarCascata(sec);
      criarBotaoTarefa(id, sec);
      focarJanela(id);
      sec.focus({ preventScroll: true });
      anunciar('Janela aberta: ' + tituloDe(sec));
      // IE: primeira abertura conecta na página inicial (com direito a discagem)
      if (id === 'internet-explorer' && ieEstado.idx < 0) ieNavegar(IE_HOME, 'empurra');
    }

    function fecharJanela(id) {
      const sec = janelaEl(id);
      const info = estado.abertas[id];
      if (!sec || !info) return;
      sec.hidden = true;
      sec.classList.remove('janela--max', 'ativa');
      const btn = tarefasEl.querySelector('[data-tarefa="' + id + '"]');
      if (btn) btn.remove();
      delete estado.abertas[id];
      // a janela visível de maior z vira a ativa (Esc continua funcionando em cadeia)
      const restantes = Object.keys(estado.abertas)
        .map(janelaEl)
        .filter((s) => s && !s.hidden);
      if (restantes.length) {
        const topo = restantes.reduce((a, b) => ((+a.style.zIndex || 0) > (+b.style.zIndex || 0) ? a : b));
        focarJanela(topo.dataset.janela);
      }
      if (info.abridor) info.abridor.focus({ preventScroll: true });
      anunciar('Janela fechada.');
    }

    function fecharTodas() {
      Object.keys(estado.abertas).forEach((id) => {
        const sec = janelaEl(id);
        if (sec) { sec.hidden = true; sec.classList.remove('janela--max', 'ativa'); }
      });
      estado.abertas = {};
      tarefasEl.innerHTML = '';
      estado.zTopo = 10;
    }

    function minimizar(id) {
      const sec = janelaEl(id);
      const info = estado.abertas[id];
      if (!sec || !info) return;
      sec.hidden = true;
      info.min = true;
      atualizarTarefas();
      const btn = tarefasEl.querySelector('[data-tarefa="' + id + '"]');
      if (btn) btn.focus();
    }

    function restaurar(id) {
      const sec = janelaEl(id);
      const info = estado.abertas[id];
      if (!sec || !info) return;
      sec.hidden = false;
      info.min = false;
    }

    function alternarMax(id) {
      const sec = janelaEl(id);
      if (!sec) return;
      sec.classList.toggle('janela--max');
      focarJanela(id);
    }

    function focarJanela(id) {
      const sec = janelaEl(id);
      if (!sec) return;
      sec.style.zIndex = String(++estado.zTopo);
      $$('.janela').forEach((j) => j.classList.toggle('ativa', j === sec));
      atualizarTarefas();
    }

    function janelaAtiva() {
      const sec = document.querySelector('.janela.ativa:not([hidden])');
      return sec ? sec.dataset.janela : null;
    }

    function atualizarTarefas() {
      $$('.tarefa').forEach((b) => {
        const sec = janelaEl(b.dataset.tarefa);
        b.classList.toggle('tarefa--ativa', !!sec && sec.classList.contains('ativa') && !sec.hidden);
      });
    }

    function posicionarCascata(sec) {
      // cascata pela ordem de abertura: a barra de título da janela de baixo
      // fica sempre à mostra (abertas já inclui esta janela)
      const n = (Object.keys(estado.abertas).length - 1 + 7) % 7;
      const estreito = window.innerWidth < 640;
      let left = estreito ? 4 : 90 + n * 26;
      let top = estreito ? 8 + n * 18 : 40 + n * 26;
      left = Math.max(0, Math.min(left, areaEl.clientWidth - 120));
      top = Math.max(0, Math.min(top, areaEl.clientHeight - 60));
      sec.style.left = left + 'px';
      sec.style.top = top + 'px';
    }

    function criarBotaoTarefa(id, sec) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'tarefa bisel-alto';
      btn.dataset.tarefa = id;
      const ico = sec.querySelector('.janela__barra .ico').outerHTML;
      btn.innerHTML = ico + '<span>' + tituloDe(sec) + '</span>';
      btn.addEventListener('click', () => {
        const info = estado.abertas[id];
        if (!info) return;
        somClique();
        if (info.min) {
          restaurar(id);
          focarJanela(id);
        } else if (sec.classList.contains('ativa')) {
          minimizar(id);
        } else {
          focarJanela(id);
        }
      });
      tarefasEl.appendChild(btn);
    }

    // ===== Arraste das janelas (pointer capture + backstop, regras da casa) =====
    function ligarArrasteJanela(sec) {
      const barra = sec.querySelector('[data-arrasta]');
      let drag = null;

      function finalizar(e) {
        if (!drag || e.pointerId !== drag.id) return;
        try { barra.releasePointerCapture(drag.id); } catch { /* já solto */ }
        drag = null;
      }

      barra.addEventListener('pointerdown', (e) => {
        focarJanela(sec.dataset.janela);
        if (e.target.closest('[data-min],[data-max],[data-fecha]')) return;
        if (sec.classList.contains('janela--max')) return;
        drag = { id: e.pointerId, dx: e.clientX - sec.offsetLeft, dy: e.clientY - sec.offsetTop };
        try { barra.setPointerCapture(e.pointerId); } catch { /* segue sem captura */ }
      });
      barra.addEventListener('pointermove', (e) => {
        if (!drag || e.pointerId !== drag.id) return;
        const areaW = areaEl.clientWidth;
        const areaH = areaEl.clientHeight;
        const larg = sec.offsetWidth;
        const x = Math.max(-larg + 60, Math.min(e.clientX - drag.dx, areaW - 60));
        const y = Math.max(0, Math.min(e.clientY - drag.dy, areaH - 24));
        sec.style.left = x + 'px';
        sec.style.top = y + 'px';
      });
      barra.addEventListener('pointerup', finalizar);
      barra.addEventListener('pointercancel', finalizar);
      barra.addEventListener('lostpointercapture', (e) => finalizar(e));
    }

    $$('.janela').forEach((sec) => {
      const id = sec.dataset.janela;
      ligarArrasteJanela(sec);
      sec.addEventListener('pointerdown', () => focarJanela(id));
      sec.querySelector('[data-min]').addEventListener('click', () => { somClique(); minimizar(id); });
      sec.querySelector('[data-max]').addEventListener('click', () => { somClique(); alternarMax(id); });
      sec.querySelector('[data-fecha]').addEventListener('click', () => { somClique(); fecharJanela(id); });
    });

    // ===== Abridores (ícones do desktop + itens do menu) =====
    $$('[data-abre]').forEach((btn) => {
      btn.addEventListener('click', () => {
        alternarMenu(false);
        abrirJanela(btn.dataset.abre, btn);
      });
    });
    $('[data-desligar]').addEventListener('click', desligar);

    // ===== Menu Iniciar =====
    function alternarMenu(abrir) {
      const alvo = typeof abrir === 'boolean' ? abrir : menuEl.hidden;
      estado.menuAberto = alvo;
      menuEl.hidden = !alvo;
      iniciarBtn.setAttribute('aria-expanded', String(alvo));
      if (alvo) {
        somClique();
        const primeiro = menuEl.querySelector('button');
        if (primeiro) primeiro.focus();
      }
    }
    iniciarBtn.addEventListener('click', () => alternarMenu());
    document.addEventListener('pointerdown', (e) => {
      if (!estado.menuAberto) return;
      if (e.target.closest('[data-menu],[data-iniciar]')) return;
      alternarMenu(false);
    });

    // ===== Teclado =====
    window.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      if (estado.menuAberto) {
        alternarMenu(false);
        iniciarBtn.focus();
        return;
      }
      const ativa = janelaAtiva();
      if (ativa) fecharJanela(ativa);
    });

    // ===== Relógio (hora de verdade, como manda o figurino) =====
    const relogioEl = $('[data-relogio]');
    function atualizarRelogio() {
      relogioEl.textContent = new Date().toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
      setTimeout(atualizarRelogio, 60000 - (Date.now() % 60000) + 250);
    }

    // Cinto e suspensório: se algo ainda rolar a área (navegador antigo), volta pro zero
    areaEl.addEventListener('scroll', () => {
      areaEl.scrollLeft = 0;
      areaEl.scrollTop = 0;
    });

    // ===== Tocador de "MIDI" (musiquinha.mid) =====
    // Melodia própria, alegre, timbre de computador antigo — sem música com direitos.
    const MELODIA = [
      [523, 0.2], [659, 0.2], [784, 0.2], [1047, 0.35],
      [784, 0.2], [880, 0.2], [1047, 0.5],
      [880, 0.2], [784, 0.2], [659, 0.2], [587, 0.35], [523, 0.65],
    ];
    let notasMidi = [];
    const midiStatusEl = $('[data-midi-status]');
    function pararMelodia(silencioso) {
      notasMidi.forEach((o) => { try { o.stop(); } catch { /* já parou */ } });
      notasMidi = [];
      if (!silencioso && midiStatusEl) midiStatusEl.textContent = 'Parado';
    }
    function tocarMelodia() {
      initAudio();
      if (actx && actx.state === 'suspended') actx.resume();
      if (estado.mudo) { midiStatusEl.textContent = 'Som desligado! Liga no alto-falante 🔊'; return; }
      if (!actx || actx.state !== 'running') return;
      pararMelodia(true);
      let t = actx.currentTime + 0.05;
      let total = 0;
      for (const par of MELODIA) {
        const o = actx.createOscillator();
        const g = actx.createGain();
        o.type = 'triangle';
        o.frequency.value = par[0];
        o.connect(g); g.connect(actx.destination);
        g.gain.setValueAtTime(0.0001, t);
        g.gain.linearRampToValueAtTime(0.13, t + 0.02);
        g.gain.exponentialRampToValueAtTime(0.0001, t + par[1]);
        o.start(t); o.stop(t + par[1] + 0.03);
        notasMidi.push(o);
        t += par[1];
        total += par[1];
      }
      midiStatusEl.textContent = 'Tocando… ♪ ♫';
      setTimeout(() => {
        if (notasMidi.length) { notasMidi = []; midiStatusEl.textContent = 'Parado'; }
      }, total * 1000 + 250);
    }
    const midiTocarBtn = $('[data-midi-tocar]');
    const midiPararBtn = $('[data-midi-parar]');
    if (midiTocarBtn) midiTocarBtn.addEventListener('click', tocarMelodia);
    if (midiPararBtn) midiPararBtn.addEventListener('click', () => pararMelodia(false));

    // ===== Internet Explorer =====
    const IE_HOME = 'www.portaldaturminha.com.br';
    const ieEstado = { hist: [], idx: -1, token: 0, discou: false, visitas: 0 };
    const iePaginaEl = $('[data-ie-pagina]');
    const ieUrlEl = $('[data-ie-url]');
    const ieStatusEl = $('[data-ie-status]');
    const ieTituloEl = $('[data-ie-titulo]');
    const ieVoltarBtn = $('[data-ie-voltar]');
    const ieAvancarBtn = $('[data-ie-avancar]');
    const ieAtualizarBtn = $('[data-ie-atualizar]');
    const ieInicioBtn = $('[data-ie-inicio]');
    const ieIrBtn = $('[data-ie-ir]');

    function siteDe(url) {
      return document.querySelector('[data-ie-sites] [data-site="' + String(url).replace(/["\\]/g, '') + '"]');
    }
    function normalizarUrl(txt) {
      let u = (txt || '').trim().toLowerCase().replace(/^https?:\/\//, '').replace(/\/+$/, '');
      if (!u) return null;
      if (!siteDe(u) && siteDe('www.' + u)) u = 'www.' + u;
      return u;
    }
    function ieUrlAtual() { return ieEstado.hist[ieEstado.idx] || null; }
    function ieBotoes() {
      ieVoltarBtn.disabled = ieEstado.idx <= 0;
      ieAvancarBtn.disabled = ieEstado.idx >= ieEstado.hist.length - 1;
      ieAtualizarBtn.disabled = ieEstado.idx < 0;
    }
    function ieRender(url) {
      const fonte = siteDe(url) || siteDe('__erro__');
      const clone = fonte.cloneNode(true);
      clone.hidden = false;
      const tinhaFoco = iePaginaEl.contains(document.activeElement);
      iePaginaEl.replaceChildren.apply(iePaginaEl, [...clone.childNodes]);
      iePaginaEl.scrollTop = 0;
      const eErro = !siteDe(url);
      if (eErro) {
        const alvo = iePaginaEl.querySelector('[data-url-erro]');
        // textContent, NUNCA innerHTML: o que a criança digitar vira texto inofensivo
        if (alvo) alvo.textContent = 'http://' + url + '/';
      }
      const titulo = fonte.dataset.titulo;
      ieTituloEl.textContent = titulo + ' — Internet Explorer';
      const spanTarefa = tarefasEl.querySelector('[data-tarefa="internet-explorer"] span');
      if (spanTarefa) spanTarefa.textContent = titulo + ' — Internet Explorer';
      if (!eErro && url === IE_HOME) {
        ieEstado.visitas++;
        const v = iePaginaEl.querySelector('[data-visitas]');
        if (v) v.textContent = String(4318 + ieEstado.visitas).padStart(6, '0').replace(/^(\d{3})/, '$1.');
      }
      if (tinhaFoco) iePaginaEl.focus({ preventScroll: true });
      anunciar(eErro ? 'A página não pode ser exibida.' : 'Página carregada: ' + titulo);
    }
    function ieNavegar(url, modo) {
      const meu = ++ieEstado.token; // navegação mais nova invalida as pendentes
      somDiscada();
      if (modo === 'empurra') {
        // digitar/clicar no meio do histórico corta o "Avançar" (igual IE de verdade)
        ieEstado.hist = ieEstado.hist.slice(0, ieEstado.idx + 1);
        ieEstado.hist.push(url);
        ieEstado.idx++;
        if (ieEstado.hist.length > 50) { ieEstado.hist.shift(); ieEstado.idx--; }
      }
      ieBotoes();
      ieUrlEl.value = 'http://' + url + '/';
      ieStatusEl.textContent = 'Conectando a ' + url + '…';
      setTimeout(() => {
        if (meu !== ieEstado.token) return;
        ieRender(url);
        ieStatusEl.textContent = 'Concluído';
      }, 400);
    }
    ieVoltarBtn.addEventListener('click', () => {
      if (ieEstado.idx <= 0) return;
      somClique();
      ieEstado.idx--;
      ieNavegar(ieUrlAtual(), 'historico');
    });
    ieAvancarBtn.addEventListener('click', () => {
      if (ieEstado.idx >= ieEstado.hist.length - 1) return;
      somClique();
      ieEstado.idx++;
      ieNavegar(ieUrlAtual(), 'historico');
    });
    ieAtualizarBtn.addEventListener('click', () => {
      if (ieEstado.idx < 0) return;
      somClique();
      ieNavegar(ieUrlAtual(), 'atualiza');
    });
    ieInicioBtn.addEventListener('click', () => {
      somClique();
      ieNavegar(IE_HOME, ieUrlAtual() === IE_HOME ? 'atualiza' : 'empurra');
    });
    function ieIrDigitado() {
      const u = normalizarUrl(ieUrlEl.value);
      if (!u) { ieStatusEl.textContent = 'Digite um endereço. Exemplo: www.dinomania.com.br'; return; }
      ieNavegar(u, u === ieUrlAtual() ? 'atualiza' : 'empurra');
    }
    ieIrBtn.addEventListener('click', () => { somClique(); ieIrDigitado(); });
    ieUrlEl.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); ieIrDigitado(); }
      if (e.key === 'Escape') {
        // sem isso o Esc global fecharia a janela enquanto a criança edita a URL
        e.stopPropagation();
        const atual = ieUrlAtual();
        if (atual) ieUrlEl.value = 'http://' + atual + '/';
      }
    });
    ieUrlEl.addEventListener('focus', () => ieUrlEl.select());
    // Cliques dentro da página (delegação — sobrevive ao replaceChildren)
    iePaginaEl.addEventListener('click', (e) => {
      const a = e.target.closest('[data-vai]');
      if (a) {
        e.preventDefault();
        somClique();
        const u = normalizarUrl(a.dataset.vai);
        if (u) ieNavegar(u, 'empurra');
        return;
      }
      const b = e.target.closest('[data-baixar]');
      if (b) {
        somClique();
        ieStatusEl.textContent = 'Baixando ' + b.dataset.baixar + '… faltam 3 horas e 47 minutos ⏳';
        const meu = ieEstado.token;
        setTimeout(() => {
          if (meu === ieEstado.token) ieStatusEl.textContent = '☎️ Alguém pegou o telefone! Download cancelado. Tente de novo… ou aceite. 😅';
        }, 2500);
        return;
      }
      if (e.target.closest('[data-votar]')) {
        somClique();
        ieStatusEl.textContent = 'Voto computado! Obrigado por votar (de mentirinha). 🗳️';
      }
    });
    // Som de discagem: DTMF + "atendeu" + chiado — só na 1ª navegação que conseguir tocar
    function somDiscada() {
      if (estado.mudo || !actx || actx.state !== 'running' || ieEstado.discou) return;
      ieEstado.discou = true;
      const t0 = actx.currentTime;
      const DTMF = [[941, 1336], [697, 1209], [770, 1477], [852, 1209]];
      DTMF.forEach((par, i) => par.forEach((f) => {
        const o = actx.createOscillator();
        const g = actx.createGain();
        o.type = 'sine'; o.frequency.value = f;
        o.connect(g); g.connect(actx.destination);
        const t = t0 + i * 0.14;
        g.gain.setValueAtTime(0.0001, t);
        g.gain.linearRampToValueAtTime(0.05, t + 0.01);
        g.gain.setValueAtTime(0.05, t + 0.08);
        g.gain.linearRampToValueAtTime(0.0001, t + 0.09);
        o.start(t); o.stop(t + 0.1);
      }));
      tom(2100, 0.6, 0.15, 'sine', 0.045);
      const dur = 0.5;
      const buf = actx.createBuffer(1, Math.ceil(actx.sampleRate * dur), actx.sampleRate);
      const dados = buf.getChannelData(0);
      for (let i = 0; i < dados.length; i++) dados[i] = Math.random() * 2 - 1;
      const src = actx.createBufferSource();
      src.buffer = buf;
      const filtro = actx.createBiquadFilter();
      filtro.type = 'bandpass'; filtro.frequency.value = 1800; filtro.Q.value = 0.7;
      const g = actx.createGain();
      src.connect(filtro); filtro.connect(g); g.connect(actx.destination);
      const t = t0 + 0.78;
      g.gain.setValueAtTime(0.0001, t);
      g.gain.linearRampToValueAtTime(0.035, t + 0.06);
      g.gain.setValueAtTime(0.035, t + 0.32);
      g.gain.linearRampToValueAtTime(0.0001, t + 0.42);
      src.start(t); src.stop(t + 0.45);
    }

    // ===== Boot =====
    document.body.classList.add('is-game');
    atualizarRelogio();
    ligar();
  </script>
</Layout>
