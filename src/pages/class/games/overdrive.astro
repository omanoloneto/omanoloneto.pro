---
import Layout from '../../../layouts/Layout.astro';
import { config, mapa, carros, pecas } from '../../../data/overdrive';

const dadosJson = JSON.stringify({ config, mapa, carros, pecas });

const title = 'Overdrive — corrida arcade à noite em São Leopoldo! | Manolo Neto';
const description =
  'Jogo de corrida arcade no navegador: acelere e derrape pelas avenidas de São Leopoldo à noite, da Av. João Corrêa à Av. Unisinos, sob o viaduto da BR-116.';
---

<Layout title={title} description={description}>
  <script type="application/json" data-dados set:html={dadosJson}></script>

  <main id="conteudo" class="slr" data-game role="application" aria-label="Overdrive: dirija um carro de corrida por São Leopoldo à noite">
    <div class="cena" data-cena>

      <div class="gps" data-gps hidden>
        <canvas class="minimapa" data-minimapa width="150" height="150" aria-label="Minimapa — toque pra abrir o mapa de São Leopoldo"></canvas>
        <div class="gps__label">
          <span class="gps__rua" data-lugar>São Leopoldo</span>
          <span class="gps__cidade">São Leopoldo - RS</span>
        </div>
      </div>

      <div class="mapa" data-mapa hidden>
        <div class="mapa__caixa" role="dialog" aria-modal="false" aria-label="Mapa de São Leopoldo">
          <div class="mapa__topo">
            <span>🗺️ São Leopoldo</span>
            <button class="mapa__fechar" type="button" data-mapa-fechar aria-label="Fechar o mapa">✖</button>
          </div>
          <canvas class="mapa__tela" data-mapa-canvas width="800" height="800"></canvas>
          <p class="mapa__dica">O triângulo amarelo é você · M abre e fecha</p>
        </div>
      </div>

      <div class="painel-vel" aria-label="Velocidade">
        <strong data-vel>0</strong>
        <span>km/h</span>
      </div>

      <button class="hud-btn hud-btn--pause" type="button" data-pause aria-label="Pausar o jogo" hidden>⏸</button>
      <button class="hud-btn hud-btn--mute" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
        <span data-mute-icon>🔊</span>
      </button>

      <div class="controles" data-controles hidden>
        <div class="controles__esq">
          <button class="ctl" type="button" data-ctl="left" aria-label="Virar à esquerda">◀</button>
          <button class="ctl" type="button" data-ctl="right" aria-label="Virar à direita">▶</button>
        </div>
        <div class="controles__dir">
          <button class="ctl ctl--drift" type="button" data-ctl="handbrake" aria-label="Derrapar">💨</button>
          <button class="ctl" type="button" data-ctl="brake" aria-label="Frear ou dar ré">▼</button>
          <button class="ctl ctl--acel" type="button" data-ctl="accel" aria-label="Acelerar">▲</button>
        </div>
      </div>

      <div class="fantasma" data-fantasma hidden>
        <span class="fantasma__desktop">W A S D ou setas dirigem · ESPAÇO derrapa · M mapa · ESC pausa</span>
        <span class="fantasma__touch">◀ ▶ viram · ▲ acelera · 💨 derrapa · toque no minimapa pro mapão</span>
      </div>
    </div>

    <p class="sr-only" data-anuncio aria-live="assertive"></p>

    <div class="modal" data-inicio>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="slr-title">
        <div class="placa__topo" id="slr-title">🏎️ Overdrive</div>
        <div class="placa__corpo">
          <p class="chamada">Noite fechada em <b>São Leopoldo</b> — mas o sol vai nascer! As avenidas são suas: da <b>Av. João Corrêa</b> à <b>Av. Unisinos</b>, cruzando por baixo do viaduto da <b>BR-116</b>.</p>
          <p class="dica">Dirija com <b>W A S D</b> ou setas · segure <b>ESPAÇO</b> pra derrapar nas curvas</p>
          <button class="botao botao--go" type="button" data-acelerar>🏁 Acelerar</button>
          <a class="voltar" href="/class/games/">← voltar pros jogos</a>
        </div>
      </div>
    </div>

    <div class="modal" data-pausa hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="slr-pausa">
        <div class="placa__topo" id="slr-pausa">⏸ Pausa</div>
        <div class="placa__corpo">
          <button class="botao botao--go" type="button" data-continuar>▶ Continuar</button>
          <button class="botao botao--sec" type="button" data-sair>🚪 Sair do jogo</button>
        </div>
      </div>
    </div>
  </main>
</Layout>

<style is:global>
  body.is-game { overflow: hidden; }
  .slr {
    position: fixed; inset: 0;
    display: flex; flex-direction: column;
    background: #05070f;
    font-family: 'Oxanium', Verdana, sans-serif;
    color: #e8ecf8;
    overflow: clip;
  }
  .cena { position: relative; z-index: 10; flex: 1; min-height: 0; }
  .cena canvas { display: block; width: 100%; height: 100%; touch-action: none; }

  .gps {
    position: absolute; top: 10px; left: 10px;
    z-index: 30;
    display: flex; flex-direction: column; align-items: center;
    gap: 6px;
    pointer-events: none;
  }
  .gps[hidden] { display: none; }
  @media (pointer: fine) {
    .gps { top: auto; left: 16px; bottom: max(16px, env(safe-area-inset-bottom)); }
  }
  canvas.minimapa {
    width: 150px; height: 150px;
    border-radius: 50%;
    cursor: pointer;
    pointer-events: auto;
    border: 5px solid transparent;
    background:
      linear-gradient(#0a0b0d, #0a0b0d) padding-box,
      conic-gradient(from 210deg, #9aa0aa, #4a4e56 18%, #23262c 38%, #7d838d 55%, #33363d 72%, #9aa0aa) border-box;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.65), 0 0 0 1px #121418;
  }
  .gps__label {
    display: flex; flex-direction: column; align-items: center;
    padding: 5px 12px 6px;
    background: rgba(10, 11, 15, 0.85);
    border: 1px solid rgba(90, 96, 106, 0.55);
    border-radius: 10px;
    text-align: center;
    line-height: 1.25;
    max-width: 195px;
  }
  .gps__rua {
    color: #ffd23f;
    font-weight: 800;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 180px;
  }
  .gps__cidade {
    color: #eef1f6;
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.9;
    white-space: nowrap;
  }
  .mapa {
    position: fixed; inset: 0;
    z-index: 55;
    display: flex; align-items: center; justify-content: center;
    background: rgba(3, 4, 12, 0.7);
    padding: 12px;
  }
  .mapa[hidden] { display: none; }
  .mapa__caixa {
    background: linear-gradient(160deg, #12142a, #0a0c1e);
    border: 1px solid rgba(0, 229, 255, 0.45);
    border-radius: 16px;
    padding: 0 14px 12px;
    box-shadow: 0 0 36px rgba(0, 229, 255, 0.22);
  }
  .mapa__topo {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px;
    padding: 10px 2px;
    font-weight: 800;
    font-size: 1.05rem;
  }
  .mapa__fechar {
    width: 34px; height: 34px;
    border: 0; border-radius: 9px;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    cursor: pointer;
  }
  canvas.mapa__tela {
    display: block;
    width: min(76vmin, 540px);
    height: min(76vmin, 540px);
    image-rendering: pixelated;
    border-radius: 10px;
    border: 1px solid rgba(122, 47, 240, 0.4);
  }
  .mapa__dica {
    margin: 8px 0 0;
    font-size: 0.82rem;
    opacity: 0.75;
    text-align: center;
  }
  @media (max-width: 560px) {
    canvas.minimapa { width: 104px; height: 104px; }
    .gps__label { max-width: 150px; padding: 4px 8px 5px; }
    .gps__rua { max-width: 132px; font-size: 0.64rem; }
    .gps__cidade { font-size: 0.52rem; }
  }

  .painel-vel {
    position: absolute; right: 18px; bottom: max(16px, env(safe-area-inset-bottom));
    z-index: 30;
    display: flex; align-items: baseline; gap: 6px;
    padding: 8px 16px;
    background: rgba(8, 10, 24, 0.72);
    border: 1px solid rgba(255, 63, 164, 0.5);
    border-radius: 14px;
    pointer-events: none;
  }
  .painel-vel strong {
    font-size: 2.3rem;
    font-weight: 800;
    line-height: 1;
    min-width: 3ch;
    text-align: right;
    color: #fff;
    text-shadow: 0 0 14px rgba(255, 63, 164, 0.8);
    font-variant-numeric: tabular-nums;
  }
  .painel-vel span { font-size: 0.8rem; opacity: 0.75; }

  .hud-btn {
    position: absolute; top: 12px;
    z-index: 40;
    width: 42px; height: 42px;
    border: 1px solid rgba(122, 47, 240, 0.6);
    border-radius: 12px;
    background: rgba(8, 10, 24, 0.72);
    color: #fff;
    font-size: 1.1rem;
    cursor: pointer;
  }
  .hud-btn--mute { right: 12px; }
  .hud-btn--pause { right: 62px; }
  .hud-btn[hidden] { display: none; }

  .controles {
    position: absolute; inset: 0;
    z-index: 35;
    pointer-events: none;
  }
  .controles[hidden] { display: none; }
  .controles__esq, .controles__dir {
    position: absolute; bottom: max(14px, env(safe-area-inset-bottom));
    display: flex; gap: 10px;
    pointer-events: auto;
  }
  .controles__esq { left: 14px; }
  .controles__dir { right: 14px; flex-direction: row; align-items: flex-end; }
  .ctl {
    width: 64px; height: 64px;
    border-radius: 16px;
    border: 1px solid rgba(0, 229, 255, 0.45);
    background: rgba(8, 10, 24, 0.6);
    color: #fff;
    font-size: 1.5rem;
    touch-action: none;
    -webkit-user-select: none;
    user-select: none;
  }
  .ctl.on { background: rgba(122, 47, 240, 0.55); }
  .ctl--acel { width: 76px; height: 76px; }
  .controles__dir .painel-vel { right: 110px; }
  @media (pointer: coarse) { .painel-vel { bottom: calc(96px + env(safe-area-inset-bottom)); } }

  .fantasma {
    position: absolute; left: 50%; bottom: 22%;
    transform: translateX(-50%);
    z-index: 30;
    padding: 10px 16px;
    background: rgba(8, 10, 24, 0.75);
    border-radius: 12px;
    font-size: 0.95rem;
    text-align: center;
    pointer-events: none;
    max-width: 90%;
  }
  .fantasma[hidden] { display: none; }
  @media (pointer: fine) { .fantasma__touch { display: none; } }
  @media (pointer: coarse) { .fantasma__desktop { display: none; } }

  .modal {
    position: fixed; inset: 0;
    z-index: 60;
    display: flex; align-items: center; justify-content: center;
    background: rgba(3, 4, 12, 0.78);
    padding: 14px;
  }
  .modal[hidden] { display: none; }
  .placa {
    width: min(440px, 94vw);
    background: linear-gradient(160deg, #12142a, #0a0c1e);
    border: 1px solid rgba(122, 47, 240, 0.55);
    border-radius: 18px;
    box-shadow: 0 0 42px rgba(122, 47, 240, 0.35);
    overflow: hidden;
  }
  .placa__topo {
    padding: 14px 18px;
    font-size: 1.3rem;
    font-weight: 800;
    background: linear-gradient(90deg, rgba(122, 47, 240, 0.4), rgba(255, 63, 164, 0.28));
    text-shadow: 0 0 14px rgba(0, 229, 255, 0.55);
  }
  .placa__corpo { padding: 18px; display: flex; flex-direction: column; gap: 12px; }
  .chamada { margin: 0; line-height: 1.5; }
  .dica { margin: 0; font-size: 0.9rem; opacity: 0.8; }
  .botao {
    padding: 13px 18px;
    border: 0;
    border-radius: 12px;
    font-family: inherit;
    font-size: 1.05rem;
    font-weight: 800;
    cursor: pointer;
  }
  .botao--go {
    background: linear-gradient(135deg, #7a2ff0, #d81f8f);
    color: #fff;
    box-shadow: 0 0 22px rgba(216, 31, 143, 0.5);
  }
  .botao--sec { background: rgba(255, 255, 255, 0.12); color: #fff; }
  .voltar { color: #7fd8ff; font-size: 0.9rem; text-align: center; }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    border: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .placa { box-shadow: none; }
  }
</style>

<script>
  import { startGame } from '../../../games/overdrive/main';
  startGame();
</script>
