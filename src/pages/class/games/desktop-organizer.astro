  <!-- ============================ JOGO ============================ -->
  <main id="conteudo" class="xp" data-game role="application" aria-label="Jogo: organize a área de trabalho separando hardware e software">
    <div class="xp__wallpaper" aria-hidden="true">
      <span class="cloud cloud--1"></span>
      <span class="cloud cloud--2"></span>
      <span class="cloud cloud--3"></span>
    </div>

    <!-- HUD -->
    <header class="hud" role="status" aria-live="polite">
      <div class="hud__score">
        <span class="hud__label">Pontos</span>
        <strong data-score>0</strong>
      </div>
      <div class="hud__phase">
        <span class="hud__label">Fase</span>
        <strong data-phase>1</strong>
        <span class="hud__phase-total" data-phase-total>de 3</span>
      </div>
      <div class="hud__progress">
        <div class="bar"><span data-progress-bar></span></div>
        <span class="hud__count" data-progress>0 / 0 organizados</span>
      </div>
      <button class="hud__mute" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
        <span data-mute-icon>🔊</span>
      </button>
    </header>

    <!-- Mesa com ícones espalhados (preenchida pelo script) -->
    <section class="desktop" data-desktop aria-label="Ícones para organizar"></section>

    <!-- Pastas (drop zones) — renderizadas pelo script por fase -->
    <div class="zones" data-zones></div>

    <!-- Taskbar -->
    <footer class="taskbar">
      <button class="start" type="button" data-start-btn aria-label="Como jogar">
        <span class="start__flag" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
        <span class="start__text">iniciar</span>
      </button>
      <div class="taskbar__title" aria-hidden="true">Organizador da Área de Trabalho</div>
      <div class="tray"><span class="clock" data-clock>00:00</span></div>
    </footer>

    <!-- Toast de feedback -->
    <div class="toast" data-toast aria-live="polite" hidden></div>

    <!-- Região para leitores de tela -->
    <p class="sr-only" data-anuncio aria-live="assertive"></p>

    <!-- Modal: instruções -->
    <div class="modal" data-intro>
      <div class="xp-window" role="dialog" aria-modal="true" aria-labelledby="intro-title">
        <div class="xp-window__bar">
