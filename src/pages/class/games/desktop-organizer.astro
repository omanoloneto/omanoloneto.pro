---
import Layout from '../../../layouts/Layout.astro';
import { itensDesktop, config, fases, categoriasInfo } from '../../../data/desktop-organizer';

const dataJson = JSON.stringify(itensDesktop);
const configJson = JSON.stringify({ config, fases, categoriasInfo });

const title = 'Organizador da Área de Trabalho — Hardware ou Software? | Manolo Neto';
const description =
  'Jogo educativo para crianças aprenderem a diferença entre hardware e software arrastando ícones numa área de trabalho estilo Windows XP. Em português.';
---

