  <script>
    // ===== Estado e dados =====
    const itens = JSON.parse(document.querySelector('[data-items]').textContent);
    const dados = JSON.parse(document.querySelector('[data-config]').textContent);
    const cfg = dados.config;
    const fases = dados.fases;
    const categoriasInfo = dados.categoriasInfo;
    const semMov = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const $ = (s) => document.querySelector(s);
    const desktop = $('[data-desktop]');
    const zonesEl = $('[data-zones]');
    let folders = {}; // { categoria: elementoDaPasta } — reconstruído por fase
    const elScore = $('[data-score]');
    const elBar = $('[data-progress-bar]');
    const elCount = $('[data-progress]');
    const elToast = $('[data-toast]');
    const elAnuncio = $('[data-anuncio]');
    const introModal = $('[data-intro]');
    const winModal = $('[data-win]');
    const faseDoneModal = $('[data-fase-done]');

    const estado = {
      itens: [],
      pontos: 0,        // ACUMULA entre fases; só zera no "Jogar de novo"
      total: 0,
      organizados: 0,
      mudo: false,
      iniciado: false,
      faseIdx: 0,
      categorias: [],   // categorias ativas na fase atual (define as pastas)
      selecionado: null, // elemento do ícone selecionado (modo toque/teclado)
    };

    // ===== Áudio (Web Audio API, sem arquivos) =====
    let actx = null;
    function initAudio() {
      if (actx) return;
      const AC = window.AudioContext || window.webkitAudioContext;
      if (AC) actx = new AC();
    }
    function tom(freq, inicio, dur, tipo, vol) {
      if (!actx) return;
      const o = actx.createOscillator();
      const g = actx.createGain();
      o.type = tipo;
      o.frequency.value = freq;
      o.connect(g);
      g.connect(actx.destination);
      const t = actx.currentTime + inicio;
      g.gain.setValueAtTime(0.0001, t);
      g.gain.linearRampToValueAtTime(vol, t + 0.02);
      g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      o.start(t);
      o.stop(t + dur + 0.03);
    }
    function somOk() { if (estado.mudo) return; tom(660, 0, 0.13, 'triangle', 0.22); tom(990, 0.1, 0.17, 'triangle', 0.2); }
    function somErr() { if (estado.mudo) return; tom(160, 0, 0.26, 'square', 0.18); }
    function somWin() {
      if (estado.mudo) return;
      [523, 659, 784, 1046].forEach((f, i) => tom(f, i * 0.12, 0.2, 'triangle', 0.2));
    }

    // ===== Mudo =====
    const muteBtn = $('[data-mute]');
    const muteIcon = $('[data-mute-icon]');
    function aplicarMudo() {
      muteBtn.setAttribute('aria-pressed', String(estado.mudo));
      muteIcon.textContent = estado.mudo ? '🔈' : '🔊';
      muteBtn.setAttribute('aria-label', estado.mudo ? 'Ligar o som' : 'Desligar o som');
    }
    (function initMudo() {
      const salvo = localStorage.getItem('desktop-organizer:mudo');
      estado.mudo = salvo === null ? !cfg.somLigadoInicial : salvo === '1';
      aplicarMudo();
    })();
    muteBtn.addEventListener('click', () => {
      estado.mudo = !estado.mudo;
      localStorage.setItem('desktop-organizer:mudo', estado.mudo ? '1' : '0');
      aplicarMudo();
    });

    // ===== Utilidades =====
    function embaralhar(arr) {
      const a = arr.slice();
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }
    function anunciar(msg) { elAnuncio.textContent = ''; requestAnimationFrame(() => { elAnuncio.textContent = msg; }); }

    // Escolhe os itens da fase: n por categoria, sorteados e misturados.
    function selecionarItensFase(fase) {
      const pick = [];
      for (const cat of fase.categorias) {
        const n = fase.quantidades[cat] || 0;
        const pool = itens.filter((i) => i.tipo === cat);
        const sorteados = cfg.embaralhar ? embaralhar(pool) : pool;
        pick.push(...sorteados.slice(0, n));
      }
      return cfg.embaralhar ? embaralhar(pick) : pick;
    }

    // Cria as pastas (drop zones) da fase atual.
    function renderFolders(categorias) {
      zonesEl.innerHTML = '';
      zonesEl.dataset.count = String(categorias.length);
      folders = {};
      for (const cat of categorias) {
        const info = categoriasInfo[cat];
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'folder';
        btn.dataset.zone = cat;
        btn.setAttribute('aria-label', 'Pasta ' + info.label + ': ' + info.hint);
        btn.innerHTML =
          '<svg class="folder__art" aria-hidden="true"><use href="#ico-pasta"/></svg>' +
          '<span class="folder__name">' + info.label + '</span>' +
          '<span class="folder__hint">' + info.hint + '</span>';
        btn.addEventListener('click', () => {
          if (!estado.iniciado || !estado.selecionado) return;
          const el = estado.selecionado;
          const item = itens.find((i) => i.id === el.dataset.id);
          if (item) resolver(el, item, cat, null);
        });
        zonesEl.appendChild(btn);
        folders[cat] = btn;
      }
    }

    function limparHot() {
      for (const cat of estado.categorias) folders[cat] && folders[cat].classList.remove('folder--hot');
    }

    // ===== Construir ícones na mesa =====
    function criarIcone(item) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'icon';
      btn.dataset.id = item.id;
      btn.dataset.tipo = item.tipo;
      btn.setAttribute('aria-label', item.label);
      btn.innerHTML =
        '<svg class="icon__art" viewBox="0 0 48 48"><use href="#ico-' + item.id + '"/></svg>' +
        '<span class="icon__label">' + item.label + '</span>';
      ligarInteracao(btn, item);
      return btn;
    }

    function espalhar() {
      const w = desktop.clientWidth;
      const h = desktop.clientHeight;
      const iconeW = 112;
      const iconeH = 116;
      const n = estado.itens.length;
      const cols = Math.max(2, Math.min(n, Math.floor(w / (iconeW + 14)) || 2));
      const rows = Math.ceil(n / cols);
      const cellW = w / cols;
      const cellH = Math.max(iconeH, h / rows);
      estado.itens.forEach((reg, idx) => {
        const col = idx % cols;
        const row = Math.floor(idx / cols);
        const folgaX = Math.max(0, cellW - iconeW);
        const folgaY = Math.max(0, cellH - iconeH);
        let x = col * cellW + Math.random() * folgaX;
        let y = row * cellH + Math.random() * folgaY;
        x = Math.min(Math.max(4, x), Math.max(4, w - iconeW));
        y = Math.min(Math.max(2, y), Math.max(2, h - iconeH));
        reg.el.style.position = 'absolute';
        reg.el.style.left = x + 'px';
        reg.el.style.top = y + 'px';
        reg.el.dataset.x = String(x);
        reg.el.dataset.y = String(y);
      });
    }

    // Monta uma fase (NÃO zera os pontos — eles acumulam entre fases).
    function montarFase(idx) {
      estado.faseIdx = idx;
      const fase = fases[idx];
      estado.categorias = fase.categorias.slice();
      renderFolders(estado.categorias);

      desktop.innerHTML = '';
      estado.organizados = 0;
      estado.selecionado = null;
      const escolhidos = selecionarItensFase(fase);
      estado.total = escolhidos.length;
      estado.itens = escolhidos.map((item) => {
        const el = criarIcone(item);
        desktop.appendChild(el);
        return { item, el };
      });
      // espalha após o layout das pastas assentar
      requestAnimationFrame(() => espalhar());

      elScore.textContent = String(estado.pontos);
      $('[data-phase]').textContent = String(idx + 1);
      $('[data-phase-total]').textContent = 'de ' + fases.length;
      atualizarProgresso();
    }

    function atualizarProgresso() {
      elCount.textContent = estado.organizados + ' / ' + estado.total + ' organizados';
      const pct = estado.total ? (estado.organizados / estado.total) * 100 : 0;
      elBar.style.width = pct + '%';
    }

    function atualizarPlacar() {
      elScore.textContent = String(estado.pontos);
      elScore.classList.add('pop');
      setTimeout(() => elScore.classList.remove('pop'), 200);
    }

    let toastTimer = null;
    function mostrarToast(html, tipo) {
      elToast.innerHTML = html;
      elToast.className = 'toast ' + tipo;
      elToast.hidden = false;
      requestAnimationFrame(() => elToast.classList.add('show'));
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        elToast.classList.remove('show');
        setTimeout(() => { elToast.hidden = true; }, 250);
      }, tipo === 'ok' ? 2600 : 1900);
    }

    function pulsoPasta(zona, classe) {
      const f = folders[zona];
      f.classList.add(classe);
      setTimeout(() => f.classList.remove(classe), 450);
    }

    // ===== Animações de resultado =====
    function voarParaPasta(el, zona, aoFim) {
      const f = folders[zona];
      const r = el.getBoundingClientRect();
      const fr = f.getBoundingClientRect();
      if (semMov) { el.remove(); aoFim(); return; }
      el.style.position = 'fixed';
      el.style.left = r.left + 'px';
      el.style.top = r.top + 'px';
      el.style.width = r.width + 'px';
      el.style.margin = '0';
      el.style.zIndex = '1000';
      el.style.pointerEvents = 'none';
      // eslint-disable-next-line no-unused-expressions
      el.offsetWidth;
      const dx = fr.left + fr.width / 2 - (r.left + r.width / 2);
      const dy = fr.top + fr.height / 2 - (r.top + r.height / 2);
      el.style.transition = 'transform 0.45s cubic-bezier(.5,.1,.2,1), opacity 0.45s ease';
      el.style.transform = 'translate(' + dx + 'px,' + dy + 'px) scale(0.12)';
      el.style.opacity = '0';
      let done = false;
      const fim = () => { if (done) return; done = true; el.remove(); aoFim(); };
      el.addEventListener('transitionend', fim, { once: true });
      setTimeout(fim, 600);
    }

    function voltarOrigem(el, drag) {
      if (semMov) { restaurar(el); return; }
      el.style.transition = 'left 0.3s ease, top 0.3s ease, transform 0.3s ease';
      el.style.left = drag.originLeft + 'px';
      el.style.top = drag.originTop + 'px';
      let done = false;
      const fim = () => { if (done) return; done = true; restaurar(el); };
      el.addEventListener('transitionend', fim, { once: true });
      setTimeout(fim, 420);
    }

    function restaurar(el) {
      el.style.position = 'absolute';
      el.style.left = el.dataset.x + 'px';
      el.style.top = el.dataset.y + 'px';
      el.style.transition = '';
      el.style.transform = '';
      el.style.width = '';
      el.style.margin = '';
      el.style.zIndex = '';
      el.style.pointerEvents = '';
      el.classList.remove('is-dragging');
    }

    function tremer(el) {
      el.classList.remove('shake');
      void el.offsetWidth;
      el.classList.add('shake');
      setTimeout(() => el.classList.remove('shake'), 420);
    }

    // ===== Resolver jogada =====
    function resolver(el, item, zona, drag) {
      const acerto = item.tipo === zona;
      limparSelecao();
      if (acerto) {
        estado.pontos += cfg.pontosPorAcerto;
        atualizarPlacar();
        pulsoPasta(zona, 'folder--ok');
        somOk();
        mostrarToast('<b>✓ Certo!</b> ' + item.explicacao, 'ok');
        anunciar('Certo! ' + item.label + ' é ' + zona + '. ' + (estado.organizados + 1) + ' de ' + estado.total + '.');
        voarParaPasta(el, zona, () => {
          estado.organizados++;
          atualizarProgresso();
          if (estado.organizados >= estado.total) concluirFase();
        });
      } else {
        if (cfg.pontosPorErro) { estado.pontos = Math.max(0, estado.pontos + cfg.pontosPorErro); atualizarPlacar(); }
        pulsoPasta(zona, 'folder--err');
        somErr();
        mostrarToast('<b>✗ Quase!</b> Tente outra pasta.', 'err');
        anunciar('Ops, tente de novo.');
        if (drag) voltarOrigem(el, drag);
        else tremer(el);
      }
    }

    // ===== Seleção (modo toque/teclado) =====
    function limparSelecao() {
      if (estado.selecionado) estado.selecionado.classList.remove('is-selected');
      estado.selecionado = null;
    }
    function alternarSelecao(el, item) {
      if (estado.selecionado === el) { limparSelecao(); return; }
      limparSelecao();
      estado.selecionado = el;
      el.classList.add('is-selected');
      anunciar(item.label + ' selecionado. Agora escolha uma pasta.');
    }

    // ===== Hit-test de pasta sob um ponto (pastas da fase atual) =====
    function pastaNoPonto(x, y) {
      for (const zona of estado.categorias) {
        const f = folders[zona];
        if (!f) continue;
        const r = f.getBoundingClientRect();
        if (x >= r.left && x <= r.right && y >= r.top && y <= r.bottom) return zona;
      }
      return null;
    }

    // ===== Interação de cada ícone (drag + tap) =====
    const LIMIAR = 8;
    function ligarInteracao(el, item) {
      let drag = null;

      // Limpeza única e idempotente do arraste; devolver=true volta à origem.
      function finalizar(e, checarDrop) {
        if (!drag || (e && e.pointerId !== drag.id)) return;
        try { el.releasePointerCapture(drag.id); } catch (_) {}
        limparHot();
        const d = drag;
        drag = null;
        if (!d.ativo) {
          if (checarDrop) alternarSelecao(el, item); // toque/clique = selecionar
          return;
        }
        const zona = checarDrop && e ? pastaNoPonto(e.clientX, e.clientY) : null;
        if (zona) resolver(el, item, zona, d);
        else voltarOrigem(el, d); // solto fora (ou captura perdida): volta sem contar erro
      }

      el.addEventListener('pointerdown', (e) => {
        if (!estado.iniciado || e.button > 0) return;
        e.preventDefault();
        if (drag) { restaurar(el); drag = null; } // descarta arraste anterior preso
        drag = {
          id: e.pointerId, startX: e.clientX, startY: e.clientY,
          ativo: false, offsetX: 0, offsetY: 0, originLeft: 0, originTop: 0,
        };
        try { el.setPointerCapture(e.pointerId); } catch (_) {}
      });

      el.addEventListener('pointermove', (e) => {
        if (!drag || e.pointerId !== drag.id) return;
        const dx = e.clientX - drag.startX;
        const dy = e.clientY - drag.startY;
        if (!drag.ativo) {
          if (Math.hypot(dx, dy) < LIMIAR) return;
          // inicia o arraste
          const r = el.getBoundingClientRect();
          drag.ativo = true;
          drag.offsetX = drag.startX - r.left;
          drag.offsetY = drag.startY - r.top;
          drag.originLeft = r.left;
          drag.originTop = r.top;
          el.classList.add('is-dragging');
          el.style.position = 'fixed';
          el.style.left = r.left + 'px';
          el.style.top = r.top + 'px';
          el.style.width = r.width + 'px';
          el.style.margin = '0';
        }
        const nx = e.clientX - drag.offsetX;
        const ny = e.clientY - drag.offsetY;
        el.style.left = nx + 'px';
        el.style.top = ny + 'px';
        const zona = pastaNoPonto(e.clientX, e.clientY);
        for (const cat of estado.categorias) {
          folders[cat] && folders[cat].classList.toggle('folder--hot', zona === cat);
        }
      });

      el.addEventListener('pointerup', (e) => finalizar(e, true));
      el.addEventListener('pointercancel', (e) => finalizar(e, true));
      // Backstop: se o navegador soltar a captura no meio do arraste, devolve à origem.
      el.addEventListener('lostpointercapture', (e) => {
        if (drag && drag.id === e.pointerId && drag.ativo) finalizar(e, false);
      });

      // Teclado: Enter/Espaço seleciona
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          if (estado.iniciado) alternarSelecao(el, item);
        }
      });
    }

    // ===== Fim de fase / vitória =====
    function concluirFase() {
      if (estado.faseIdx < fases.length - 1) {
        somWin();
        $('[data-fase-done-title]').textContent = 'Fase ' + (estado.faseIdx + 1) + ' completa!';
        $('[data-fase-score]').textContent = String(estado.pontos);
        const prox = fases[estado.faseIdx + 1];
        $('[data-fase-next-label]').textContent = 'Agora a fase "' + prox.nome + '".';
        faseDoneModal.hidden = false;
        setTimeout(() => $('[data-next-fase]').focus(), 60);
      } else {
        venceu();
      }
    }

    function venceu() {
      somWin();
      $('[data-final-score]').textContent = String(estado.pontos);
      const totalItens = fases.reduce(
        (s, f) => s + Object.values(f.quantidades).reduce((a, b) => a + b, 0), 0);
      const max = totalItens * cfg.pontosPorAcerto;
      const msg = estado.pontos >= max
        ? 'Perfeito! Você acertou tudo de primeira! 🌟'
        : 'Muito bem! Continue praticando. 💪';
      $('[data-final-msg]').textContent = msg;
      winModal.hidden = false;
      setTimeout(() => $('[data-replay]').focus(), 60);
    }

    // ===== Relógio =====
    const relogio = $('[data-clock]');
    function tique() {
      const d = new Date();
      const p = (n) => String(n).padStart(2, '0');
      relogio.textContent = p(d.getHours()) + ':' + p(d.getMinutes());
    }
    tique();
    setInterval(tique, 15000);

    // ===== Fluxo: começar / próxima fase / rejogar / ajuda =====
    function comecar() {
      initAudio();
      if (actx && actx.state === 'suspended') actx.resume();
      estado.iniciado = true;
      introModal.hidden = true;
    }
    $('[data-comecar]').addEventListener('click', comecar);
    $('[data-next-fase]').addEventListener('click', () => {
      faseDoneModal.hidden = true;
      montarFase(estado.faseIdx + 1);
      estado.iniciado = true;
    });
    $('[data-replay]').addEventListener('click', () => {
      winModal.hidden = true;
      estado.pontos = 0; // reinício total zera os pontos
      montarFase(0);
      estado.iniciado = true;
    });
    $('[data-start-btn]').addEventListener('click', () => {
      if (winModal.hidden && faseDoneModal.hidden) introModal.hidden = false;
    });

    // ===== Reposicionar ao redimensionar =====
    let resizeTimer = null;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => { if (estado.itens.length) espalhar(); }, 200);
    });

    // ===== Boot =====
    document.body.classList.add('is-game');
    introModal.hidden = false;
    montarFase(0);
    setTimeout(() => $('[data-comecar]').focus(), 60);
  </script>
</Layout>
