    // ===== Áudio (Web Audio, sem arquivos) =====
    let actx = null;
    function initAudio() {
      if (actx) return;
      const AC = window.AudioContext || window.webkitAudioContext;
      if (AC) actx = new AC();
    }
    function tom(freq, inicio, dur, tipo, vol) {
      if (!actx) return;
      const o = actx.createOscillator();
      const g = actx.createGain();
      o.type = tipo; o.frequency.value = freq;
      o.connect(g); g.connect(actx.destination);
      const t = actx.currentTime + inicio;
      g.gain.setValueAtTime(0.0001, t);
      g.gain.linearRampToValueAtTime(vol, t + 0.02);
      g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      o.start(t); o.stop(t + dur + 0.03);
    }
    function somTiro() { if (estado.mudo) return; tom(920, 0, 0.07, 'sawtooth', 0.08); tom(680, 0.05, 0.08, 'sawtooth', 0.07); }
    function somExplosao() { if (estado.mudo) return; tom(180, 0, 0.18, 'square', 0.14); tom(1200, 0.03, 0.08, 'triangle', 0.1); tom(1500, 0.09, 0.1, 'triangle', 0.08); }
    // Acerto parcial (nave dupla): blip alegre, sem explosão cheia
    function somAcerto() { if (estado.mudo) return; tom(700, 0, 0.08, 'triangle', 0.14); tom(950, 0.06, 0.1, 'triangle', 0.12); }
    // Erro bem suave: grave, curto e baixinho — sem susto.
    function somErroSuave() { if (estado.mudo) return; tom(200, 0, 0.22, 'sine', 0.08); }
    function somCoracao() { if (estado.mudo) return; tom(660, 0, 0.12, 'triangle', 0.16); tom(990, 0.12, 0.2, 'triangle', 0.16); }
    function somEscapou() { if (estado.mudo) return; tom(500, 0, 0.18, 'sine', 0.12); tom(380, 0.16, 0.24, 'sine', 0.12); }
    function somNivel() { if (estado.mudo) return; [523, 659, 784, 1046].forEach((f, i) => tom(f, i * 0.12, 0.22, 'triangle', 0.2)); }
    // Fim gentil: acorde quente subindo — nunca som de "derrota".
    function somFimGentil() { if (estado.mudo) return; tom(392, 0, 0.5, 'triangle', 0.14); tom(494, 0.14, 0.5, 'triangle', 0.14); tom(587, 0.28, 0.6, 'triangle', 0.14); }
    // Arma superaqueceu: tons graves descendo (sem susto)
    function somSuperaquecida() { if (estado.mudo) return; tom(300, 0, 0.25, 'square', 0.1); tom(220, 0.18, 0.3, 'square', 0.09); tom(150, 0.4, 0.4, 'square', 0.08); }
    function somDestrava() { if (estado.mudo) return; tom(520, 0, 0.1, 'triangle', 0.12); tom(780, 0.09, 0.12, 'triangle', 0.12); }

    // ===== Mudo =====
    const muteBtn = $('[data-mute]');
    const muteIcon = $('[data-mute-icon]');
    function aplicarMudo() {
      muteBtn.setAttribute('aria-pressed', String(estado.mudo));
      muteIcon.textContent = estado.mudo ? '🔈' : '🔊';
      muteBtn.setAttribute('aria-label', estado.mudo ? 'Ligar o som' : 'Desligar o som');
    }
    (function initMudo() {
      const salvo = localStorage.getItem('letras-espaciais:mudo');
      estado.mudo = salvo === null ? !CFG.somLigadoInicial : salvo === '1';
      aplicarMudo();
    })();
    muteBtn.addEventListener('click', () => {
      estado.mudo = !estado.mudo;
      localStorage.setItem('letras-espaciais:mudo', estado.mudo ? '1' : '0');
      aplicarMudo();
    });

    // ===== Utilidades =====
    function anunciar(msg) { anuncioEl.textContent = ''; requestAnimationFrame(() => { anuncioEl.textContent = msg; }); }

    let toastTimer = null;
    function mostrarToast(html, tipo, ms) {
      toastEl.innerHTML = html;
      toastEl.className = 'toast ' + tipo;
      toastEl.hidden = false;
      requestAnimationFrame(() => toastEl.classList.add('show'));
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toastEl.classList.remove('show');
        setTimeout(() => { toastEl.hidden = true; }, 250);
      }, ms || 2200);
    }

    function atualizarPlacar() {
      const el = $('[data-pontos]');
      el.textContent = String(estado.pontos);
      el.classList.add('pop');
      setTimeout(() => el.classList.remove('pop'), 200);
    }

    function atualizarAbates() {
      $('[data-abates]').textContent = String(estado.abatesNoNivel);
      $('[data-abates-total]').textContent = 'de ' + NIVEIS[estado.nivelIdx].abates;
    }

    function atualizarVidas(pop) {
      let html = '';
      for (let i = 0; i < CFG.vidasMaximas; i++) {
        const cheio = i < estado.vidas;
        const classes = 'vida' + (cheio ? '' : ' vida--vazia') + (pop && i === estado.vidas - 1 ? ' vida--pop' : '');
        html += '<svg class="' + classes + '" viewBox="0 0 32 32" aria-hidden="true"><use href="#coracao"></use></svg>';
      }
      vidasEl.innerHTML = html;
      vidasWrapEl.setAttribute('aria-label', 'Vidas: ' + estado.vidas + ' de ' + CFG.vidasMaximas);
    }

    function medirCampo() {
      const r = campoEl.getBoundingClientRect();
      estado.campo.w = r.width || 1;
      estado.campo.h = r.height || 1;
      estado.campo.left = r.left;
      estado.campo.top = r.top;
      const n = naveEl.getBoundingClientRect();
      estado.campo.naveX = (n.left + n.width / 2 - r.left) / estado.campo.w;
      estado.campo.naveY = (n.top + 4 - r.top) / estado.campo.h;
    }

    function tremerNave() {
      naveEl.classList.remove('nave--treme');
      void naveEl.offsetWidth; // reinicia a animação
      naveEl.classList.add('nave--treme');
    }

    // ===== Superaquecimento (anti-apertar-tudo) =====
    // Tecla errada esquenta a arma; barra cheia = arma trava e a barra
    // drena até zerar (a criança vê exatamente quanto falta esperar).
    function atualizarCalor() {
      const nivel = estado.travaRestante > 0 ? estado.travaRestante / CFG.travaMs : estado.calor;
      calorFillEl.style.transform = 'scaleX(' + Math.min(1, Math.max(0, nivel)) + ')';
      calorEl.classList.toggle('calor--quente', estado.travaRestante === 0 && estado.calor >= 0.6);
    }
    function registrarErro() {
      somErroSuave();
      tremerNave();
      estado.calor = Math.min(1, estado.calor + CFG.calorPorErro);
      if (estado.calor >= 1) travarArma();
      atualizarCalor();
    }
    function travarArma() {
      estado.travaRestante = CFG.travaMs;
      calorEl.classList.add('calor--trava');
      naveEl.classList.add('nave--trava');
      travaAvisoEl.hidden = false;
      somSuperaquecida();
      anunciar('A arma superaqueceu de tanto errar! Espere a barra esvaziar.');
    }
    function destravarArma() {
      estado.travaRestante = 0;
      estado.calor = 0;
      calorEl.classList.remove('calor--trava');
      naveEl.classList.remove('nave--trava');
      travaAvisoEl.hidden = true;
      somDestrava();
      atualizarCalor();
    }
    function resetarCalor() {
      estado.calor = 0;
      estado.travaRestante = 0;
      calorEl.classList.remove('calor--trava', 'calor--quente');
      naveEl.classList.remove('nave--trava');
      travaAvisoEl.hidden = true;
      atualizarCalor();
    }

    // ===== Inimigos =====
    function letrasVivas() {
      return new Set(estado.inimigos.flatMap((i) => i.letras.map((l) => l.ch)));
    }
    // Sorteia `qtd` letras livres (nunca repete letra que já está na tela)
    function escolherLetras(nivel, qtd) {
      const vivas = letrasVivas();
      const livres = nivel.letras.filter((l) => !vivas.has(l));
      if (livres.length < qtd) return null;
      const sorteadas = [];
      for (let n = 0; n < qtd; n++) {
        sorteadas.push(livres.splice(Math.floor(Math.random() * livres.length), 1)[0]);
      }
      return sorteadas;
    }

    function criarInimigo(nivel) {
      let letras;
      let fator;
      let classe;
      if (estado.palavras) {
        // Difícil: o inimigo carrega uma palavra inteira (nave lenta).
        letras = PALAVRAS[Math.floor(Math.random() * PALAVRAS.length)].split('');
        fator = CFG.fatorTripla;
        classe = ' inimigo--palavra';
      } else {
        // Sorteia o tamanho da nave: tripla, dupla ou solo.
        // Se dupla+tripla somam 1, nave de 1 letra não nasce mais — e o
        // fallback (quando faltam letras livres) também para no 2.
        const r = Math.random();
        let qtd = r < nivel.chanceTripla ? 3 : r < nivel.chanceTripla + nivel.chanceDupla ? 2 : 1;
        const minimo = nivel.chanceTripla + nivel.chanceDupla >= 1 ? 2 : 1;
        letras = null;
        while (qtd >= minimo) {
          letras = escolherLetras(nivel, qtd);
          if (letras) break;
          qtd--;
        }
        if (!letras) return false;
        // Velocidade própria: dupla/tripla mais lentas; vogal solta mais
        // rápida nos níveis com vogaisRapidas
        fator = 1;
        if (letras.length === 3) fator = CFG.fatorTripla;
        else if (letras.length === 2) fator = CFG.fatorDupla;
        else if (nivel.vogaisRapidas && VOGAIS.has(letras[0])) fator = CFG.fatorVogal;
        classe = letras.length === 2 ? ' inimigo--dupla' : letras.length === 3 ? ' inimigo--tripla' : '';
      }
      // x aleatório afastado dos inimigos vivos (até 12 tentativas)
      const folga = estado.palavras ? 0.24 : 0.14;
      let x = 0.08 + Math.random() * 0.84;
      for (let t = 0; t < 12; t++) {
        const cand = 0.08 + Math.random() * 0.84;
        x = cand;
        if (estado.inimigos.every((i) => Math.abs(i.x - cand) >= folga)) break;
      }
      const id = ++idSeq;
      const mov = document.createElement('div');
      mov.className = 'mov';
      mov.setAttribute('aria-hidden', 'true');
      mov.innerHTML =
        '<div class="inimigo' + classe + '" style="--cor:' + CORES[id % CORES.length] + '">' +
        '<svg class="inimigo__svg" viewBox="0 0 100 100"><use href="#inimigo-' + (1 + (id % VARIANTES)) + '"></use></svg>' +
        '<span class="inimigo__letras">' +
        letras.map((l, i) => '<span class="inimigo__letra' + (estado.palavras && i === 0 ? ' inimigo__letra--proxima' : '') + '" data-letra="' + l + '" data-idx="' + i + '">' + l + '</span>').join('') +
        '</span>' +
        '</div>';
      inimigosEl.appendChild(mov);
      estado.inimigos.push({
        id,
        letras: letras.map((ch) => ({ ch, mirada: false, viva: true })),
        idx: 0,
        x,
        y: -0.1,
        fator,
        parado: false,
        el: mov,
      });
      return true;
    }

    function spawn(dt, nivel) {
      estado.proximoSpawn -= dt;
      if (estado.proximoSpawn > 0) return;
      // Cada leva traz spawnsPorVez inimigos (respeitando os tetos)
      let criou = false;
      const teto = estado.palavras ? Math.min(nivel.maxInimigos, 3) : nivel.maxInimigos;
      for (let n = 0; n < nivel.spawnsPorVez; n++) {
        if (estado.inimigos.length >= teto) break;
        if (estado.modo === 'tranquilo') {
          const parados = estado.inimigos.filter((i) => i.parado).length;
          if (parados >= CFG.maxInimigosEsperando) break;
        }
        if (!criarInimigo(nivel)) break; // sem letra livre
        criou = true;
      }
      // Nada nasceu? Tenta de novo daqui a pouco.
      estado.proximoSpawn = criou ? nivel.intervaloSpawn : 600;
    }

    // ===== Tiro e impacto =====
    function processarLetra(letra) {
      if (estado.fase !== 'jogando') return;
      // Arma superaquecida: nem a letra certa atira (e teclar não estende a trava)
      if (estado.travaRestante > 0) {
        somErroSuave();
        tremerNave();
        return;
      }
      if (estado.palavras) {
        processarLetraPalavra(letra);
        return;
      }
      let alvoIdx = -1;
      const inimigo = estado.inimigos.find((i) => {
        alvoIdx = i.letras.findIndex((l) => l.viva && !l.mirada && l.ch === letra);
        return alvoIdx !== -1;
      });
      if (inimigo) {
        estado.calor = Math.max(0, estado.calor - CFG.resfriarPorAcerto);
        atualizarCalor();
        atirar(inimigo, alvoIdx);
      } else {
        registrarErro();
      }
    }

    // Difícil: digita a palavra letra a letra, na ordem. A primeira letra
    // "trava" um alvo; erro de sequência esquenta a arma sem trocar de alvo.
    function proximoAlvo() {
      return estado.inimigos.find((i) => i.id === estado.alvoAtual) || null;
    }
    function destacarProxima(inimigo) {
      inimigo.el.querySelectorAll('.inimigo__letra--proxima').forEach((el) => el.classList.remove('inimigo__letra--proxima'));
      const alvo = inimigo.el.querySelector('.inimigo__letra[data-idx="' + inimigo.idx + '"]');
      if (alvo) alvo.classList.add('inimigo__letra--proxima');
    }
    function mirarNaPalavra(inimigo, letra) {
      if (inimigo.idx >= inimigo.letras.length) return false;
      if (inimigo.letras[inimigo.idx].ch !== letra) return false;
      estado.calor = Math.max(0, estado.calor - CFG.resfriarPorAcerto);
      atualizarCalor();
      atirar(inimigo, inimigo.idx);
      inimigo.idx++;
      if (inimigo.idx >= inimigo.letras.length) {
        estado.alvoAtual = null;
      } else {
        destacarProxima(inimigo);
      }
      return true;
    }
    function processarLetraPalavra(letra) {
      let alvo = proximoAlvo();
      if (alvo && alvo.idx >= alvo.letras.length) { estado.alvoAtual = null; alvo = null; }
      if (alvo) {
        if (!mirarNaPalavra(alvo, letra)) registrarErro();
        return;
      }
      // sem alvo: pega o inimigo mais baixo cuja próxima letra bate
      const candidatos = estado.inimigos
        .filter((i) => i.idx < i.letras.length && i.letras[i.idx].ch === letra)
        .sort((a, b) => b.y - a.y);
      if (candidatos.length) {
        estado.alvoAtual = candidatos[0].id;
        mirarNaPalavra(candidatos[0], letra);
      } else {
        registrarErro();
      }
    }

    function atirar(inimigo, letraIdx) {
      inimigo.letras[letraIdx].mirada = true;
      const mov = document.createElement('div');
      mov.className = 'mov';
      mov.setAttribute('aria-hidden', 'true');
      mov.innerHTML = '<span class="tiro"></span>';
      mov.style.transform = 'translate3d(' + estado.campo.naveX * estado.campo.w + 'px, ' + estado.campo.naveY * estado.campo.h + 'px, 0)';
      tirosEl.appendChild(mov);
      estado.tiros.push({ t: 0, x0: estado.campo.naveX, y0: estado.campo.naveY, alvoId: inimigo.id, letraIdx, el: mov });
      somTiro();
    }

    function explodir(x, y) {
      const mov = document.createElement('div');
      mov.className = 'mov';
      mov.setAttribute('aria-hidden', 'true');
      mov.innerHTML = '<span class="explosao"></span>';
      mov.style.transform = 'translate3d(' + x * estado.campo.w + 'px, ' + y * estado.campo.h + 'px, 0)';
      tirosEl.appendChild(mov);
      setTimeout(() => mov.remove(), 700);
    }

    function acertarLetra(alvoId, letraIdx) {
      const inimigo = estado.inimigos.find((i) => i.id === alvoId);
      if (!inimigo) return;
      const letra = inimigo.letras[letraIdx];
      letra.viva = false;
      estado.pontos += CFG.pontosPorAcerto;
      atualizarPlacar();
      if (inimigo.letras.some((l) => l.viva)) {
        // Acerto parcial: a placa (por índice, pra palavra com letra repetida
        // funcionar) pipoca, a nave pisca e segue
        const placa = inimigo.el.querySelector('[data-idx="' + letraIdx + '"]');
        if (placa) {
          placa.classList.add('inimigo__letra--pop');
          setTimeout(() => placa.remove(), 280);
        }
        const corpo = inimigo.el.querySelector('.inimigo');
        corpo.classList.remove('inimigo--hit');
        void corpo.offsetWidth;
        corpo.classList.add('inimigo--hit');
        somAcerto();
        return;
      }
      destruirInimigo(inimigo);
    }

    function destruirInimigo(inimigo) {
      if (inimigo.id === estado.alvoAtual) estado.alvoAtual = null;
      const idx = estado.inimigos.indexOf(inimigo);
      if (idx !== -1) estado.inimigos.splice(idx, 1);
      inimigo.el.remove();
      explodir(inimigo.x, inimigo.y);
      somExplosao();
      estado.abatesNoNivel++;
      estado.abatesTotal++;
      atualizarAbates();
      if (estado.modo === 'vidas' && estado.vidas < CFG.vidasMaximas && Math.random() < CFG.chanceCoracao) {
        soltarCoracao(inimigo.x, inimigo.y);
      }
      if (estado.abatesNoNivel >= NIVEIS[estado.nivelIdx].abates) concluirNivel();
    }

    // ===== Coração bônus (voa sozinho até o HUD) =====
    function soltarCoracao(x, y) {
      const alvo = vidasWrapEl.getBoundingClientRect();
      const x1 = (alvo.left + alvo.width / 2 - estado.campo.left) / estado.campo.w;
      const y1 = (alvo.top + alvo.height / 2 - estado.campo.top) / estado.campo.h;
      const mov = document.createElement('div');
      mov.className = 'mov';
      mov.setAttribute('aria-hidden', 'true');
      mov.innerHTML = '<svg class="coracao-voa" viewBox="0 0 32 32"><use href="#coracao"></use></svg>';
      mov.style.transform = 'translate3d(' + x * estado.campo.w + 'px, ' + y * estado.campo.h + 'px, 0)';
      tirosEl.appendChild(mov);
      estado.coracoesVoando.push({ t: 0, x0: x, y0: y, x1, y1, el: mov });
    }

    // ===== Inimigo chegou na linha =====
    function inimigoChegou(inimigo) {
      if (estado.modo === 'tranquilo') {
        inimigo.parado = true;
        inimigo.y = CFG.linhaEspera;
        inimigo.el.classList.add('mov--parado');
        return;
      }
      // Modo com vidas: o inimigo foge voando pro lado (nada de bater na nave)
      if (inimigo.id === estado.alvoAtual) estado.alvoAtual = null;
      const idx = estado.inimigos.indexOf(inimigo);
      if (idx !== -1) estado.inimigos.splice(idx, 1);
      inimigo.el.style.setProperty('--fuga', inimigo.x < 0.5 ? '-1' : '1');
      inimigo.el.classList.add('mov--fugiu');
      setTimeout(() => inimigo.el.remove(), 900);
      perderVida();
    }

    function perderVida() {
      estado.vidas--;
      atualizarVidas(false);
      somEscapou();
      tremerNave();
      anunciar('Ih, um inimigo passou! Você tem ' + estado.vidas + (estado.vidas === 1 ? ' vida.' : ' vidas.'));
      if (estado.vidas <= 0) fimDeJogo();
    }

    // ===== Fluxo de níveis =====
    function limparCampo() {
      estado.inimigos.forEach((i) => {
        i.el.classList.add('mov--sai');
        setTimeout(() => i.el.remove(), 500);
      });
      estado.tiros.forEach((t) => t.el.remove());
      estado.coracoesVoando.forEach((c) => c.el.remove());
      estado.inimigos = [];
      estado.tiros = [];
      estado.coracoesVoando = [];
    }

    function montarTeclado(nivel) {
      tecladoEl.innerHTML = '';
      const teclas = estado.palavras ? ALFABETO : nivel.letras;
      teclas.forEach((letra) => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'tecla';
        btn.textContent = letra;
        btn.addEventListener('pointerdown', (e) => {
          e.preventDefault();
          processarLetra(letra);
        });
        tecladoEl.appendChild(btn);
      });
    }

    function montarNivel(idx) {
      inimigosEl.innerHTML = '';
      tirosEl.innerHTML = '';
      prepararNivel(idx);
    }

    // Versão sem zerar o innerHTML: usada na troca silenciosa de nível,
    // deixando os inimigos do nível anterior terminarem a animação de saída
    // (eles se auto-removem via setTimeout do limparCampo).
    function prepararNivel(idx) {
      estado.nivelIdx = idx;
      estado.abatesNoNivel = 0;
      estado.proximoSpawn = 900; // respiro antes do primeiro inimigo
      estado.inimigos = [];
      estado.tiros = [];
      estado.coracoesVoando = [];
      const nivel = NIVEIS[idx];
      $('[data-nivel]').textContent = String(idx + 1);
      $('[data-nivel-nome]').textContent = nivel.nome;
      atualizarAbates();
      montarTeclado(nivel);
      anunciar('Nível ' + (idx + 1) + ': ' + nivel.nome + '. Letras: ' + nivel.letras.join(', ') + '.');
    }

    // ===== Banner de nível (troca silenciosa, sem modal) =====
    let bannerTimer = null;
    function mostrarBannerNivel(titulo, sub) {
      $('[data-banner-titulo]').textContent = titulo;
      $('[data-banner-sub]').textContent = sub;
      bannerEl.hidden = false;
      bannerEl.classList.remove('show', 'hide');
      void bannerEl.offsetWidth;
      bannerEl.classList.add('show');
      clearTimeout(bannerTimer);
      bannerTimer = setTimeout(() => {
        bannerEl.classList.add('hide');
        setTimeout(() => {
          bannerEl.hidden = true;
          bannerEl.classList.remove('show', 'hide');
        }, 400);
      }, CFG.bannerNivelMs);
    }

    function concluirNivel() {
      limparCampo();
      if (estado.nivelIdx < NIVEIS.length - 1) {
        // Troca silenciosa: banner rápido e o jogo segue sem parar
        somNivel();
        const atual = NIVEIS[estado.nivelIdx];
        const prox = NIVEIS[estado.nivelIdx + 1];
        const atuais = new Set(atual.letras);
        const novas = prox.letras.filter((l) => !atuais.has(l));
        let sub = novas.length ? 'Letras novas: ' + novas.join(', ') : prox.nome;
        if (prox.chanceDupla > 0 && atual.chanceDupla === 0) sub = 'Naves com 2 letras!';
        else if (prox.chanceTripla > 0 && atual.chanceTripla === 0) sub = 'Naves com 3 letras!';
        else if (prox.spawnsPorVez > atual.spawnsPorVez) sub = 'Inimigos de dois em dois!';
        prepararNivel(estado.nivelIdx + 1);
        mostrarBannerNivel('NÍVEL ' + (estado.nivelIdx + 1), sub);
        // Respiro sem spawn pra ninguém nascer em cima do banner
        estado.proximoSpawn = CFG.respiroEntreNiveisMs;
        anunciar('Nível completo! Nível ' + (estado.nivelIdx + 1) + ': ' + NIVEIS[estado.nivelIdx].nome + '.' +
          (novas.length ? ' Letras novas: ' + novas.join(', ') + '.' : ''));
      } else {
        venceu();
      }
    }

    function venceu() {
      estado.fase = 'vitoria';
      resetarCalor();
      somNivel();
      $('[data-final-score]').textContent = String(estado.pontos);
      $('[data-final-msg]').textContent =
        'Você derrubou ' + estado.abatesTotal + ' inimigos nas ' + NIVEIS.length + ' missões — do A ao Z! 🌟';
      // Ranking só no modo com vidas (tranquilo não tem morte — pontuação sem limite)
      const gravar = winModal.querySelector('[data-gravar-nome]');
      gravar.hidden = estado.modo !== 'vidas';
      winModal.hidden = false;
      setTimeout(() => (gravar.hidden ? $('[data-replay]') : gravar).focus(), 60);
      anunciar('Parabéns! Você venceu o jogo com ' + estado.pontos + ' pontos.');
    }

    function fimDeJogo() {
      estado.fase = 'fim';
      limparCampo();
      resetarCalor();
      somFimGentil();
      $('[data-fim-msg]').textContent =
        'Você derrubou ' + estado.abatesTotal + (estado.abatesTotal === 1 ? ' inimigo' : ' inimigos') +
        ' e chegou ao nível ' + (estado.nivelIdx + 1) + '!';
      $('[data-fim-score]').textContent = String(estado.pontos);
      const gravar = fimModal.querySelector('[data-gravar-nome]');
      gravar.hidden = estado.modo !== 'vidas';
      fimModal.hidden = false;
      setTimeout(() => (gravar.hidden ? $('[data-replay-fim]') : gravar).focus(), 60);
      anunciar('Fim do voo! Você fez ' + estado.pontos + ' pontos. Grave seu nome no ranking ou jogue de novo.');
    }

    // ===== Loop =====
    function loop(ts) {
      estado.rafId = requestAnimationFrame(loop);
      if (!estado.ultimoTempo) { estado.ultimoTempo = ts; return; }
      const dt = Math.min(ts - estado.ultimoTempo, 50);
      estado.ultimoTempo = ts;
      if (estado.fase !== 'jogando') return;

      const nivel = NIVEIS[estado.nivelIdx];
      const cw = estado.campo.w;
      const ch = estado.campo.h;

      // Arma: com trava, a barra drena até 0 e destrava;
      // sem trava, o calor esfria sozinho com o tempo
      if (estado.travaRestante > 0) {
        estado.travaRestante -= dt;
        if (estado.travaRestante <= 0) destravarArma();
        else atualizarCalor();
      } else if (estado.calor > 0) {
        estado.calor = Math.max(0, estado.calor - CFG.calorDecaimentoPorSegundo * (dt / 1000));
        atualizarCalor();
      }

      spawn(dt, nivel);

      // Inimigos descem (cada um com seu fator: dupla lenta, vogal rápida)
      for (const i of estado.inimigos.slice()) {
        if (!i.parado) {
          i.y += nivel.velocidade * i.fator * (dt / 1000);
          // Só "chega" se ainda tem letra viva sem tiro a caminho
          const aindaVivo = i.letras.some((l) => l.viva && !l.mirada);
          if (i.y >= CFG.linhaEspera && aindaVivo) {
            inimigoChegou(i);
            if (estado.fase !== 'jogando') return;
            if (!i.parado) continue; // fugiu: já saiu do array
          }
        }
        i.el.style.transform = 'translate3d(' + i.x * cw + 'px, ' + i.y * ch + 'px, 0)';
      }

      // Tiros perseguem o alvo (lerp de duração fixa — chegada garantida)
      for (const t of estado.tiros.slice()) {
        const alvo = estado.inimigos.find((i) => i.id === t.alvoId);
        if (!alvo) {
          t.el.remove();
          const ix = estado.tiros.indexOf(t);
          if (ix !== -1) estado.tiros.splice(ix, 1);
          continue;
        }
        t.t += dt / CFG.duracaoTiroMs;
        if (t.t >= 1) {
          t.el.remove();
          const ix = estado.tiros.indexOf(t);
          if (ix !== -1) estado.tiros.splice(ix, 1);
          const nivelAntes = estado.nivelIdx;
          acertarLetra(t.alvoId, t.letraIdx);
          if (estado.fase !== 'jogando') return;
          // Troca silenciosa de nível no meio do frame: o slice() deste for
          // ainda tem os tiros velhos (já removidos do estado) — aborta o frame
          if (estado.nivelIdx !== nivelAntes) return;
          continue;
        }
        const x = t.x0 + (alvo.x - t.x0) * t.t;
        const y = t.y0 + (alvo.y - t.y0) * t.t;
        // Aponta a cápsula do laser pro alvo (o filho .tiro é vertical)
        const ang = Math.atan2(alvo.y * ch - y * ch, alvo.x * cw - x * cw) + Math.PI / 2;
        t.el.style.transform = 'translate3d(' + x * cw + 'px, ' + y * ch + 'px, 0) rotate(' + ang + 'rad)';
      }

      // Corações voando até o HUD
      for (const c of estado.coracoesVoando.slice()) {
        c.t += dt / 700;
        if (c.t >= 1) {
          c.el.remove();
          estado.coracoesVoando.splice(estado.coracoesVoando.indexOf(c), 1);
          estado.vidas = Math.min(estado.vidas + 1, CFG.vidasMaximas);
          atualizarVidas(true);
          somCoracao();
          mostrarToast('💖 Você ganhou um coração!', 'ok', 1600);
          anunciar('Você ganhou um coração! Vidas: ' + estado.vidas + '.');
          continue;
        }
        const k = c.t;
        const x = c.x0 + (c.x1 - c.x0) * k;
        const y = c.y0 + (c.y1 - c.y0) * k - Math.sin(k * Math.PI) * 0.06; // leve arco
        c.el.style.transform = 'translate3d(' + x * cw + 'px, ' + y * ch + 'px, 0)';
      }
    }

    // ===== Fluxo =====
    function comecarJogo(dif) {
      initAudio();
      if (actx && actx.state === 'suspended') actx.resume();
      estado.dificuldade = dif;
      estado.palavras = dif === 'dificil';
      estado.alvoAtual = null;
      const modo = dif === 'facil' ? 'tranquilo' : 'vidas';
      estado.modo = modo;
      estado.pontos = 0;
      estado.abatesTotal = 0;
      estado.vidas = modo === 'vidas' ? CFG.vidasIniciais : 0;
      vidasWrapEl.hidden = modo !== 'vidas';
      linhaEsperaEl.hidden = modo !== 'tranquilo';
      if (modo === 'vidas') atualizarVidas(false);
      atualizarPlacar();
      introModal.hidden = true;
      estado.fase = 'jogando';
      resetarCalor();
      medirCampo();
      montarNivel(0);
      if (!estado.rafId) estado.rafId = requestAnimationFrame(loop);
    }

    function reiniciar() {
      estado.fase = 'inicio';
      limparCampo();
      winModal.hidden = true;
      fimModal.hidden = true;
      pausaModal.hidden = true;
      nomeModal.hidden = true;
      recordesModal.hidden = true;
      vidasWrapEl.hidden = true;
      linhaEsperaEl.hidden = true;
      resetarCalor();
      bannerEl.hidden = true;
      estado.pontos = 0;
      estado.abatesTotal = 0;
      atualizarPlacar();
      introModal.hidden = false;
      setTimeout(() => $('[data-dif="medio"]').focus(), 60);
    }

    document.querySelectorAll('[data-dif]').forEach((btn) => {
      btn.addEventListener('click', () => comecarJogo(btn.dataset.dif));
    });
    $('[data-replay]').addEventListener('click', reiniciar);
    $('[data-replay-fim]').addEventListener('click', reiniciar);

    // ===== Pausa =====
    function pausar() {
      if (estado.fase !== 'jogando') return;
      estado.fase = 'pausado';
      pausaModal.hidden = false;
      setTimeout(() => $('[data-continuar]').focus(), 60);
      anunciar('Jogo pausado.');
    }
    function continuarJogo() {
      if (estado.fase !== 'pausado') return;
      pausaModal.hidden = true;
      medirCampo(); // a janela pode ter mudado de tamanho durante a pausa
      estado.fase = 'jogando';
      anunciar('Jogo continuando!');
    }
    $('[data-pause]').addEventListener('click', pausar);
    $('[data-continuar]').addEventListener('click', continuarJogo);
    $('[data-recomecar]').addEventListener('click', () => {
      pausaModal.hidden = true;
      reiniciar();
    });

    // ===== Ranking arcade (online via PHP + cache/fallback localStorage) =====
    const API_RANKING = '/class/api/ranking.php';
    // Ranking separado por dificuldade: médio no slug antigo (preserva recordes),
    // difícil no seu próprio. Fácil (tranquilo) não grava.
    function jogoId() { return estado.dificuldade === 'dificil' ? 'letras-espaciais-dificil' : 'letras-espaciais'; }
    function rankKey() { return estado.dificuldade === 'dificil' ? 'letras-espaciais:ranking:dificil' : 'letras-espaciais:ranking'; }

    function lerRanking() {
      try { return JSON.parse(localStorage.getItem(rankKey()) || '[]'); }
      catch (_) { return []; }
    }
    function salvarRanking(lista) {
      try { localStorage.setItem(rankKey(), JSON.stringify(lista)); } catch (_) {}
    }

    // Devolve a lista do servidor ou null (falhou/timeout → cai pro local)
    function fetchRanking(opts) {
      const ctl = new AbortController();
      const timer = setTimeout(() => ctl.abort(), 4000);
      const url = opts ? API_RANKING : API_RANKING + '?jogo=' + jogoId();
      return fetch(url, Object.assign({ signal: ctl.signal }, opts || {}))
        .then((r) => (r.ok ? r.json() : null))
        .then((lista) => (Array.isArray(lista) ? lista : null))
        .catch(() => null)
        .finally(() => clearTimeout(timer));
    }
    function enviarRankingOnline(entrada) {
      return fetchRanking({
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ jogo: jogoId(), nome: entrada.nome, pontos: entrada.pontos, nivel: entrada.nivel }),
      });
    }
    function indiceDe(lista, entrada) {
      return lista.findIndex((r) => r.nome === entrada.nome && r.pontos === entrada.pontos && r.data === entrada.data);
    }

    function atualizarSlots() {
      const slots = [];
      for (let i = 0; i < CFG.nomeMax; i++) slots.push(estado.nome[i] || '_');
      $('[data-nome-slots]').textContent = slots.join(' ');
    }

    function abrirNome() {
      winModal.hidden = true;
      fimModal.hidden = true;
      estado.fase = 'nome';
      estado.nome = '';
      atualizarSlots();
      nomeModal.hidden = false;
      setTimeout(() => $('[data-tecla-nome="A"]').focus(), 60);
      anunciar('Digite seu nome usando as letras da tela. De ' + CFG.nomeMin + ' a ' + CFG.nomeMax + ' letras. Depois aperte o botão de confirmar.');
    }
    document.querySelectorAll('[data-gravar-nome]').forEach((btn) => btn.addEventListener('click', abrirNome));

    function digitarLetra(l) {
      if (estado.fase !== 'nome') return;
      if (estado.nome.length >= CFG.nomeMax) return;
      estado.nome += l;
      somAcerto();
      atualizarSlots();
    }
    function apagarLetra() {
      if (estado.fase !== 'nome' || !estado.nome) return;
      estado.nome = estado.nome.slice(0, -1);
      somErroSuave();
      atualizarSlots();
    }
    function confirmarNome() {
      if (estado.fase !== 'nome') return;
      if (estado.nome.length < CFG.nomeMin) {
        mostrarToast('Escreva pelo menos ' + CFG.nomeMin + ' letras!', 'info', 1800);
        return;
      }
      const entrada = {
        nome: estado.nome.toUpperCase(),
        pontos: estado.pontos,
        nivel: estado.nivelIdx + 1,
        data: new Date().toISOString().slice(0, 10),
      };
      // grava local sempre — funciona offline e serve de cache
      const local = lerRanking();
      local.push(entrada);
      local.sort((a, b) => b.pontos - a.pontos);
      salvarRanking(local.slice(0, CFG.rankingMax));
      nomeModal.hidden = true;
      somNivel();
      abrirRecordes(false, entrada);
    }
    document.querySelectorAll('[data-tecla-nome]').forEach((btn) => {
      btn.addEventListener('click', () => digitarLetra(btn.dataset.teclaNome));
    });
    $('[data-nome-apagar]').addEventListener('click', apagarLetra);
    $('[data-nome-ok]').addEventListener('click', confirmarNome);

    function renderRecordes(lista, destaque, consulta, fonte) {
      const tabela = $('[data-tabela]');
      tabela.innerHTML = '';
      $('[data-recordes-vazio]').hidden = lista.length > 0;
      lista.forEach((r, i) => {
        const li = document.createElement('li');
        if (i === destaque) li.className = 'novo';
        li.innerHTML =
          '<span class="pos">' + (i + 1) + 'º</span>' +
          '<span class="nome">' + r.nome + '</span>' +
          '<span class="det">nível ' + r.nivel + '</span>' +
          '<span class="pts">' + r.pontos + '</span>';
        tabela.appendChild(li);
      });
      const fonteEl = $('[data-recordes-fonte]');
      if (fonte === 'online') fonteEl.textContent = '🌐 Ranking online — vale pra turma toda!';
      else if (fonte === 'offline') fonteEl.textContent = '📴 Sem internet agora: mostrando o ranking deste aparelho.';
      else fonteEl.textContent = 'Buscando o ranking online…';
      // Veio da intro (consulta) → botão voltar; veio de uma partida → jogar de novo
      $('[data-voltar-intro]').hidden = !consulta;
      $('[data-recordes-replay]').hidden = consulta;
    }

    // Abre os recordes: mostra o local na hora e troca pelo online quando chegar.
    // entrada != null → acabou de salvar (envia pro servidor e destaca a linha).
    function abrirRecordes(consulta, entrada) {
      estado.fase = 'recordes';
      const local = lerRanking();
      const idxLocal = entrada ? indiceDe(local, entrada) : -1;
      renderRecordes(local, idxLocal, consulta, 'buscando');
      recordesModal.hidden = false;
      setTimeout(() => (consulta ? $('[data-voltar-intro]') : $('[data-recordes-replay]')).focus(), 60);
      const pedido = entrada ? enviarRankingOnline(entrada) : fetchRanking(null);
      pedido.then((listaOnline) => {
        if (estado.fase !== 'recordes') return; // já saiu da tela
        if (listaOnline) {
          salvarRanking(listaOnline); // cache local vira o ranking da turma
          renderRecordes(listaOnline, entrada ? indiceDe(listaOnline, entrada) : -1, consulta, 'online');
        } else {
          renderRecordes(local, idxLocal, consulta, 'offline');
        }
      });
    }
    $('[data-voltar-intro]').addEventListener('click', () => {
      recordesModal.hidden = true;
      estado.fase = 'inicio';
      introModal.hidden = false;
      setTimeout(() => $('[data-dif="medio"]').focus(), 60);
    });
    $('[data-recordes-replay]').addEventListener('click', () => {
      recordesModal.hidden = true;
      reiniciar();
    });

    // ===== Entrada: teclado físico =====
    window.addEventListener('keydown', (e) => {
      if (e.repeat || e.ctrlKey || e.altKey || e.metaKey) return;
      if (e.key === 'Escape') {
        if (estado.fase === 'jogando') { e.preventDefault(); pausar(); }
        else if (estado.fase === 'pausado') { e.preventDefault(); continuarJogo(); }
        return;
      }
      if (estado.fase === 'nome') {
        const l = e.key.length === 1 ? e.key.toUpperCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '') : '';
        if (/^[A-Z]$/.test(l)) { e.preventDefault(); digitarLetra(l); }
        else if (e.key === 'Backspace') { e.preventDefault(); apagarLetra(); }
        else if (e.key === 'Enter') {
          // Enter com foco numa letra da grade: deixa o clique nativo digitar
          if (document.activeElement && document.activeElement.tagName === 'BUTTON' && document.activeElement.dataset.teclaNome) return;
          e.preventDefault();
          confirmarNome();
        }
        return;
      }
      if (estado.fase !== 'jogando') return;
      if (e.key.length !== 1) return;
      // Maiúscula + remove acento (Ç vira C — vizinha do L no teclado ABNT)
      const letra = e.key.toUpperCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
      if (!/^[A-Z]$/.test(letra)) return;
      processarLetra(letra);
    });

    // Dispositivo touch sem teclado físico: mostra a barra de letras
    window.addEventListener('touchstart', () => tecladoEl.classList.add('teclado--on'), { once: true, passive: true });

    // ===== Pausa automática (troca de aba) / medidas =====
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        pausar(); // ao voltar pra aba, o aluno encontra o overlay de pausa
        cancelAnimationFrame(estado.rafId);
        estado.rafId = 0;
        estado.ultimoTempo = 0;
      } else if (estado.modo && !estado.rafId) {
        estado.rafId = requestAnimationFrame(loop);
      }
    });
    window.addEventListener('resize', medirCampo);

    // ===== Boot =====
    document.body.classList.add('is-game');
    linhaEsperaEl.style.top = CFG.linhaEspera * 100 + '%';
    medirCampo();
    setTimeout(() => $('[data-dif="medio"]').focus(), 60);

    window.__le = {
      estado,
      dificuldade: () => estado.dificuldade,
      comecar: (dif) => comecarJogo(dif),
      resolverProximo() {
        if (estado.fase !== 'jogando' || !estado.inimigos.length) return null;
        if (estado.palavras) {
          const alvo = estado.inimigos.find((i) => i.id === estado.alvoAtual)
            || estado.inimigos.slice().sort((a, b) => b.y - a.y).find((i) => i.idx < i.letras.length);
          if (!alvo) return null;
          const ch = alvo.letras[alvo.idx].ch;
          processarLetra(ch);
          return ch;
        }
        const alvo = estado.inimigos.slice().sort((a, b) => b.y - a.y)[0];
        const l = alvo.letras.find((x) => x.viva && !x.mirada);
        if (!l) return null;
        processarLetra(l.ch);
        return l.ch;
      },
      teclar: (ch) => processarLetra(ch),
    };
  </script>
</Layout>
