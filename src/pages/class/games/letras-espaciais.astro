    const VOGAIS = new Set(['A', 'E', 'I', 'O', 'U']);
    let idSeq = 0;

    const estado = {
      fase: 'inicio',   // 'inicio' | 'jogando' | 'pausado' | 'vitoria' | 'fim' | 'nome' | 'recordes'
      modo: null,       // 'vidas' | 'tranquilo'
      dificuldade: 'medio', // 'facil' | 'medio' | 'dificil'
      palavras: false,  // difícil: inimigo carrega palavra inteira
