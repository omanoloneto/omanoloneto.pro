      abatesNoNivel: 0,
      abatesTotal: 0,
      inimigos: [],       // {id, letras:[{ch, mirada, viva}], x, y, fator, parado, el}
      tiros: [],          // {t, x0, y0, alvoId, letraIdx, el}
