---
import Layout from '../../../layouts/Layout.astro';
import { paleta, tamanhos, config } from '../../../data/atelie';

const dadosJson = JSON.stringify({ paleta, tamanhos, config });

const title = 'Ateliê — desenhe e pinte à vontade! | Manolo Neto';
const description =
  'Paint para crianças direto no navegador: pincel com 16 cores, borracha e balde de tinta. Desenhe livre, desfaça quando errar e baixe seu desenho pra imprimir!';
---

<Layout title={title} description={description}>
  <script type="application/json" data-dados set:html={dadosJson}></script>

  <main id="conteudo" class="at" data-game role="application" aria-label="Ateliê: desenho livre com pincel, borracha e balde de tinta">
    <!-- sprite dos ícones (tudo SVG, nada de emoji) -->
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
      <symbol id="ico-pincel" viewBox="0 0 24 24">
        <path d="M19.5 3.2c.9.9 1 2.3.1 3.2l-7.4 8-3.4-3.4 8-7.4c.9-.9 2.3-.8 2.7-.4z" fill="#c98a4b" stroke="#7a4a1e" stroke-width="1.3" stroke-linejoin="round"/>
        <path d="M8.6 11.2 12 14.6c-.4 2-1.6 3.6-3.6 4.4-1.9.8-4 .6-5.4-.2 1.2-.7 1.6-1.5 1.8-2.8.3-2 1.6-4 3.8-4.8z" fill="#3a3128" stroke="#1c1c1e" stroke-width="1.3" stroke-linejoin="round"/>
        <circle cx="5.4" cy="17.4" r="1.3" fill="#9b6dd6"/>
      </symbol>
      <symbol id="ico-borracha" viewBox="0 0 24 24">
        <path d="M13.2 4.4 20 11.2a2 2 0 0 1 0 2.8l-4.4 4.4H10L4 12.4a2 2 0 0 1 0-2.8l6.4-6.4a2 2 0 0 1 2.8 0z" fill="#ff8ab5" stroke="#a23258" stroke-width="1.4" stroke-linejoin="round"/>
        <path d="m8.2 8.2 7.6 7.6" stroke="#a23258" stroke-width="1.4"/>
        <path d="M4.5 20.5h15" stroke="#3a3128" stroke-width="1.6" stroke-linecap="round" stroke-dasharray="2.4 2.6"/>
      </symbol>
      <symbol id="ico-balde" viewBox="0 0 24 24">
        <path d="M12.7 3.1 20 10.4l-7.2 7.2a2.4 2.4 0 0 1-3.4 0l-4.8-4.8a2.4 2.4 0 0 1 0-3.4l6-6a1.5 1.5 0 0 1 2.1-.3z" fill="#37c2ce" stroke="#136a73" stroke-width="1.4" stroke-linejoin="round"/>
        <path d="M4.3 9.6h13.5" stroke="#136a73" stroke-width="1.4"/>
        <path d="M20.3 14.2s1.7 2 1.7 3.3a1.7 1.7 0 1 1-3.4 0c0-1.3 1.7-3.3 1.7-3.3z" fill="#2469d4" stroke="#12336b" stroke-width="1.2" stroke-linejoin="round"/>
      </symbol>
      <symbol id="ico-desfazer" viewBox="0 0 24 24">
        <path d="M8.5 5 4 9.5 8.5 14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M4.6 9.5h9.2a5.7 5.7 0 0 1 0 11.4H9" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
      </symbol>
      <symbol id="ico-limpar" viewBox="0 0 24 24">
        <path d="M5.5 7.5h13l-1 12a2 2 0 0 1-2 1.8h-7a2 2 0 0 1-2-1.8l-1-12z" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round"/>
        <path d="M3.8 7.5h16.4M9.5 7.3V5a1.4 1.4 0 0 1 1.4-1.4h2.2A1.4 1.4 0 0 1 14.5 5v2.3M9.8 11v6.2M14.2 11v6.2" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/>
      </symbol>
      <symbol id="ico-baixar" viewBox="0 0 24 24">
        <path d="M12 3.5v10.6M7.5 9.9l4.5 4.6 4.5-4.6" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M4 15.5v3A2.5 2.5 0 0 0 6.5 21h11a2.5 2.5 0 0 0 2.5-2.5v-3" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round"/>
      </symbol>
      <symbol id="ico-sair" viewBox="0 0 24 24">
        <path d="M13.5 3.5H6.8A1.8 1.8 0 0 0 5 5.3v13.4a1.8 1.8 0 0 0 1.8 1.8h6.7" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
        <path d="M10.5 12h9.5M16.6 8.4l3.6 3.6-3.6 3.6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
      </symbol>
      <symbol id="ico-paleta" viewBox="0 0 24 24">
        <path d="M12 3a9 9 0 1 0 .4 18c1.7 0 2.2-1 1.7-2-.6-1.2-.3-2.5 1-3h2.4A3.6 3.6 0 0 0 21 12.3C20.7 7 16.8 3 12 3z" fill="#f6f0e6" stroke="#3a3128" stroke-width="1.6"/>
        <circle cx="8.2" cy="9" r="1.5" fill="#e63946"/><circle cx="12.6" cy="7.2" r="1.5" fill="#ffd23f"/><circle cx="16.4" cy="9.8" r="1.5" fill="#2469d4"/><circle cx="7.8" cy="13.6" r="1.5" fill="#7bc950"/>
      </symbol>
    </svg>

    <!-- topo fininho -->
    <header class="topo">
      <span class="topo__nome"><svg class="ico ico--nome" aria-hidden="true"><use href="#ico-paleta"/></svg> Ateliê</span>
      <span class="topo__vao" aria-hidden="true"></span>
      <button class="acao" type="button" data-desfazer aria-label="Desfazer o último traço"><svg class="ico" aria-hidden="true"><use href="#ico-desfazer"/></svg><small>desfazer</small></button>
      <button class="acao" type="button" data-limpar aria-label="Apagar o desenho inteiro"><svg class="ico" aria-hidden="true"><use href="#ico-limpar"/></svg><small>limpar</small></button>
      <button class="acao" type="button" data-baixar aria-label="Baixar o desenho como imagem"><svg class="ico" aria-hidden="true"><use href="#ico-baixar"/></svg><small>baixar</small></button>
      <a class="acao acao--sair" href="/class/games/" aria-label="Sair do Ateliê"><svg class="ico" aria-hidden="true"><use href="#ico-sair"/></svg><small>sair</small></a>
    </header>

    <!-- miolo: ferramentas à ESQUERDA (paint raiz) + papel -->
    <div class="meio">
      <aside class="lateral">
        <div class="grupo grupo--vertical" role="group" aria-label="Ferramentas">
          <button class="ferramenta sel" type="button" data-ferramenta="pincel" aria-pressed="true" aria-label="Pincel"><svg class="ico ico--ferr" aria-hidden="true"><use href="#ico-pincel"/></svg></button>
          <button class="ferramenta" type="button" data-ferramenta="borracha" aria-pressed="false" aria-label="Borracha"><svg class="ico ico--ferr" aria-hidden="true"><use href="#ico-borracha"/></svg></button>
          <button class="ferramenta" type="button" data-ferramenta="balde" aria-pressed="false" aria-label="Balde de tinta"><svg class="ico ico--ferr" aria-hidden="true"><use href="#ico-balde"/></svg></button>
        </div>
        <div class="grupo grupo--vertical grupo--tamanhos" role="group" aria-label="Tamanho do pincel">
          {tamanhos.map((t, i) => (
            <button class={'tamanho' + (i === 1 ? ' sel' : '')} type="button" data-tamanho={String(i)} aria-pressed={i === 1 ? 'true' : 'false'} aria-label={'Tamanho ' + t.nome}>
              <span class="tamanho__bola" style={`width:${8 + i * 7}px;height:${8 + i * 7}px`}></span>
            </button>
          ))}
        </div>
      </aside>

      <div class="area" data-area>
        <canvas class="tela" data-tela></canvas>
        <div class="preview" data-preview aria-hidden="true" hidden></div>
        <div class="fantasma" data-fantasma>Arrasta o dedo ou o mouse pra desenhar! ✏️</div>
      </div>
    </div>

    <!-- cores embaixo -->
    <footer class="barra">
      <div class="cores" role="group" aria-label="Cores">
        {paleta.map((c, i) => (
          <button
            class={'cor' + (i === 0 ? ' sel' : '') + (c.hex === '#ffffff' ? ' cor--branca' : '')}
            type="button"
            data-cor={c.hex}
            data-cor-nome={c.nome}
            aria-pressed={i === 0 ? 'true' : 'false'}
            aria-label={'Cor ' + c.nome}
            style={`background:${c.hex}`}
          ></button>
        ))}
      </div>
    </footer>

    <p class="sr-only" data-anuncio aria-live="polite"></p>
  </main>

  <style is:global>
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-Regular.ttf') format('truetype');
      font-weight: 400;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-SemiBold.ttf') format('truetype');
      font-weight: 600;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-ExtraBold.ttf') format('truetype');
      font-weight: 800;
      font-display: swap;
    }

    body.is-game { background: #f3eee8; overflow: hidden; }
    body.is-game::before { display: none !important; }

    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
    }

    .at {
      position: fixed;
      inset: 0;
      overflow: clip;
      display: flex;
      flex-direction: column;
      font-family: 'Oxanium', Verdana, Tahoma, 'Segoe UI', Geneva, sans-serif;
      user-select: none;
      -webkit-user-select: none;
      background: #f3eee8;
      color: #3a3128;
      --tinta: #9b6dd6;
    }

    /* ===== topo ===== */
    .topo {
      display: flex; align-items: center; gap: 8px;
      padding: 6px 12px;
      background: #fffdf8;
      border-bottom: 2px solid #e5dccd;
    }
    .topo__nome { font-weight: 800; font-size: 1.1rem; }
    .topo__vao { flex: 1; }
    .acao {
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      min-width: 54px; height: 48px;
      border-radius: 12px; cursor: pointer;
      font-family: inherit; font-size: 1.05rem; line-height: 1; color: inherit;
      background: #f6f0e6;
      border: 2px solid #e0d5c2;
      text-decoration: none;
      touch-action: manipulation;
    }
    .acao small { font-size: 0.58rem; font-weight: 700; margin-top: 2px; }
    .ico { width: 22px; height: 22px; display: block; }
    .ico--nome { width: 20px; height: 20px; display: inline-block; vertical-align: -4px; }
    .ico--ferr { width: 28px; height: 28px; }
    .acao:hover { border-color: var(--tinta); }
    .acao:disabled { opacity: 0.4; cursor: default; }

    /* ===== miolo: lateral + papel ===== */
    .meio { display: flex; flex: 1; min-height: 0; }
    .lateral {
      display: flex; flex-direction: column; gap: 14px;
      padding: 10px 8px;
      background: #fffdf8;
      border-right: 2px solid #e5dccd;
      overflow-y: auto;
    }
    .grupo--vertical { flex-direction: column; }
    .grupo--tamanhos { margin-top: auto; }
    .area { position: relative; flex: 1; min-height: 0; overflow: hidden; }
    .tela { display: block; width: 100%; height: 100%; touch-action: none; cursor: crosshair; }
    .preview {
      position: absolute; z-index: 5;
      border: 2px solid rgba(60, 50, 40, 0.55);
      border-radius: 50%;
      pointer-events: none;
      transform: translate(-50%, -50%);
    }
    .preview[hidden] { display: none; }
    .fantasma {
      position: absolute; left: 50%; top: 14px;
      transform: translateX(-50%);
      z-index: 6; pointer-events: none;
      padding: 8px 16px; border-radius: 999px;
      background: rgba(58, 49, 40, 0.85); color: #fffdf8;
      font-weight: 700; font-size: 0.95rem;
      max-width: 92vw; text-align: center;
      animation: fantasma-pulsa 1.6s ease-in-out infinite alternate;
    }
    .fantasma[hidden] { display: none; }
    @keyframes fantasma-pulsa { from { opacity: 0.75; } to { opacity: 1; } }

    /* ===== barra de cores (embaixo) ===== */
    .barra {
      display: flex; align-items: center; justify-content: center;
      padding: 8px 12px calc(8px + env(safe-area-inset-bottom));
      background: #fffdf8;
      border-top: 2px solid #e5dccd;
    }
    .grupo { display: flex; gap: 6px; }
    .ferramenta {
      width: 52px; height: 52px;
      display: grid; place-items: center;
      border-radius: 14px; cursor: pointer;
      font-family: inherit; color: #3a3128;
      background: #f6f0e6;
      border: 3px solid #e0d5c2;
      touch-action: manipulation;
    }
    .ferramenta.sel { border-color: var(--tinta); background: #efe6fb; }
    .tamanho {
      width: 44px; height: 52px;
      display: grid; place-items: center;
      border-radius: 12px; cursor: pointer;
      background: #f6f0e6;
      border: 3px solid #e0d5c2;
      touch-action: manipulation;
    }
    .tamanho.sel { border-color: var(--tinta); background: #efe6fb; }
    .tamanho__bola { background: #3a3128; border-radius: 50%; }
    .cores {
      display: grid;
      /* 24 cores em 3 fileiras de 8; minmax(0,1fr) = sem blowout no 360px */
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 5px;
      flex: 1;
      min-width: 0;
      max-width: 560px;
    }
    .cor {
      width: 100%; aspect-ratio: 1;
      max-width: 42px;
      border-radius: 50%; cursor: pointer;
      border: 3px solid rgba(0, 0, 0, 0.15);
      touch-action: manipulation;
    }
    .cor--branca { border-color: #d5cbb9; }
    .cor.sel { border-color: var(--tinta); box-shadow: 0 0 0 3px rgba(155, 109, 214, 0.35); }

    @media (max-width: 640px) {
      .topo__nome { font-size: 0.95rem; }
      .acao { min-width: 44px; height: 44px; }
      .acao small { display: none; }
      .lateral { padding: 8px 5px; gap: 10px; }
      .ferramenta { width: 44px; height: 44px; }
      .tamanho { width: 40px; height: 40px; }
      .ico--ferr { width: 24px; height: 24px; }
      .cores { grid-template-columns: repeat(8, minmax(0, 1fr)); gap: 4px; max-width: none; flex: 1 1 100%; }
    }

    @media (prefers-reduced-motion: reduce) {
      .fantasma { animation: none; }
    }
  </style>

  <script>
    const dados = JSON.parse(document.querySelector('[data-dados]')!.textContent!);
    const CFG = dados.config;

    // ----- papel lógico (a verdade) + tela visível (escala) -----
    const papel = document.createElement('canvas');
    papel.width = CFG.larguraLogica;
    papel.height = CFG.alturaLogica;
    const pctx = papel.getContext('2d', { willReadFrequently: true })!;
    pctx.fillStyle = '#ffffff';
    pctx.fillRect(0, 0, papel.width, papel.height);
    pctx.lineCap = 'round';
    pctx.lineJoin = 'round';

    const area = document.querySelector('[data-area]') as HTMLElement;
    const tela = document.querySelector('[data-tela]') as HTMLCanvasElement;
    const tctx = tela.getContext('2d')!;
    let escala = 1;
    let ox = 0;
    let oy = 0;

    function medir() {
      const w = area.clientWidth || 1;
      const h = area.clientHeight || 1;
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      tela.width = Math.round(w * dpr);
      tela.height = Math.round(h * dpr);
      tctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      escala = Math.min(w / papel.width, h / papel.height);
      ox = (w - papel.width * escala) / 2;
      oy = (h - papel.height * escala) / 2;
      pintar();
    }

    function pintar() {
      const w = tela.width / (Math.min(window.devicePixelRatio || 1, 2));
      const h = tela.height / (Math.min(window.devicePixelRatio || 1, 2));
      tctx.fillStyle = '#e8e0d2'; // mesa em volta do papel
      tctx.fillRect(0, 0, w + 1, h + 1);
      tctx.drawImage(papel, ox, oy, papel.width * escala, papel.height * escala);
    }

    window.addEventListener('resize', medir);

    // ----- estado das ferramentas -----
    const estado = {
      ferramenta: 'pincel' as 'pincel' | 'borracha' | 'balde',
      cor: dados.paleta[0].hex as string,
      corNome: dados.paleta[0].nome as string,
      tamanho: 1,
      primeiroTraco: false,
    };

    const anuncioEl = document.querySelector('[data-anuncio]') as HTMLElement;
    let anuncioMs = 0;
    function anunciar(msg: string) {
      const agora = performance.now();
      if (agora - anuncioMs < 800) return;
      anuncioMs = agora;
      anuncioEl.textContent = '';
      requestAnimationFrame(() => { anuncioEl.textContent = msg; });
    }

    function aoPrimeiroTraco() {
      if (estado.primeiroTraco) return;
      estado.primeiroTraco = true;
      (document.querySelector('[data-fantasma]') as HTMLElement).hidden = true;
    }

    // ----- undo: pilha de PNG blobs (ImageData cru estouraria a RAM) -----
    const pilha: Blob[] = [];
    let fila: Promise<void> = Promise.resolve();
    function salvarSnapshot() {
      // clona o papel AGORA (drawImage síncrono): o PNG pode demorar na
      // fila, mas fotografa este instante — nunca o traço seguinte pela metade
      const copia = document.createElement('canvas');
      copia.width = papel.width;
      copia.height = papel.height;
      copia.getContext('2d')!.drawImage(papel, 0, 0);
      fila = fila.then(() => new Promise<void>((res) => {
        copia.toBlob((b) => {
          if (b) {
            pilha.push(b);
            if (pilha.length > CFG.undoMax) pilha.shift();
          }
          res();
        }, 'image/png');
      }));
    }
    function desfazer() {
      fila = fila.then(async () => {
        if (pilha.length <= 1) return; // só resta o papel em branco inicial
        pilha.pop();
        const bmp = await createImageBitmap(pilha[pilha.length - 1]);
        pctx.fillStyle = '#ffffff';
        pctx.fillRect(0, 0, papel.width, papel.height);
        pctx.drawImage(bmp, 0, 0);
        bmp.close();
        pintar();
        anunciar('Desfeito!');
      });
    }
    salvarSnapshot(); // estado inicial (papel em branco)

    // ----- balde: flood fill scanline com tolerância + dilatação 1px -----
    function hexParaRgb(hex: string): [number, number, number] {
      return [parseInt(hex.slice(1, 3), 16), parseInt(hex.slice(3, 5), 16), parseInt(hex.slice(5, 7), 16)];
    }

    function baldear(sx: number, sy: number, hex: string): boolean {
      const W = papel.width;
      const H = papel.height;
      sx = Math.floor(sx); sy = Math.floor(sy);
      if (sx < 0 || sx >= W || sy < 0 || sy >= H) return false;
      const img = pctx.getImageData(0, 0, W, H);
      const px = img.data;
      const i0 = (sy * W + sx) * 4;
      const alvo = [px[i0], px[i0 + 1], px[i0 + 2]];
      const [fr, fg, fb] = hexParaRgb(hex);
      // clicou numa área que já é da cor do balde: nada a fazer
      if (Math.abs(alvo[0] - fr) + Math.abs(alvo[1] - fg) + Math.abs(alvo[2] - fb) < 12) return false;
      const tol = CFG.toleranciaBalde;
      const parecido = (i: number) =>
        Math.abs(px[i] - alvo[0]) <= tol && Math.abs(px[i + 1] - alvo[1]) <= tol && Math.abs(px[i + 2] - alvo[2]) <= tol;
      const mask = new Uint8Array(W * H);
      const pendentes: number[] = [sy * W + sx];
      mask[sy * W + sx] = 1;
      while (pendentes.length) {
        const p = pendentes.pop()!;
        const y = (p / W) | 0;
        // estica pra esquerda e direita na mesma linha
        let esq = p;
        while (esq % W > 0 && !mask[esq - 1] && parecido((esq - 1) * 4)) { esq--; mask[esq] = 1; }
        let dir = p;
        while (dir % W < W - 1 && !mask[dir + 1] && parecido((dir + 1) * 4)) { dir++; mask[dir] = 1; }
        for (let q = esq; q <= dir; q++) {
          if (y > 0 && !mask[q - W] && parecido((q - W) * 4)) { mask[q - W] = 1; pendentes.push(q - W); }
          if (y < H - 1 && !mask[q + W] && parecido((q + W) * 4)) { mask[q + W] = 1; pendentes.push(q + W); }
        }
      }
      // pinta + dilata 1px (senão o antialias do traço deixa um halo sujo)
      const borda: number[] = [];
      for (let p = 0; p < mask.length; p++) {
        if (!mask[p]) continue;
        const i = p * 4;
        px[i] = fr; px[i + 1] = fg; px[i + 2] = fb; px[i + 3] = 255;
        const x = p % W;
        const y = (p / W) | 0;
        if (x > 0 && !mask[p - 1]) borda.push(p - 1);
        if (x < W - 1 && !mask[p + 1]) borda.push(p + 1);
        if (y > 0 && !mask[p - W]) borda.push(p - W);
        if (y < H - 1 && !mask[p + W]) borda.push(p + W);
      }
      for (const p of borda) {
        const i = p * 4;
        px[i] = fr; px[i + 1] = fg; px[i + 2] = fb; px[i + 3] = 255;
      }
      pctx.putImageData(img, 0, 0);
      return true;
    }

    // ----- desenho com pointer events (1 dedo por vez, capture + backstop) -----
    let desenhandoId: number | null = null;
    let ultX = 0;
    let ultY = 0;

    function tamanhoAtual(): number {
      const base = dados.tamanhos[estado.tamanho].px;
      return estado.ferramenta === 'borracha' ? base * CFG.borrachaFator : base;
    }
    function corAtual(): string {
      return estado.ferramenta === 'borracha' ? '#ffffff' : estado.cor;
    }
    function paraLogico(e: PointerEvent): [number, number] {
      const r = tela.getBoundingClientRect();
      return [(e.clientX - r.left - ox) / escala, (e.clientY - r.top - oy) / escala];
    }

    function pingo(x: number, y: number) {
      pctx.beginPath();
      pctx.fillStyle = corAtual();
      pctx.arc(x, y, tamanhoAtual() / 2, 0, Math.PI * 2);
      pctx.fill();
    }

    tela.addEventListener('contextmenu', (e) => e.preventDefault());
    tela.addEventListener('pointerdown', (e) => {
      if (desenhandoId !== null) return; // segundo dedo/palma: ignora
      // tap de dois dedos no trackpad / botão direito não é pincel
      if (e.pointerType === 'mouse' && e.button !== 0) return;
      e.preventDefault();
      const [x, y] = paraLogico(e);
      // clicou na mesa em volta do papel: não desenha, não gasta undo
      if (x < 0 || x >= papel.width || y < 0 || y >= papel.height) return;
      aoPrimeiroTraco();
      if (estado.ferramenta === 'balde') {
        if (baldear(x, y, estado.cor)) {
          pintar();
          salvarSnapshot();
          anunciar('Pintou com ' + estado.corNome + '!');
        }
        return;
      }
      desenhandoId = e.pointerId;
      tela.setPointerCapture(e.pointerId);
      ultX = x;
      ultY = y;
      pingo(x, y);
      pintar();
    });

    tela.addEventListener('pointermove', (e) => {
      // preview do pincel (só mouse)
      if (e.pointerType === 'mouse') {
        const prev = document.querySelector('[data-preview]') as HTMLElement;
        if (estado.ferramenta === 'balde') {
          prev.hidden = true;
        } else {
          const d = tamanhoAtual() * escala;
          prev.hidden = false;
          prev.style.width = d + 'px';
          prev.style.height = d + 'px';
          const r = area.getBoundingClientRect();
          prev.style.left = (e.clientX - r.left) + 'px';
          prev.style.top = (e.clientY - r.top) + 'px';
        }
      }
      if (e.pointerId !== desenhandoId) return;
      const eventos = (e as any).getCoalescedEvents ? (e as any).getCoalescedEvents() : [e];
      pctx.strokeStyle = corAtual();
      pctx.lineWidth = tamanhoAtual();
      for (const ev of eventos.length ? eventos : [e]) {
        const [x, y] = paraLogico(ev);
        pctx.beginPath();
        pctx.moveTo(ultX, ultY);
        pctx.lineTo(x, y);
        pctx.stroke();
        ultX = x;
        ultY = y;
      }
      pintar();
    });

    function soltar(e: PointerEvent) {
      if (e.pointerId !== desenhandoId) return;
      desenhandoId = null;
      salvarSnapshot();
    }
    tela.addEventListener('pointerup', soltar);
    tela.addEventListener('pointercancel', soltar);
    tela.addEventListener('lostpointercapture', soltar);
    tela.addEventListener('pointerleave', () => {
      (document.querySelector('[data-preview]') as HTMLElement).hidden = true;
    });

    // ----- barra de ferramentas -----
    document.querySelectorAll<HTMLElement>('[data-ferramenta]').forEach((btn) => {
      btn.addEventListener('click', () => {
        estado.ferramenta = btn.dataset.ferramenta as typeof estado.ferramenta;
        document.querySelectorAll('[data-ferramenta]').forEach((b) => {
          b.classList.toggle('sel', b === btn);
          b.setAttribute('aria-pressed', String(b === btn));
        });
        const nomes = { pincel: 'Pincel', borracha: 'Borracha', balde: 'Balde de tinta' };
        anunciar(nomes[estado.ferramenta] + (estado.ferramenta === 'borracha' ? '' : ', cor ' + estado.corNome));
      });
    });

    document.querySelectorAll<HTMLElement>('[data-tamanho]').forEach((btn) => {
      btn.addEventListener('click', () => {
        estado.tamanho = +btn.dataset.tamanho!;
        document.querySelectorAll('[data-tamanho]').forEach((b) => {
          b.classList.toggle('sel', b === btn);
          b.setAttribute('aria-pressed', String(b === btn));
        });
        anunciar('Tamanho ' + dados.tamanhos[estado.tamanho].nome);
      });
    });

    document.querySelectorAll<HTMLElement>('[data-cor]').forEach((btn) => {
      btn.addEventListener('click', () => {
        estado.cor = btn.dataset.cor!;
        estado.corNome = btn.dataset.corNome!;
        document.querySelectorAll('[data-cor]').forEach((b) => {
          b.classList.toggle('sel', b === btn);
          b.setAttribute('aria-pressed', String(b === btn));
        });
        // pegou uma cor com a borracha na mão? volta pro pincel
        if (estado.ferramenta === 'borracha') {
          (document.querySelector('[data-ferramenta="pincel"]') as HTMLElement).click();
        } else {
          anunciar('Cor ' + estado.corNome);
        }
      });
    });

    (document.querySelector('[data-desfazer]') as HTMLElement).addEventListener('click', desfazer);
    (document.querySelector('[data-limpar]') as HTMLElement).addEventListener('click', () => {
      if (!window.confirm('Apagar o desenho INTEIRO?')) return;
      pctx.fillStyle = '#ffffff';
      pctx.fillRect(0, 0, papel.width, papel.height);
      pintar();
      salvarSnapshot();
      anunciar('Papel em branco!');
    });
    (document.querySelector('[data-baixar]') as HTMLElement).addEventListener('click', () => {
      papel.toBlob((b) => {
        if (!b) return;
        const url = URL.createObjectURL(b);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'meu-desenho.png';
        a.click();
        setTimeout(() => URL.revokeObjectURL(url), 2000);
      }, 'image/png');
      anunciar('Desenho baixado!');
    });

    // Ctrl+Z de quem já usa computador
    window.addEventListener('keydown', (e) => {
      if ((e.ctrlKey || e.metaKey) && (e.key === 'z' || e.key === 'Z')) {
        e.preventDefault();
        if (!e.repeat) desfazer();
      }
    });

    // ----- boot -----
    document.body.classList.add('is-game');
    medir();

    // handle de teste/depuração
    (window as any).__at = {
      estado,
      papel,
      corEm(x: number, y: number) {
        const d = pctx.getImageData(Math.floor(x), Math.floor(y), 1, 1).data;
        return [d[0], d[1], d[2]];
      },
      pilhaLen: () => pilha.length,
      prontoUndo: () => fila,
      info: () => ({ escala, ox, oy }),
    };
  </script>
</Layout>
