---
import Layout from '../../../layouts/Layout.astro';
import { config, caixotes, spawnsBots, spawnsTime } from '../../../data/sugar-splash';

const dadosJson = JSON.stringify({ config, caixotes, spawnsBots, spawnsTime });
const letrasNome = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

const title = 'Sugar Splash — guerra d\'água entre times de açúcar! | Manolo Neto';
const description =
  'Jogo de bisnaga d\'água para crianças: partida de 5 minutos entre time azul e vermelho num clube com piscina e vestiários. Derreta o time inimigo, esconda-se nas cabines e recarregue mergulhando na piscina. Em português.';
---

<Layout title={title} description={description}>
  <script type="application/json" data-dados set:html={dadosJson}></script>

  <main id="conteudo" class="ss" data-game role="application" aria-label="Sugar Splash: derreta os bonecos de açúcar com sua bisnaga d'água">
    <div class="cena" data-cena>
      <div class="mira" aria-hidden="true">+</div>
      <div class="fps-topo" data-hud-top aria-hidden="true">
        <span>⏱ <strong data-tempo>5:00</strong></span>
        <span class="fps-sep">·</span>
        <strong data-placar>🔵 0 × 0 🔴</strong>
        <span class="fps-sep" data-room-sep hidden>·</span>
        <strong class="fps-room" data-room-code hidden></strong>
      </div>
      <div class="fps-pontos" aria-hidden="true">⭐ <strong data-pontos>0</strong></div>
      <div class="fps-team" data-team-badge aria-hidden="true" hidden></div>
      <div class="fps-botoes">
        <button class="hud__mute" type="button" data-pause aria-label="Pausar o jogo" hidden>⏸</button>
        <button class="hud__mute" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
          <span data-mute-icon>🔊</span>
        </button>
      </div>
      <div class="fps-vida" data-vida-box aria-label="Solidez do boneco">❤️ <strong data-solidez-num>100</strong></div>
      <div class="fps-agua" data-agua-box aria-label="Água na bisnaga">💧 <strong data-tanque-num>40</strong></div>
      <div class="scoreboard" data-scoreboard aria-hidden="true" hidden>
        <p class="scoreboard__titulo">🏆 Placar da sala</p>
        <ol class="tabela" data-scoreboard-list></ol>
      </div>
      <div class="dano-flash" data-dano-flash aria-hidden="true"></div>
      <div class="agua-tint" data-agua-tint aria-hidden="true"></div>
      <div class="respawn" data-respawn aria-hidden="true" hidden></div>
      <div class="toast" data-toast aria-live="polite" hidden></div>
      <div class="banner" data-banner aria-hidden="true" hidden>
        <strong data-banner-titulo></strong>
        <span data-banner-sub></span>
      </div>
    </div>

    <div class="controles" data-controles hidden>
      <div class="joy" data-joy aria-label="Andar">
        <div class="joy__pino" data-joy-pino></div>
      </div>
      <div class="botoes-dir">
        <button class="ctl ctl--pular" type="button" data-pular aria-label="Pular">⬆</button>
        <button class="ctl ctl--atirar" type="button" data-atirar aria-label="Atirar água">💦</button>
      </div>
    </div>

    <p class="sr-only" data-anuncio aria-live="assertive"></p>

    <div class="modal" data-intro>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="intro-title">
        <div class="placa__topo" id="intro-title">🔫💦 Sugar Splash</div>
        <div class="placa__corpo">
          <ol class="regras">
            <li>Partida de <b>5 minutos</b>: time azul contra time vermelho! 🔵🔴</li>
            <li>Derreta os bonecos do outro time com sua <b>bisnaga d'água</b>. 💦</li>
            <li>Derreteu? Sem drama: volta em <b>5 segundos</b> no seu vestiário.</li>
            <li>Sem água? <b>Mergulhe na piscina</b>. Quer se esconder? Usa as <b>cabines</b>! 🚽</li>
          </ol>
          <label class="campo"><span>Seu nome</span>
            <input data-campo-nome type="text" maxlength="6" autocomplete="off" autocapitalize="characters" spellcheck="false" placeholder="ex: LEO" />
          </label>
          <p class="erro" data-erro-intro hidden></p>
          <button class="botao botao--go" type="button" data-comecar>🤖 Jogar sozinho</button>
          <button class="botao botao--sec" type="button" data-criar-sala>➕ Criar sala com amigos</button>
          <div class="sala-linha">
            <input class="sala-codigo" data-campo-codigo type="text" maxlength="5" autocomplete="off" autocapitalize="characters" spellcheck="false" placeholder="CÓDIGO" aria-label="Código da sala" />
            <button class="botao botao--sec sala-entrar" type="button" data-entrar-sala>🚪 Entrar</button>
          </div>
          <button class="recordes-btn" type="button" data-ver-recordes>🏆 Recordes</button>
          <a class="voltar" href="/class/games/">← voltar pros jogos</a>
        </div>
      </div>
    </div>

    <div class="modal" data-lobby hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="lobby-title">
        <div class="placa__topo" id="lobby-title">🏊 Sala dos amigos</div>
        <div class="placa__corpo center">
          <p class="lobby-codigo" data-lobby-codigo>—</p>
          <p class="aviso">Esse é o código da sala. Passa pros amigos!</p>
          <ul class="lobby-lista" data-lobby-lista></ul>
          <p class="aviso" data-lobby-status></p>
          <button class="botao botao--go" type="button" data-lobby-comecar hidden>▶ Começar!</button>
          <button class="botao botao--sec botao--mini" type="button" data-lobby-sair>← Sair da sala</button>
        </div>
      </div>
    </div>

    <div class="modal" data-pausa hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="pausa-title">
        <div class="placa__topo" id="pausa-title">⏸ Pausa — secando as mãos…</div>
        <div class="placa__corpo center">
          <div class="pausa-acoes">
            <button class="botao botao--go" type="button" data-continuar>▶ Continuar</button>
            <button class="botao botao--sec" type="button" data-recomecar>🔄 Recomeçar</button>
            <a class="botao botao--sec" href="/class/games/">🚪 Sair do jogo</a>
          </div>
        </div>
      </div>
    </div>

    <div class="modal" data-fim hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="fim-title">
        <div class="placa__topo" id="fim-title">⏱ Fim de jogo!</div>
        <div class="placa__corpo center">
          <p class="grande" data-fim-msg></p>
          <p class="placar">Sua pontuação: <strong data-fim-score>0</strong></p>
          <ol class="tabela" data-fim-tabela hidden></ol>
          <div class="fim-acoes">
            <button class="botao botao--go" type="button" data-gravar-nome hidden>🏆 Gravar meu nome</button>
            <button class="botao botao--sec" type="button" data-fim-mesma-sala hidden>🔁 Jogar de novo aqui</button>
            <button class="botao botao--sec" type="button" data-replay>Jogar de novo</button>
          </div>
        </div>
      </div>
    </div>

    <div class="modal" data-entrada hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="entrada-title">
        <div class="placa__topo" id="entrada-title">Digite seu nome!</div>
        <div class="placa__corpo center">
          <p class="nome-slots" data-entrada-slots aria-live="polite">_ _ _</p>
          <div class="grade-letras" role="group" aria-label="Letras">
            {letrasNome.map((l) => (
              <button class="letra" type="button" data-tecla-nome={l}>{l}</button>
            ))}
            <button class="letra letra--apagar" type="button" data-nome-apagar aria-label="Apagar letra">⌫</button>
            <button class="letra letra--ok" type="button" data-nome-ok aria-label="Confirmar">✓</button>
          </div>
          <button class="botao botao--sec botao--mini" type="button" data-entrada-voltar>← Voltar</button>
        </div>
      </div>
    </div>

    <div class="modal" data-recordes hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="recordes-title">
        <div class="placa__topo" id="recordes-title">🏆 Recordes do Splash</div>
        <div class="placa__corpo center">
          <div class="recordes-abas" role="group" aria-label="Tipo de recorde">
            <button class="aba" type="button" data-recordes-aba="solo" aria-pressed="true">🤖 Sozinho</button>
            <button class="aba" type="button" data-recordes-aba="multi" aria-pressed="false">👥 Salas</button>
          </div>
          <ol class="tabela" data-tabela></ol>
          <p class="aviso" data-recordes-vazio hidden>Ninguém gravou o nome ainda. Seja o primeiro! 💦</p>
          <p class="aviso aviso--fonte" data-recordes-fonte></p>
          <div class="recordes-acoes">
            <button class="botao botao--go" type="button" data-recordes-replay>Jogar de novo</button>
            <button class="botao botao--sec" type="button" data-voltar-intro hidden>Voltar</button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <style is:global>
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-Regular.ttf') format('truetype');
      font-weight: 400;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-ExtraBold.ttf') format('truetype');
      font-weight: 800;
      font-display: swap;
    }

    body.is-game { background: #8fd4f0; overflow: hidden; overscroll-behavior: none; position: fixed; inset: 0; width: 100%; touch-action: none; }
    body.is-game::before { display: none !important; }

    .ss {
      position: fixed; inset: 0; overflow: clip;
      display: flex; flex-direction: column;
      font-family: 'Oxanium', Verdana, sans-serif;
      color: #08303f; user-select: none;
      -webkit-user-select: none;
      -webkit-touch-callout: none;
      --azul: #2098d8;
      --branco: #f5f2ea;
    }

    .fps-topo {
      position: absolute; top: 12px; left: 50%;
      transform: translateX(-50%);
      z-index: 24; pointer-events: auto; cursor: pointer;
      display: flex; align-items: center; justify-content: center;
      flex-wrap: wrap; gap: 14px; row-gap: 2px;
      max-width: calc(100% - 284px);
      padding: 9px 26px; border-radius: 999px;
      background: rgba(8, 48, 63, 0.55);
      color: #fff; font-weight: 800; font-size: clamp(1.2rem, 2.4vw, 1.6rem);
    }
    .fps-topo > span, .fps-topo > strong { white-space: nowrap; }
    .fps-sep { opacity: 0.5; }
    .fps-sep[hidden] { display: none; }
    .fps-room { font-size: 0.72em; letter-spacing: 3px; opacity: 0.85; }
    .fps-room[hidden] { display: none; }
    .fps-team {
      position: absolute; top: 68px; left: 16px;
      z-index: 24; pointer-events: none;
      color: #fff; font-weight: 800; font-size: clamp(0.95rem, 1.8vw, 1.15rem);
      text-shadow: 0 2px 6px rgba(8, 48, 63, 0.85);
    }
    .fps-team[hidden] { display: none; }
    .scoreboard {
      position: absolute; left: 50%; top: 50%;
      transform: translate(-50%, -50%);
      z-index: 30; pointer-events: none;
      width: min(88vw, 380px);
      padding: 14px 16px; border-radius: 16px;
      background: rgba(8, 48, 63, 0.82);
    }
    .scoreboard[hidden] { display: none; }
    .scoreboard__titulo { margin: 0 0 10px; text-align: center; color: #fff; font-weight: 800; }
    .scoreboard .tabela { margin: 0; }
    .scoreboard .tabela li { background: rgba(240, 250, 255, 0.94); border-color: rgba(32, 152, 216, 0.35); }
    .scoreboard .tabela li.novo { background: rgba(255, 231, 150, 0.96); border-color: #dcaa28; }
    .fps-pontos {
      position: absolute; top: 18px; left: 16px;
      z-index: 24; pointer-events: none;
      color: #fff; font-weight: 800; font-size: clamp(1.2rem, 2.4vw, 1.6rem);
      text-shadow: 0 2px 6px rgba(8, 48, 63, 0.85);
    }
    .fps-botoes {
      position: absolute; top: 12px; right: 12px;
      z-index: 26; display: flex; gap: 10px;
    }
    .fps-vida, .fps-agua {
      position: absolute; bottom: 20px;
      z-index: 24; pointer-events: none;
      display: flex; align-items: center; gap: 12px;
      font-weight: 800; font-size: clamp(2.5rem, 6.8vw, 3.8rem);
      color: #fff;
      text-shadow: 0 3px 14px rgba(8, 48, 63, 0.9), 0 0 30px rgba(8, 48, 63, 0.5);
    }
    .fps-vida { left: 18px; }
    .fps-agua { right: 18px; }
    .fps-vida strong, .fps-agua strong { display: inline-block; }
    .fps-agua strong { color: #6cd2ff; }
    .fps-vida.media strong { color: #ffd23f; }
    .fps-vida.baixa strong { color: #ff5c39; }
    .fps-vida.hit strong { animation: vida-pulso 0.3s ease-out; }
    @keyframes vida-pulso { 0% { transform: scale(1.4); } 100% { transform: scale(1); } }
    .fps-agua.low strong { color: #ff5c39; animation: agua-pisca 0.7s steps(2) infinite; }
    @keyframes agua-pisca { 50% { opacity: 0.35; } }
    @media (hover: none) {
      .fps-vida, .fps-agua { bottom: calc(126px + env(safe-area-inset-bottom)); }
    }
    @media (max-width: 860px) {
      .fps-topo { left: 10px; right: 140px; transform: none; max-width: none; font-size: 1.05rem; gap: 8px; padding: 7px 14px; justify-content: flex-start; }
      .fps-pontos { top: 76px; left: 12px; }
      .fps-team { top: 108px; left: 12px; }
      .hud__mute { width: 46px; height: 46px; font-size: 1.25rem; }
    }
    @media (max-width: 480px) {
      .fps-topo { font-size: 0.92rem; gap: 6px; padding: 6px 10px; }
    }
    @media (max-height: 540px) {
      .fps-vida, .fps-agua { font-size: clamp(1.6rem, 8vh, 2.6rem); }
    }
    @media (max-height: 540px) and (hover: hover) {
      .fps-vida, .fps-agua { bottom: 12px; }
    }
    @media (hover: none) and (max-height: 420px) {
      .fps-vida { left: 138px; bottom: 12px; }
      .fps-agua { right: 158px; bottom: 12px; }
    }
    .hud__mute {
      width: 54px; height: 54px; border-radius: 14px; cursor: pointer;
      background: rgba(8, 48, 63, 0.5); border: 1px solid rgba(122, 216, 245, 0.45);
      color: #eaf6ff; font-size: 1.5rem;
    }
    .hud__mute[hidden] { display: none; }

    .cena { position: relative; flex: 1; touch-action: none; overflow: clip; }
    .cena canvas { display: block; width: 100%; height: 100%; touch-action: none; }

    .mira {
      position: absolute; left: 50%; top: 50%;
      transform: translate(-50%, -50%);
      font-size: 1.6rem; font-weight: 400; color: rgba(255, 255, 255, 0.9);
      text-shadow: 0 0 4px rgba(8, 48, 63, 0.8);
      pointer-events: none; z-index: 20;
    }

    .dano-flash {
      position: absolute; inset: 0; z-index: 22;
      pointer-events: none; opacity: 0;
      box-shadow: inset 0 0 90px 30px rgba(32, 152, 216, 0.8);
    }
    .dano-flash.show { animation: dano-pisca 0.35s ease-out; }
    @keyframes dano-pisca { 0% { opacity: 1; } 100% { opacity: 0; } }

    .agua-tint {
      position: absolute; inset: 0; z-index: 21;
      pointer-events: none;
      background: rgba(48, 150, 210, 0.28);
      opacity: 0; transition: opacity 0.25s ease;
    }
    .agua-tint.show { opacity: 1; }

    .respawn {
      position: absolute; left: 50%; top: 42%;
      transform: translate(-50%, -50%);
      z-index: 26; pointer-events: none; text-align: center;
      font-size: clamp(1.2rem, 4vw, 1.7rem); font-weight: 800; color: #fff;
      text-shadow: 0 2px 10px rgba(8, 48, 63, 0.85);
      white-space: nowrap;
    }
    .respawn[hidden] { display: none; }

    .pontos-voa {
      position: absolute; z-index: 23;
      transform: translate(-50%, -50%);
      font-weight: 800; font-size: 1.3rem; color: #ffd23f;
      text-shadow: 0 2px 6px rgba(8, 48, 63, 0.9);
      pointer-events: none;
      animation: pontos-sobe 0.9s ease-out forwards;
    }
    @keyframes pontos-sobe {
      from { opacity: 1; margin-top: 0; }
      to { opacity: 0; margin-top: -46px; }
    }

    .toast {
      position: absolute; left: 50%; top: 14px;
      transform: translate(-50%, 0);
      z-index: 25; max-width: min(88vw, 460px);
      padding: 10px 16px; border-radius: 12px;
      font-size: 1rem; font-weight: 700; text-align: center; color: #fff;
      opacity: 0; transition: opacity 0.2s ease;
      pointer-events: none;
    }
    .toast.ok { background: rgba(24, 138, 88, 0.92); }
    .toast.info { background: rgba(8, 48, 63, 0.92); }
    .toast.show { opacity: 1; }
    .toast[hidden] { display: none; }

    .banner {
      position: absolute; left: 50%; top: 38%;
      transform: translate(-50%, -50%);
      text-align: center; pointer-events: none; z-index: 24;
      display: grid; gap: 4px;
    }
    .banner[hidden] { display: none; }
    .banner strong {
      font-size: clamp(1.8rem, 6vw, 2.6rem); font-weight: 800;
      color: #fff; text-shadow: 0 0 14px rgba(32, 152, 216, 0.9), 0 2px 8px rgba(0, 0, 0, 0.4);
    }
    .banner span { font-weight: 700; color: #eaf6ff; text-shadow: 0 1px 6px rgba(0, 0, 0, 0.5); }
    .banner.show { animation: banner-in 0.4s cubic-bezier(0.2, 1.4, 0.4, 1); }
    @keyframes banner-in {
      from { transform: translate(-50%, -50%) scale(0.6); opacity: 0; }
      to { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    }

    .controles {
      position: absolute; inset: 0; z-index: 28; pointer-events: none;
      touch-action: none;
    }
    .controles[hidden] { display: none; }
    .joy {
      position: absolute; left: 18px; bottom: calc(18px + env(safe-area-inset-bottom));
      width: 108px; height: 108px; border-radius: 50%;
      background: rgba(8, 48, 63, 0.35);
      border: 2px solid rgba(234, 246, 255, 0.5);
      pointer-events: auto; touch-action: none;
      display: grid; place-items: center;
    }
    .joy__pino {
      width: 44px; height: 44px; border-radius: 50%;
      background: rgba(234, 246, 255, 0.75);
      pointer-events: none;
    }
    .botoes-dir {
      position: absolute; right: 18px; bottom: calc(18px + env(safe-area-inset-bottom));
      display: flex; align-items: flex-end; gap: 12px;
      pointer-events: auto; touch-action: none;
    }
    .ctl {
      border-radius: 50%; cursor: pointer;
      background: rgba(8, 48, 63, 0.4);
      border: 2px solid rgba(234, 246, 255, 0.55);
      color: #eaf6ff; font-family: inherit; font-weight: 800;
      touch-action: none;
    }
    .ctl--pular { width: 56px; height: 56px; font-size: 1.3rem; }
    .ctl--atirar { width: 76px; height: 76px; font-size: 1.8rem; }
    .ctl.on, .ctl:active { background: rgba(88, 200, 240, 0.55); }

    @media (min-width: 900px) and (hover: hover) {
      .controles { display: none; }
    }

    .modal {
      position: absolute; inset: 0; z-index: 70;
      display: grid; place-items: center; padding: 20px;
      background: rgba(8, 30, 40, 0.65);
    }
    .modal[hidden] { display: none; }
    .placa {
      width: min(94vw, 460px);
      max-height: 92svh; overflow: auto;
      background: rgba(240, 250, 255, 0.97);
      border: 3px solid var(--azul);
      border-radius: 18px;
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.4);
      animation: placa-pop 0.25s ease;
      color: #08303f;
    }
    @keyframes placa-pop { from { transform: scale(0.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    .placa__topo {
      padding: 12px 18px;
      background: linear-gradient(90deg, #2098d8, #58c8f0);
      color: #fff; font-size: 1.2rem; font-weight: 800;
    }
    .placa__corpo { padding: 18px 22px 22px; }
    .placa__corpo.center { text-align: center; }
    .regras { margin: 0 0 14px 20px; display: grid; gap: 9px; font-size: 0.98rem; line-height: 1.45; }
    .grande { font-size: 1.15rem; font-weight: 800; margin-bottom: 10px; }
    .placar { font-size: 1.05rem; margin-bottom: 14px; }
    .placar strong { font-size: 1.6rem; color: var(--azul); }
    .aviso { color: #3a6a7d; font-size: 0.92rem; margin-bottom: 12px; min-height: 1.2em; }
    .aviso--fonte { font-size: 0.8rem; }

    .botao {
      display: block; width: 100%; text-align: center; text-decoration: none; cursor: pointer;
      font-family: inherit; font-weight: 800; font-size: 1.05rem;
      padding: 12px; border-radius: 12px; margin-bottom: 10px;
      touch-action: manipulation;
      box-sizing: border-box;
    }
    .botao[hidden] { display: none; }
    .botao--go {
      color: #fff; border: 0;
      background: linear-gradient(180deg, #58c8f0 0%, #2098d8 60%, #1878b0 100%);
      box-shadow: 0 4px 0 #0f5880;
    }
    .botao--go:active { transform: translateY(3px); box-shadow: 0 1px 0 #0f5880; }
    .botao--sec {
      color: #08303f; background: rgba(32, 152, 216, 0.1);
      border: 2px solid rgba(32, 152, 216, 0.5);
    }
    .botao--mini { padding: 9px 16px; font-size: 0.92rem; width: auto; margin: 0 auto; }
    .botao:focus-visible, .letra:focus-visible, .ctl:focus-visible, .recordes-btn:focus-visible { outline: 3px solid #f7a11b; outline-offset: 2px; }
