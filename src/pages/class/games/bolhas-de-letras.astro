---
import Layout from '../../../layouts/Layout.astro';

const title = 'Bubble Pop — combine maiúsculas e minúsculas! | Manolo Neto';
const description =
  'Bubble Pop: jogo educativo de estourar bolhas: mire a letra maiúscula na minúscula certa (M com m) e limpe o quadro! Três dificuldades, modo teclado e progressão do alfabeto inteiro. Em português.';
---

<Layout title={title} description={description}>
  <main id="conteudo" class="bl" data-game role="application" aria-label="Bubble Pop: combine a letra maiúscula com a minúscula">
    <canvas class="fundo" data-fundo aria-hidden="true"></canvas>
    <div class="princesas" data-princesas aria-hidden="true">
      <img class="princesa" data-princesa alt="" width="336" height="560" loading="lazy" />
    </div>
    <header class="hud" data-hud role="status" aria-live="polite">
      <div class="hud__bloco"><span class="hud__label">Pontos</span><strong data-pontos>0</strong></div>
      <div class="hud__bloco"><span class="hud__label">Nível</span><strong data-nivel>—</strong></div>
      <div class="hud__bloco hud__bloco--obj"><span class="hud__label">Objetivo</span><strong data-objetivo>—</strong></div>
      <div class="hud__bloco" data-proxima-wrap hidden><span class="hud__label">Próxima</span><strong class="hud__proxima" data-proxima></strong></div>
      <button class="hud__mute" type="button" data-falar aria-pressed="false" aria-label="Falar o nome das letras">🗣️</button>
      <button class="hud__mute" type="button" data-pausa-btn aria-label="Pausar o jogo" hidden>⏸️</button>
      <button class="hud__mute hud__mute--som" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
        <img class="hud__som-img" data-mute-icon src="/class/games/bolhas-de-letras/ui/audio-on.png" alt="Som" width="34" height="34" />
      </button>
    </header>

    <div class="palco">
      <canvas class="tela" data-tela width="480" height="640" aria-label="Quadro de bolhas"></canvas>
      <div class="toast" data-toast aria-live="polite"></div>
    </div>

    <div class="modal" data-intro>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="intro-title">
        <div class="placa__topo" id="intro-title">🫧 Bubble Pop</div>
        <div class="placa__corpo">
          <input class="campo-nome" data-campo-nome type="text" maxlength="6" autocomplete="off" autocapitalize="characters" spellcheck="false" placeholder="SEU NOME" aria-label="Seu nome" />
          <div class="difs" role="group" aria-label="Escolha a dificuldade">
            <button class="dif" type="button" data-dif="easy">
              <span class="dif__emoji">🎨</span>
              <span class="dif__nome">Fácil</span>
              <span class="dif__feitos" data-dif-feitos="easy">0/5</span>
            </button>
            <button class="dif" type="button" data-dif="medium">
              <span class="dif__emoji">⚪</span>
              <span class="dif__nome">Médio</span>
              <span class="dif__feitos" data-dif-feitos="medium">0/5</span>
            </button>
            <button class="dif" type="button" data-dif="hard">
              <span class="dif__emoji">🔤</span>
              <span class="dif__nome">Difícil</span>
              <span class="dif__feitos" data-dif-feitos="hard">0/5</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <div class="modal" data-pausa hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="pausa-title">
        <div class="placa__topo" id="pausa-title">⏸️ Pausa</div>
        <div class="placa__corpo">
          <button class="botao botao--go" type="button" data-pausa-voltar>▶️ Voltar a jogar</button>
          <button class="botao" type="button" data-pausa-recomecar>🔄 Recomeçar</button>
          <button class="botao" type="button" data-pausa-sair>🚪 Sair do jogo</button>
        </div>
      </div>
    </div>

    <div class="modal" data-ranking hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="ranking-title">
        <div class="placa__topo" id="ranking-title" data-rank-titulo>🏆 Ranking</div>
        <div class="placa__corpo">
          <ol class="tabela" data-rank-lista></ol>
          <p class="rank-vazio" data-rank-vazio hidden>Seja o primeiro a gravar o nome! 🫧</p>
          <p class="rank-fonte" data-rank-fonte></p>
          <button class="botao botao--go" type="button" data-rank-jogar>🔁 Jogar de novo</button>
          <button class="botao" type="button" data-rank-inicio>🏠 Início</button>
        </div>
      </div>
    </div>

    <div class="modal" data-nivel-done hidden>
      <div class="placa" role="dialog" aria-modal="true">
        <div class="placa__topo" data-nivel-done-titulo>⭐ Nível completo!</div>
        <div class="placa__corpo">
          <button class="botao botao--go" type="button" data-nd-continuar>➡️ Próximo nível</button>
        </div>
      </div>
    </div>

    <div class="modal" data-win hidden>
      <div class="placa" role="dialog" aria-modal="true">
        <div class="placa__topo">🏆 Parabéns!</div>
        <div class="placa__corpo">
          <p class="win-texto" data-win-texto></p>
          <div class="resumo" data-resumo hidden>
            <p class="resumo__linha resumo__linha--bom">💪 Reconhece bem: <strong data-resumo-bons></strong></p>
            <p class="resumo__linha">📚 Precisa praticar mais: <strong data-resumo-praticar></strong></p>
          </div>
          <button class="botao botao--go" type="button" data-win-ranking>🏆 Ver ranking</button>
          <button class="botao" type="button" data-win-menu>🏠 Voltar ao início</button>
        </div>
      </div>
    </div>

    <div class="modal" data-fail hidden>
      <div class="placa" role="dialog" aria-modal="true">
        <div class="placa__topo">🫧 Quase!</div>
        <div class="placa__corpo">
          <p class="win-texto" data-fail-texto></p>
          <button class="botao botao--go" type="button" data-fail-retry>🔁 Tentar de novo</button>
          <button class="botao" type="button" data-fail-ranking>🏆 Ver ranking</button>
          <button class="botao" type="button" data-fail-menu>🏠 Voltar ao início</button>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  import { iniciarJogo } from '../../../games/letter-bubble/main';

  iniciarJogo();
</script>

<style is:global>
  body.is-game {
    background: #6db3dd;
    overflow: clip;
  }
  body.is-game header,
  body.is-game footer {
    display: none;
  }
  .bl .tabela li {
    display: grid;
    grid-template-columns: 2.2em 1fr auto auto;
    align-items: center;
    gap: 8px;
    background: #eef4fb;
    border-radius: 10px;
    padding: 7px 10px;
    font-size: 0.95rem;
    color: #2b4562;
  }
  .bl .tabela li.novo {
    background: #d6ecff;
    outline: 2px solid #4d7fe8;
  }
  .bl .tabela .pos {
    font-weight: 700;
    color: #4a6685;
  }
  .bl .tabela .nome {
    font-family: 'Andika', sans-serif;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #143250;
  }
  .bl .tabela .det {
    font-size: 0.75rem;
    color: #7089a5;
  }
  .bl .tabela .pts {
    font-weight: 700;
    color: #1d7a3c;
  }
</style>

<style>
  @font-face {
    font-family: 'Andika';
    src: url('/class/fonts/andika/Andika-Regular.woff2') format('woff2');
    font-weight: 400;
    font-display: swap;
  }
  @font-face {
    font-family: 'Andika';
    src: url('/class/fonts/andika/Andika-Bold.woff2') format('woff2');
    font-weight: 700;
    font-display: swap;
  }
  @font-face {
    font-family: 'Oxanium';
    src: url('/class/fonts/oxanium/Oxanium-SemiBold.ttf') format('truetype');
    font-weight: 600;
    font-display: swap;
  }

  .bl {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    font-family: 'Oxanium', system-ui, sans-serif;
    background: linear-gradient(180deg, #5aa7d6, #7fc3e8);
    overflow: clip;
  }

  .fundo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    display: block;
  }

  .princesas {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }
  .princesa {
    position: fixed;
    top: 50%;
    height: clamp(300px, 58vh, 560px);
    width: auto;
    max-width: none;
    opacity: 0;
    transition: opacity 3s ease;
    animation: princesaFlutua 5.5s ease-in-out infinite;
    will-change: transform, opacity;
  }
  .princesa.lado-esq { left: 0; }
  .princesa.lado-dir { right: 0; animation-name: princesaFlutuaEsp; }
  .princesa.aparece { opacity: 1; }
  @keyframes princesaFlutua {
    0%, 100% { transform: translateY(-50%) rotate(-2deg); }
    50% { transform: translateY(calc(-50% - 20px)) rotate(2deg); }
  }
  @keyframes princesaFlutuaEsp {
    0%, 100% { transform: translateY(-50%) scaleX(-1) rotate(-2deg); }
    50% { transform: translateY(calc(-50% - 20px)) scaleX(-1) rotate(2deg); }
  }
  @media (max-width: 1120px) {
    .princesas { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .princesa { animation: none; transform: translateY(-50%); }
    .princesa.lado-dir { transform: translateY(-50%) scaleX(-1); }
  }

  .hud {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 12px;
    width: 100%;
    max-width: 560px;
    box-sizing: border-box;
  }
  .hud__bloco {
    background: rgba(255, 255, 255, 0.92);
    border-radius: 12px;
    padding: 4px 12px;
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1.15;
    box-shadow: 0 2px 0 rgba(20, 50, 80, 0.25);
  }
  .hud__label {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #4a6685;
  }
  .hud__bloco strong {
    font-size: 1.05rem;
    color: #143250;
  }
  .hud__bloco--obj {
    flex: 1;
    min-width: 0;
  }
  .hud__bloco--obj strong {
    font-size: 0.85rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }
  .hud__proxima {
    font-family: 'Andika', sans-serif;
  }
  .hud__mute {
    background: rgba(255, 255, 255, 0.92);
    border: 0;
    border-radius: 12px;
    font-size: 1.1rem;
    padding: 6px 10px;
    cursor: pointer;
    box-shadow: 0 2px 0 rgba(20, 50, 80, 0.25);
  }
  .hud__mute.on {
    outline: 3px solid #ffb520;
  }
  .hud__mute--som {
    background: none;
    box-shadow: none;
    padding: 2px;
  }
  .hud__som-img {
    width: 34px;
    height: 34px;
    display: block;
    max-width: none;
    filter: drop-shadow(0 2px 1px rgba(20, 50, 80, 0.3));
  }

  .palco {
    position: relative;
    z-index: 1;
    flex: 1;
    width: 100%;
    max-width: 560px;
    min-height: 0;
    display: flex;
    justify-content: center;
    padding: 0 8px 8px;
    box-sizing: border-box;
  }
  .tela {
    width: 100%;
    height: auto;
    max-height: 100%;
    align-self: center;
    touch-action: none;
  }

  .toast {
    position: absolute;
    left: 50%;
    bottom: 90px;
    transform: translateX(-50%) translateY(12px);
    background: #143250;
    color: #fff;
    padding: 8px 16px;
    border-radius: 999px;
    font-size: 0.95rem;
    opacity: 0;
    transition: opacity 0.25s, transform 0.25s;
    pointer-events: none;
    white-space: nowrap;
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .modal {
    position: fixed;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(15, 40, 70, 0.55);
    padding: 14px;
    z-index: 10;
  }
  .modal[hidden] {
    display: none;
  }
  .placa {
    background: #fdfcf7;
    border-radius: 20px;
    max-width: 420px;
    width: 100%;
    max-height: 92vh;
    overflow-y: auto;
    box-shadow: 0 10px 0 rgba(15, 40, 70, 0.35);
  }
  .placa__topo {
    background: linear-gradient(135deg, #4d7fe8, #52c7d9);
    color: #fff;
    font-size: 1.3rem;
    font-weight: 700;
    text-align: center;
    padding: 14px;
    border-radius: 20px 20px 0 0;
  }
  .placa__corpo {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .campo-nome {
    font-family: 'Andika', sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    text-align: center;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #143250;
    background: #eef4fb;
    border: 3px solid #c7d8ec;
    border-radius: 14px;
    padding: 12px;
    outline: none;
  }
  .campo-nome:focus {
    border-color: #4d7fe8;
  }
  .campo-nome.treme {
    animation: campoTreme 0.4s ease;
  }
  @keyframes campoTreme {
    0%, 100% { transform: translateX(0); }
    20%, 60% { transform: translateX(-8px); }
    40%, 80% { transform: translateX(8px); }
  }

  .difs {
    display: flex;
    gap: 10px;
  }
  .dif {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    background: #eef4fb;
    border: 3px solid #c7d8ec;
    border-radius: 16px;
    padding: 10px 6px;
    cursor: pointer;
    font-family: inherit;
    transition: transform 0.12s, border-color 0.12s;
  }
  .dif:hover,
  .dif:focus-visible {
    transform: translateY(-2px);
    border-color: #4d7fe8;
  }
  .dif__emoji {
    font-size: 1.6rem;
  }
  .dif__nome {
    font-weight: 700;
    color: #143250;
    font-size: 1.02rem;
  }
  .dif__feitos {
    font-size: 0.72rem;
    background: #143250;
    color: #fff;
    border-radius: 999px;
    padding: 2px 8px;
  }

  .botao {
    background: #eef4fb;
    border: 3px solid #c7d8ec;
    border-radius: 14px;
    padding: 12px;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    color: #143250;
    cursor: pointer;
  }
  .botao:hover,
  .botao:focus-visible {
    border-color: #4d7fe8;
  }
  .botao--go {
    background: linear-gradient(135deg, #58c471, #2fa457);
    border-color: #1d7a3c;
    color: #fff;
  }

  .tabela {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-height: 46vh;
    overflow-y: auto;
  }
  .rank-vazio {
    margin: 0;
    text-align: center;
    color: #4a6685;
  }
  .rank-vazio[hidden] {
    display: none;
  }
  .rank-fonte {
    margin: 0;
    text-align: center;
    font-size: 0.78rem;
    color: #7089a5;
    min-height: 1em;
  }

  .win-texto {
    margin: 0;
    text-align: center;
    font-size: 1.05rem;
    color: #2b4562;
  }
  .resumo {
    background: #eef4fb;
    border-radius: 14px;
    padding: 10px 12px;
  }
  .resumo[hidden] {
    display: none;
  }
  .resumo__linha {
    margin: 4px 0;
    font-size: 0.92rem;
    color: #2b4562;
  }
  .resumo__linha strong {
    font-family: 'Andika', sans-serif;
    letter-spacing: 0.18em;
  }
  .resumo__linha--bom strong {
    color: #1d7a3c;
  }

  @media (max-width: 480px) {
    .hud {
      flex-wrap: wrap;
      gap: 6px;
      padding: 6px 8px;
    }
    .difs {
      flex-direction: column;
    }
    .dif {
      flex-direction: row;
      justify-content: center;
      gap: 10px;
    }
  }
</style>
