---
import Layout from '../../../layouts/Layout.astro';
import { mapa, destinos, config, skins } from '../../../data/entrega-turbo';

const dadosJson = JSON.stringify({ mapa, destinos, config, skins });
const letrasNome = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

const title = 'Entrega Turbo — dirija o caminhão e entregue as caixas! | Manolo Neto';
const description =
  'Jogo 3D de caminhão para crianças: dirija pela cidadezinha, pegue as caixas no depósito e entregue na padaria, na escola, no mercado! Modo fácil sem pressa e modo normal contra o tempo, em português.';
---

<Layout title={title} description={description}>
  <script type="application/json" data-dados set:html={dadosJson}></script>

  <main id="conteudo" class="et" data-game role="application" aria-label="Jogo 3D: dirija o caminhão, pegue a carga e entregue">
    <!-- HUD -->
    <header class="hud" role="status" aria-live="polite">
      <div class="hud__bloco">
        <span class="hud__label">📦</span>
        <strong data-caixas>0</strong>
      </div>
      <div class="hud__bloco hud__bloco--prazo" data-prazo-wrap hidden aria-label="Tempo restante da entrega">
        <span class="hud__label">⏰</span>
        <strong class="relogio" data-relogio>0:00</strong>
      </div>
      <div class="hud__bloco">
        <span class="hud__label">⭐</span>
        <strong data-pontos>0</strong>
      </div>
      <div class="hud__bloco">
        <span class="hud__label">Nível</span>
        <strong data-nivel>1</strong>
      </div>
      <div class="hud__bloco hud__bloco--vidas" data-vidas-wrap hidden>
        <span class="vidas" data-vidas></span>
      </div>
      <div class="hud__bloco hud__bloco--nome" data-destino-atual aria-hidden="true"></div>
      <button class="hud__mute" type="button" data-pause aria-label="Pausar o jogo" hidden>⏸</button>
      <button class="hud__mute" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
        <span data-mute-icon>🔊</span>
      </button>
    </header>

    <!-- Cena 3D + overlays -->
    <div class="cena" data-cena>
      <!-- canvas WebGL entra aqui via JS -->

      <!-- seta 2D na borda quando o alvo sai da tela -->
      <div class="seta-borda" data-seta-borda hidden>➤</div>

      <!-- controles touch -->
      <div class="controles" data-controles hidden>
        <div class="controles__grupo controles__grupo--esq">
          <button class="ctl" type="button" data-ctl="esq" aria-label="Virar à esquerda">◀</button>
          <button class="ctl" type="button" data-ctl="dir" aria-label="Virar à direita">▶</button>
        </div>
        <div class="controles__grupo controles__grupo--dir">
          <button class="ctl ctl--buzina" type="button" data-ctl="buzina" aria-label="Buzinar">📯</button>
          <button class="ctl" type="button" data-ctl="re" aria-label="Frear ou dar ré">▼</button>
          <button class="ctl ctl--acel" type="button" data-ctl="acel" aria-label="Acelerar">▲</button>
        </div>
      </div>

      <!-- overlay fantasma de controles (some no 1º input) -->
      <div class="fantasma" data-fantasma hidden>
        <span data-fantasma-txt>◀ ▶ pra virar</span>
      </div>

      <div class="toast" data-toast aria-live="polite" hidden></div>
      <div class="banner-nivel" data-banner-nivel aria-hidden="true" hidden>
        <strong data-banner-titulo></strong>
        <span data-banner-sub></span>
      </div>
      <button class="botao botao--mini resgate" type="button" data-resgate hidden>🚚 Voltar pra pista</button>
    </div>

    <p class="sr-only" data-anuncio aria-live="assertive"></p>

    <!-- Modal: intro -->
    <div class="modal" data-intro>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="intro-title">
        <div class="placa__topo" id="intro-title">🚚 Entrega Turbo</div>
        <div class="placa__corpo">
          <ol class="regras">
            <li><b>Dirija o caminhão</b> pela cidadezinha em 3D! 🏙️</li>
            <li>Pegue a caixa 📦 no <b>depósito</b> (anel amarelo).</li>
            <li>Siga a <b>seta</b> e leve até a loja (anel verde)! 🏪</li>
            <li>Chegue <b>devagarzinho</b> na vaga pra entregar.</li>
          </ol>
          <p class="escolha__titulo">Como você quer jogar?</p>
          <div class="escolha">
            <button class="botao-modo botao-modo--tranquilo" type="button" data-modo="facil">
              <span class="botao-modo__titulo">😌 Fácil</span>
              <small>Sem tempo e sem pressa: acelere com ▲, explore e entregue no seu ritmo!</small>
            </button>
            <button class="botao-modo botao-modo--vidas" type="button" data-modo="normal">
              <span class="botao-modo__titulo">🎯 Normal</span>
              <small>Você pisa no pedal e corre contra o tempo. Vale ranking!</small>
            </button>
          </div>
          <button class="recordes-btn" type="button" data-ver-recordes>🏆 Recordes</button>
        </div>
      </div>
    </div>

    <!-- Modal: pausa -->
    <div class="modal" data-pausa hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="pausa-title">
        <div class="placa__topo" id="pausa-title">⏸ Pausa — descansando o motor…</div>
        <div class="placa__corpo center">
          <div class="pausa-acoes">
            <button class="botao botao--go" type="button" data-continuar>▶ Continuar</button>
            <button class="botao botao--sec" type="button" data-encerrar>🏁 Encerrar turno</button>
            <button class="botao botao--sec" type="button" data-recomecar>🔄 Recomeçar</button>
            <a class="botao botao--sec" href="/class/games/">🚪 Sair do jogo</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: fim de turno -->
    <div class="modal" data-fim hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="fim-title">
        <div class="placa__topo" id="fim-title">Fim do turno! 🚚🎉</div>
        <div class="placa__corpo center">
          <p class="grande" data-fim-msg></p>
          <p class="placar">Sua pontuação: <strong data-fim-score>0</strong></p>
          <p class="aviso" data-fim-detalhe></p>
          <div class="fim-acoes">
            <button class="botao botao--go" type="button" data-gravar-nome hidden>🏆 Gravar meu nome</button>
            <button class="botao botao--sec" type="button" data-replay>Dirigir de novo</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: entrada arcade (nome do ranking) -->
    <div class="modal" data-entrada hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="entrada-title">
        <div class="placa__topo" id="entrada-title">Digite seu nome, caminhoneiro!</div>
        <div class="placa__corpo center">
          <p class="nome-slots" data-entrada-slots aria-live="polite">_ _ _</p>
          <div class="grade-letras" role="group" aria-label="Letras">
            {letrasNome.map((l) => (
              <button class="letra" type="button" data-tecla-nome={l}>{l}</button>
            ))}
            <button class="letra letra--apagar" type="button" data-nome-apagar aria-label="Apagar letra">⌫</button>
            <button class="letra letra--ok" type="button" data-nome-ok aria-label="Confirmar">✓</button>
          </div>
          <button class="botao botao--sec botao--mini" type="button" data-entrada-voltar>← Voltar</button>
        </div>
      </div>
    </div>

    <!-- Modal: recordes -->
    <div class="modal" data-recordes hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="recordes-title">
        <div class="placa__topo" id="recordes-title">🏆 Recordes dos Caminhoneiros</div>
        <div class="placa__corpo center">
          <ol class="tabela" data-tabela></ol>
          <p class="aviso" data-recordes-vazio hidden>Ninguém gravou o nome ainda. Seja o primeiro! 🚚</p>
          <p class="aviso aviso--fonte" data-recordes-fonte></p>
          <div class="recordes-acoes">
            <button class="botao botao--go" type="button" data-recordes-replay>Dirigir de novo</button>
            <button class="botao botao--sec" type="button" data-voltar-intro hidden>Voltar</button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <style is:global>
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-Regular.ttf') format('truetype');
      font-weight: 400;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-SemiBold.ttf') format('truetype');
      font-weight: 600;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-ExtraBold.ttf') format('truetype');
      font-weight: 800;
      font-display: swap;
    }

    body.is-game { background: #79c4e8; overflow: hidden; }
    body.is-game::before { display: none !important; }

    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
    }

    .et {
      position: fixed;
      inset: 0;
      overflow: clip;
      font-family: 'Oxanium', Verdana, Tahoma, 'Segoe UI', Geneva, sans-serif;
      user-select: none;
      -webkit-user-select: none;
      color: var(--texto);
      display: flex;
      flex-direction: column;
      --ciano: #22e0ff;
      --verde: #2ee08a;
      --amarelo: #ffd23f;
      --quente: #ff5c39;
      --texto: #eaf6ff;
      overscroll-behavior: none;
    }

    /* ===== HUD (glass escuro sobre o 3D, padrão do site) ===== */
    .hud {
      position: relative; z-index: 30;
      display: flex; align-items: center; gap: 16px;
      padding: 8px 16px;
      background: rgba(10, 22, 44, 0.6);
      border-bottom: 1px solid rgba(34, 224, 255, 0.35);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .hud__bloco { display: flex; align-items: center; gap: 7px; }
    .hud__bloco[hidden] { display: none; }
    .hud__label { font-size: 1rem; }
    .hud__bloco strong { font-size: 1.4rem; line-height: 1; text-shadow: 0 0 8px rgba(34, 224, 255, 0.55); transition: transform 0.18s ease; }
    .hud__bloco strong.pop { transform: scale(1.4); color: var(--verde); }
    .hud__bloco--nome { flex: 1; justify-content: center; font-weight: 700; font-size: 0.95rem; }
    .vidas { display: inline-flex; gap: 4px; font-size: 1.05rem; }
    .vida--vazia { opacity: 0.25; filter: grayscale(1); }
    .vida--pop { animation: vida-pop 0.45s ease; display: inline-block; }
    @keyframes vida-pop { 0% { transform: scale(0.4); } 55% { transform: scale(1.5); } 100% { transform: scale(1); } }
    .hud__mute {
      width: 44px; height: 44px; border-radius: 10px; cursor: pointer;
      border: 1px solid rgba(34, 224, 255, 0.45); background: rgba(10, 22, 44, 0.55);
      font-size: 1.15rem; display: grid; place-items: center; color: var(--texto);
    }
    .hud__mute[hidden] { display: none; }
    /* relógio digital da entrega: verde → âmbar → vermelho pulsando */
    .relogio {
      font-size: 1.5rem; font-weight: 800; font-variant-numeric: tabular-nums;
      color: var(--verde);
      text-shadow: 0 0 10px rgba(46, 224, 138, 0.5);
      line-height: 1;
    }
    .relogio.ambar { color: var(--amarelo); text-shadow: 0 0 10px rgba(255, 210, 63, 0.5); }
    .relogio.urgente {
      color: var(--quente); text-shadow: 0 0 12px rgba(255, 92, 57, 0.7);
      animation: relogio-pulsa 0.6s ease-in-out infinite alternate;
      display: inline-block;
    }
    @keyframes relogio-pulsa { from { transform: scale(1); } to { transform: scale(1.14); } }

    /* ===== Cena ===== */
    .cena { position: relative; z-index: 10; flex: 1; min-height: 0; }
    .cena canvas { display: block; width: 100%; height: 100%; touch-action: none; }

    .seta-borda {
      position: absolute; z-index: 35;
      font-size: 2.2rem; color: var(--amarelo);
      text-shadow: 0 0 10px rgba(0, 0, 0, 0.6);
      pointer-events: none;
      transform-origin: center;
    }
    .seta-borda[hidden] { display: none; }

    /* ===== Controles touch ===== */
    .controles { position: absolute; inset: 0; z-index: 40; pointer-events: none; }
    .controles[hidden] { display: none; }
    .controles__grupo {
      position: absolute; bottom: max(14px, env(safe-area-inset-bottom));
      display: flex; gap: 12px; align-items: flex-end;
      pointer-events: none;
    }
    .controles__grupo--esq { left: 14px; }
    .controles__grupo--dir { right: 14px; flex-direction: row; }
    .ctl {
      pointer-events: auto;
      width: 76px; height: 76px; border-radius: 20px;
      font-size: 1.9rem; font-family: inherit; color: var(--texto);
      background: rgba(10, 22, 44, 0.5);
      border: 2px solid rgba(34, 224, 255, 0.5);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      touch-action: none;
      cursor: pointer;
    }
    .ctl:active, .ctl.on { background: rgba(34, 224, 255, 0.35); }
    .ctl--buzina { width: 56px; height: 56px; font-size: 1.3rem; border-radius: 50%; align-self: flex-start; }
    .ctl[hidden] { display: none; }

    .fantasma {
      position: absolute; left: 50%; bottom: 24%;
      transform: translateX(-50%);
      z-index: 38; pointer-events: none;
      padding: 10px 18px; border-radius: 12px;
      background: rgba(10, 22, 44, 0.75);
      border: 1px solid rgba(34, 224, 255, 0.5);
      font-weight: 700; font-size: 1.05rem;
      animation: fantasma-pulsa 1.2s ease-in-out infinite alternate;
    }
    .fantasma[hidden] { display: none; }
    @keyframes fantasma-pulsa { from { opacity: 0.75; } to { opacity: 1; transform: translateX(-50%) scale(1.04); } }

    .resgate {
      position: absolute; right: 12px; top: 12px; z-index: 40;
    }
    .resgate[hidden] { display: none; }

    /* ===== Toast / banner ===== */
    .toast {
      position: absolute; left: 50%; top: 12px;
      transform: translate(-50%, 0) translateY(-6px);
      z-index: 45;
      max-width: min(88vw, 480px);
      padding: 11px 18px; border-radius: 14px;
      font-size: 1.02rem; font-weight: 700; text-align: center; color: #fff;
      opacity: 0;
      transition: opacity 0.25s ease, transform 0.25s ease;
      pointer-events: none;
    }
    .toast.show { opacity: 1; transform: translate(-50%, 0); }
    .toast.ok {
      background: linear-gradient(180deg, rgba(23, 168, 102, 0.95), rgba(15, 122, 74, 0.95));
      border: 1px solid rgba(110, 231, 160, 0.6);
    }
    .toast.info {
      background: linear-gradient(180deg, rgba(38, 84, 140, 0.95), rgba(24, 56, 100, 0.95));
      border: 1px solid rgba(34, 224, 255, 0.5);
    }
    .banner-nivel {
      position: absolute; left: 50%; top: 22%; z-index: 45;
      transform: translate(-50%, -50%);
      text-align: center; pointer-events: none;
      display: grid; gap: 4px;
    }
    .banner-nivel[hidden] { display: none; }
    .banner-nivel strong {
      font-size: clamp(1.8rem, 6vw, 2.6rem); font-weight: 800; letter-spacing: 0.06em;
      color: #fff; text-shadow: 0 0 12px var(--ciano), 0 2px 8px rgba(0, 0, 0, 0.5);
    }
    .banner-nivel span { font-weight: 600; text-shadow: 0 1px 6px rgba(0, 0, 0, 0.6); }
    .banner-nivel.show { animation: banner-in 0.45s cubic-bezier(0.2, 1.4, 0.4, 1); }
    @keyframes banner-in {
      from { transform: translate(-50%, -50%) scale(0.6); opacity: 0; }
      to { transform: translate(-50%, -50%) scale(1); opacity: 1; }
    }

    /* ===== Modais (padrão do site) ===== */
    .modal {
      position: absolute; inset: 0; z-index: 70;
      display: grid; place-items: center; padding: 20px;
      background: rgba(4, 10, 22, 0.6);
    }
    .modal[hidden] { display: none; }
    .placa {
      width: min(94vw, 480px);
      max-height: 92svh; overflow: auto;
      background: rgba(10, 20, 40, 0.94);
      border: 2px solid rgba(34, 224, 255, 0.5);
      border-radius: 18px;
      box-shadow: 0 0 24px rgba(34, 224, 255, 0.25), 0 18px 50px rgba(0, 0, 0, 0.65);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      animation: placa-pop 0.25s ease;
    }
    @keyframes placa-pop { from { transform: scale(0.92); opacity: 0; } to { transform: scale(1); opacity: 1; } }
    .placa__topo {
      padding: 12px 18px;
      background: linear-gradient(90deg, rgba(34, 224, 255, 0.3), rgba(255, 210, 63, 0.22));
      color: #fff; font-size: 1.15rem; font-weight: 800;
      text-shadow: 0 0 10px rgba(34, 224, 255, 0.8);
      border-bottom: 1px solid rgba(34, 224, 255, 0.4);
    }
    .placa__corpo { padding: 18px 22px 22px; color: var(--texto); }
    .placa__corpo.center { text-align: center; }
    .regras { margin: 0 0 16px 20px; display: grid; gap: 10px; font-size: 0.98rem; line-height: 1.45; }
    .grande { font-size: 1.2rem; font-weight: 800; margin-bottom: 10px; }
    .placar { font-size: 1.05rem; margin-bottom: 6px; }
    .placar strong { font-size: 1.6rem; color: var(--ciano); text-shadow: 0 0 10px rgba(34, 224, 255, 0.6); }
    .aviso { color: rgba(191, 233, 255, 0.75); font-size: 0.95rem; margin-bottom: 16px; min-height: 1.2em; }
    .aviso--fonte { font-size: 0.82rem; margin-bottom: 12px; min-height: 1em; }

    .botao[hidden] { display: none; }
    .botao {
      display: inline-block; text-align: center; text-decoration: none;
      font-family: inherit; cursor: pointer; font-weight: 800;
      padding: 11px 26px; border-radius: 12px; font-size: 1.05rem;
      border: 2px solid rgba(34, 224, 255, 0.7); color: #04121f;
      background: linear-gradient(180deg, #7ef0ff 0%, #22e0ff 55%, #0ea8d8 100%);
      box-shadow: 0 0 14px rgba(34, 224, 255, 0.45), 0 4px 0 #086a8a;
      transition: transform 0.12s ease, box-shadow 0.12s ease;
    }
    .botao:active { transform: translateY(3px); box-shadow: 0 0 10px rgba(34, 224, 255, 0.35), 0 1px 0 #086a8a; }
    .botao:focus-visible { outline: 3px solid var(--amarelo); outline-offset: 2px; }
    .botao--sec {
      color: var(--texto);
      background: rgba(10, 22, 44, 0.7);
      border-color: rgba(34, 224, 255, 0.4);
      box-shadow: 0 0 10px rgba(34, 224, 255, 0.15), 0 4px 0 rgba(8, 30, 60, 0.9);
    }
    .botao--mini { padding: 9px 16px; font-size: 0.92rem; }
    .fim-acoes { display: grid; gap: 10px; justify-items: center; }
    .pausa-acoes { display: grid; gap: 10px; }

    .escolha__titulo { font-weight: 800; font-size: 1.05rem; margin-bottom: 10px; }
    .escolha { display: grid; gap: 10px; }
    .botao-modo {
      font-family: inherit; cursor: pointer; text-align: left;
      display: flex; flex-direction: column; gap: 4px;
      padding: 12px 16px; border-radius: 14px;
      border: 3px solid transparent;
      transition: transform 0.12s ease, filter 0.15s ease;
    }
    .botao-modo:hover { transform: translateY(-2px); filter: brightness(1.15); }
    .botao-modo:focus-visible { outline: 3px solid var(--ciano); outline-offset: 2px; }
    .botao-modo__titulo { font-size: 1.1rem; font-weight: 800; color: var(--texto); }
    .botao-modo small { font-size: 0.85rem; line-height: 1.4; color: rgba(191, 233, 255, 0.8); }
    .botao-modo--tranquilo {
      background: linear-gradient(135deg, rgba(34, 224, 255, 0.14), rgba(110, 231, 160, 0.1));
      border-color: rgba(34, 224, 255, 0.55);
    }
    .botao-modo--vidas {
      background: linear-gradient(135deg, rgba(255, 210, 63, 0.16), rgba(255, 92, 57, 0.1));
      border-color: rgba(255, 210, 63, 0.6);
    }
    .recordes-btn {
      display: block; margin: 14px auto 0;
      font-family: inherit; cursor: pointer; font-weight: 800;
      padding: 8px 18px; border-radius: 10px; font-size: 0.92rem;
      color: #ffe9a8; background: rgba(10, 22, 44, 0.7);
      border: 2px solid rgba(255, 210, 63, 0.6);
    }

    .nome-slots {
      font-size: 2rem; font-weight: 800; letter-spacing: 8px;
      color: var(--ciano); text-shadow: 0 0 10px rgba(34, 224, 255, 0.7);
      margin-bottom: 12px; min-height: 1.3em;
    }
    .grade-letras { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; margin-bottom: 12px; }
    .letra {
      height: 44px;
      font-family: inherit; font-size: 1.1rem; font-weight: 800;
      color: var(--texto); background: rgba(10, 22, 44, 0.85);
      border: 2px solid rgba(34, 224, 255, 0.5); border-radius: 8px;
      cursor: pointer;
      touch-action: manipulation;
    }
    .letra--apagar { border-color: rgba(255, 92, 57, 0.6); color: #ffb59f; }
    .letra--ok { border-color: rgba(110, 231, 160, 0.7); color: #6ee7a0; }
    .tabela {
      margin: 0 0 12px; padding: 0; list-style: none;
      display: grid; gap: 4px; font-size: 0.95rem; text-align: left;
    }
    .tabela li {
      display: flex; align-items: center; gap: 8px;
      padding: 5px 10px;
      background: rgba(34, 224, 255, 0.07);
      border: 1px solid rgba(34, 224, 255, 0.18);
      border-radius: 8px;
    }
    .tabela li.novo { background: rgba(255, 210, 63, 0.14); border-color: #ffd23f; }
