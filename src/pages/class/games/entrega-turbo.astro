    @media (prefers-reduced-motion: reduce) {
      .placa, .banner-nivel.show, .fantasma { animation: none !important; }
      .toast, .vida--pop, .hud__bloco strong { transition: none !important; animation: none !important; }
    }
  </style>

  <script>
    import * as THREE from 'three';
    import { mergeGeometries } from 'three/addons/utils/BufferGeometryUtils.js';

    // ===== Dados =====
    const dados = JSON.parse(document.querySelector('[data-dados]').textContent);
    const MAPA = dados.mapa;
    const DESTINOS = dados.destinos;
    const CFG = dados.config;
    const SKINS = dados.skins;
    const POR_SIMBOLO = new Map(DESTINOS.map((d) => [d.simbolo, d]));

    const $ = (s) => document.querySelector(s);
    const cenaEl = $('[data-cena]');
    const toastEl = $('[data-toast]');
    const anuncioEl = $('[data-anuncio]');
    const introModal = $('[data-intro]');
    const pausaModal = $('[data-pausa]');
    const fimModal = $('[data-fim]');
    const entradaModal = $('[data-entrada]');
    const recordesModal = $('[data-recordes]');
    const vidasWrapEl = $('[data-vidas-wrap]');
    const vidasEl = $('[data-vidas]');
    const prazoWrapEl = $('[data-prazo-wrap]');
    const prazoFillEl = $('[data-prazo-fill]');
    const setaBordaEl = $('[data-seta-borda]');
    const controlesEl = $('[data-controles]');
    const fantasmaEl = $('[data-fantasma]');
    const bannerEl = $('[data-banner-nivel]');
    const resgateBtn = $('[data-resgate]');

    const API_RANKING = '/class/api/ranking.php';
    const JOGO_ID = 'entrega-turbo';
    const RANKING_KEY = 'entrega-turbo:ranking';
    const MOTION_REDUZIDO = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Geometria do mundo derivada do mapa (célula 28m: rua 8 + lote 20)
    const N = MAPA.length;
    const CEL = CFG.celulaM;
    const MEIO = (N * CEL + 8) / 2; // 74 — mundo vai de -74 a 74
    const loteCentro = (i) => -MEIO + 8 + CFG.loteM / 2 + i * CEL; // centros: -56,-28,0,28,56
    const ruaCentro = (i) => -MEIO + 4 + i * CEL; // centros das ruas: -70..70

    const estado = {
      fase: 'inicio', // 'inicio' | 'jogando' | 'pausado' | 'fim' | 'entrada' | 'recordes'
      modo: null,     // 'facil' | 'normal'
      pontos: 0,
      nivel: 1,
      vidas: 0,
      pedidosCompletos: 0,
      entregasTotais: 0,
      pedido: null,   // {caixas:[destino], coletado, bateu, prazoMs, inicioMs, pausadoMs}
      mudo: false,
      primeiroInput: false,
      longeDesdeMs: 0,
    };

    // caminhão (física em coordenadas do mundo; y é pra cima)
    const truck = { x: 0, z: 14, heading: 0, v: 0, ultimaBatidaMs: 0, squashAte: 0 };
    const input = { esq: false, dir: false, acel: false, re: false };

    // ===== Áudio =====
    let actx = null;
    let motorOsc = null;
    let motorGain = null;
    function initAudio() {
      if (actx) return;
      const AC = window.AudioContext || window.webkitAudioContext;
      if (!AC) return;
      actx = new AC();
      motorOsc = actx.createOscillator();
      motorGain = actx.createGain();
      motorOsc.type = 'sawtooth';
      motorOsc.frequency.value = 70;
      motorGain.gain.value = 0;
      motorOsc.connect(motorGain);
      motorGain.connect(actx.destination);
      motorOsc.start();
    }
    function tom(freq, inicio, dur, tipo, vol) {
      if (!actx) return;
      const o = actx.createOscillator();
      const g = actx.createGain();
      o.type = tipo; o.frequency.value = freq;
      o.connect(g); g.connect(actx.destination);
      const t = actx.currentTime + inicio;
      g.gain.setValueAtTime(0.0001, t);
      g.gain.linearRampToValueAtTime(vol, t + 0.02);
      g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      o.start(t); o.stop(t + dur + 0.03);
    }
    function somColeta() { if (estado.mudo) return; tom(523, 0, 0.1, 'triangle', 0.16); tom(659, 0.09, 0.14, 'triangle', 0.16); }
    function somEntrega() { if (estado.mudo) return; [523, 659, 784, 1046].forEach((f, i) => tom(f, i * 0.09, 0.18, 'triangle', 0.18)); }
    function somBatida() { if (estado.mudo) return; tom(120, 0, 0.18, 'square', 0.14); }
    function somBuzina() { if (estado.mudo) return; tom(392, 0, 0.18, 'square', 0.14); tom(494, 0.02, 0.22, 'square', 0.12); }
    function somPedido() { if (estado.mudo) return; tom(660, 0, 0.09, 'triangle', 0.14); tom(880, 0.1, 0.12, 'triangle', 0.14); }
    function somNivel() { if (estado.mudo) return; [523, 659, 784, 1046].forEach((f, i) => tom(f, i * 0.12, 0.22, 'triangle', 0.2)); }
    function somFim() { if (estado.mudo) return; tom(392, 0, 0.5, 'triangle', 0.14); tom(494, 0.14, 0.5, 'triangle', 0.14); tom(587, 0.28, 0.6, 'triangle', 0.14); }
    function somUfa() { if (estado.mudo) return; tom(300, 0, 0.25, 'sine', 0.12); tom(392, 0.2, 0.3, 'sine', 0.12); }
    function atualizarMotor(dt) {
      if (!motorGain) return;
      const alvoGain = estado.mudo || estado.fase !== 'jogando' ? 0 : 0.028;
      motorGain.gain.setTargetAtTime(alvoGain, actx.currentTime, 0.08);
      motorOsc.frequency.setTargetAtTime(70 + Math.abs(truck.v) * 16, actx.currentTime, 0.05);
    }

    // ===== Mudo =====
    const muteBtn = $('[data-mute]');
    const muteIcon = $('[data-mute-icon]');
    function aplicarMudo() {
      muteBtn.setAttribute('aria-pressed', String(estado.mudo));
      muteIcon.textContent = estado.mudo ? '🔈' : '🔊';
    }
    (function initMudo() {
      const salvo = localStorage.getItem('entrega-turbo:mudo');
      estado.mudo = salvo === null ? !CFG.somLigadoInicial : salvo === '1';
      aplicarMudo();
    })();
    muteBtn.addEventListener('click', () => {
      estado.mudo = !estado.mudo;
      localStorage.setItem('entrega-turbo:mudo', estado.mudo ? '1' : '0');
      aplicarMudo();
    });

    // ===== Utilidades =====
    function anunciar(msg) { anuncioEl.textContent = ''; requestAnimationFrame(() => { anuncioEl.textContent = msg; }); }
    let toastTimer = null;
    function mostrarToast(html, tipo, ms) {
      toastEl.innerHTML = html;
      toastEl.className = 'toast ' + tipo;
      toastEl.hidden = false;
      requestAnimationFrame(() => toastEl.classList.add('show'));
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toastEl.classList.remove('show');
        setTimeout(() => { toastEl.hidden = true; }, 250);
      }, ms || 2400);
    }
    function popHud(sel, valor) {
      const el = $(sel);
      el.textContent = String(valor);
      el.classList.add('pop');
      setTimeout(() => el.classList.remove('pop'), 200);
    }
    function atualizarVidas(pop) {
      let html = '';
      for (let i = 0; i < CFG.coracoes; i++) {
        const cheio = i < estado.vidas;
        html += '<span class="vida' + (cheio ? '' : ' vida--vazia') + (pop && i === estado.vidas - 1 ? ' vida--pop' : '') + '">❤️</span>';
      }
      vidasEl.innerHTML = html;
    }
    const ELOGIOS = ['Boa entrega!', 'Mandou bem!', 'Uhul!', 'Que rápido!', 'Valeu!', 'Show!', 'Chegou certinho!', 'É isso aí!', 'Obrigado, caminhoneiro!', 'Demais!'];
    let elogiosRestantes = [];
    function elogio() {
      if (!elogiosRestantes.length) elogiosRestantes = ELOGIOS.slice();
      return elogiosRestantes.splice(Math.floor(Math.random() * elogiosRestantes.length), 1)[0];
    }

    // ===== Three.js: setup =====
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x79c4e8);
    scene.fog = new THREE.Fog(0x79c4e8, 60, 120);
    const camera = new THREE.PerspectiveCamera(55, 1, 0.1, 130);
    camera.position.set(0, 30, 40);

    const renderer = new THREE.WebGLRenderer({ antialias: true, powerPreference: 'high-performance' });
    let tierBaixo = false;
    try {
      const gl = renderer.getContext();
      const dbg = gl.getExtension('WEBGL_debug_renderer_info');
      const gpu = dbg ? gl.getParameter(dbg.UNMASKED_RENDERER_WEBGL) : '';
      if (/swiftshader|llvmpipe|software/i.test(gpu)) tierBaixo = true;
    } catch (_) {}
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, tierBaixo ? 1 : 1.5));
    cenaEl.insertBefore(renderer.domElement, cenaEl.firstChild);

    // contexto WebGL pode se perder em Chromebook — pausa e espera voltar
    renderer.domElement.addEventListener('webglcontextlost', (e) => {
      e.preventDefault();
      if (estado.fase === 'jogando') pausar();
    });

    scene.add(new THREE.HemisphereLight(0xdfefff, 0x8a9a6a, 1.05));
    const sol = new THREE.DirectionalLight(0xfff2d5, 1.2);
    sol.position.set(40, 60, 25);
    scene.add(sol);

    function medir() {
      const w = cenaEl.clientWidth || 1;
      const h = cenaEl.clientHeight || 1;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
      // com o loop parado (intro/pausa/fim), setSize limpa o canvas —
      // re-renderiza um frame estático pra não ficar preto
      if (!rafId) renderer.render(scene, camera);
    }
    window.addEventListener('resize', medir);
    renderer.domElement.addEventListener('webglcontextrestored', () => medir());

    // ===== Chão (1 draw call): asfalto + calçadas + grama + sombras assadas =====
    const aabbs = []; // colisões dos prédios/árvores {minX,maxX,minZ,maxZ}
    function ehRuaIdx(worldPos) { // posição está dentro de alguma faixa de rua?
      for (let i = 0; i <= N; i++) {
        const c = ruaCentro(i);
        if (Math.abs(worldPos - c) <= 4) return true;
      }
      return false;
    }
    function gerarChao() {
      const c = document.createElement('canvas');
      c.width = 1024; c.height = 1024;
      const g = c.getContext('2d');
      const esc = 1024 / 160; // mundo -80..80 → 0..1024
      const px = (m) => (m + 80) * esc;
      // grama base
      g.fillStyle = '#8fbf5a';
      g.fillRect(0, 0, 1024, 1024);
      // calçadas: quadrado do lote levemente maior
      g.fillStyle = '#cfc7b8';
      for (let r = 0; r < N; r++) {
        for (let q = 0; q < N; q++) {
          const cx = px(loteCentro(q));
          const cy = px(loteCentro(r));
          const lado = (CFG.loteM + 4) * esc;
          g.fillRect(cx - lado / 2, cy - lado / 2, lado, lado);
        }
      }
      // ruas (faixas horizontais e verticais)
      g.fillStyle = '#4a4d55';
      for (let i = 0; i <= N; i++) {
        const c1 = px(ruaCentro(i) - 4);
        g.fillRect(c1, px(-MEIO), 8 * esc, (2 * MEIO) * esc);
        g.fillRect(px(-MEIO), c1, (2 * MEIO) * esc, 8 * esc);
      }
      // faixas centrais amarelas tracejadas
      g.strokeStyle = '#e8c84a';
      g.lineWidth = 2;
      g.setLineDash([10, 12]);
      for (let i = 0; i <= N; i++) {
        const cc = px(ruaCentro(i));
        g.beginPath(); g.moveTo(cc, px(-MEIO)); g.lineTo(cc, px(MEIO)); g.stroke();
        g.beginPath(); g.moveTo(px(-MEIO), cc); g.lineTo(px(MEIO), cc); g.stroke();
      }
      g.setLineDash([]);
      return c;
    }
    const chaoCanvas = gerarChao();

    // ===== Cidade: prédios mesclados + árvores instanciadas =====
    const PALETA = [0xe8b04b, 0xd97757, 0x7ba3c9, 0xa3c47e, 0xc9917b, 0xb9a3d9, 0x8fbfae, 0xd9c47e];
    const geosPredios = [];
    const geosJanelas = [];
    const zonas = new Map(); // simbolo -> {x, z, destino} ('D' = depósito)
    const sombras = []; // retângulos pra assar no chão
    const arvores = []; // [x, z] de cada árvore

    function caixaColorida(w, h, d, x, z, corHex, comTopo) {
      const geo = new THREE.BoxGeometry(w, h, d);
      const cor = new THREE.Color(corHex);
      const teto = cor.clone().multiplyScalar(0.75);
      const cores = [];
      const pos = geo.getAttribute('position');
      const normal = geo.getAttribute('normal');
      for (let i = 0; i < pos.count; i++) {
        const usar = normal.getY(i) > 0.5 && comTopo ? teto : cor;
        cores.push(usar.r, usar.g, usar.b);
      }
      geo.setAttribute('color', new THREE.Float32BufferAttribute(cores, 3));
      geo.translate(x, h / 2, z);
      return geo;
    }

    for (let r = 0; r < N; r++) {
      for (let q = 0; q < N; q++) {
        const sim = MAPA[r][q];
        const cx = loteCentro(q);
        const cz = loteCentro(r);
        if (sim === '.') continue; // pracinha
        if (sim === 'T') {
          // arvoredo: 4-6 árvores no lote (posições determinísticas por índice)
          const nArv = 4 + ((r * 5 + q) % 3);
          for (let a = 0; a < nArv; a++) {
            const ax = cx + ((a * 37 + r * 13) % 14) - 7;
            const az = cz + ((a * 53 + q * 17) % 14) - 7;
            arvores.push([ax, az]);
          }
          continue;
        }
        if (sim === 'D') {
          // depósito: galpão largo e baixo
          geosPredios.push(caixaColorida(16, 7, 14, cx, cz - 2, 0xc9b458, true));
          geosPredios.push(caixaColorida(17, 1.2, 15, cx, cz - 2, 0x8a8578, true)); // base
          aabbs.push({ minX: cx - 8.5, maxX: cx + 8.5, minZ: cz - 9.5, maxZ: cz + 5.5 });
          sombras.push([cx - 8.5, cz - 9.5, 17, 15]);
          zonas.set('D', { x: cx, z: cz + 14, destino: null });
          continue;
        }
        const destino = POR_SIMBOLO.get(sim);
        if (destino) {
          // lojinha do destino: caixa menor colorida + toldo
          geosPredios.push(caixaColorida(11, 6, 10, cx, cz - 3, destino.cor, true));
          geosPredios.push(caixaColorida(12, 1, 2.4, cx, cz + 2.2, 0xffffff, false)); // toldo
          aabbs.push({ minX: cx - 6, maxX: cx + 6, minZ: cz - 8, maxZ: cz + 3.4 });
          sombras.push([cx - 6, cz - 8, 12, 11]);
          zonas.set(sim, { x: cx, z: cz + 14, destino });
          continue;
        }
        // prédio comum: 1-2 blocos com alturas variadas (determinístico)
        const seed = r * 31 + q * 7;
        const h1 = 7 + (seed % 8);
        const cor1 = PALETA[seed % PALETA.length];
        geosPredios.push(caixaColorida(13, h1, 13, cx - 2, cz - 2, cor1, true));
        aabbs.push({ minX: cx - 8.5, maxX: cx + 4.5, minZ: cz - 8.5, maxZ: cz + 4.5 });
        sombras.push([cx - 8.5, cz - 8.5, 13, 13]);
        if (seed % 3 === 0) {
          const h2 = 5 + (seed % 4);
          const cor2 = PALETA[(seed + 3) % PALETA.length];
          geosPredios.push(caixaColorida(6, h2, 6, cx + 5.5, cz + 4, cor2, true));
          aabbs.push({ minX: cx + 2.5, maxX: cx + 8.5, minZ: cz + 1, maxZ: cz + 7 });
          sombras.push([cx + 2.5, cz + 1, 6, 6]);
        }
        // janelas: quadros escuros na face sul (voltada pra rua)
        const nJan = 2 + (seed % 3);
        for (let j = 0; j < nJan; j++) {
          const jg = new THREE.PlaneGeometry(1.6, 2);
          const cores = [];
          for (let i = 0; i < jg.getAttribute('position').count; i++) cores.push(0.12, 0.2, 0.32);
          jg.setAttribute('color', new THREE.Float32BufferAttribute(cores, 3));
          jg.translate(cx - 2 - 4 + j * 4, 3.4, cz - 2 + 6.51);
          geosJanelas.push(jg);
        }
      }
    }
    // assar sombras dos prédios no chão (deslocadas pro nordeste do sol)
    (function assarSombras() {
      const g = chaoCanvas.getContext('2d');
      const esc = 1024 / 160;
      const px = (m) => (m + 80) * esc;
      g.fillStyle = 'rgba(30, 40, 30, 0.25)';
      sombras.forEach(([x, z, w, d]) => {
        g.fillRect(px(x) - 8, px(z) + 8, w * esc, d * esc);
      });
    })();

    const chaoTex = new THREE.CanvasTexture(chaoCanvas);
    chaoTex.colorSpace = THREE.SRGBColorSpace;
    const chao = new THREE.Mesh(
      new THREE.PlaneGeometry(160, 160),
      new THREE.MeshLambertMaterial({ map: chaoTex })
    );
    chao.rotation.x = -Math.PI / 2;
    scene.add(chao);

    const matVertex = new THREE.MeshLambertMaterial({ vertexColors: true });
    if (geosPredios.length) {
      scene.add(new THREE.Mesh(mergeGeometries(geosPredios), matVertex));
    }
    if (geosJanelas.length) {
      const jm = new THREE.Mesh(mergeGeometries(geosJanelas), new THREE.MeshBasicMaterial({ vertexColors: true }));
      scene.add(jm);
    }

    // árvores: 2 InstancedMesh (troncos + copas), colisão como caixinha
    if (arvores.length) {
      const tronco = new THREE.InstancedMesh(
        new THREE.CylinderGeometry(0.3, 0.4, 1.6, 6),
        new THREE.MeshLambertMaterial({ color: 0x8a6242 }),
        arvores.length
      );
      const copa = new THREE.InstancedMesh(
        new THREE.ConeGeometry(1.7, 3.2, 7),
        new THREE.MeshLambertMaterial({ color: 0x4f9e46 }),
        arvores.length
      );
      const m = new THREE.Matrix4();
      arvores.forEach(([x, z], i) => {
        m.makeTranslation(x, 0.8, z);
        tronco.setMatrixAt(i, m);
        m.makeTranslation(x, 3.1, z);
        copa.setMatrixAt(i, m);
        aabbs.push({ minX: x - 0.7, maxX: x + 0.7, minZ: z - 0.7, maxZ: z + 0.7 });
      });
      scene.add(tronco, copa);
    }

    // placas flutuantes dos destinos (sprite com emoji + nome)
    function fazerPlaca(texto, emoji) {
      const c = document.createElement('canvas');
      c.width = 256; c.height = 96;
      const g = c.getContext('2d');
      g.fillStyle = 'rgba(10, 22, 44, 0.85)';
      g.beginPath();
      g.roundRect(4, 4, 248, 88, 18);
      g.fill();
      g.strokeStyle = 'rgba(34, 224, 255, 0.8)';
      g.lineWidth = 4;
      g.stroke();
      g.font = '44px sans-serif';
      g.textAlign = 'center';
      g.fillText(emoji, 46, 64);
      g.fillStyle = '#eaf6ff';
      g.font = '800 30px Verdana, sans-serif';
      g.fillText(texto, 152, 62);
      const tex = new THREE.CanvasTexture(c);
      tex.colorSpace = THREE.SRGBColorSpace;
      const sp = new THREE.Sprite(new THREE.SpriteMaterial({ map: tex, transparent: true }));
      sp.scale.set(9, 3.4, 1);
      return sp;
    }
    zonas.forEach((z, sim) => {
      if (sim === 'D') {
        const sp = fazerPlaca('Depósito', '📦');
        sp.position.set(z.x, 9.5, z.z - 16);
        scene.add(sp);
      } else {
        const sp = fazerPlaca(z.destino.rotulo, z.destino.emoji);
        sp.position.set(z.x, 8, z.z - 14);
        scene.add(sp);
      }
    });

    // ===== Caminhão procedural =====
    const truckGroup = new THREE.Group();
    const cabMat = new THREE.MeshLambertMaterial({ color: SKINS[0][0] });
    const bauMat = new THREE.MeshLambertMaterial({ color: SKINS[0][1] });
    const escuroMat = new THREE.MeshLambertMaterial({ color: 0x2a2e38 });
    const vidroMat = new THREE.MeshLambertMaterial({ color: 0x9fd8ef });
    // frente do caminhão aponta pra +z
    const cab = new THREE.Mesh(new THREE.BoxGeometry(2.2, 1.7, 1.7), cabMat);
    cab.position.set(0, 1.35, 1.95);
    const vidro = new THREE.Mesh(new THREE.BoxGeometry(1.9, 0.7, 0.1), vidroMat);
    vidro.position.set(0, 1.75, 2.81);
    const bau = new THREE.Mesh(new THREE.BoxGeometry(2.4, 2.2, 3.6), bauMat);
    bau.position.set(0, 1.7, -0.9);
    const chassi = new THREE.Mesh(new THREE.BoxGeometry(2.2, 0.5, 5.6), escuroMat);
    chassi.position.set(0, 0.55, 0.2);
    truckGroup.add(cab, vidro, bau, chassi);
    // rodas: dianteiras esterçam (pivôs), todas giram
    const rodaGeo = new THREE.CylinderGeometry(0.55, 0.55, 0.4, 10);
    rodaGeo.rotateZ(Math.PI / 2);
    const rodas = [];
    const pivosDianteiros = [];
    [[-1.15, 1.9, true], [1.15, 1.9, true], [-1.15, -1.4, false], [1.15, -1.4, false]].forEach(([x, z, frente]) => {
      const roda = new THREE.Mesh(rodaGeo, escuroMat);
      rodas.push(roda);
      if (frente) {
        const pivo = new THREE.Group();
        pivo.position.set(x, 0.55, z);
        pivo.add(roda);
        pivosDianteiros.push(pivo);
        truckGroup.add(pivo);
      } else {
        roda.position.set(x, 0.55, z);
        truckGroup.add(roda);
      }
    });
    // caixas no baú (instanciadas, até 3 visíveis)
    const caixaMesh = new THREE.InstancedMesh(
      new THREE.BoxGeometry(0.9, 0.9, 0.9),
      new THREE.MeshLambertMaterial({ color: 0xc9925b }),
      3
    );
    caixaMesh.count = 0;
    caixaMesh.frustumCulled = false; // mesmo gotcha do boundingSphere vazio da rota
    truckGroup.add(caixaMesh);
    function atualizarCaixasVisiveis(n) {
      const m = new THREE.Matrix4();
      caixaMesh.count = Math.min(3, n);
      for (let i = 0; i < caixaMesh.count; i++) {
        m.makeTranslation((i % 2) * 1 - 0.5, 2.95 + Math.floor(i / 2) * 0.95, -0.9 - (i % 2) * 0.2);
        caixaMesh.setMatrixAt(i, m);
      }
      caixaMesh.instanceMatrix.needsUpdate = true;
      popHud('[data-caixas]', n);
    }
    // sombra blob
    const blobTex = (() => {
      const c = document.createElement('canvas');
      c.width = 64; c.height = 64;
      const g = c.getContext('2d');
      const rad = g.createRadialGradient(32, 32, 4, 32, 32, 30);
      rad.addColorStop(0, 'rgba(0,0,0,0.4)');
      rad.addColorStop(1, 'rgba(0,0,0,0)');
      g.fillStyle = rad;
      g.fillRect(0, 0, 64, 64);
      return new THREE.CanvasTexture(c);
    })();
    const blob = new THREE.Mesh(
      new THREE.PlaneGeometry(4.6, 6.6),
      new THREE.MeshBasicMaterial({ map: blobTex, transparent: true, depthWrite: false })
    );
    blob.rotation.x = -Math.PI / 2;
    blob.position.y = 0.02;
    truckGroup.add(blob);
    scene.add(truckGroup);

    function aplicarSkin(nivel) {
      const idx = Math.min(Math.floor((nivel - 1) / 2), SKINS.length - 1);
      cabMat.color.setHex(SKINS[idx][0]);
      bauMat.color.setHex(SKINS[idx][1]);
    }

    // ===== Zonas visuais (anel + pilar) e seta-guia =====
    function fazerAnel(cor) {
      const anel = new THREE.Mesh(
        new THREE.RingGeometry(CFG.raioZona - 0.7, CFG.raioZona, 36),
        new THREE.MeshBasicMaterial({ color: cor, transparent: true, opacity: 0.85, depthWrite: false })
      );
      anel.rotation.x = -Math.PI / 2;
      anel.position.y = 0.05;
      return anel;
    }
    function fazerPilar(cor) {
      const pilar = new THREE.Mesh(
        new THREE.CylinderGeometry(0.9, 0.9, 26, 10, 1, true),
        new THREE.MeshBasicMaterial({ color: cor, transparent: true, opacity: 0.3, depthWrite: false, fog: false, side: THREE.DoubleSide })
      );
      pilar.position.y = 13;
      return pilar;
    }
    const zonaColeta = new THREE.Group();
    zonaColeta.add(fazerAnel(0xffd23f), fazerPilar(0xffd23f));
    const zonaEntrega = new THREE.Group();
    zonaEntrega.add(fazerAnel(0x2ee08a), fazerPilar(0x2ee08a));
    zonaColeta.visible = false;
    zonaEntrega.visible = false;
    scene.add(zonaColeta, zonaEntrega);

    // seta 3D flutuando sobre o caminhão apontando pro alvo
    const setaGeo = new THREE.ConeGeometry(0.7, 1.6, 5);
    setaGeo.rotateX(Math.PI / 2); // aponta pra +z
    const setaMat = new THREE.MeshBasicMaterial({ color: 0xffd23f });
    const seta = new THREE.Mesh(setaGeo, setaMat);
    seta.visible = false;
    scene.add(seta);

    // linha pontilhada de rota (instâncias de bolinha achatada)
    const MAX_PONTOS = 90;
    const pontosRota = new THREE.InstancedMesh(
      new THREE.CylinderGeometry(0.35, 0.35, 0.06, 8),
      new THREE.MeshBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.8 }),
      MAX_PONTOS
    );
    pontosRota.count = 0;
    // InstancedMesh dinâmico: o boundingSphere é cacheado VAZIO no 1º render
    // (count=0) e o frustum culling apagaria a rota inteira quando a origem
    // do mundo sai da tela — culling manual desligado
    pontosRota.frustumCulled = false;
    scene.add(pontosRota);

    // grafo das ruas (cruzamentos 6×6) pra rota pontilhada
    function noMaisProximo(x, z) {
      let melhor = null;
      let dist = Infinity;
      for (let i = 0; i <= N; i++) {
        for (let j = 0; j <= N; j++) {
          const nx = ruaCentro(i);
          const nz = ruaCentro(j);
          const d = Math.abs(nx - x) + Math.abs(nz - z);
          if (d < dist) { dist = d; melhor = [i, j]; }
        }
      }
      return melhor;
    }
    function rotaBFS(deXZ, ateXZ) {
      const inicio = noMaisProximo(deXZ[0], deXZ[1]);
      const fim = noMaisProximo(ateXZ[0], ateXZ[1]);
      const chave = (n) => n[0] * 10 + n[1];
      const veio = new Map([[chave(inicio), null]]);
      const fila = [inicio];
      while (fila.length) {
        const atual = fila.shift();
        if (atual[0] === fim[0] && atual[1] === fim[1]) break;
        [[1, 0], [-1, 0], [0, 1], [0, -1]].forEach(([di, dj]) => {
          const viz = [atual[0] + di, atual[1] + dj];
          if (viz[0] < 0 || viz[0] > N || viz[1] < 0 || viz[1] > N) return;
          if (veio.has(chave(viz))) return;
          veio.set(chave(viz), atual);
          fila.push(viz);
        });
      }
      const caminho = [];
      let atual = fim;
      while (atual) {
        caminho.unshift([ruaCentro(atual[0]), ruaCentro(atual[1])]);
        atual = veio.get(chave(atual));
      }
      return [deXZ, ...caminho, ateXZ];
    }
    function atualizarRota(alvo) {
      if (!alvo) { pontosRota.count = 0; return; }
      const caminho = rotaBFS([truck.x, truck.z], [alvo.x, alvo.z]);
      const m = new THREE.Matrix4();
      let n = 0;
      for (let s = 0; s < caminho.length - 1 && n < MAX_PONTOS; s++) {
        const [ax, az] = caminho[s];
        const [bx, bz] = caminho[s + 1];
        const comp = Math.hypot(bx - ax, bz - az);
        const passos = Math.max(1, Math.floor(comp / 2.5));
        for (let p = 0; p < passos && n < MAX_PONTOS; p++) {
          const k = p / passos;
          m.makeTranslation(ax + (bx - ax) * k, 0.1, az + (bz - az) * k);
          pontosRota.setMatrixAt(n++, m);
        }
      }
      pontosRota.count = n;
      pontosRota.instanceMatrix.needsUpdate = true;
    }

    // morador que acena na entrega
    const morador = new THREE.Group();
    const corpoM = new THREE.Mesh(new THREE.CapsuleGeometry(0.4, 0.9, 3, 8), new THREE.MeshLambertMaterial({ color: 0xd94f7c }));
    corpoM.position.y = 1.1;
    const cabecaM = new THREE.Mesh(new THREE.SphereGeometry(0.35, 10, 8), new THREE.MeshLambertMaterial({ color: 0xf2c9a0 }));
    cabecaM.position.y = 2.1;
    morador.add(corpoM, cabecaM);
    morador.visible = false;
    scene.add(morador);
    let moradorAte = 0;

    // ===== Física + colisão =====
    function passoFisica(dt) {
      const vmax = estado.modo === 'facil' ? CFG.vmaxFacil : CFG.vmaxNormal;
      // aceleração: Fácil anda sozinho; Normal usa pedal
      const querAcel = estado.modo === 'facil' ? !input.re : input.acel;
      if (querAcel && !input.re) {
        truck.v = Math.min(vmax, truck.v + CFG.aceleracao * dt);
      } else if (input.re) {
        if (truck.v > 0.3) truck.v = Math.max(0, truck.v - CFG.freio * dt);
        else truck.v = Math.max(-CFG.vmaxRe, truck.v - CFG.aceleracao * dt);
      } else {
        truck.v -= truck.v * CFG.arrasto * dt;
        if (Math.abs(truck.v) < 0.05) truck.v = 0;
      }
      // esterço (escala com velocidade, aperta em alta, inverte em ré)
      const steer = (input.esq ? 1 : 0) - (input.dir ? 1 : 0);
      if (steer && Math.abs(truck.v) > 0.1) {
        truck.heading +=
          steer * CFG.esterco *
          Math.min(1, Math.abs(truck.v) / 3) *
          (1 / (1 + 0.06 * Math.abs(truck.v))) *
          Math.sign(truck.v) * dt;
      }
      truck.x += Math.sin(truck.heading) * truck.v * dt;
      truck.z += Math.cos(truck.heading) * truck.v * dt;
      // cerca da borda
      truck.x = Math.max(-MEIO + 2, Math.min(MEIO - 2, truck.x));
      truck.z = Math.max(-MEIO + 2, Math.min(MEIO - 2, truck.z));
      // colisão círculo × AABBs com slide
      const r = CFG.raioColisao;
      for (const b of aabbs) {
        const px = Math.max(b.minX, Math.min(truck.x, b.maxX));
        const pz = Math.max(b.minZ, Math.min(truck.z, b.maxZ));
        const dx = truck.x - px;
        const dz = truck.z - pz;
        const d2 = dx * dx + dz * dz;
        if (d2 < r * r) {
          const d = Math.sqrt(d2) || 0.001;
          const pen = r - d;
          truck.x += (dx / d) * pen;
          truck.z += (dz / d) * pen;
          const agora = performance.now();
          if (Math.abs(truck.v) > 2 && agora - truck.ultimaBatidaMs > CFG.batidaCooldownMs) {
            truck.ultimaBatidaMs = agora;
            truck.squashAte = agora + 90;
            truck.v *= CFG.batidaFreio;
            somBatida();
            if (estado.pedido) estado.pedido.bateu = true;
          }
        }
      }
      // visual
      truckGroup.position.set(truck.x, 0, truck.z);
      truckGroup.rotation.y = truck.heading;
      const squash = performance.now() < truck.squashAte && !MOTION_REDUZIDO ? 0.92 : 1;
      truckGroup.scale.set(2 - squash, squash, 1);
      truckGroup.scale.x = 1; // squash só vertical
      const giro = (truck.v * dt) / 0.55;
      rodas.forEach((roda) => { roda.rotation.x += giro; });
      pivosDianteiros.forEach((p) => { p.rotation.y = steer * 0.45 * Math.sign(truck.v || 1); });
    }

    // ===== Câmera follow =====
    const camAlvo = new THREE.Vector3();
    const camOlhar = new THREE.Vector3();
    let flyoverAte = 0;
    function dentroDePredio(x, z) {
      for (const b of aabbs) {
        if (x > b.minX - 0.6 && x < b.maxX + 0.6 && z > b.minZ - 0.6 && z < b.maxZ + 0.6) return true;
      }
      return false;
    }
    function passoCamera(dt) {
      const fwdX = Math.sin(truck.heading);
      const fwdZ = Math.cos(truck.heading);
      camAlvo.set(truck.x - fwdX * 10, 6, truck.z - fwdZ * 10);
      // câmera cairia dentro de um prédio? aproxima do caminhão e sobe
      if (dentroDePredio(camAlvo.x, camAlvo.z)) {
        let achou = false;
        for (let t = 0.87; t >= 0.3; t -= 0.14) {
          const x = truck.x - fwdX * 10 * t;
          const z = truck.z - fwdZ * 10 * t;
          if (!dentroDePredio(x, z)) {
            camAlvo.set(x, 6 + (1 - t) * 11, z);
            achou = true;
            break;
          }
        }
        if (!achou) camAlvo.set(truck.x, 17, truck.z); // vista de cima como último recurso
      }
      camOlhar.set(truck.x + fwdX * 3, 1.5, truck.z + fwdZ * 3);
      const agora = performance.now();
      if (agora < flyoverAte) {
        // sobrevoo de abertura: desce suavemente da vista aérea
        const k = 1 - (flyoverAte - agora) / 2000;
        camera.position.lerpVectors(new THREE.Vector3(0, 46, 46), camAlvo, k * k);
      } else {
        const k = 1 - Math.exp(-4 * dt);
        camera.position.lerp(camAlvo, k);
      }
      camera.lookAt(camOlhar);
    }

    // ===== Seta-guia + seta de borda =====
    const projV = new THREE.Vector3();
    function passoGuia(alvo, cor) {
      if (!alvo) { seta.visible = false; setaBordaEl.hidden = true; return; }
      seta.visible = true;
      setaMat.color.setHex(cor);
      const bob = MOTION_REDUZIDO ? 0 : Math.sin(performance.now() / 260) * 0.25;
      seta.position.set(truck.x, 5.4 + bob, truck.z);
      seta.rotation.y = Math.atan2(alvo.x - truck.x, alvo.z - truck.z);
      // alvo fora da tela → seta 2D na borda
      projV.set(alvo.x, 1, alvo.z).project(camera);
      const fora = projV.x < -1 || projV.x > 1 || projV.y < -1 || projV.y > 1 || projV.z > 1;
      setaBordaEl.hidden = !fora;
      if (fora) {
        const cw = cenaEl.clientWidth;
        const chh = cenaEl.clientHeight;
        const x = Math.max(0.06, Math.min(0.94, (projV.x + 1) / 2));
        const y = Math.max(0.08, Math.min(0.9, 1 - (projV.y + 1) / 2));
        setaBordaEl.style.left = x * cw - 18 + 'px';
        setaBordaEl.style.top = y * chh - 18 + 'px';
        const ang = Math.atan2(y * chh - chh / 2, x * cw - cw / 2);
        setaBordaEl.style.transform = 'rotate(' + ang + 'rad)';
        setaBordaEl.style.color = '#' + cor.toString(16).padStart(6, '0');
      }
    }

    // ===== Pedidos / coleta / entrega =====
    function zonaDe(sim) { return zonas.get(sim); }
    function alvoAtual() {
      const p = estado.pedido;
      if (!p) return null;
      if (!p.coletado) return zonaDe('D');
      // destino pendente mais próximo
      let melhor = null;
      let dist = Infinity;
      p.caixas.forEach((sim) => {
        const z = zonaDe(sim);
        const d = Math.abs(z.x - truck.x) + Math.abs(z.z - truck.z);
        if (d < dist) { dist = d; melhor = z; }
      });
      return melhor;
    }

    function caixasDoNivel() {
      if (estado.nivel >= CFG.caixas3APartirDoNivel) return 3;
      if (estado.nivel >= CFG.caixas2APartirDoNivel) return 2;
      return 1;
    }

    let ultimoDestino = null;
    function novoPedido() {
      const n = caixasDoNivel();
      const disponiveis = DESTINOS.map((d) => d.simbolo).filter((s) => s !== ultimoDestino);
      const caixas = [];
      for (let i = 0; i < n; i++) {
        caixas.push(disponiveis.splice(Math.floor(Math.random() * disponiveis.length), 1)[0]);
      }
      ultimoDestino = caixas[caixas.length - 1];
      // prazo: distância manhattan estimada da rota
      const dep = zonaDe('D');
      let dist = Math.abs(dep.x - truck.x) + Math.abs(dep.z - truck.z);
      let px = dep.x;
      let pz = dep.z;
      caixas.forEach((sim) => {
        const z = zonaDe(sim);
        dist += Math.abs(z.x - px) + Math.abs(z.z - pz);
        px = z.x; pz = z.z;
      });
      const fator = Math.max(CFG.prazoFatorMin, CFG.prazoFatorBase - CFG.prazoQuedaPorNivel * (estado.nivel - 1));
      const prazoS = Math.max(CFG.prazoMinS, (dist / CFG.prazoVelRef) * fator);
      estado.pedido = {
        caixas,
        total: n,
        coletado: false,
        bateu: false,
        prazoMs: prazoS * 1000,
        // relógio do pedido corre em TEMPO DE SIMULAÇÃO (somado no loop com o
        // mesmo dt clampado da física) — em Chromebook lento a física desacelera
        // e o prazo desacelera JUNTO; pausa congela de graça
        decorridoMs: 0,
      };
      const nomes = caixas.map((s) => POR_SIMBOLO.get(s).rotulo);
      const primeiro = POR_SIMBOLO.get(caixas[0]);
      const txt = n === 1
        ? 'Pedido! ' + primeiro.emoji + ' ' + primeiro.rotulo + ' quer 1 caixa!'
        : 'Pedido! ' + n + ' caixas: ' + nomes.join(', ') + '!';
      mostrarToast(txt, 'info', 3000);
      somPedido();
      anunciar(txt + ' Primeiro, pegue as caixas no depósito.');
      $('[data-destino-atual]').textContent = '📦 Pegue no depósito';
      zonaColeta.visible = true;
      const dep2 = zonaDe('D');
      zonaColeta.position.set(dep2.x, 0, dep2.z);
      zonaEntrega.visible = false;
      prazoWrapEl.hidden = estado.modo !== 'normal';
      estado.longeDesdeMs = 0;
    }

    function prazoRestanteMs() {
      const p = estado.pedido;
      if (!p) return 0;
      return Math.max(0, p.prazoMs - p.decorridoMs);
    }

    function tentarZona(dt) {
      const p = estado.pedido;
      if (!p) return;
      const alvo = p.coletado ? null : zonaDe('D');
      const imaRaio = estado.modo === 'facil' ? CFG.imaRaioFacil : CFG.imaRaio;
      const checar = (zona, aoEntrar) => {
        const dx = truck.x - zona.x;
        const dz = truck.z - zona.z;
        const d = Math.hypot(dx, dz);
        if (d < CFG.raioZona && Math.abs(truck.v) < CFG.vMaxColeta) {
          // ímã: puxa suavemente pro centro quando devagar e perto
          if (d > 0.3 && d < CFG.raioZona) {
            const k = Math.min(1, 3 * dt);
            truck.x -= dx * k * (d < imaRaio ? 1 : 0.4);
            truck.z -= dz * k * (d < imaRaio ? 1 : 0.4);
          }
          aoEntrar();
        }
      };
      if (!p.coletado) {
        checar(zonaDe('D'), () => coletar());
      } else {
        // qualquer destino pendente aceita
        for (const sim of p.caixas.slice()) {
          checar(zonaDe(sim), () => entregar(sim));
        }
      }
    }

    function coletar() {
      const p = estado.pedido;
      if (!p || p.coletado) return;
      p.coletado = true;
      atualizarCaixasVisiveis(p.caixas.length);
      zonaColeta.visible = false;
      zonaEntrega.visible = true;
      somColeta();
      const alvo = alvoAtual();
      const nomeAlvo = p.caixas.length === 1 ? POR_SIMBOLO.get(p.caixas[0]).nome : p.caixas.length + ' lugares';
      mostrarToast('📦 Caixa a bordo! Leve até ' + (p.caixas.length === 1 ? nomeAlvo : 'as lojas') + '!', 'ok', 2200);
      anunciar('Caixa a bordo! Siga a seta verde.');
      $('[data-destino-atual]').textContent = '🏪 Entregue: ' + p.caixas.map((s) => POR_SIMBOLO.get(s).emoji + ' ' + POR_SIMBOLO.get(s).rotulo).join(' · ');
    }

    function entregar(sim) {
      const p = estado.pedido;
      const idx = p.caixas.indexOf(sim);
      if (idx === -1) return;
      p.caixas.splice(idx, 1);
      atualizarCaixasVisiveis(p.caixas.length);
      const destino = POR_SIMBOLO.get(sim);
      const zona = zonaDe(sim);
      estado.pontos += CFG.pontosPorCaixa;
      estado.entregasTotais++;
      popHud('[data-pontos]', estado.pontos);
      somEntrega();
      confete();
      // morador acena
      morador.position.set(zona.x + 2, 0, zona.z - 3);
      morador.visible = true;
      moradorAte = performance.now() + 1200;
      mostrarToast('🎉 ' + elogio() + ' +' + CFG.pontosPorCaixa, 'ok', 2000);
      anunciar('Entregue n' + destino.nome + '! Mais ' + CFG.pontosPorCaixa + ' pontos.');
      if (p.caixas.length === 0) {
        concluirPedido();
      } else {
        $('[data-destino-atual]').textContent = '🏪 Entregue: ' + p.caixas.map((s) => POR_SIMBOLO.get(s).emoji + ' ' + POR_SIMBOLO.get(s).rotulo).join(' · ');
      }
    }

    function concluirPedido() {
      const p = estado.pedido;
      let extra = 0;
      const restMs = prazoRestanteMs();
      if (estado.modo === 'normal') {
        if (restMs > 0) {
          extra += Math.min(CFG.bonusTempoTeto, Math.round((restMs / 1000) * CFG.bonusTempoPorS));
        } else {
          estado.vidas--;
          atualizarVidas(false);
          somUfa();
          mostrarToast('⏰ Ufa, chegou! Mas o relógio estourou…', 'info', 2200);
        }
      }
      if (!p.bateu) extra += CFG.bonusLimpa;
      extra += (p.total - 1) * CFG.bonusCaixaExtra;
      if (extra > 0) {
        estado.pontos += extra;
        popHud('[data-pontos]', estado.pontos);
        mostrarToast('⭐ Bônus +' + extra + '!', 'ok', 1600);
      }
      estado.pedido = null;
      estado.pedidosCompletos++;
      zonaEntrega.visible = false;
      prazoWrapEl.hidden = true;
      $('[data-destino-atual]').textContent = '';
      if (estado.modo === 'normal' && estado.vidas <= 0) {
        // timer guardado + com guarda: não pode atravessar recomeço/partida nova
        clearTimeout(fimTimer);
        fimTimer = setTimeout(() => {
          if (estado.fase !== 'jogando' && estado.fase !== 'pausado') return;
          pausaModal.hidden = true;
          fimDeTurno();
        }, 900);
        return;
      }
      // subir de nível?
      if (estado.pedidosCompletos % CFG.pedidosPorNivel === 0 && estado.nivel < CFG.nivelMax) {
        estado.nivel++;
        popHud('[data-nivel]', estado.nivel);
        aplicarSkin(estado.nivel);
        somNivel();
        mostrarBanner('Nível ' + estado.nivel + '! 🎉', estado.nivel % 2 === 1 ? 'Caminhão novo na garagem! 🚚' : '');
        anunciar('Nível ' + estado.nivel + '!');
      }
      clearTimeout(respiroTimer);
      respiroTimer = setTimeout(() => {
        if (estado.fase === 'jogando' && !estado.pedido) novoPedido();
      }, CFG.respiroEntrePedidosMs);
    }

    let bannerTimer = null;
    function mostrarBanner(titulo, sub) {
      $('[data-banner-titulo]').textContent = titulo;
      $('[data-banner-sub]').textContent = sub || '';
      bannerEl.hidden = false;
      bannerEl.classList.remove('show');
      void bannerEl.offsetWidth;
      bannerEl.classList.add('show');
      clearTimeout(bannerTimer);
      bannerTimer = setTimeout(() => { bannerEl.hidden = true; }, 2200);
    }

    // confete DOM (14 quads, pool descartável)
    function confete() {
      if (MOTION_REDUZIDO) return;
      const cores = ['#22e0ff', '#2ee08a', '#ffd23f', '#ff5c8a'];
      for (let i = 0; i < 14; i++) {
        const p = document.createElement('span');
        p.style.cssText =
          'position:absolute;z-index:44;width:9px;height:9px;border-radius:2px;pointer-events:none;' +
          'left:' + (38 + Math.random() * 24) + '%;top:26%;background:' + cores[i % 4] + ';' +
          'transition:transform 0.9s ease-out, opacity 0.9s ease-out;';
        cenaEl.appendChild(p);
        requestAnimationFrame(() => {
          p.style.transform = 'translate(' + (Math.random() * 240 - 120) + 'px,' + (140 + Math.random() * 160) + 'px) rotate(' + (Math.random() * 520 - 260) + 'deg)';
          p.style.opacity = '0';
        });
        setTimeout(() => p.remove(), 950);
      }
    }

    // ===== Fluxo do jogo =====
    let fimTimer = 0;
    let respiroTimer = 0;
    function limparTimersPartida() {
      clearTimeout(fimTimer);
      clearTimeout(respiroTimer);
    }
    function soltarInputs() {
      input.esq = input.dir = input.acel = input.re = false;
      document.querySelectorAll('.ctl.on').forEach((b) => b.classList.remove('on'));
    }
    function comecar(modo) {
      initAudio();
      if (actx && actx.state === 'suspended') actx.resume();
      limparTimersPartida();
      soltarInputs();
      estado.modo = modo;
      estado.fase = 'jogando';
      estado.pontos = 0;
      estado.nivel = 1;
      estado.pedidosCompletos = 0;
      estado.entregasTotais = 0;
      estado.pedido = null;
      estado.primeiroInput = false;
      estado.vidas = modo === 'normal' ? CFG.coracoes : 0;
      vidasWrapEl.hidden = modo !== 'normal';
      if (modo === 'normal') atualizarVidas(false);
      popHud('[data-pontos]', 0);
      popHud('[data-nivel]', 1);
      atualizarCaixasVisiveis(0);
      aplicarSkin(1);
      // nasce uma rua ao sul do depósito, já olhando pra ele
      truck.x = 0; truck.z = 42; truck.heading = Math.PI; truck.v = 0;
      introModal.hidden = true;
      $('[data-pause]').hidden = false;
      // touch: mostra controles (sempre — teclado também funciona)
      controlesEl.hidden = false;
      $('[data-ctl="acel"]').hidden = modo === 'facil';
      fantasmaEl.hidden = false;
      $('[data-fantasma-txt]').textContent = modo === 'facil' ? '◀ ▶ pra virar o caminhão!' : '▲ acelera · ◀ ▶ vira';
      medir();
      if (!MOTION_REDUZIDO) flyoverAte = performance.now() + 2000;
      novoPedido();
      retomarLoop();
      anunciar(modo === 'facil'
        ? 'Modo fácil: o caminhão anda sozinho, você vira com as setas.'
        : 'Modo normal: acelere com a seta pra cima e corra contra o tempo!');
    }
    document.querySelectorAll('[data-modo]').forEach((btn) => {
      btn.addEventListener('click', () => comecar(btn.dataset.modo));
    });

    function fimDeTurno() {
      estado.fase = 'fim';
      limparTimersPartida();
      soltarInputs();
      pararLoop();
      somFim();
      if (actx) actx.suspend(); // motor/áudio param de processar (bateria!)
      $('[data-fim-msg]').textContent =
        'Você entregou ' + estado.entregasTotais + (estado.entregasTotais === 1 ? ' caixa' : ' caixas') +
        ' e chegou ao nível ' + estado.nivel + '! A cidade agradece! 🏙️';
      $('[data-fim-score]').textContent = String(estado.pontos);
      $('[data-fim-detalhe]').textContent = estado.modo === 'normal'
        ? 'Grave seu nome no ranking dos caminhoneiros!'
        : 'No modo Normal você corre contra o tempo e vale ranking!';
      const gravar = fimModal.querySelector('[data-gravar-nome]');
      gravar.hidden = estado.modo !== 'normal' || estado.pontos <= 0;
      fimModal.hidden = false;
      setTimeout(() => (gravar.hidden ? $('[data-replay]') : gravar).focus(), 60);
      anunciar('Fim do turno! Você fez ' + estado.pontos + ' pontos.');
    }

    function reiniciar() {
      estado.fase = 'inicio';
      estado.modo = null;
      estado.pedido = null;
      limparTimersPartida();
      soltarInputs();
      pararLoop();
      if (actx) actx.suspend();
      [pausaModal, fimModal, entradaModal, recordesModal].forEach((m) => { m.hidden = true; });
      controlesEl.hidden = true;
      fantasmaEl.hidden = true;
      $('[data-pause]').hidden = true;
      prazoWrapEl.hidden = true;
      vidasWrapEl.hidden = true;
      resgateBtn.hidden = true;
      setaBordaEl.hidden = true;
      zonaColeta.visible = false;
      zonaEntrega.visible = false;
      seta.visible = false;
      pontosRota.count = 0;
      $('[data-destino-atual]').textContent = '';
      introModal.hidden = false;
      renderer.render(scene, camera);
      setTimeout(() => $('[data-modo="facil"]').focus(), 60);
    }
    $('[data-replay]').addEventListener('click', reiniciar);

    // ===== Pausa =====
    function pausar() {
      if (estado.fase !== 'jogando') return;
      estado.fase = 'pausado';
      soltarInputs(); // keyup perdido no alt-tab não pode deixar tecla presa
      pararLoop();
      renderer.render(scene, camera); // 1 frame estático
      if (motorGain && actx) motorGain.gain.setTargetAtTime(0, actx.currentTime, 0.05);
      pausaModal.hidden = false;
      setTimeout(() => $('[data-continuar]').focus(), 60);
      anunciar('Jogo pausado.');
    }
    function continuarJogo() {
      if (estado.fase !== 'pausado') return;
      pausaModal.hidden = true;
      estado.fase = 'jogando';
      medir();
      retomarLoop();
      // pausou bem no respiro entre pedidos? agenda o próximo de novo
      if (!estado.pedido) {
        clearTimeout(respiroTimer);
        respiroTimer = setTimeout(() => { if (estado.fase === 'jogando' && !estado.pedido) novoPedido(); }, 600);
      }
      anunciar('Voltando pra estrada!');
    }
    $('[data-pause]').addEventListener('click', pausar);
    $('[data-continuar]').addEventListener('click', continuarJogo);
    $('[data-encerrar]').addEventListener('click', () => { pausaModal.hidden = true; fimDeTurno(); });
    $('[data-recomecar]').addEventListener('click', () => { pausaModal.hidden = true; reiniciar(); });
    document.addEventListener('visibilitychange', () => {
      if (document.hidden && estado.fase === 'jogando') pausar();
    });
    // janela perdeu o foco (popup, outra janela por cima): solta as teclas
    window.addEventListener('blur', soltarInputs);

    // resgate: teleporta pra rua mais próxima olhando pro alvo
    resgateBtn.addEventListener('click', () => {
      const no = noMaisProximo(truck.x, truck.z);
      truck.x = ruaCentro(no[0]);
      truck.z = ruaCentro(no[1]);
      truck.v = 0;
      const alvo = alvoAtual();
      if (alvo) truck.heading = Math.atan2(alvo.x - truck.x, alvo.z - truck.z);
      resgateBtn.hidden = true;
      estado.longeDesdeMs = 0;
      anunciar('De volta pra pista!');
    });

    // ===== Entrada: teclado =====
    const TECLAS = {
      ArrowLeft: 'esq', a: 'esq', A: 'esq',
      ArrowRight: 'dir', d: 'dir', D: 'dir',
      ArrowUp: 'acel', w: 'acel', W: 'acel',
      ArrowDown: 're', s: 're', S: 're',
    };
    window.addEventListener('keydown', (e) => {
      if (e.repeat || e.ctrlKey || e.altKey || e.metaKey) return;
      if (e.key === 'Escape') {
        if (estado.fase === 'jogando') { e.preventDefault(); pausar(); }
        else if (estado.fase === 'pausado') { e.preventDefault(); continuarJogo(); }
        return;
      }
      if (estado.fase === 'entrada') {
        const l = e.key.length === 1 ? e.key.toUpperCase().normalize('NFD').replace(/[̀-ͯ]/g, '') : '';
        if (/^[A-Z]$/.test(l)) { e.preventDefault(); digitarLetra(l); }
        else if (e.key === 'Backspace') { e.preventDefault(); apagarLetra(); }
        else if (e.key === 'Enter') {
          // foco em QUALQUER botão do modal (letra, ⌫, voltar): deixa o clique nativo agir
          if (document.activeElement && document.activeElement.closest && document.activeElement.closest('[data-entrada]')) return;
          e.preventDefault();
          confirmarEntrada();
        }
        return;
      }
      if (estado.fase !== 'jogando') return;
      if (e.key === ' ') { e.preventDefault(); somBuzina(); return; }
      const acao = TECLAS[e.key];
      if (acao) {
        e.preventDefault();
        input[acao] = true;
        aoPrimeiroInput();
      }
    });
    window.addEventListener('keyup', (e) => {
      const acao = TECLAS[e.key];
      if (acao) input[acao] = false;
    });

    // ===== Entrada: touch (Pointer Events, multi-touch) =====
    document.querySelectorAll('.ctl').forEach((btn) => {
      const acao = btn.dataset.ctl;
      const liga = (e) => {
        e.preventDefault();
        btn.setPointerCapture && btn.setPointerCapture(e.pointerId);
        if (acao === 'buzina') { somBuzina(); return; }
        input[acao] = true;
        btn.classList.add('on');
        aoPrimeiroInput();
      };
      const desliga = () => {
        if (acao !== 'buzina') input[acao] = false;
        btn.classList.remove('on');
      };
      btn.addEventListener('pointerdown', liga);
      btn.addEventListener('pointerup', desliga);
      btn.addEventListener('pointercancel', desliga);
      btn.addEventListener('lostpointercapture', desliga);
    });
    function aoPrimeiroInput() {
      if (estado.primeiroInput) return;
      estado.primeiroInput = true;
      fantasmaEl.hidden = true;
    }

    // ===== Ranking (padrão do site) =====
    function lerRanking() {
      try { return JSON.parse(localStorage.getItem(RANKING_KEY) || '[]'); }
      catch (_) { return []; }
    }
    function salvarRanking(lista) {
      try { localStorage.setItem(RANKING_KEY, JSON.stringify(lista)); } catch (_) {}
    }
    function fetchRanking(opts) {
      const ctl = new AbortController();
      const timer = setTimeout(() => ctl.abort(), 4000);
      const url = opts ? API_RANKING : API_RANKING + '?jogo=' + JOGO_ID;
      return fetch(url, Object.assign({ signal: ctl.signal }, opts || {}))
        .then((r) => (r.ok ? r.json() : null))
        .then((lista) => (Array.isArray(lista) ? lista : null))
        .catch(() => null)
        .finally(() => clearTimeout(timer));
    }
    function enviarRankingOnline(entrada) {
      return fetchRanking({
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ jogo: JOGO_ID, nome: entrada.nome, pontos: entrada.pontos, nivel: entrada.nivel }),
      });
    }
    function indiceDe(lista, entrada) {
      return lista.findIndex((r) => r.nome === entrada.nome && r.pontos === entrada.pontos && r.data === entrada.data);
    }
    function renderRecordes(lista, destaque, consulta, fonte) {
      const tabela = $('[data-tabela]');
      tabela.innerHTML = '';
      $('[data-recordes-vazio]').hidden = lista.length > 0;
      lista.forEach((r, i) => {
        const li = document.createElement('li');
        if (i === destaque) li.className = 'novo';
        li.innerHTML =
          '<span class="pos">' + (i + 1) + 'º</span>' +
          '<span class="nome">' + r.nome + '</span>' +
          '<span class="det">nível ' + r.nivel + '</span>' +
          '<span class="pts">' + r.pontos + '</span>';
        tabela.appendChild(li);
      });
      const fonteEl = $('[data-recordes-fonte]');
      if (fonte === 'online') fonteEl.textContent = '🌐 Ranking online — vale pra turma toda!';
      else if (fonte === 'offline') fonteEl.textContent = '📴 Sem internet agora: mostrando o ranking deste aparelho.';
      else fonteEl.textContent = 'Buscando o ranking online…';
      $('[data-voltar-intro]').hidden = !consulta;
      $('[data-recordes-replay]').hidden = consulta;
    }
    function abrirRecordes(consulta, entrada) {
      estado.fase = 'recordes';
      const local = lerRanking();
      const idxLocal = entrada ? indiceDe(local, entrada) : -1;
      renderRecordes(local, idxLocal, consulta, 'buscando');
      recordesModal.hidden = false;
      setTimeout(() => (consulta ? $('[data-voltar-intro]') : $('[data-recordes-replay]')).focus(), 60);
      const pedido = entrada ? enviarRankingOnline(entrada) : fetchRanking(null);
      pedido.then((listaOnline) => {
        if (estado.fase !== 'recordes') return;
        if (listaOnline) {
          salvarRanking(listaOnline);
          renderRecordes(listaOnline, entrada ? indiceDe(listaOnline, entrada) : -1, consulta, 'online');
        } else {
          renderRecordes(local, idxLocal, consulta, 'offline');
        }
      });
    }

    // entrada arcade (nome)
    let entradaCtx = null;
    function abrirEntrada(ctx) {
      entradaCtx = Object.assign({ valor: '' }, ctx);
      estado.fase = 'entrada';
      fimModal.hidden = true;
      atualizarSlots();
      entradaModal.hidden = false;
      setTimeout(() => $('[data-tecla-nome="A"]').focus(), 60);
      anunciar('Digite seu nome usando as letras da tela.');
    }
    function atualizarSlots() {
      const slots = [];
      for (let i = 0; i < CFG.nomeMax; i++) slots.push(entradaCtx.valor[i] || '_');
      $('[data-entrada-slots]').textContent = slots.join(' ');
    }
    function digitarLetra(l) {
      if (estado.fase !== 'entrada' || entradaCtx.valor.length >= CFG.nomeMax) return;
      entradaCtx.valor += l;
      somColeta();
      atualizarSlots();
    }
    function apagarLetra() {
      if (estado.fase !== 'entrada' || !entradaCtx.valor) return;
      entradaCtx.valor = entradaCtx.valor.slice(0, -1);
      atualizarSlots();
    }
    function confirmarEntrada() {
      if (estado.fase !== 'entrada') return;
      if (entradaCtx.valor.length < CFG.nomeMin) {
        mostrarToast('Escreva pelo menos ' + CFG.nomeMin + ' letras!', 'info', 1800);
        return;
      }
      entradaModal.hidden = true;
      const entrada = {
        nome: entradaCtx.valor.toUpperCase(),
        pontos: estado.pontos,
        nivel: estado.nivel,
        data: new Date().toISOString().slice(0, 10),
      };
      const local = lerRanking();
      local.push(entrada);
      local.sort((a, b) => b.pontos - a.pontos);
      salvarRanking(local.slice(0, CFG.rankingMax));
      somNivel();
      abrirRecordes(false, entrada);
    }
    document.querySelectorAll('[data-tecla-nome]').forEach((btn) => {
      btn.addEventListener('click', () => digitarLetra(btn.dataset.teclaNome));
    });
    $('[data-nome-apagar]').addEventListener('click', apagarLetra);
    $('[data-nome-ok]').addEventListener('click', confirmarEntrada);
    $('[data-entrada-voltar]').addEventListener('click', () => {
      entradaModal.hidden = true;
      estado.fase = 'fim';
      fimModal.hidden = false;
    });
    fimModal.querySelector('[data-gravar-nome]').addEventListener('click', () => abrirEntrada({}));
    $('[data-ver-recordes]').addEventListener('click', () => {
      introModal.hidden = true;
      abrirRecordes(true, null);
    });
    $('[data-voltar-intro]').addEventListener('click', () => {
      recordesModal.hidden = true;
      estado.fase = 'inicio';
      introModal.hidden = false;
      setTimeout(() => $('[data-modo="facil"]').focus(), 60);
    });
    $('[data-recordes-replay]').addEventListener('click', () => {
      recordesModal.hidden = true;
      reiniciar();
    });

    // ===== Loop principal =====
    let rafId = 0;
    let ultimoTs = 0;
    let dtMedio = 16; // média móvel exponencial do frame time
    let degrade = 0;  // 0 = cheio, 1 = pixelRatio 0.85, 2 = 0.7
    let rotaTimer = 0;
    let rotaAlvoKey = '';
    function retomarLoop() {
      if (!rafId) {
        ultimoTs = 0;
        rafId = requestAnimationFrame(loop);
      }
    }
    function pararLoop() {
      cancelAnimationFrame(rafId);
      rafId = 0;
      if (motorGain && actx) motorGain.gain.setTargetAtTime(0, actx.currentTime, 0.05);
    }
    function loop(ts) {
      rafId = requestAnimationFrame(loop);
      if (!ultimoTs) { ultimoTs = ts; return; }
      const dtMs = ts - ultimoTs;
      ultimoTs = ts;
      const dt = Math.min(dtMs / 1000, 0.05);
      if (estado.fase !== 'jogando') return;

      // auto-degrade por média móvel (jank intermitente também conta):
      // média > 45ms sustentada → reduz pixelRatio em 2 degraus
      dtMedio = dtMedio * 0.95 + dtMs * 0.05;
      if (dtMedio > 45 && degrade < 2) {
        degrade++;
        dtMedio = 16; // re-mede depois do degrau
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, degrade === 1 ? 0.85 : 0.7));
        medir();
      }

      passoFisica(dt);
      tentarZona(dt);
      passoCamera(dt);
      atualizarMotor(dt);

      const p = estado.pedido;
      // relógio do pedido em tempo de simulação (justo em FPS baixo)
      if (p) p.decorridoMs += dt * 1000;
      const alvo = alvoAtual();
      passoGuia(alvo, p && p.coletado ? 0x2ee08a : 0xffd23f);
      // zona de entrega segue o destino mais próximo pendente
      if (p && p.coletado && alvo) zonaEntrega.position.set(alvo.x, 0, alvo.z);
      // anel pulsa
      if (!MOTION_REDUZIDO) {
        const puls = 1 + Math.sin(ts / 300) * 0.08;
        zonaColeta.children[0].scale.set(puls, puls, 1);
        zonaEntrega.children[0].scale.set(puls, puls, 1);
      }
      // linha pontilhada: Fácil sempre; 1º pedido da partida; Normal como resgate
      rotaTimer -= dtMs;
      const mostrarRota = alvo && (estado.modo === 'facil' || estado.pedidosCompletos === 0 || estado.longeDesdeMs > 20000);
      if (mostrarRota) {
        const chave = alvo.x + ',' + alvo.z;
        if (chave !== rotaAlvoKey) rotaTimer = 0; // alvo mudou (coletou/entregou): rota na hora
        if (rotaTimer <= 0) {
          atualizarRota(alvo);
          rotaAlvoKey = chave;
          rotaTimer = 900;
        }
      } else if (pontosRota.count) {
        pontosRota.count = 0;
        rotaAlvoKey = '';
      }
      // resgate: longe do alvo e sem progresso
      if (alvo) {
        const d = Math.hypot(alvo.x - truck.x, alvo.z - truck.z);
        if (d > 55) {
          estado.longeDesdeMs += dtMs;
          if (estado.longeDesdeMs > 9000) resgateBtn.hidden = false;
        } else {
          estado.longeDesdeMs = 0;
          resgateBtn.hidden = true;
        }
      }
      // prazo (Normal)
      if (estado.modo === 'normal' && p) {
        const rest = prazoRestanteMs();
        const frac = Math.max(0, Math.min(1, rest / p.prazoMs));
        prazoFillEl.style.transform = 'scaleX(' + frac + ')';
        prazoFillEl.className = 'prazo__fill' + (frac < 0.25 ? ' urgente' : frac < 0.55 ? ' ambar' : '');
      }
      // morador acenando
      if (morador.visible) {
        if (performance.now() > moradorAte) morador.visible = false;
        else if (!MOTION_REDUZIDO) morador.rotation.z = Math.sin(ts / 90) * 0.18;
      }

      renderer.render(scene, camera);
    }

    // ===== Boot =====
    document.body.classList.add('is-game');
    medir();
    renderer.render(scene, camera);
    setTimeout(() => $('[data-modo="facil"]').focus(), 60);

    // handle de depuração/testes (posição, estado e zonas — sem dados sensíveis)
    window.__et = { truck, estado, input, zonas, renderer };
  </script>
</Layout>
