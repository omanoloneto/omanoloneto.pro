---
import Layout from '../../../layouts/Layout.astro';
import { blocos, itens, materiais, config, receitas } from '../../../data/mineblocks';

const dadosJson = JSON.stringify({ blocos, itens, materiais, config, receitas });

const title = 'MineBlocks — construa seu mundo de blocos em 3D! | Manolo Neto';
const description =
  'Sandbox de blocos 3D para crianças, direto no navegador: explore uma ilha, quebre e coloque blocos, construa casas e castelos. O mundo fica salvo online com nome e senha — continue de qualquer computador!';
---

<Layout title={title} description={description}>
  <script type="application/json" data-dados set:html={dadosJson}></script>

  <main id="conteudo" class="mc" data-game role="application" aria-label="MineBlocks: mundo de blocos 3D pra construir e explorar">
    <div class="cena" data-cena>

      <div class="hud-pills">
        <div class="pill pill--nome" data-nome-mundo></div>
        <span class="salvando" data-salvando hidden></span>
        <span class="sala-chip" data-sala-chip hidden></span>
      </div>
      <div class="reticula" data-reticula aria-hidden="true" hidden>+</div>
      <div class="agua-overlay" data-agua aria-hidden="true" hidden></div>
      <div class="susto" data-susto aria-hidden="true"></div>
      <div class="fome-dano" data-fome-dano aria-hidden="true"></div>
      <div class="fome" data-fome role="status" aria-label="Fome" hidden></div>
      <canvas class="minimapa" data-minimapa width="132" height="132" aria-label="Minimapa — toque pra abrir o mapa grande" hidden></canvas>

      <nav class="hotbar" data-hotbar aria-label="Blocos pra construir" hidden></nav>
      <div class="balao" data-balao aria-hidden="true"></div>
      <button class="craft-btn" type="button" data-craft-btn aria-expanded="false" aria-label="Abrir o inventário (tecla E)" hidden>🎒</button>

      <div class="hud-cmd" aria-hidden="true">
        <span><b>E</b> abrir mochila</span>
        <span><b>M</b> ver mapa</span>
        <span><b>TAB</b> ver jogadores</span>
      </div>

      <div class="tab-jogadores" data-tab-jogadores aria-live="polite" hidden></div>

      <div class="inv" data-inv hidden>
        <div class="inv__caixa" role="dialog" aria-modal="false" aria-label="Inventário e fabricação">
          <div class="inv__topo">
            <span>🎒 Inventário</span>
            <button class="inv__fechar" type="button" data-inv-fechar aria-label="Fechar o inventário">✖</button>
          </div>
          <div class="inv__grade" data-inv-grade></div>
          <p class="craft__titulo">🛠️ Fabricar</p>
          <div class="craft__lista" data-craft-painel></div>
        </div>
      </div>

      <div class="inv bau" data-bau hidden>
        <div class="inv__caixa" role="dialog" aria-modal="false" aria-label="Baú">
          <div class="inv__topo">
            <span data-bau-titulo>Baú</span>
            <button class="inv__fechar" type="button" data-bau-fechar aria-label="Fechar o baú">✖</button>
          </div>
          <button class="bau__trava" type="button" data-bau-trava aria-pressed="false" hidden>🔒 Só eu abro</button>
          <p class="bau__rotulo">📦 Dentro do baú <small>(clique pra pegar)</small></p>
          <div class="bau__grade" data-bau-conteudo></div>
          <p class="bau__rotulo">🎒 Seus itens <small>(clique pra guardar)</small></p>
          <div class="bau__grade" data-bau-inv></div>
        </div>
      </div>

      <div class="inv mapa" data-mapa hidden>
        <div class="inv__caixa inv__caixa--mapa" role="dialog" aria-modal="false" aria-label="Mapa do mundo">
          <div class="inv__topo">
            <span>🗺️ Mapa do mundo</span>
            <button class="inv__fechar" type="button" data-mapa-fechar aria-label="Fechar o mapa">✖</button>
          </div>
          <canvas class="mapa__tela" data-mapa-canvas width="384" height="384"></canvas>
          <p class="mapa__dica">O triângulo amarelo é você · 🏠 é a sua casa · M fecha</p>
        </div>
      </div>

      <div class="inv" data-fornalha hidden>
        <div class="inv__caixa" role="dialog" aria-modal="false" aria-label="Fornalha">
          <div class="inv__topo">
            <span>🔥 Fornalha</span>
            <button class="inv__fechar" type="button" data-fornalha-fechar aria-label="Fechar a fornalha">✖</button>
          </div>
          <p class="craft__titulo">Coisas que precisam de fogo</p>
          <div class="craft__lista" data-fornalha-painel></div>
        </div>
      </div>

      <div class="inv" data-maquina hidden>
        <div class="inv__caixa" role="dialog" aria-modal="false" aria-label="Máquina de vendas">
          <div class="inv__topo">
            <span>🎰 Máquina de Vendas</span>
            <button class="inv__fechar" type="button" data-maquina-fechar aria-label="Fechar a máquina">✖</button>
          </div>
          <p class="craft__titulo">Venda suas barras e ganhe moedas! Você tem <b data-maquina-saldo>0</b> 🪙</p>
          <div class="craft__lista" data-maquina-painel></div>
        </div>
      </div>

      <div class="inv" data-loja hidden>
        <div class="inv__caixa" role="dialog" aria-modal="false" aria-label="Loja do Yujack">
          <div class="inv__topo">
            <span>🦫 Loja do Yujack</span>
            <button class="inv__fechar" type="button" data-loja-fechar aria-label="Fechar a loja">✖</button>
          </div>
          <p class="craft__titulo">Móveis pra sua casa! Você tem <b data-loja-saldo>0</b> 🪙</p>
          <div class="craft__lista" data-loja-painel></div>
        </div>
      </div>

      <div class="inv" data-placa-form hidden>
        <div class="inv__caixa inv__caixa--mini" role="dialog" aria-modal="true" aria-label="Escrever na placa">
          <div class="inv__topo"><span>📜 Escreva na placa</span></div>
          <input class="placa__input" data-placa-input type="text" maxlength="48" autocomplete="off" spellcheck="false" placeholder="ex: Casa do Léo!" />
          <div class="placa__botoes">
            <button class="botao botao--go" type="button" data-placa-ok>✅ Pôr a placa</button>
            <button class="botao botao--sec botao--mini" type="button" data-placa-cancelar>cancelar</button>
          </div>
        </div>
      </div>

      <div class="controles" data-controles hidden>
        <div class="joy" data-joystick aria-label="Andar">
          <div class="joy__pino" data-joystick-pino></div>
        </div>
        <button class="ctl ctl--quebrar" type="button" data-btn-quebrar aria-label="Segurar pra quebrar o bloco na mira">⛏️</button>
        <button class="ctl ctl--pulo" type="button" data-btn-pulo aria-label="Pular">⬆️</button>
      </div>

      <div class="fantasma" data-fantasma hidden>
        <span class="fantasma__desktop">Clique na tela pra olhar · W A S D anda · espaço pula · SEGURE o clique pra quebrar · botão direito coloca · E abre o inventário</span>
        <span class="fantasma__touch">Alavanca anda · arraste pra olhar · SEGURE ⛏️ pra quebrar · toque na tela coloca</span>
      </div>

      <div class="toast" data-toast aria-live="polite" hidden></div>
    </div>

    <p class="sr-only" data-anuncio aria-live="assertive"></p>

    <div class="gerando" data-gerando hidden>
      <div class="gerando__caixa">
        <span class="gerando__cubo" aria-hidden="true"></span>
        <p>🌱 Criando seu mundo…</p>
      </div>
    </div>

    <div class="modal" data-inicio>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="inicio-title">
        <div class="placa__topo" id="inicio-title">🧱 MineBlocks</div>
        <div class="placa__corpo">
          <form data-form-jogar>
            <label class="campo">
              <span>Seu nome</span>
              <input data-campo-apelido type="text" maxlength="10" autocomplete="off" autocapitalize="characters" spellcheck="false" placeholder="ex: LEO" required />
            </label>
            <button class="botao botao--aleatorio" type="submit">▶ Jogar agora</button>
            <p class="aviso-senha">Seu mundo ganha um código de 5 letrinhas — anota ele pra voltar depois ou chamar amigos!</p>
          </form>
          <p class="divisor"><span>— ou —</span></p>
          <form data-form-entrar>
            <label class="campo">
              <span>Código do mundo <small>(5 letras e números)</small></span>
              <input data-campo-codigo class="campo--codigo" type="text" autocomplete="off" autocapitalize="characters" spellcheck="false" placeholder="ex: K7Q2X" required />
            </label>
            <button class="botao botao--go" type="submit">🌍 Entrar nesse mundo</button>
          </form>
          <p class="erro" data-erro-inicio role="alert" hidden></p>
          <a class="voltar" href="/class/games/" data-voltar-jogos>← voltar pros jogos</a>
        </div>
      </div>
    </div>

    <div class="modal" data-pausa hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="pausa-title">
        <div class="placa__topo" id="pausa-title">⏸ Pausa</div>
        <div class="placa__corpo center">
          <div class="pausa-acoes">
            <button class="botao botao--go" type="button" data-continuar>▶ Continuar</button>
            <button class="botao botao--sec" type="button" data-salvar-agora>💾 Salvar agora</button>
            <button class="botao botao--sec" type="button" data-sair>🚪 Salvar e sair</button>
          </div>
          <div class="sala" data-sala-secao>
            <div data-sala-info hidden>
              <p class="sala__chamada">Esse é o código do mundo — fala pros amigos entrarem (ou anota pra voltar)!</p>
              <div class="sala__codigo" data-sala-codigo></div>
              <p class="sala__quem" data-sala-lista></p>
            </div>
          </div>
          <p class="aviso" data-pausa-aviso>Relaxa: o mundo se salva sozinho de tempos em tempos. 😉</p>
        </div>
      </div>
    </div>

    <div class="hud-botoes">
      <button class="hud__mute" type="button" data-pause aria-label="Pausar o jogo" hidden>⏸</button>
      <button class="hud__mute" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som" hidden>
        <span data-mute-icon>🔊</span>
      </button>
    </div>
  </main>

  <style is:global>
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-Regular.ttf') format('truetype');
      font-weight: 400;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-SemiBold.ttf') format('truetype');
      font-weight: 600;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-ExtraBold.ttf') format('truetype');
      font-weight: 800;
      font-display: swap;
    }

    body.is-game { background: #87c6ea; overflow: hidden; position: fixed; inset: 0; width: 100%; touch-action: none; }
    body.is-game::before { display: none !important; }

    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
    }

    .mc {
      position: fixed;
      inset: 0;
      overflow: clip;
      font-family: 'Oxanium', Verdana, Tahoma, 'Segoe UI', Geneva, sans-serif;
      user-select: none;
      -webkit-user-select: none;
      color: var(--texto);
      display: flex;
      flex-direction: column;
      --verde: #2ee08a;
      --amarelo: #ffd23f;
      --quente: #ff5c39;
      --texto: #eaf6ff;
      overscroll-behavior: none;
    }

    .hud-pills {
      position: absolute;
      top: max(8px, env(safe-area-inset-top));
      left: max(10px, env(safe-area-inset-left));
      right: 118px;
      z-index: 30; pointer-events: none;
      display: flex; flex-wrap: wrap; align-items: center; gap: 6px;
    }
    .pill {
      padding: 5px 12px; border-radius: 999px;
      background: rgba(14, 26, 20, 0.6); border: 1px solid rgba(123, 182, 97, 0.45);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    .pill--nome { font-weight: 700; font-size: 0.95rem; }
    .hud-botoes {
      position: fixed;
      top: max(8px, env(safe-area-inset-top));
      right: max(10px, env(safe-area-inset-right));
      z-index: 51; display: flex; gap: 8px;
    }
    .hud__mute {
      width: 46px; height: 46px; border-radius: 12px; cursor: pointer;
      border: 1px solid rgba(123, 182, 97, 0.55); background: rgba(14, 26, 20, 0.55);
      font-size: 1.15rem; display: grid; place-items: center; color: var(--texto);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    .hud__mute[hidden] { display: none; }
    .salvando {
      font-size: 0.82rem; font-weight: 600; opacity: 0.9;
      padding: 3px 10px; border-radius: 999px;
      background: rgba(14, 26, 20, 0.55); border: 1px solid rgba(123, 182, 97, 0.4);
    }
    .salvando[hidden] { display: none; }

    .cena { position: relative; z-index: 10; flex: 1; min-height: 0; }
    .cena canvas { display: block; width: 100%; height: 100%; touch-action: none; }

    .reticula {
      position: absolute; left: 50%; top: 50%; z-index: 20;
      transform: translate(-50%, -50%);
      font-size: 1.6rem; font-weight: 400; color: #fff;
      mix-blend-mode: difference;
      pointer-events: none;
      line-height: 1;
    }
    .reticula[hidden] { display: none; }

    .agua-overlay {
      position: absolute; inset: 0; z-index: 15;
      background: rgba(30, 90, 200, 0.34);
      pointer-events: none;
    }
    .agua-overlay[hidden] { display: none; }
    .susto {
      position: absolute; inset: 0; z-index: 16;
      pointer-events: none; opacity: 0;
      box-shadow: inset 0 0 120px 40px rgba(120, 80, 200, 0.75);
    }
    .susto.show { animation: susto-pisca 0.45s ease-out; }
    @keyframes susto-pisca { 0% { opacity: 1; } 100% { opacity: 0; } }
    .fome-dano {
      position: absolute; inset: 0; z-index: 16;
      pointer-events: none; opacity: 0;
      box-shadow: inset 0 0 120px 46px rgba(214, 40, 28, 0.8);
    }
    .fome-dano.show { animation: susto-pisca 0.5s ease-out; }
    .fome {
      position: absolute; left: 50%;
      bottom: calc(max(10px, env(safe-area-inset-bottom)) + 62px);
      transform: translateX(-50%);
      z-index: 40;
      display: flex; gap: 1px;
      font-size: 17px; line-height: 1;
      pointer-events: none;
      filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.65));
    }
    .fome[hidden] { display: none; }
    .fome__ponto--vazio { filter: grayscale(1) brightness(0.55); opacity: 0.4; }
    .fome--zerada { animation: fome-treme 0.45s ease-in-out infinite; }
    @keyframes fome-treme {
      0%, 100% { transform: translateX(-50%); }
      25% { transform: translateX(calc(-50% - 3px)); }
      75% { transform: translateX(calc(-50% + 3px)); }
    }
    canvas.minimapa {
      position: absolute; top: 66px; right: 12px;
      width: 132px; height: 132px;
      z-index: 30;
      border: 2px solid rgba(123, 182, 97, 0.45);
      border-radius: 10px;
      background: rgba(14, 26, 20, 0.55);
      image-rendering: pixelated;
      cursor: pointer;
    }
    canvas.minimapa[hidden] { display: none; }
    .inv__caixa--mapa { width: auto; max-width: none; }
    canvas.mapa__tela {
      display: block;
      width: min(72vmin, 520px);
      height: min(72vmin, 520px);
      image-rendering: pixelated;
      border: 1px solid rgba(123, 182, 97, 0.45);
      border-radius: 8px;
      background: rgba(14, 26, 20, 0.55);
    }
    .mapa__dica {
      margin: 8px 0 0;
      font-size: 0.82rem;
      opacity: 0.75;
      text-align: center;
    }

    .hotbar {
      position: absolute; left: 50%; bottom: max(10px, env(safe-area-inset-bottom));
      transform: translateX(-50%);
      z-index: 40;
      display: flex; gap: 3px;
      padding: 5px;
      background: rgba(14, 26, 20, 0.55);
      border: 1px solid rgba(123, 182, 97, 0.45);
      border-radius: 12px;
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .hotbar[hidden] { display: none; }
    .slot {
      position: relative;
      width: 44px; height: 44px;
      padding: 0; border-radius: 8px; cursor: pointer;
      border: 2px solid rgba(255, 255, 255, 0.18);
      background: rgba(0, 0, 0, 0.25);
      touch-action: none;
    }
    .slot.sel { border-color: var(--amarelo); box-shadow: 0 0 8px rgba(255, 210, 63, 0.6); }
    .slot__img {
      position: absolute; inset: 4px;
      background-size: 400% 1600%;
      image-rendering: pixelated;
      border-radius: 4px;
    }
    .slot__num {
      position: absolute; top: 1px; left: 4px;
      font-size: 0.6rem; font-weight: 700; color: rgba(255, 255, 255, 0.85);
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
      pointer-events: none;
    }
    .slot__qtd {
      position: absolute; right: 2px; bottom: 0;
      font-size: 0.66rem; font-weight: 800; color: #fff;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.9), 0 0 3px rgba(0, 0, 0, 0.9);
      pointer-events: none;
    }
    .slot.vazio .slot__img { opacity: 0.28; filter: grayscale(0.7); }
    .slot.vago { background: rgba(0, 0, 0, 0.45); border-style: dashed; }
    .slot__img[hidden] { display: none; }

    .craft-btn {
      position: absolute; left: 12px; bottom: max(10px, env(safe-area-inset-bottom));
      z-index: 41;
      width: 54px; height: 54px; border-radius: 14px; cursor: pointer;
      font-size: 1.5rem;
      background: rgba(14, 26, 20, 0.55);
      border: 1px solid rgba(123, 182, 97, 0.45);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .craft-btn[hidden] { display: none; }
    .craft-btn[aria-expanded='true'] { border-color: var(--amarelo); }

    .hud-cmd {
      position: absolute; left: 12px; z-index: 41; pointer-events: none;
      bottom: calc(74px + env(safe-area-inset-bottom));
      display: flex; flex-direction: column; gap: 4px;
      padding: 8px 12px; border-radius: 12px;
      background: rgba(14, 26, 20, 0.55); border: 1px solid rgba(123, 182, 97, 0.4);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      font-size: 0.82rem; font-weight: 600; line-height: 1.1;
    }
    .hud-cmd b {
      display: inline-block; min-width: 34px; margin-right: 6px; text-align: center;
      padding: 1px 6px; border-radius: 6px; color: var(--amarelo);
      background: rgba(0, 0, 0, 0.35); border: 1px solid rgba(255, 255, 255, 0.18);
      font-size: 0.78rem;
    }
    @media (pointer: coarse) { .hud-cmd { display: none; } }

    .tab-jogadores {
      position: absolute; left: 50%; top: calc(max(8px, env(safe-area-inset-top)) + 58px);
      transform: translateX(-50%); z-index: 45; pointer-events: none;
      min-width: 220px; max-width: min(92vw, 360px);
      padding: 12px 16px; border-radius: 14px;
      background: rgba(8, 16, 10, 0.82); border: 1px solid rgba(123, 182, 97, 0.5);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .tab-jogadores[hidden] { display: none; }
    .tabj__titulo { margin: 0 0 8px; font-size: 0.95rem; font-weight: 800; text-align: center; }
    .tabj__lista { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 4px; }
    .tabj__lista li {
      display: flex; align-items: center; gap: 6px;
      padding: 5px 10px; border-radius: 8px; background: rgba(255, 255, 255, 0.06);
      font-weight: 600; font-size: 0.9rem;
    }
    .tabj__nome { font-weight: 800; }
    .tabj__eu { opacity: 0.7; font-weight: 400; font-size: 0.82rem; }

    .inv {
      position: absolute; inset: 0; z-index: 46;
      display: grid; place-items: center;
      padding: 12px;
      background: rgba(8, 16, 10, 0.45);
    }
    .inv[hidden] { display: none; }
    .inv__caixa {
      width: min(94vw, 520px);
      max-height: min(88svh, 560px);
      overflow-y: auto;
      padding: 14px 16px 16px;
      border-radius: 16px;
      background: rgba(14, 26, 20, 0.94);
      border: 2px solid rgba(123, 182, 97, 0.55);
      box-shadow: 0 16px 50px rgba(0, 0, 0, 0.5);
    }
    .inv__topo {
      display: flex; justify-content: space-between; align-items: center;
      font-weight: 800; font-size: 1.15rem;
      margin-bottom: 10px;
    }
    .inv__fechar {
      width: 38px; height: 38px; border-radius: 10px; cursor: pointer;
      font-size: 0.95rem; color: var(--texto);
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .inv__grade {
      display: grid;
      grid-template-columns: repeat(9, 1fr);
      gap: 5px;
      margin-bottom: 12px;
    }
    .inv-slot {
      position: relative; aspect-ratio: 1; width: 100%;
      padding: 0; border-radius: 8px;
      font-family: inherit; color: var(--texto);
      background: rgba(0, 0, 0, 0.3);
      border: 2px solid rgba(255, 255, 255, 0.14);
    }
    .inv-slot.tem { cursor: pointer; }
    .inv-slot .slot__img {
      position: absolute; inset: 5px;
      background-size: 400% 1600%;
      image-rendering: pixelated;
      border-radius: 5px;
    }
    .inv-slot__qtd {
      position: absolute; right: 3px; bottom: 1px;
      font-size: 0.72rem; font-weight: 800; color: var(--amarelo);
      text-shadow: 0 1px 2px #000; pointer-events: none;
    }
    .inv-slot.sel { border-color: var(--amarelo); box-shadow: 0 0 8px rgba(255, 210, 63, 0.6); }

