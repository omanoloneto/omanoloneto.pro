---
import Layout from '../../../layouts/Layout.astro';
import { blocos, itens, materiais, config, receitas } from '../../../data/mineblocks';

const dadosJson = JSON.stringify({ blocos, itens, materiais, config, receitas });

const title = 'MineBlocks — construa seu mundo de blocos em 3D! | Manolo Neto';
const description =
  'Sandbox de blocos 3D para crianças, direto no navegador: explore uma ilha, quebre e coloque blocos, construa casas e castelos. O mundo fica salvo online com nome e senha — continue de qualquer computador!';
---

<Layout title={title} description={description}>
  <script type="application/json" data-dados set:html={dadosJson}></script>

  <main id="conteudo" class="mc" data-game role="application" aria-label="MineBlocks: mundo de blocos 3D pra construir e explorar">
    <!-- HUD -->
    <header class="hud">
      <div class="hud__bloco hud__bloco--nome" data-nome-mundo></div>
      <span class="salvando" data-salvando hidden></span>
      <span class="sala-chip" data-sala-chip hidden></span>
      <span class="hud__vao" aria-hidden="true"></span>
      <button class="hud__mute" type="button" data-pause aria-label="Pausar o jogo" hidden>⏸</button>
      <button class="hud__mute" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
        <span data-mute-icon>🔊</span>
      </button>
    </header>

    <!-- Cena 3D + overlays -->
    <div class="cena" data-cena>
      <!-- canvas WebGL entra aqui via JS -->

      <div class="reticula" data-reticula aria-hidden="true" hidden>+</div>
      <div class="agua-overlay" data-agua aria-hidden="true" hidden></div>

      <!-- hotbar de blocos + fabricação -->
      <nav class="hotbar" data-hotbar aria-label="Blocos pra construir" hidden></nav>
      <div class="balao" data-balao aria-hidden="true"></div>
      <button class="craft-btn" type="button" data-craft-btn aria-expanded="false" aria-label="Abrir o inventário (tecla E)" hidden>🎒</button>

      <!-- inventário estilo Minecraft (tecla E) com a fabricação dentro -->
      <div class="inv" data-inv hidden>
        <div class="inv__caixa" role="dialog" aria-modal="false" aria-label="Inventário e fabricação">
          <div class="inv__topo">
            <span>🎒 Inventário</span>
            <button class="inv__fechar" type="button" data-inv-fechar aria-label="Fechar o inventário">✖</button>
          </div>
          <div class="inv__grade" data-inv-grade></div>
          <p class="mat__titulo">🧶 Materiais <small>(recursos pra fabricar)</small></p>
          <div class="mat__lista" data-mat-lista></div>
          <p class="craft__titulo">🛠️ Fabricar</p>
          <div class="craft__lista" data-craft-painel></div>
        </div>
      </div>

      <!-- baú: painel de troca de itens (conteúdo ↔ inventário) -->
      <div class="inv bau" data-bau hidden>
        <div class="inv__caixa" role="dialog" aria-modal="false" aria-label="Baú">
          <div class="inv__topo">
            <span data-bau-titulo>Baú</span>
            <button class="inv__fechar" type="button" data-bau-fechar aria-label="Fechar o baú">✖</button>
          </div>
          <p class="bau__rotulo">📦 Dentro do baú <small>(clique pra pegar)</small></p>
          <div class="bau__grade" data-bau-conteudo></div>
          <p class="bau__rotulo">🎒 Seus itens <small>(clique pra guardar)</small></p>
          <div class="bau__grade" data-bau-inv></div>
        </div>
      </div>

      <!-- placa: escrever a mensagem ao colocar -->
      <div class="inv" data-placa-form hidden>
        <div class="inv__caixa inv__caixa--mini" role="dialog" aria-modal="true" aria-label="Escrever na placa">
          <div class="inv__topo"><span>📜 Escreva na placa</span></div>
          <input class="placa__input" data-placa-input type="text" maxlength="48" autocomplete="off" spellcheck="false" placeholder="ex: Casa do Léo!" />
          <div class="placa__botoes">
            <button class="botao botao--go" type="button" data-placa-ok>✅ Pôr a placa</button>
            <button class="botao botao--sec botao--mini" type="button" data-placa-cancelar>cancelar</button>
          </div>
        </div>
      </div>

      <!-- controles touch (aparecem no 1º toque) -->
      <div class="controles" data-controles hidden>
        <button class="ctl ctl--modo" type="button" data-btn-modo aria-label="Modo: quebrar bloco (toque pra trocar)">⛏️</button>
        <button class="ctl ctl--pulo" type="button" data-btn-pulo aria-label="Pular">⬆️</button>
      </div>
      <div class="joystick" data-joystick aria-hidden="true" hidden>
        <div class="joystick__pino" data-joystick-pino></div>
      </div>

      <!-- dica fantasma (some no 1º input) -->
      <div class="fantasma" data-fantasma hidden>
        <span class="fantasma__desktop">Clique na tela pra olhar · W A S D anda · espaço pula · SEGURE o clique pra quebrar · botão direito coloca · E abre o inventário</span>
        <span class="fantasma__touch">Dedo esquerdo anda · arraste pra olhar · SEGURE o dedo parado pra quebrar · no modo 🧱 o toque coloca</span>
      </div>

      <div class="toast" data-toast aria-live="polite" hidden></div>
    </div>

    <p class="sr-only" data-anuncio aria-live="assertive"></p>

    <!-- Overlay: gerando mundo -->
    <div class="gerando" data-gerando hidden>
      <div class="gerando__caixa">
        <span class="gerando__cubo" aria-hidden="true"></span>
        <p>🌱 Criando seu mundo…</p>
      </div>
    </div>

    <!-- Modal: início (novo mundo × carregar) -->
    <div class="modal" data-inicio>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="inicio-title">
        <div class="placa__topo" id="inicio-title" data-inicio-titulo>🧱 MineBlocks</div>
        <div class="placa__corpo">
          <p class="sub" data-inicio-sub hidden></p>
          <button class="botao botao--aleatorio" type="button" data-jogar-aleatorio>Jogar agora</button>
          <p class="divisor" data-divisor><span>— ou —</span></p>
          <div class="abas" role="tablist">
            <button class="aba ativa" type="button" data-aba="novo" role="tab">🌱 Novo</button>
            <button class="aba" type="button" data-aba="carregar" role="tab">📂 Carregar</button>
            <button class="aba" type="button" data-aba="visitar" role="tab">Join</button>
          </div>
          <form data-form-novo>
            <label class="campo">
              <span>Nome do seu mundo</span>
              <input data-campo-nome type="text" maxlength="16" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder="ex: castelo-do-leo" required />
            </label>
            <label class="campo">
              <span>Crie uma senha <small>(4 números fáceis de lembrar!)</small></span>
              <input data-campo-senha type="text" inputmode="numeric" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder="ex: 2015" required />
            </label>
            <p class="aviso-senha">⚠️ Não esqueça a senha! Sem ela não dá pra abrir o mundo de novo.</p>
            <button class="botao botao--go" type="submit">Criar meu mundo!</button>
          </form>
          <form data-form-carregar hidden>
            <label class="campo">
              <span>Nome do mundo</span>
              <input data-campo-nome type="text" maxlength="16" autocomplete="off" autocapitalize="off" spellcheck="false" required />
            </label>
            <label class="campo">
              <span>Senha</span>
              <input data-campo-senha type="text" inputmode="numeric" autocomplete="off" autocapitalize="off" spellcheck="false" required />
            </label>
            <button class="botao botao--go" type="submit">Entrar no mundo!</button>
          </form>
          <form data-form-visitar hidden>
            <label class="campo">
              <span>Código da sala <small>(4 letras)</small></span>
              <input data-campo-codigo class="campo--codigo" type="text" autocomplete="off" autocapitalize="characters" spellcheck="false" placeholder="ex: KZTP" required />
            </label>
            <label class="campo">
              <span>Seu nome <small>(pros amigos te verem)</small></span>
              <input data-campo-apelido type="text" maxlength="10" autocomplete="off" autocapitalize="characters" spellcheck="false" placeholder="ex: LEO" required />
            </label>
            <button class="botao botao--go" type="submit">🧑‍🤝‍🧑 Entrar na sala!</button>
          </form>
          <p class="erro" data-erro-inicio role="alert" hidden></p>
          <button class="botao botao--sec botao--mini" type="button" data-batizar-voltar hidden>← voltar pro jogo</button>
          <a class="voltar" href="/class/games/" data-voltar-jogos>← voltar pros jogos</a>
        </div>
      </div>
    </div>

    <!-- Modal: pausa -->
    <div class="modal" data-pausa hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="pausa-title">
        <div class="placa__topo" id="pausa-title">⏸ Pausa</div>
        <div class="placa__corpo center">
          <div class="pausa-acoes">
            <button class="botao botao--go" type="button" data-continuar>▶ Continuar</button>
            <button class="botao botao--sec" type="button" data-salvar-agora>💾 Salvar agora</button>
            <button class="botao botao--sec" type="button" data-batizar hidden>💾 Dar um nome pra salvar</button>
            <button class="botao botao--sec" type="button" data-sair>🚪 Salvar e sair</button>
          </div>
          <div class="sala" data-sala-secao>
            <div data-sala-abrir>
              <p class="sala__chamada">🧑‍🤝‍🧑 Chame amigos pro seu mundo — cada um na casa dele!</p>
              <div class="sala__linha">
                <input class="sala__nome" data-sala-nome type="text" maxlength="10" autocomplete="off" autocapitalize="characters" spellcheck="false" placeholder="seu nome (ex: LEO)" aria-label="Seu nome na sala" />
                <button class="botao botao--sec" type="button" data-sala-criar>🎮 Abrir sala</button>
              </div>
            </div>
            <div data-sala-info hidden>
              <p class="sala__chamada">Manda esse código pros seus amigos:</p>
              <div class="sala__codigo" data-sala-codigo></div>
              <p class="sala__quem" data-sala-lista></p>
              <button class="botao botao--sec botao--mini" type="button" data-sala-sair>🚪 Sair da sala</button>
            </div>
            <p class="erro" data-sala-erro role="alert" hidden></p>
          </div>
          <p class="aviso" data-pausa-aviso>Relaxa: o mundo se salva sozinho de tempos em tempos. 😉</p>
        </div>
      </div>
    </div>
  </main>

  <style is:global>
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-Regular.ttf') format('truetype');
      font-weight: 400;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-SemiBold.ttf') format('truetype');
      font-weight: 600;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-ExtraBold.ttf') format('truetype');
      font-weight: 800;
      font-display: swap;
    }

    body.is-game { background: #87c6ea; overflow: hidden; }
    body.is-game::before { display: none !important; }

    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
    }

    .mc {
      position: fixed;
      inset: 0;
      overflow: clip;
      font-family: 'Oxanium', Verdana, Tahoma, 'Segoe UI', Geneva, sans-serif;
      user-select: none;
      -webkit-user-select: none;
      color: var(--texto);
      display: flex;
      flex-direction: column;
      --verde: #2ee08a;
      --amarelo: #ffd23f;
      --quente: #ff5c39;
      --texto: #eaf6ff;
      overscroll-behavior: none;
    }

    /* ===== HUD ===== */
    .hud {
      position: relative; z-index: 30;
      display: flex; align-items: center; gap: 12px;
      padding: 8px 16px;
      background: rgba(14, 26, 20, 0.6);
      border-bottom: 1px solid rgba(123, 182, 97, 0.45);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .hud__bloco--nome { font-weight: 700; font-size: 1rem; }
    .hud__vao { flex: 1; }
    .hud__mute {
      width: 44px; height: 44px; border-radius: 10px; cursor: pointer;
      border: 1px solid rgba(123, 182, 97, 0.55); background: rgba(14, 26, 20, 0.55);
      font-size: 1.15rem; display: grid; place-items: center; color: var(--texto);
    }
    .hud__mute[hidden] { display: none; }
    .salvando {
      font-size: 0.82rem; font-weight: 600; opacity: 0.9;
      padding: 3px 10px; border-radius: 999px;
      background: rgba(14, 26, 20, 0.55); border: 1px solid rgba(123, 182, 97, 0.4);
    }
    .salvando[hidden] { display: none; }

    /* ===== Cena ===== */
    .cena { position: relative; z-index: 10; flex: 1; min-height: 0; }
    .cena canvas { display: block; width: 100%; height: 100%; touch-action: none; }

    .reticula {
      position: absolute; left: 50%; top: 50%; z-index: 20;
      transform: translate(-50%, -50%);
      font-size: 1.6rem; font-weight: 400; color: #fff;
      mix-blend-mode: difference;
      pointer-events: none;
      line-height: 1;
    }
    .reticula[hidden] { display: none; }

    .agua-overlay {
      position: absolute; inset: 0; z-index: 15;
      background: rgba(30, 90, 200, 0.34);
      pointer-events: none;
    }
    .agua-overlay[hidden] { display: none; }

    /* ===== Hotbar ===== */
    .hotbar {
      position: absolute; left: 50%; bottom: max(10px, env(safe-area-inset-bottom));
      transform: translateX(-50%);
      z-index: 40;
      display: flex; gap: 3px;
      padding: 5px;
      background: rgba(14, 26, 20, 0.55);
      border: 1px solid rgba(123, 182, 97, 0.45);
      border-radius: 12px;
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .hotbar[hidden] { display: none; }
    .slot {
      position: relative;
      width: 44px; height: 44px;
      padding: 0; border-radius: 8px; cursor: pointer;
      border: 2px solid rgba(255, 255, 255, 0.18);
      background: rgba(0, 0, 0, 0.25);
      touch-action: none;
    }
    .slot.sel { border-color: var(--amarelo); box-shadow: 0 0 8px rgba(255, 210, 63, 0.6); }
    .slot__img {
      position: absolute; inset: 4px;
      background-size: 400% 800%; /* atlas 4 colunas × 8 linhas */
      image-rendering: pixelated;
      border-radius: 4px;
    }
    .slot__num {
      position: absolute; top: 1px; left: 4px;
      font-size: 0.6rem; font-weight: 700; color: rgba(255, 255, 255, 0.85);
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
      pointer-events: none;
    }
    .slot__qtd {
      position: absolute; right: 2px; bottom: 0;
      font-size: 0.66rem; font-weight: 800; color: #fff;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.9), 0 0 3px rgba(0, 0, 0, 0.9);
      pointer-events: none;
    }
    .slot.vazio .slot__img { opacity: 0.28; filter: grayscale(0.7); }
    .slot.vago { background: rgba(0, 0, 0, 0.45); border-style: dashed; }
    .slot__img[hidden] { display: none; }

    /* ===== Fabricação ===== */
    .craft-btn {
      position: absolute; left: 12px; bottom: max(10px, env(safe-area-inset-bottom));
      z-index: 41;
      width: 54px; height: 54px; border-radius: 14px; cursor: pointer;
      font-size: 1.5rem;
      background: rgba(14, 26, 20, 0.55);
      border: 1px solid rgba(123, 182, 97, 0.45);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .craft-btn[hidden] { display: none; }
    .craft-btn[aria-expanded='true'] { border-color: var(--amarelo); }

    /* painel do inventário (tecla E) */
    .inv {
      position: absolute; inset: 0; z-index: 46;
      display: grid; place-items: center;
      padding: 12px;
      background: rgba(8, 16, 10, 0.45);
    }
    .inv[hidden] { display: none; }
    .inv__caixa {
      width: min(94vw, 520px);
      max-height: min(88vh, 560px);
      overflow-y: auto;
      padding: 14px 16px 16px;
      border-radius: 16px;
      background: rgba(14, 26, 20, 0.94);
      border: 2px solid rgba(123, 182, 97, 0.55);
      box-shadow: 0 16px 50px rgba(0, 0, 0, 0.5);
    }
    .inv__topo {
      display: flex; justify-content: space-between; align-items: center;
      font-weight: 800; font-size: 1.15rem;
      margin-bottom: 10px;
    }
    .inv__fechar {
      width: 38px; height: 38px; border-radius: 10px; cursor: pointer;
      font-size: 0.95rem; color: var(--texto);
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .inv__grade {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(102px, 1fr));
      gap: 6px;
      margin-bottom: 12px;
    }
    .inv-item {
      display: flex; flex-direction: column; align-items: center; gap: 3px;
      padding: 8px 4px 6px; border-radius: 10px; cursor: pointer;
      font-family: inherit; color: var(--texto);
      background: rgba(0, 0, 0, 0.3);
      border: 2px solid rgba(255, 255, 255, 0.12);
    }
    .inv-item .slot__img {
      position: static; display: block;
      width: 34px; height: 34px;
      background-size: 400% 800%;
      image-rendering: pixelated;
      border-radius: 5px;
    }
    .inv-item__nome { font-size: 0.72rem; font-weight: 700; line-height: 1.1; text-align: center; }
    .inv-item__qtd { font-size: 0.78rem; font-weight: 800; color: var(--amarelo); }
    .inv-item.vazio { opacity: 0.45; }
    .inv-item.vazio .inv-item__qtd { color: rgba(255, 255, 255, 0.4); }
    .inv-item.sel { border-color: var(--amarelo); }

    /* baú + placa */
    .bau__rotulo { margin: 8px 0 6px; font-weight: 800; font-size: 0.9rem; }
    .bau__rotulo small { font-weight: 400; opacity: 0.75; }
    .bau__grade {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(52px, 1fr));
      gap: 6px;
      min-height: 56px;
      padding: 6px;
      border-radius: 10px;
      background: rgba(0, 0, 0, 0.25);
    }
    .bau__vazio { grid-column: 1 / -1; margin: 0; padding: 8px; font-size: 0.82rem; opacity: 0.7; text-align: center; }
    .bau-item {
      position: relative;
      width: 100%; aspect-ratio: 1; padding: 0;
      border-radius: 8px; cursor: pointer;
      background: rgba(0, 0, 0, 0.3);
      border: 2px solid rgba(255, 255, 255, 0.14);
    }
    .bau-item:hover { border-color: var(--amarelo); }
    .bau-item .slot__img {
      position: absolute; inset: 4px;
      background-size: 400% 800%;
      image-rendering: pixelated;
      border-radius: 4px;
    }
    .bau-item__q {
      position: absolute; right: 2px; bottom: 0;
      font-size: 0.66rem; font-weight: 800; color: #fff;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.9), 0 0 3px rgba(0, 0, 0, 0.9);
    }
    .inv__caixa--mini { width: min(92vw, 380px); }
    .placa__input {
      display: block; width: 100%; margin: 4px 0 12px;
      padding: 11px 12px; border-radius: 10px;
      font-family: inherit; font-size: 1.05rem; color: var(--texto);
      background: rgba(0, 0, 0, 0.35);
      border: 2px solid rgba(123, 182, 97, 0.4);
    }
    .placa__input:focus { outline: none; border-color: var(--verde); }
    .placa__botoes { display: flex; align-items: center; gap: 10px; }
    .placa__botoes .botao--go { flex: 1; }
    .placa__autor { opacity: 0.85; font-weight: 600; }

    .craft__lista { display: grid; gap: 6px; }
    .craft__titulo { margin: 0 0 6px; font-weight: 800; font-size: 0.95rem; }

    /* materiais (recursos só-coletáveis, ex.: lã do Winpup) */
    .mat__titulo { margin: 2px 0 6px; font-weight: 800; font-size: 0.95rem; }
    .mat__titulo small { font-weight: 400; opacity: 0.72; font-size: 0.78rem; }
    .mat__lista {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(102px, 1fr));
      gap: 6px;
      margin-bottom: 12px;
    }
    .mat-item {
      display: flex; flex-direction: column; align-items: center; gap: 3px;
      padding: 8px 4px 6px; border-radius: 10px;
      color: var(--texto);
      background: rgba(0, 0, 0, 0.3);
      border: 2px solid rgba(255, 255, 255, 0.12);
    }
    .mat-item .slot__img {
      position: static; display: block;
      width: 34px; height: 34px;
      background-size: 400% 800%;
      image-rendering: pixelated;
      border-radius: 5px;
    }
    .mat-item__nome { font-size: 0.72rem; font-weight: 700; line-height: 1.1; text-align: center; }
    .mat-item__qtd { font-size: 0.78rem; font-weight: 800; color: var(--amarelo); }
    .mat-item.vazio { opacity: 0.5; }
    .mat-item.vazio .mat-item__qtd { color: rgba(255, 255, 255, 0.4); }
    .receita {
      display: flex; align-items: center; gap: 10px;
      padding: 7px 10px; border-radius: 10px; cursor: pointer;
      font-family: inherit; font-weight: 700; font-size: 0.95rem; color: var(--texto);
      background: rgba(0, 0, 0, 0.3);
      border: 2px solid rgba(255, 255, 255, 0.12);
      opacity: 0.55;
    }
    .receita.pode { opacity: 1; border-color: rgba(123, 182, 97, 0.7); }
    .receita.pode:hover { background: rgba(123, 182, 97, 0.25); }
    .receita__lado { display: inline-flex; align-items: center; gap: 5px; }
    .receita__lado .slot__img {
      position: static; display: inline-block;
      width: 26px; height: 26px;
      background-size: 400% 800%;
      image-rendering: pixelated;
      border-radius: 4px;
    }
    .receita__seta { color: var(--amarelo); font-weight: 800; }

    .balao {
      position: absolute; left: 50%; bottom: 68px;
