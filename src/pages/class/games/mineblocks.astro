---
import Layout from '../../../layouts/Layout.astro';
import { blocos, hotbar, config, receitas } from '../../../data/mineblocks';

const dadosJson = JSON.stringify({ blocos, hotbar, config, receitas });

const title = 'MineBlocks — construa seu mundo de blocos em 3D! | Manolo Neto';
const description =
  'Sandbox de blocos 3D para crianças, direto no navegador: explore uma ilha, quebre e coloque blocos, construa casas e castelos. O mundo fica salvo online com nome e senha — continue de qualquer computador!';
---

<Layout title={title} description={description}>
  <script type="application/json" data-dados set:html={dadosJson}></script>

  <main id="conteudo" class="mc" data-game role="application" aria-label="MineBlocks: mundo de blocos 3D pra construir e explorar">
    <!-- HUD -->
    <header class="hud">
      <div class="hud__bloco hud__bloco--nome" data-nome-mundo></div>
      <span class="salvando" data-salvando hidden></span>
      <span class="hud__vao" aria-hidden="true"></span>
      <button class="hud__mute" type="button" data-pause aria-label="Pausar o jogo" hidden>⏸</button>
      <button class="hud__mute" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
        <span data-mute-icon>🔊</span>
      </button>
    </header>

    <!-- Cena 3D + overlays -->
    <div class="cena" data-cena>
      <!-- canvas WebGL entra aqui via JS -->

      <div class="reticula" data-reticula aria-hidden="true" hidden>+</div>
      <div class="agua-overlay" data-agua aria-hidden="true" hidden></div>

      <!-- hotbar de blocos + fabricação -->
      <nav class="hotbar" data-hotbar aria-label="Blocos pra construir" hidden></nav>
      <div class="balao" data-balao aria-hidden="true"></div>
      <button class="craft-btn" type="button" data-craft-btn aria-expanded="false" aria-label="Abrir a fabricação de blocos" hidden>🛠️</button>
      <div class="craft" data-craft-painel aria-label="Receitas de fabricação" hidden></div>

      <!-- controles touch (aparecem no 1º toque) -->
      <div class="controles" data-controles hidden>
        <button class="ctl ctl--modo" type="button" data-btn-modo aria-label="Modo: quebrar bloco (toque pra trocar)">⛏️</button>
        <button class="ctl ctl--pulo" type="button" data-btn-pulo aria-label="Pular">⬆️</button>
      </div>
      <div class="joystick" data-joystick aria-hidden="true" hidden>
        <div class="joystick__pino" data-joystick-pino></div>
      </div>

      <!-- dica fantasma (some no 1º input) -->
      <div class="fantasma" data-fantasma hidden>
        <span class="fantasma__desktop">Clique na tela pra olhar · W A S D anda · espaço pula · clique quebra · botão direito coloca</span>
        <span class="fantasma__touch">Dedo esquerdo anda · arraste pra olhar · toque quebra ou coloca</span>
      </div>

      <div class="toast" data-toast aria-live="polite" hidden></div>
    </div>

    <p class="sr-only" data-anuncio aria-live="assertive"></p>

    <!-- Overlay: gerando mundo -->
    <div class="gerando" data-gerando hidden>
      <div class="gerando__caixa">
        <span class="gerando__cubo" aria-hidden="true"></span>
        <p>🌱 Criando seu mundo…</p>
      </div>
    </div>

    <!-- Modal: início (novo mundo × carregar) -->
    <div class="modal" data-inicio>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="inicio-title">
        <div class="placa__topo" id="inicio-title">🧱 MineBlocks</div>
        <div class="placa__corpo">
          <p class="sub">Explore a ilha e construa o que quiser — mas do jeito sobrevivência: <b>quebre blocos pra ganhar eles</b>, fabrique tábuas e vidro na oficina 🛠️! Seu mundo fica guardado <b>na internet</b> com nome e senha — dá pra continuar de qualquer computador.</p>
          <div class="abas" role="tablist">
            <button class="aba ativa" type="button" data-aba="novo" role="tab">🌱 Novo mundo</button>
            <button class="aba" type="button" data-aba="carregar" role="tab">📂 Carregar mundo</button>
          </div>
          <form data-form-novo>
            <label class="campo">
              <span>Nome do seu mundo</span>
              <input data-campo-nome type="text" maxlength="16" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder="ex: castelo-do-leo" required />
            </label>
            <label class="campo">
              <span>Crie uma senha <small>(use 4 números fáceis de lembrar!)</small></span>
              <input data-campo-senha type="text" maxlength="20" autocomplete="off" autocapitalize="off" spellcheck="false" placeholder="ex: 2015" required />
            </label>
            <p class="aviso-senha">⚠️ Não esqueça a senha! Sem ela não dá pra abrir o mundo de novo.</p>
            <button class="botao botao--go" type="submit">Criar meu mundo!</button>
          </form>
          <form data-form-carregar hidden>
            <label class="campo">
              <span>Nome do mundo</span>
              <input data-campo-nome type="text" maxlength="16" autocomplete="off" autocapitalize="off" spellcheck="false" required />
            </label>
            <label class="campo">
              <span>Senha</span>
              <input data-campo-senha type="text" maxlength="20" autocomplete="off" autocapitalize="off" spellcheck="false" required />
            </label>
            <button class="botao botao--go" type="submit">Entrar no mundo!</button>
          </form>
          <p class="erro" data-erro-inicio role="alert" hidden></p>
          <a class="voltar" href="/class/games/">← voltar pros jogos</a>
        </div>
      </div>
    </div>

    <!-- Modal: pausa -->
    <div class="modal" data-pausa hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="pausa-title">
        <div class="placa__topo" id="pausa-title">⏸ Pausa</div>
        <div class="placa__corpo center">
          <div class="pausa-acoes">
            <button class="botao botao--go" type="button" data-continuar>▶ Continuar</button>
            <button class="botao botao--sec" type="button" data-salvar-agora>💾 Salvar agora</button>
            <button class="botao botao--sec" type="button" data-sair>🚪 Salvar e sair</button>
          </div>
          <p class="aviso">Relaxa: o mundo se salva sozinho de tempos em tempos. 😉</p>
        </div>
      </div>
    </div>
  </main>

  <style is:global>
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-Regular.ttf') format('truetype');
      font-weight: 400;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-SemiBold.ttf') format('truetype');
      font-weight: 600;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-ExtraBold.ttf') format('truetype');
      font-weight: 800;
      font-display: swap;
    }

    body.is-game { background: #87c6ea; overflow: hidden; }
    body.is-game::before { display: none !important; }

    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
    }

    .mc {
      position: fixed;
      inset: 0;
      overflow: clip;
      font-family: 'Oxanium', Verdana, Tahoma, 'Segoe UI', Geneva, sans-serif;
      user-select: none;
      -webkit-user-select: none;
      color: var(--texto);
      display: flex;
      flex-direction: column;
      --verde: #2ee08a;
      --amarelo: #ffd23f;
      --quente: #ff5c39;
      --texto: #eaf6ff;
      overscroll-behavior: none;
    }

    /* ===== HUD ===== */
    .hud {
      position: relative; z-index: 30;
      display: flex; align-items: center; gap: 12px;
      padding: 8px 16px;
      background: rgba(14, 26, 20, 0.6);
      border-bottom: 1px solid rgba(123, 182, 97, 0.45);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .hud__bloco--nome { font-weight: 700; font-size: 1rem; }
    .hud__vao { flex: 1; }
    .hud__mute {
      width: 44px; height: 44px; border-radius: 10px; cursor: pointer;
      border: 1px solid rgba(123, 182, 97, 0.55); background: rgba(14, 26, 20, 0.55);
      font-size: 1.15rem; display: grid; place-items: center; color: var(--texto);
    }
    .hud__mute[hidden] { display: none; }
    .salvando {
      font-size: 0.82rem; font-weight: 600; opacity: 0.9;
      padding: 3px 10px; border-radius: 999px;
      background: rgba(14, 26, 20, 0.55); border: 1px solid rgba(123, 182, 97, 0.4);
    }
    .salvando[hidden] { display: none; }

    /* ===== Cena ===== */
    .cena { position: relative; z-index: 10; flex: 1; min-height: 0; }
    .cena canvas { display: block; width: 100%; height: 100%; touch-action: none; }

    .reticula {
      position: absolute; left: 50%; top: 50%; z-index: 20;
      transform: translate(-50%, -50%);
      font-size: 1.6rem; font-weight: 400; color: #fff;
      mix-blend-mode: difference;
      pointer-events: none;
      line-height: 1;
    }
    .reticula[hidden] { display: none; }

    .agua-overlay {
      position: absolute; inset: 0; z-index: 15;
      background: rgba(30, 90, 200, 0.34);
      pointer-events: none;
    }
    .agua-overlay[hidden] { display: none; }

    /* ===== Hotbar ===== */
    .hotbar {
      position: absolute; left: 50%; bottom: max(10px, env(safe-area-inset-bottom));
      transform: translateX(-50%);
      z-index: 40;
      display: flex; gap: 3px;
      padding: 5px;
      background: rgba(14, 26, 20, 0.55);
      border: 1px solid rgba(123, 182, 97, 0.45);
      border-radius: 12px;
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .hotbar[hidden] { display: none; }
    .slot {
      position: relative;
      width: 44px; height: 44px;
      padding: 0; border-radius: 8px; cursor: pointer;
      border: 2px solid rgba(255, 255, 255, 0.18);
      background: rgba(0, 0, 0, 0.25);
      touch-action: none;
    }
    .slot.sel { border-color: var(--amarelo); box-shadow: 0 0 8px rgba(255, 210, 63, 0.6); }
    .slot__img {
      position: absolute; inset: 4px;
      background-size: 400% 400%;
      image-rendering: pixelated;
      border-radius: 4px;
    }
    .slot__num {
      position: absolute; top: 1px; left: 4px;
      font-size: 0.6rem; font-weight: 700; color: rgba(255, 255, 255, 0.85);
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.8);
      pointer-events: none;
    }
    .slot__qtd {
      position: absolute; right: 2px; bottom: 0;
      font-size: 0.66rem; font-weight: 800; color: #fff;
      text-shadow: 0 1px 2px rgba(0, 0, 0, 0.9), 0 0 3px rgba(0, 0, 0, 0.9);
      pointer-events: none;
    }
    .slot.vazio .slot__img { opacity: 0.28; filter: grayscale(0.7); }

    /* ===== Fabricação ===== */
    .craft-btn {
      position: absolute; left: 12px; bottom: max(10px, env(safe-area-inset-bottom));
      z-index: 41;
      width: 54px; height: 54px; border-radius: 14px; cursor: pointer;
      font-size: 1.5rem;
      background: rgba(14, 26, 20, 0.55);
      border: 1px solid rgba(123, 182, 97, 0.45);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
    }
    .craft-btn[hidden] { display: none; }
    .craft-btn[aria-expanded='true'] { border-color: var(--amarelo); }
    .craft {
      position: absolute; left: 12px; bottom: 74px;
      z-index: 42;
      display: grid; gap: 6px;
      padding: 10px;
      background: rgba(14, 26, 20, 0.88);
      border: 1px solid rgba(123, 182, 97, 0.5);
      border-radius: 14px;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
    }
    .craft[hidden] { display: none; }
    .craft__titulo { margin: 0 0 2px; font-weight: 800; font-size: 0.95rem; }
    .receita {
      display: flex; align-items: center; gap: 10px;
      padding: 7px 10px; border-radius: 10px; cursor: pointer;
      font-family: inherit; font-weight: 700; font-size: 0.95rem; color: var(--texto);
      background: rgba(0, 0, 0, 0.3);
      border: 2px solid rgba(255, 255, 255, 0.12);
      opacity: 0.55;
    }
    .receita.pode { opacity: 1; border-color: rgba(123, 182, 97, 0.7); }
    .receita.pode:hover { background: rgba(123, 182, 97, 0.25); }
    .receita__lado { display: inline-flex; align-items: center; gap: 5px; }
    .receita__lado .slot__img {
      position: static; display: inline-block;
      width: 26px; height: 26px;
      background-size: 400% 400%;
      image-rendering: pixelated;
      border-radius: 4px;
    }
    .receita__seta { color: var(--amarelo); font-weight: 800; }

    .balao {
      position: absolute; left: 50%; bottom: 68px;
      transform: translateX(-50%) translateY(6px);
      z-index: 40; pointer-events: none;
      padding: 4px 14px; border-radius: 999px;
      background: rgba(14, 26, 20, 0.75); color: var(--texto);
      font-weight: 700; font-size: 0.95rem;
      opacity: 0; transition: opacity 0.18s ease, transform 0.18s ease;
    }
    .balao.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* ===== Touch ===== */
    .controles { position: absolute; inset: 0; z-index: 40; pointer-events: none; }
    .controles[hidden] { display: none; }
    .ctl {
      pointer-events: auto;
      position: absolute;
      border-radius: 50%;
      font-size: 1.9rem; font-family: inherit; color: var(--texto);
      background: rgba(14, 26, 20, 0.5);
      border: 2px solid rgba(123, 182, 97, 0.6);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      touch-action: none;
      cursor: pointer;
    }
    .ctl:active, .ctl.on { background: rgba(123, 182, 97, 0.4); }
    .ctl--pulo { right: 16px; bottom: 96px; width: 84px; height: 84px; }
    .ctl--modo { right: 26px; bottom: 196px; width: 64px; height: 64px; }
    .ctl--modo.colocar { border-color: var(--amarelo); }

    .joystick {
      position: absolute; z-index: 41;
      width: 110px; height: 110px;
      transform: translate(-50%, -50%);
      border-radius: 50%;
      border: 2px solid rgba(255, 255, 255, 0.45);
      background: rgba(14, 26, 20, 0.25);
      pointer-events: none;
    }
    .joystick[hidden] { display: none; }
    .joystick__pino {
      position: absolute; left: 50%; top: 50%;
      width: 48px; height: 48px; border-radius: 50%;
      background: rgba(255, 255, 255, 0.55);
      transform: translate(-50%, -50%);
    }

    .fantasma {
      position: absolute; left: 50%; bottom: 22%;
      transform: translateX(-50%);
      z-index: 38; pointer-events: none;
      max-width: min(92vw, 560px);
      padding: 10px 18px; border-radius: 12px;
      background: rgba(14, 26, 20, 0.65);
      font-weight: 600; font-size: 0.95rem; text-align: center;
      animation: fantasma-pulsa 1.6s ease-in-out infinite alternate;
    }
    .fantasma[hidden] { display: none; }
    .fantasma__touch { display: none; }
    @media (pointer: coarse) {
      .fantasma__desktop { display: none; }
      .fantasma__touch { display: inline; }
    }
    @keyframes fantasma-pulsa { from { opacity: 0.75; } to { opacity: 1; } }

    .toast {
      position: absolute; left: 50%; top: 14px;
      transform: translateX(-50%) translateY(-8px);
      z-index: 45; pointer-events: none;
      max-width: min(92vw, 480px);
      padding: 10px 18px; border-radius: 12px;
      font-weight: 700; font-size: 1rem; text-align: center;
      background: rgba(14, 26, 20, 0.85);
      border: 1px solid rgba(123, 182, 97, 0.5);
      opacity: 0; transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
    .toast.err { border-color: rgba(255, 92, 57, 0.7); }
    .toast[hidden] { display: none; }

    /* ===== Overlay gerando ===== */
    .gerando {
      position: fixed; inset: 0; z-index: 60;
      display: grid; place-items: center;
      background: rgba(10, 20, 14, 0.88);
    }
    .gerando[hidden] { display: none; }
    .gerando__caixa { text-align: center; font-size: 1.3rem; font-weight: 700; }
    .gerando__cubo {
      display: block; width: 44px; height: 44px; margin: 0 auto 16px;
      background: linear-gradient(135deg, #7bb661, #57a24c);
      border-radius: 8px;
      animation: cubo-gira 1.1s ease-in-out infinite;
    }
    @keyframes cubo-gira { 50% { transform: rotate(180deg) scale(0.8); } }

    /* ===== Modais ===== */
    .modal {
      position: fixed; inset: 0; z-index: 50;
      display: grid; place-items: center;
      padding: 16px;
      background: rgba(8, 16, 10, 0.72);
      overflow: auto;
    }
    .modal[hidden] { display: none; }
    .placa {
      width: min(94vw, 480px);
      border-radius: 18px;
      background: #10231a;
      border: 2px solid rgba(123, 182, 97, 0.55);
      box-shadow: 0 18px 60px rgba(0, 0, 0, 0.55);
      overflow: hidden;
    }
    .placa__topo {
      padding: 14px 20px;
      font-size: 1.35rem; font-weight: 800;
      background: linear-gradient(135deg, #3e7d3a, #2c5a2a);
    }
    .placa__corpo { padding: 16px 20px 20px; }
    .placa__corpo.center { text-align: center; }
    .sub { font-size: 0.95rem; line-height: 1.45; margin: 0 0 14px; }

    .abas { display: flex; gap: 8px; margin-bottom: 14px; }
    .aba {
      flex: 1; padding: 10px; border-radius: 10px; cursor: pointer;
      font-family: inherit; font-weight: 700; font-size: 0.95rem; color: var(--texto);
      background: rgba(255, 255, 255, 0.06);
      border: 2px solid rgba(123, 182, 97, 0.35);
    }
    .aba.ativa { background: rgba(123, 182, 97, 0.3); border-color: var(--verde); }

    form[hidden] { display: none; }
    .campo { display: block; margin-bottom: 12px; font-weight: 600; font-size: 0.92rem; }
    .campo small { font-weight: 400; opacity: 0.8; }
    .campo input {
      display: block; width: 100%; margin-top: 5px;
      padding: 11px 12px; border-radius: 10px;
      font-family: inherit; font-size: 1.05rem; color: var(--texto);
      background: rgba(0, 0, 0, 0.35);
      border: 2px solid rgba(123, 182, 97, 0.4);
    }
    .campo input:focus { outline: none; border-color: var(--verde); }
    .aviso-senha { font-size: 0.85rem; margin: 0 0 14px; opacity: 0.9; }

    .botao {
      display: inline-block;
      padding: 12px 22px; border-radius: 12px; cursor: pointer;
      font-family: inherit; font-weight: 800; font-size: 1.05rem; color: #0c1a10;
      border: 0; text-decoration: none;
    }
    .botao[hidden] { display: none; }
    .botao--go { background: linear-gradient(135deg, #7be08a, #2ee08a); width: 100%; }
    .botao--sec { background: rgba(255, 255, 255, 0.85); }
    .botao:disabled { opacity: 0.55; cursor: wait; }
    .pausa-acoes { display: grid; gap: 10px; margin-bottom: 12px; }
    .aviso { font-size: 0.88rem; opacity: 0.85; margin: 0; }

    .erro {
      margin: 12px 0 0; padding: 10px 12px; border-radius: 10px;
      font-weight: 700; font-size: 0.92rem;
      background: rgba(255, 92, 57, 0.16);
      border: 1px solid rgba(255, 92, 57, 0.55);
    }
    .erro[hidden] { display: none; }
    .voltar { display: inline-block; margin-top: 14px; color: var(--verde); font-weight: 600; font-size: 0.9rem; }

    @media (max-width: 560px) {
      .slot { width: 26px; height: 26px; border-radius: 6px; }
      .slot__img { inset: 2px; }
      .slot__num { display: none; }
      .hud__bloco--nome { font-size: 0.85rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      .fantasma, .gerando__cubo { animation: none; }
      .toast, .balao { transition: none; }
    }
  </style>

  <script>
    import { iniciarJogo } from '../../../games/mineblocks/main';
    iniciarJogo();
  </script>
</Layout>
