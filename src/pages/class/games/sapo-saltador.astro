---
import Layout from '../../../layouts/Layout.astro';
import { fases, config } from '../../../data/sapo-saltador';

const dadosJson = JSON.stringify({ fases, config });

const title = 'Sapo Saltador — Lago das Esmeraldas | Manolo Neto';
const description =
  'Jogo de matemática para o 1º ano: resolva continhas de soma e subtração na reta numérica e ajude o sapo a atravessar o Lago das Esmeraldas — moedas, flores raras, plantas carnívoras e ranking arcade!';

const pedras = Array.from({ length: config.retaMax - config.retaMin + 1 }, (_, i) => config.retaMin + i);
const letras = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
---

<Layout title={title} description={description}>
  <script type="application/json" data-dados set:html={dadosJson}></script>

  <main id="conteudo" class="ss" data-game role="application" aria-label="Jogo: resolva continhas na reta numérica e atravesse o lago de vitória-régia em vitória-régia">
    <!-- HUD -->
    <header class="hud" role="status" aria-live="polite">
      <div class="hud__bloco">
        <span class="hud__label">Pontos</span>
        <strong data-pontos>0</strong>
      </div>
      <div class="hud__bloco">
        <img class="hud__icone" src="/class/img/sapo-saltador/moeda.png" alt="Moedas" />
        <strong data-moedas>0</strong>
      </div>
      <div class="hud__bloco">
        <img class="hud__icone" src="/class/img/sapo-saltador/flor.png" alt="Flores raras" />
        <strong data-flores>0</strong>
        <span class="hud__sub">de 3</span>
      </div>
      <div class="hud__bloco">
        <span class="hud__label">Fase</span>
        <strong data-fase>1</strong>
        <span class="hud__sub">de {fases.length}</span>
      </div>
      <div class="hud__bloco hud__bloco--vidas" data-vidas-wrap hidden>
        <span class="vidas" data-vidas aria-label="Vidas"></span>
      </div>
      <div class="hud__bloco hud__bloco--nome" data-fase-nome aria-hidden="true"></div>
      <button class="hud__mute" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
        <span data-mute-icon>🔊</span>
      </button>
    </header>

    <!-- Mapa do lago -->
    <section class="mapa" data-mapa aria-label="Mapa do lago: vitórias-régias até a lótus">
      <div class="lago" data-lago>
        <div data-trilhas aria-hidden="true"></div>
        <div data-pads></div>
        <div class="sapo-mapa" data-sapo-mapa aria-hidden="true">
          <span class="sapo-mapa__corpo"><img src="/class/img/sapo-saltador/sapo.png" alt="" /></span>
        </div>
        <div data-decor aria-hidden="true"></div>
      </div>
    </section>

    <!-- Faixa da continha (micro-loop na reta numérica) -->
    <section class="faixa" data-faixa>
      <div class="faixa__aviso" data-faixa-aviso hidden>👆 Escolha uma vitória-régia lá em cima!</div>
      <div class="continha" aria-label="Continha para resolver" aria-live="polite">
        <span class="continha__desafio" data-desafio hidden>💀</span>
        <span class="continha__num" data-num-a>?</span>
        <span class="continha__op" data-op>+</span>
        <span class="continha__num" data-num-b>?</span>
        <span class="continha__igual">=</span>
        <span class="continha__resposta" data-resposta>?</span>
      </div>
      <div class="rio" data-rio aria-label="Reta numérica: pedras de 0 a 20">
        <div class="trilho" data-trilho>
          {
            pedras.map((n) => (
              <button
                class={'pedra' + (n % 5 === 0 ? ' pedra--marco' : '')}
                type="button"
                data-pedra={n}
                tabindex="-1"
                aria-label={'Pular para a pedra ' + n}
              >
                <span class="pedra__num">{n}</span>
              </button>
            ))
          }
          <div class="sapo" data-sapo aria-hidden="true">
            <span class="sapo__corpo"><img src="/class/img/sapo-saltador/sapo.png" alt="" /></span>
          </div>
          <div class="fx fx--splash" data-splash aria-hidden="true" hidden>💦</div>
        </div>
      </div>
      <div class="controles" aria-label="Controles do sapo">
        <button class="salto" type="button" data-menos aria-label="Pular uma pedra para trás">−1</button>
        <span class="posicao" data-posicao>🐸 na pedra 0</span>
        <button class="salto" type="button" data-mais aria-label="Pular uma pedra para a frente">+1</button>
        <button class="confirmar" type="button" data-confirmar>É aqui!</button>
      </div>
    </section>

    <!-- Toast + leitor de tela -->
    <div class="toast" data-toast aria-live="polite" hidden></div>
    <p class="sr-only" data-anuncio aria-live="assertive"></p>

    <!-- Modal: instruções + modos -->
    <div class="modal" data-intro>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="intro-title">
        <div class="placa__topo" id="intro-title">🐸 Sapo Saltador — Lago das Esmeraldas</div>
        <div class="placa__corpo">
          <ol class="regras">
            <li>Resolva a <b>continha</b> pulando na reta: <b>+1</b> pra frente, <b>−1</b> pra trás. Chegou? <b>É aqui!</b></li>
            <li>Cada acerto = um <b>salto no lago</b> rumo à 🪷 lótus. Nas bifurcações, <b>escolha o caminho</b>!</li>
            <li>Colete 🟡 <b>moedas</b> e 🌸 <b>flores raras</b> (3 flores = ⭐⭐⭐).</li>
            <li>⚡ <b>Impulso</b>: acerte de primeira e dê um salto duplo!</li>
            <li>💀 <b>Planta carnívora</b>: acerte DE PRIMEIRA e ela paga 10 moedas… erre e ela morde!</li>
            <li>No fim, grave seu <b>nome no ranking</b>! 🏆</li>
          </ol>
          <p class="escolha__titulo">Como você quer jogar?</p>
          <div class="escolha">
            <button class="botao-modo botao-modo--vidas" type="button" data-modo="vidas">
              <span class="botao-modo__titulo">❤️❤️❤️ Com vidas</span>
              <small>A planta carnívora tira um coração. Complete fases pra recuperar. Errar continha normal NUNCA tira vida!</small>
            </button>
            <button class="botao-modo botao-modo--tranquilo" type="button" data-modo="tranquilo">
              <span class="botao-modo__titulo">🛸 Tranquilo</span>
              <small>Sem corações: a planta só empurra o sapo uma casa pra trás. Ninguém perde!</small>
            </button>
          </div>
          <button class="recordes-btn" type="button" data-ver-recordes>🏆 Recordes</button>
        </div>
      </div>
    </div>

    <!-- Modal: fase completa -->
    <div class="modal" data-fase-done hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="fase-done-title">
        <div class="placa__topo" id="fase-done-title" data-fase-done-title>Fase completa!</div>
        <div class="placa__corpo center">
          <p class="grande">🪷 O sapo chegou na lótus!</p>
          <p class="estrelas" data-estrelas aria-label="Estrelas da fase"></p>
          <p class="placar">Pontos: <strong data-fase-score>0</strong></p>
          <p class="aviso" data-fase-next-label></p>
          <button class="botao botao--go" type="button" data-next-fase>Próxima fase</button>
        </div>
      </div>
    </div>

    <!-- Modal: fim da run (vitória OU fim gentil) -->
    <div class="modal" data-fim-run hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="fim-run-title">
        <div class="placa__topo" id="fim-run-title" data-fim-run-title>Fim da aventura!</div>
        <div class="placa__corpo center">
          <p class="grande" data-fim-run-msg></p>
          <p class="placar">Pontuação final: <strong data-fim-run-score>0</strong></p>
          <p class="aviso" data-fim-run-detalhe></p>
          <button class="botao botao--go" type="button" data-gravar-nome>🏆 Gravar meu nome</button>
        </div>
      </div>
    </div>

    <!-- Modal: nome (arcade) -->
    <div class="modal" data-nome hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="nome-title">
        <div class="placa__topo" id="nome-title">Digite seu nome, campeão!</div>
        <div class="placa__corpo center">
          <p class="nome-slots" data-nome-slots aria-live="polite">_ _ _</p>
          <div class="grade-letras" data-grade role="group" aria-label="Letras para o nome">
            {letras.map((l) => (
              <button class="letra" type="button" data-letra={l}>{l}</button>
            ))}
            <button class="letra letra--apagar" type="button" data-nome-apagar aria-label="Apagar letra">⌫</button>
            <button class="letra letra--ok" type="button" data-nome-ok aria-label="Confirmar nome">✓</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: recordes -->
    <div class="modal" data-recordes hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="recordes-title">
        <div class="placa__topo" id="recordes-title">🏆 Recordes do Lago</div>
        <div class="placa__corpo center">
          <ol class="tabela" data-tabela></ol>
          <p class="aviso" data-recordes-vazio hidden>Ninguém gravou o nome ainda. Seja o primeiro! 🐸</p>
          <div class="recordes-acoes">
            <button class="botao botao--go" type="button" data-replay>Jogar de novo</button>
            <button class="botao botao--sec" type="button" data-voltar-intro hidden>Voltar</button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <style is:global>
    body.is-game { background: #12707f; overflow: hidden; }
    body.is-game::before { display: none !important; }

    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
    }

    .ss {
      position: fixed;
      inset: 0;
      /* clip (não hidden): impede o browser de scrollar o jogo pra fora
         da tela se algum filho vazar da viewport */
      overflow: clip;
      font-family: Verdana, Tahoma, 'Segoe UI', Geneva, sans-serif;
      user-select: none;
      -webkit-user-select: none;
      color: #eafaf2;
      display: flex;
      flex-direction: column;
      background: linear-gradient(180deg, #0e5e6e 0%, #12707f 45%, #178a8f 100%);
    }

    /* ===== HUD ===== */
    .hud {
      position: relative; z-index: 30;
      display: flex; align-items: center; gap: 16px;
      padding: 8px 14px;
      background: rgba(6, 50, 55, 0.7);
      color: #fff;
      backdrop-filter: blur(2px);
    }
    .hud__bloco { display: flex; align-items: baseline; gap: 6px; white-space: nowrap; }
    .hud__bloco[hidden] { display: none; }
    .hud__label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.9; }
    .hud__bloco strong { font-size: 1.45rem; line-height: 1; text-shadow: 0 1px 2px rgba(0, 0, 0, 0.4); transition: transform 0.18s ease; }
    .hud__bloco strong.pop { transform: scale(1.4); color: #ffe8a3; }
    .hud__sub { font-size: 0.72rem; opacity: 0.85; }
    .hud__icone { width: 20px; height: 20px; object-fit: contain; align-self: center; }
    .hud__bloco--nome { flex: 1; font-size: 0.9rem; font-weight: 700; opacity: 0.95; justify-content: center; }
    .hud__bloco--vidas { align-items: center; }
    .vidas { font-size: 1.15rem; letter-spacing: 2px; }
    .hud__mute {
      width: 40px; height: 40px; border-radius: 10px; cursor: pointer;
      border: 1px solid rgba(255, 255, 255, 0.55); background: rgba(255, 255, 255, 0.16);
      font-size: 1.1rem; display: grid; place-items: center; color: #fff;
    }
    .hud__mute:hover { background: rgba(255, 255, 255, 0.3); }

    /* ===== Mapa do lago ===== */
    .mapa {
      position: relative; z-index: 10;
      flex: 1;
      overflow: clip;
      background:
        radial-gradient(120% 60% at 50% 0%, rgba(255, 255, 255, 0.08), transparent 60%),
        linear-gradient(180deg, #1d8f96 0%, #17828e 50%, #14747f 100%);
    }
    /* margens com folhagem */
    .mapa::before, .mapa::after {
      content: '';
      position: absolute; top: 0; bottom: 0; width: 34px; z-index: 3;
      pointer-events: none;
      background: linear-gradient(90deg, rgba(20, 90, 50, 0.85), rgba(20, 90, 50, 0));
    }
    .mapa::before { left: 0; }
    .mapa::after { right: 0; transform: scaleX(-1); }
    .lago {
      position: absolute; left: 0; right: 0; top: 0;
      transition: transform 0.6s ease-in-out;
      will-change: transform;
    }
    .lago.sem-transicao { transition: none; }

    /* trilhas pontilhadas */
    .trilha {
      position: absolute;
      border-top: 4px dotted rgba(255, 255, 255, 0.55);
      transform-origin: 0 0;
      pointer-events: none;
    }

    /* vitórias-régias (sprites) */
    .pad {
      position: absolute;
      width: 78px; height: 78px;
      transform: translate(-50%, -50%);
      display: grid; place-items: center;
      padding: 0;
      border: none;
      border-radius: 50%;
      cursor: default;
      font-family: inherit;
      background: url('/class/img/sapo-saltador/pad.png') center / contain no-repeat;
      touch-action: manipulation;
    }
    .pad__icone { font-size: 1.7rem; line-height: 1; filter: drop-shadow(0 2px 3px rgba(0, 0, 0, 0.35)); pointer-events: none; }
    .pad__icone img { display: block; width: 32px; height: auto; }
    .pad__icone--flor img { width: 36px; }
    .pad__icone--lotus img { width: 76px; }
    /* pad da planta: escurece o sprite por dentro do círculo */
    .pad--perigo { box-shadow: inset 0 0 0 999px rgba(12, 34, 16, 0.42); }
    .pad--usado .pad__icone { opacity: 0.35; filter: grayscale(1); }
    .pad--lotus {
      width: 104px; height: 104px;
      box-shadow: 0 0 0 5px rgba(255, 230, 120, 0.7), 0 0 30px 8px rgba(255, 220, 90, 0.45);
      animation: lotus-glow 2.2s ease-in-out infinite alternate;
    }
    @keyframes lotus-glow {
      from { box-shadow: 0 0 0 5px rgba(255, 230, 120, 0.55), 0 0 22px 5px rgba(255, 220, 90, 0.35); }
      to { box-shadow: 0 0 0 6px rgba(255, 230, 120, 0.85), 0 0 38px 12px rgba(255, 220, 90, 0.55); }
    }
    .pad--escolha {
      cursor: pointer;
      background-image: url('/class/img/sapo-saltador/pad-claro.png');
      animation: pad-pulsa 0.9s ease-in-out infinite;
    }
    .pad--escolha:focus-visible { outline: 4px solid #fff; outline-offset: 3px; }
    @keyframes pad-pulsa {
      0%, 100% { box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.65), 0 6px 12px rgba(0, 0, 30, 0.35); }
      50% { box-shadow: 0 0 0 10px rgba(255, 255, 255, 0.25), 0 6px 12px rgba(0, 0, 30, 0.35); }
    }
    .pad--sapo-aqui { box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.85), 0 6px 12px rgba(0, 0, 30, 0.4); }

    /* sapo do mapa */
    .sapo-mapa {
      position: absolute; left: 0; top: 0;
      width: 0; height: 0;
      display: flex; align-items: center; justify-content: center;
      transition: transform 0.65s ease-in-out;
      pointer-events: none;
      z-index: 5;
    }
    .sapo-mapa.sem-transicao { transition: none; }
    .sapo-mapa__corpo {
      display: inline-block;
      filter: drop-shadow(0 4px 5px rgba(0, 0, 30, 0.4));
    }
    /* max-width: none — o reset global (img { max-width: 100% }) colapsa
       a imagem pra 0 dentro da âncora de largura zero */
    .sapo-mapa__corpo img { display: block; width: 58px; max-width: none; height: auto; }
    .sapo-mapa--pula .sapo-mapa__corpo { animation: mapa-pulo 0.65s ease-in-out; }
    @keyframes mapa-pulo {
      0%, 100% { transform: translateY(0) scale(1); }
      50% { transform: translateY(-34px) scale(1.18); }
    }
    .decor { position: absolute; font-size: 1.2rem; opacity: 0.8; pointer-events: none; }

    /* efeito flutuante (+5 🟡 etc.) */
    .ganho {
      position: absolute;
      transform: translate(-50%, -50%);
      font-size: 1.15rem; font-weight: 800; color: #fff;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
      white-space: nowrap;
      pointer-events: none;
      animation: ganho-sobe 1.1s ease-out forwards;
      z-index: 6;
    }
    @keyframes ganho-sobe {
      0% { opacity: 0; margin-top: 8px; }
      15% { opacity: 1; margin-top: 0; }
      100% { opacity: 0; margin-top: -44px; }
    }
    .ganho img { display: inline-block; width: 20px; max-width: none; height: auto; vertical-align: -4px; }

    /* ===== Faixa da continha ===== */
    .faixa {
      position: relative; z-index: 15;
      background: rgba(6, 50, 55, 0.78);
      padding: 6px 10px calc(8px + env(safe-area-inset-bottom));
      display: flex; flex-direction: column; gap: 4px;
    }
    .faixa--inativa .continha, .faixa--inativa .rio, .faixa--inativa .controles { opacity: 0.3; filter: grayscale(0.6); }
    .faixa__aviso {
      position: absolute; inset: 0; z-index: 5;
      display: grid; place-items: center;
      font-size: 1.15rem; font-weight: 800; color: #fff;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.5);
      pointer-events: none;
    }
    .faixa__aviso[hidden] { display: none; }

    .continha {
      align-self: center;
      display: flex; align-items: center; gap: 10px;
      padding: 3px 18px;
      background: #fffdf4;
      border: 3px solid #8a5d33;
      border-radius: 12px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.25);
      font-size: clamp(1.25rem, 3.2vh, 1.6rem);
      font-weight: 800;
      color: #23303c;
    }
    .continha__desafio[hidden] { display: none; }
    .continha--perigo { border-color: #7a2ca0; box-shadow: 0 0 0 3px rgba(160, 70, 220, 0.5), 0 4px 10px rgba(0, 0, 0, 0.25); }
    .continha__op { color: #d97b16; }
    .continha__igual { color: #8a8a8a; }
    .continha__resposta { min-width: 1.3em; text-align: center; color: #b0682a; transition: transform 0.2s ease; }
    .continha--ok .continha__resposta { color: #2e8a28; transform: scale(1.2); }

    /* ===== Reta numérica compacta ===== */
    .rio {
      position: relative;
      border-radius: 12px;
      background: linear-gradient(180deg, rgba(87, 183, 232, 0.4) 0%, #3f96c4 40%, #2f7fae 100%);
      box-shadow: inset 0 4px 10px rgba(0, 0, 40, 0.15);
      overflow-x: auto;
      overscroll-behavior-x: contain;
      touch-action: pan-x;
    }
    .trilho {
      --pedra: clamp(26px, 3.4vw, 42px);
      position: relative;
      width: 100%;
      display: flex; align-items: flex-end; justify-content: space-between;
      padding: 62px 8px 8px;
    }
    .pedra {
      width: var(--pedra);
      aspect-ratio: 1;
      flex-shrink: 0;
      display: grid; place-items: center;
      font-family: inherit;
      border: 2px solid #b09a5f;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 30%, #f4ecd2 0%, #e0d5ac 55%, #c4b384 100%);
      box-shadow: 0 3px 6px rgba(0, 0, 30, 0.35);
      cursor: pointer;
      touch-action: manipulation;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
      padding: 0;
    }
    .pedra:hover { transform: translateY(-2px); }
    .pedra:focus-visible { outline: 3px solid #fff; outline-offset: 2px; }
    .pedra__num { font-size: calc(var(--pedra) * 0.42); font-weight: 800; color: #5a4a26; line-height: 1; }
    .pedra--marco { border-color: #7a8a3a; background: radial-gradient(circle at 35% 30%, #e4f0c0 0%, #c9dd94 55%, #a3bd6a 100%); }
    .pedra--marco .pedra__num { color: #3a5216; }
    .pedra--atual { box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.9), 0 3px 8px rgba(0, 0, 30, 0.4); }
    .pedra--inicio { box-shadow: 0 0 0 3px rgba(46, 138, 40, 0.8), 0 3px 6px rgba(0, 0, 30, 0.35); }
    .pedra--dica { animation: dica 0.9s ease-in-out infinite; }
    @keyframes dica {
      0%, 100% { box-shadow: 0 0 0 2px rgba(255, 214, 64, 0.4), 0 3px 6px rgba(0, 0, 30, 0.35); }
      50% { box-shadow: 0 0 0 7px rgba(255, 214, 64, 0.85), 0 3px 10px rgba(0, 0, 30, 0.4); }
    }

    .sapo {
      position: absolute; left: 0; bottom: calc(8px + var(--pedra) * 0.7);
      width: 0;
      display: flex; justify-content: center;
      transition: transform var(--dur, 320ms) ease-in-out, opacity 0.25s ease;
      pointer-events: none;
      z-index: 5;
    }
    .sapo.sem-transicao { transition: none; }
    .sapo--sumiu { opacity: 0; }
    .sapo__corpo {
      display: inline-block;
      filter: drop-shadow(0 3px 3px rgba(0, 0, 30, 0.35));
    }
    .sapo__corpo img { display: block; width: 34px; max-width: none; height: auto; }
    .sapo--pula .sapo__corpo { animation: pulo var(--dur, 320ms) ease-in-out; }
    @keyframes pulo {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-24px); }
    }
    .sapo--cai .sapo__corpo { animation: cai 0.55s ease-in forwards; }
    @keyframes cai {
      0% { transform: translateY(0) rotate(0deg); opacity: 1; }
      100% { transform: translateY(26px) rotate(24deg); opacity: 0; }
    }
    .fx {
      position: absolute; left: 0;
      width: 0;
      display: flex; justify-content: center;
      pointer-events: none;
      font-size: 1.5rem;
      z-index: 6;
    }
    .fx[hidden] { display: none; }
