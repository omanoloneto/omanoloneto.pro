    // ============================================================
    //  MAPA DO LAGO
    // ============================================================
    const IMG = '/class/img/sapo-saltador/';
    const ICONES = {
      moeda: '<img src="' + IMG + 'moeda.png" alt="">',
      flor: '<img src="' + IMG + 'flor.png" alt="">',
      impulso: '⚡',
      perigo: '💀',
      comum: '',
      lotus: '<img src="' + IMG + 'lotus.png" alt="">',
    };
    const DECOR = ['🐟', '🌼', '🪻', '🦟', '🐌'];

    function gerarMapa(fase) {
      const linhas = [];
      // fileiras 0..saltos: 0 = partida, saltos = lótus
      // bifurcações: sorteadas entre 1..saltos-1, nunca adjacentes
      const candidatas = [];
      for (let i = 1; i < fase.saltos; i++) candidatas.push(i);
      const bifs = new Set();
      for (const i of embaralhar(candidatas)) {
        if (bifs.size >= fase.bifurcacoes) break;
        if (bifs.has(i - 1) || bifs.has(i + 1)) continue;
        bifs.add(i);
      }
      for (let i = 0; i <= fase.saltos; i++) {
        const tipoLinha = i === 0 ? 'partida' : i === fase.saltos ? 'lotus' : bifs.has(i) ? 'bif' : 'solo';
        const qtd = tipoLinha === 'bif' ? 2 : 1;
        linhas.push({ tipo: tipoLinha, pads: Array.from({ length: qtd }, () => ({ tipo: 'comum', usado: false, el: null, x: 0, y: 0 })) });
      }
      // efeitos: perigo só em bifurcação; flor prefere bifurcação (escolha!)
      const slotsBif = [];
      const slotsSolo = [];
      for (let i = 1; i < fase.saltos; i++) {
        for (let p = 0; p < linhas[i].pads.length; p++) {
          (linhas[i].tipo === 'bif' ? slotsBif : slotsSolo).push({ i, p });
        }
      }
      const bifLivres = embaralhar(slotsBif);
      const soloLivres = embaralhar(slotsSolo);
      const pegar = (preferencia) => {
        if (preferencia === 'bif') return bifLivres.pop() || soloLivres.pop();
        return soloLivres.pop() || bifLivres.pop();
      };
      const aplicar = (slot, tipo) => { if (slot) linhas[slot.i].pads[slot.p].tipo = tipo; };
      // perigo: um pad de bifurcação (o irmão fica livre = rota segura)
      for (let n = 0; n < fase.perigos; n++) {
        const slot = bifLivres.pop();
        if (!slot) break;
        linhas[slot.i].pads[slot.p].tipo = 'perigo';
        // remove o irmão da lista de bif livres? não — irmão pode ter flor (dilema bom)
      }
      for (let n = 0; n < fase.flores; n++) {
        const slot = pegar('bif');
        aplicar(slot, 'flor');
        // a irmã da bifurcação não pode receber OUTRA flor (uma sempre
        // se perderia e as 3 estrelas ficariam impossíveis) — move ela
        // pra fila comum, onde vira moeda/impulso sem conflito
        if (slot) {
          const irma = bifLivres.findIndex((s) => s.i === slot.i);
          if (irma !== -1) soloLivres.unshift(...bifLivres.splice(irma, 1));
        }
      }
      for (let n = 0; n < fase.impulsos; n++) aplicar(pegar('solo'), 'impulso');
      for (let n = 0; n < fase.moedas; n++) aplicar(pegar('solo'), 'moeda');
      return linhas;
    }

    function alturaLago(fase) { return (fase.saltos + 1) * ROW_H + 120; }

    function renderMapa() {
      const fase = FASES[estado.faseIdx];
      trilhasEl.innerHTML = '';
      padsEl.innerHTML = '';
      decorEl.innerHTML = '';
      const w = mapaEl.clientWidth || 1;
      const h = alturaLago(fase);
      lagoEl.style.height = h + 'px';
      // posições
      estado.linhas.forEach((linha, i) => {
        const y = h - 70 - i * ROW_H;
        linha.pads.forEach((pad, p) => {
          pad.x = linha.pads.length === 1 ? w * 0.5 : w * (p === 0 ? 0.3 : 0.7);
          pad.y = y;
        });
      });
      // trilhas (cada pad → pads alcançáveis da fileira seguinte)
      for (let i = 0; i < estado.linhas.length - 1; i++) {
        for (const de of estado.linhas[i].pads) {
          for (const ate of estado.linhas[i + 1].pads) {
            const dx = ate.x - de.x;
            const dy = ate.y - de.y;
            const len = Math.hypot(dx, dy);
            const ang = Math.atan2(dy, dx);
            const t = document.createElement('div');
            t.className = 'trilha';
            t.style.left = de.x + 'px';
            t.style.top = de.y + 'px';
            t.style.width = len + 'px';
            t.style.transform = 'rotate(' + ang + 'rad)';
            trilhasEl.appendChild(t);
          }
        }
      }
      // pads
      estado.linhas.forEach((linha, i) => {
        linha.pads.forEach((pad, p) => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.tabIndex = -1;
          btn.className = 'pad' + (linha.tipo === 'lotus' ? ' pad--lotus' : '') + (pad.tipo === 'perigo' ? ' pad--perigo' : '') + (pad.usado ? ' pad--usado' : '');
          btn.dataset.linha = String(i);
          btn.dataset.pad = String(p);
          btn.style.left = pad.x + 'px';
          btn.style.top = pad.y + 'px';
          const tipoIcone = linha.tipo === 'lotus' ? 'lotus' : pad.tipo;
          btn.innerHTML = '<span class="pad__icone pad__icone--' + tipoIcone + '">' + ICONES[tipoIcone] + '</span>';
          btn.setAttribute('aria-label', linha.tipo === 'lotus' ? 'Lótus — chegada' : 'Vitória-régia' + (pad.tipo !== 'comum' ? ' com ' + pad.tipo : ''));
          btn.addEventListener('click', () => escolherPad(i, p));
          padsEl.appendChild(btn);
          pad.el = btn;
        });
      });
      // decoração
      for (let n = 0; n < 8; n++) {
        const d = document.createElement('span');
        d.className = 'decor';
        d.textContent = DECOR[n % DECOR.length];
        d.style.left = (w * (0.12 + Math.random() * 0.76)) + 'px';
        d.style.top = (Math.random() * (h - 60) + 30) + 'px';
        decorEl.appendChild(d);
      }
      posicionarSapoMapa(false);
    }

    function padDoSapo() { return estado.linhas[estado.sapoLinha].pads[estado.sapoPadIdx]; }

    function posicionarSapoMapa(animado) {
      const pad = padDoSapo();
      if (!animado || semMov) {
        sapoMapaEl.classList.add('sem-transicao');
        sapoMapaEl.style.transform = 'translate3d(' + pad.x + 'px, ' + (pad.y - 6) + 'px, 0)';
        void sapoMapaEl.offsetWidth;
        sapoMapaEl.classList.remove('sem-transicao');
      } else {
        sapoMapaEl.style.transform = 'translate3d(' + pad.x + 'px, ' + (pad.y - 6) + 'px, 0)';
        reiniciarAnimacao(sapoMapaEl, 'sapo-mapa--pula');
      }
      for (const linha of estado.linhas) for (const p of linha.pads) p.el && p.el.classList.remove('pad--sapo-aqui');
      pad.el && pad.el.classList.add('pad--sapo-aqui');
      centralizarMapa(animado);
    }

    function centralizarMapa(suave) {
      const fase = FASES[estado.faseIdx];
      const h = alturaLago(fase);
      const vh = mapaEl.clientHeight || 1;
      const pad = padDoSapo();
      let top = pad.y - vh * 0.62;
      top = Math.max(0, Math.min(top, h - vh));
      if (h <= vh) top = h - vh; // lago menor que a tela: encosta no fundo
      if (!suave || semMov) lagoEl.classList.add('sem-transicao');
      lagoEl.style.transform = 'translateY(' + -top + 'px)';
      if (!suave || semMov) { void lagoEl.offsetWidth; lagoEl.classList.remove('sem-transicao'); }
    }

    // ============================================================
    //  PASSO A PASSO (macro-loop)
    // ============================================================
    function prepararPasso() {
      const prox = estado.sapoLinha + 1;
      if (prox >= estado.linhas.length) return; // segurança
      const linha = estado.linhas[prox];
      if (linha.pads.length === 2) {
        estado.fase = 'escolhendo';
        faixaEl.classList.add('faixa--inativa');
        faixaAvisoEl.hidden = false;
        linha.pads.forEach((pad) => {
          pad.el.classList.add('pad--escolha');
          pad.el.tabIndex = 0;
        });
        setTimeout(() => linha.pads[0].el.focus({ preventScroll: true }), 80);
        anunciar('Bifurcação! Escolha uma vitória-régia: esquerda ' + rotuloPad(linha.pads[0]) + ', ou direita ' + rotuloPad(linha.pads[1]) + '. Use as setas ou toque.');
      } else {
        estado.alvo = { linha: prox, padIdx: 0 };
        if (estado.saltoLivrePendente) { estado.saltoLivrePendente = false; executarSalto(); }
        else iniciarContinha();
      }
    }

    function rotuloPad(pad) {
      return { moeda: 'com moeda', flor: 'com flor rara', impulso: 'com impulso', perigo: 'com planta carnívora, cuidado', comum: 'comum' }[pad.tipo];
    }

    function escolherPad(linha, padIdx) {
      if (estado.fase !== 'escolhendo' || linha !== estado.sapoLinha + 1) return;
      const l = estado.linhas[linha];
      l.pads.forEach((pad) => {
        pad.el.classList.remove('pad--escolha');
        pad.el.tabIndex = -1;
      });
      faixaAvisoEl.hidden = true;
      estado.alvo = { linha, padIdx };
      somSaltoLongo();
      if (estado.saltoLivrePendente) { estado.saltoLivrePendente = false; executarSalto(); }
      else iniciarContinha();
    }

    function executarSalto() {
      estado.fase = 'saltando';
      faixaEl.classList.add('faixa--inativa');
      estado.sapoLinha = estado.alvo.linha;
      estado.sapoPadIdx = estado.alvo.padIdx;
      posicionarSapoMapa(true);
      setTimeout(aoAterrissar, semMov ? 80 : 700);
    }

    function aoAterrissar() {
      const linha = estado.linhas[estado.sapoLinha];
      const pad = padDoSapo();
      if (linha.tipo === 'lotus') { faseCompleta(); return; }
      // efeito do pad
      if (!pad.usado && pad.tipo !== 'comum') {
        pad.usado = true;
        if (pad.tipo === 'moeda') {
          estado.moedas += CFG.moedasPorPad;
          popHud('[data-moedas]', estado.moedas);
          somMoeda();
          ganhoNoMapa('+' + CFG.moedasPorPad + ' ' + ICONES.moeda, pad.x, pad.y);
          anunciar('Você pegou ' + CFG.moedasPorPad + ' moedas!');
          pad.el.classList.add('pad--usado');
        } else if (pad.tipo === 'flor') {
          estado.floresFase++;
          popHud('[data-flores]', estado.floresFase);
          somFlor();
          ganhoNoMapa('+1 ' + ICONES.flor, pad.x, pad.y);
          anunciar('Flor rara coletada! ' + estado.floresFase + ' de 3.');
          pad.el.classList.add('pad--usado');
        } else if (pad.tipo === 'impulso') {
          estado.impulsoArmado = true;
          somImpulso();
          ganhoNoMapa('⚡', pad.x, pad.y);
          mostrarToast('⚡ Impulso! Acerte a próxima DE PRIMEIRA e dê um salto duplo!', 'info', 2600);
          anunciar('Impulso! Acerte a próxima continha de primeira pra dar um salto duplo.');
          pad.el.classList.add('pad--usado');
        } else if (pad.tipo === 'perigo') {
          estado.desafioPlanta = true;
          somPlanta();
          mostrarToast('💀 Planta faminta! Acerte DE PRIMEIRA e ela paga ' + CFG.moedasPlanta + ' moedas… erre e ela morde!', 'perigo', 3000);
          anunciar('Cuidado! Planta carnívora. Acerte a próxima continha de primeira, ou ela morde.');
        }
      }
      // salto duplo?
      if (estado.duploGanho && estado.sapoLinha < estado.linhas.length - 1) {
        estado.duploGanho = false;
        estado.saltoLivrePendente = true;
        mostrarToast('⚡ Salto duplo!', 'ok', 1400);
        setTimeout(prepararPasso, semMov ? 100 : 700);
        return;
      }
      estado.duploGanho = false;
      setTimeout(prepararPasso, semMov ? 100 : 500);
    }

    // ============================================================
    //  MICRO-LOOP: continha na reta numérica
    // ============================================================
    function proximaContinha() {
      if (estado.baralhoIdx >= estado.baralho.length) {
        estado.baralho = embaralhar(FASES[estado.faseIdx].pool);
        estado.baralhoIdx = 0;
      }
      return estado.baralho[estado.baralhoIdx++];
    }

    function iniciarContinha() {
      estado.fase = 'resolvendo';
      faixaEl.classList.remove('faixa--inativa');
      faixaAvisoEl.hidden = true;
      const c = proximaContinha();
      estado.continha = c;
      estado.errosNaContinha = 0;
      limparDica();
      $('[data-num-a]').textContent = String(c.a);
      $('[data-op]').textContent = c.op === '+' ? '+' : '−';
      $('[data-num-b]').textContent = String(c.b);
      $('[data-resposta]').textContent = '?';
      $('.continha').classList.remove('continha--ok');
      $('.continha').classList.toggle('continha--perigo', estado.desafioPlanta);
      $('[data-desafio]').hidden = !estado.desafioPlanta;
      posicionarSapoReta(c.a, 'teleporte');
      anunciar((estado.desafioPlanta ? 'Desafio da planta! ' : '') + 'Quanto é ' + c.a + ' ' + nomeOp(c.op) + ' ' + c.b + '? O sapo está na pedra ' + c.a + '.');
    }

    function xDaPedra(n) {
      const p = pedraEls[n];
      return p.offsetLeft + p.offsetWidth / 2;
    }
    function centralizarNaReta(suave) {
      if (rioEl.scrollWidth <= rioEl.clientWidth + 2) return;
      const alvo = trilhoEl.offsetLeft + xDaPedra(estado.pedraAtual) - rioEl.clientWidth / 2;
      rioEl.scrollTo({ left: alvo, behavior: suave && !semMov ? 'smooth' : 'auto' });
    }
    function marcarPedras() {
      const c = estado.continha;
      for (const p of pedraEls) {
        const n = Number(p.dataset.pedra);
        p.classList.toggle('pedra--atual', n === estado.pedraAtual);
        p.classList.toggle('pedra--inicio', !!c && n === c.a && n !== estado.pedraAtual);
      }
    }
    function posicionarSapoReta(n, modo) {
      estado.pedraAtual = n;
      const x = xDaPedra(n);
      if (modo === 'teleporte' || semMov) {
        sapoEl.classList.add('sem-transicao');
        sapoEl.style.transform = 'translateX(' + x + 'px)';
        void sapoEl.offsetWidth;
        sapoEl.classList.remove('sem-transicao');
      } else {
        const dur = modo === 'salto' ? CFG.duracaoSaltoMs : CFG.duracaoPuloMs;
        sapoEl.style.setProperty('--dur', dur + 'ms');
        sapoEl.style.transform = 'translateX(' + x + 'px)';
        reiniciarAnimacao(sapoEl, 'sapo--pula');
      }
      marcarPedras();
      $('[data-posicao]').textContent = '🐸 na pedra ' + n;
      centralizarNaReta(modo !== 'teleporte');
    }
    function limparDica() { for (const p of pedraEls) p.classList.remove('pedra--dica'); }

    function pularCasa(delta) {
      if (estado.fase !== 'resolvendo') return;
      const alvo = estado.pedraAtual + delta;
      if (alvo < CFG.retaMin || alvo > CFG.retaMax) { somLimite(); return; }
      if (delta > 0) somPulo(); else somPuloTras();
      posicionarSapoReta(alvo, 'pulo');
      anunciar('Pedra ' + alvo);
    }
    $('[data-menos]').addEventListener('click', () => pularCasa(-1));
    $('[data-mais]').addEventListener('click', () => pularCasa(1));
    for (const p of pedraEls) {
      p.addEventListener('click', () => {
        if (estado.fase !== 'resolvendo' || estado.animando) return;
        const n = Number(p.dataset.pedra);
        if (n === estado.pedraAtual) return;
        somSaltoLongo();
        estado.animando = true;
        posicionarSapoReta(n, 'salto');
        anunciar('Pedra ' + n);
        setTimeout(() => { estado.animando = false; }, semMov ? 0 : CFG.duracaoSaltoMs);
      });
    }

    function confirmar() {
      if (estado.fase !== 'resolvendo' || estado.animando) return;
      const c = estado.continha;
      if (estado.pedraAtual === c.resultado) {
        // ---- Acertou ----
        const primeira = estado.errosNaContinha === 0;
        limparDica();
        estado.continhasResolvidas++;
        estado.pontos += CFG.pontosPorContinha + (primeira ? CFG.bonusPrimeira : 0);
        popHud('[data-pontos]', estado.pontos);
        somAcerto();
        $('[data-resposta]').textContent = String(c.resultado);
        $('.continha').classList.add('continha--ok');
        anunciar('Muito bem! ' + c.a + ' ' + nomeOp(c.op) + ' ' + c.b + ' é igual a ' + c.resultado + '.');
        // desafio da planta: chegar aqui com o desafio vivo = acertou de primeira
        if (estado.desafioPlanta) {
          estado.desafioPlanta = false;
          estado.moedas += CFG.moedasPlanta;
          popHud('[data-moedas]', estado.moedas);
          somMoeda();
          mostrarToast('🌿 A planta cuspiu +' + CFG.moedasPlanta + ' moedas! Que coragem!', 'ok', 2200);
          padVirouComum(padDoSapo());
        }
        estado.duploGanho = estado.impulsoArmado && primeira;
        estado.impulsoArmado = false;
        setTimeout(executarSalto, semMov ? 200 : 750);
      } else {
        // ---- Errou ----
        estado.errosNaContinha++;
        somSplash();
        splashEl.style.transform = 'translateX(' + xDaPedra(estado.pedraAtual) + 'px)';
        splashEl.hidden = false;
        reiniciarAnimacao(splashEl, 'anima');
        if (!semMov) reiniciarAnimacao(sapoEl, 'sapo--cai');
        if (estado.desafioPlanta) { morder(); return; }
        // erro produtivo normal: volta pra pedra inicial, sem punição
        estado.fase = 'caindo';
        mostrarToast('💦 Quase! Conte os pulos de novo, com calma.', 'err', 1800);
        anunciar('Splash! Essa não é a pedra certa. O sapo voltou pra pedra ' + c.a + '. Tente de novo.');
        setTimeout(() => {
          splashEl.hidden = true;
          sapoEl.classList.remove('sapo--cai');
          sapoEl.classList.add('sapo--sumiu');
          posicionarSapoReta(c.a, 'teleporte');
          void sapoEl.offsetWidth;
          sapoEl.classList.remove('sapo--sumiu');
          if (estado.errosNaContinha >= CFG.errosParaDica) pedraEls[c.resultado].classList.add('pedra--dica');
          estado.fase = 'resolvendo';
        }, semMov ? 250 : 900);
      }
    }
    $('[data-confirmar]').addEventListener('click', confirmar);

    function padVirouComum(pad) {
      pad.tipo = 'comum';
      pad.el.classList.remove('pad--perigo');
      pad.el.classList.add('pad--usado');
      pad.el.querySelector('.pad__icone').textContent = '🌿';
    }

    // A planta mordeu (primeiro erro durante o desafio)
    function morder() {
      estado.fase = 'caindo'; // trava entradas durante a animação
      estado.desafioPlanta = false;
      $('[data-desafio]').hidden = true;
      $('.continha').classList.remove('continha--perigo');
      somPlanta();
      const c = estado.continha;
      if (estado.modo === 'vidas') {
        estado.coracoes--;
        atualizarVidas();
        mostrarToast('😖 Au! A planta mordeu — você perdeu um coração!', 'perigo', 2400);
        anunciar('A planta mordeu! Você perdeu um coração. Vidas: ' + estado.coracoes + '.');
        padVirouComum(padDoSapo());
        if (estado.coracoes <= 0) { setTimeout(() => fimRun(false), 900); return; }
        // continua a mesma continha, agora sem desafio
        setTimeout(() => {
          splashEl.hidden = true;
          sapoEl.classList.remove('sapo--cai');
          posicionarSapoReta(c.a, 'teleporte');
          estado.fase = 'resolvendo';
        }, semMov ? 250 : 900);
      } else {
        // tranquilo: a planta empurra o sapo uma fileira pra trás — pode re-escolher a rota
        mostrarToast('😖 Au! A planta empurrou o sapo pra trás. Escolha o caminho de novo!', 'perigo', 2400);
        anunciar('A planta empurrou o sapo uma casa pra trás. Escolha o caminho de novo.');
        estado.fase = 'saltando';
        setTimeout(() => {
          splashEl.hidden = true;
          sapoEl.classList.remove('sapo--cai');
          estado.sapoLinha = Math.max(0, estado.sapoLinha - 1);
          estado.sapoPadIdx = 0;
          const l = estado.linhas[estado.sapoLinha];
          if (estado.sapoPadIdx >= l.pads.length) estado.sapoPadIdx = 0;
          posicionarSapoMapa(true);
          setTimeout(prepararPasso, semMov ? 100 : 750);
        }, semMov ? 250 : 900);
      }
    }

    // ============================================================
    //  FASES / FIM DE RUN
    // ============================================================
    function montarFase(idx) {
      estado.faseIdx = idx;
      estado.floresFase = 0;
      estado.impulsoArmado = false;
      estado.duploGanho = false;
      estado.desafioPlanta = false;
      estado.saltoLivrePendente = false;
      const fase = FASES[idx];
      estado.baralho = embaralhar(fase.pool);
      estado.baralhoIdx = 0;
      estado.linhas = gerarMapa(fase);
      estado.sapoLinha = 0;
      estado.sapoPadIdx = 0;
      $('[data-fase]').textContent = String(idx + 1);
      $('[data-fase-nome]').textContent = fase.nome;
      $('[data-flores]').textContent = '0';
      $('[data-pontos]').textContent = String(estado.pontos);
      $('[data-moedas]').textContent = String(estado.moedas);
      renderMapa();
      anunciar('Fase ' + (idx + 1) + ': ' + fase.nome + '. ' + fase.descricao);
      prepararPasso();
    }

    function faseCompleta() {
      estado.fase = 'entrefases';
      const ganhoFase = CFG.pontosPorFase + estado.floresFase * CFG.pontosPorFlor;
      estado.pontos += ganhoFase;
      popHud('[data-pontos]', estado.pontos);
      somNivel();
      if (estado.modo === 'vidas' && estado.coracoes < CFG.coracoesMaximos) {
        estado.coracoes++;
        atualizarVidas();
      }
      if (estado.faseIdx >= FASES.length - 1) { fimRun(true); return; }
      $('[data-fase-done-title]').textContent = 'Fase ' + (estado.faseIdx + 1) + ' completa!';
      $('[data-estrelas]').textContent = '⭐'.repeat(Math.max(1, estado.floresFase)) + '☆'.repeat(Math.max(0, 3 - Math.max(1, estado.floresFase)));
      $('[data-fase-score]').textContent = String(estado.pontos);
      const prox = FASES[estado.faseIdx + 1];
      $('[data-fase-next-label]').textContent = 'Próxima: ' + prox.nome + ' — ' + prox.descricao;
      faseDoneModal.hidden = false;
      setTimeout(() => $('[data-next-fase]').focus(), 60);
      anunciar('Fase completa! Você fez ' + ganhoFase + ' pontos com flores e travessia.');
    }
    $('[data-next-fase]').addEventListener('click', () => {
      faseDoneModal.hidden = true;
      montarFase(estado.faseIdx + 1);
    });

    function fimRun(venceu) {
      estado.fase = 'fimRun';
      // moedas viram pontos; corações restantes valem bônus na vitória
      const bonusMoedas = estado.moedas * CFG.pontosPorMoeda;
      const bonusCoracoes = venceu && estado.modo === 'vidas' ? estado.coracoes * CFG.pontosPorCoracao : 0;
      estado.pontos += bonusMoedas + bonusCoracoes;
      popHud('[data-pontos]', estado.pontos);
      if (venceu) somNivel(); else somFimGentil();
      $('[data-fim-run-title]').textContent = venceu ? 'Parabéns, Sapo Mestre! 🐸👑' : 'Que travessia incrível! 🌟';
      $('[data-fim-run-msg]').textContent = venceu
        ? 'Você atravessou o Lago das Esmeraldas inteiro!'
        : 'As plantas venceram desta vez — você chegou na fase ' + (estado.faseIdx + 1) + '!';
      $('[data-fim-run-score]').textContent = String(estado.pontos);
      $('[data-fim-run-detalhe]').textContent =
        estado.continhasResolvidas + ' continhas · ' + estado.moedas + ' moedas (+' + bonusMoedas + ')' +
        (bonusCoracoes ? ' · corações +' + bonusCoracoes : '');
      fimRunModal.hidden = false;
      setTimeout(() => $('[data-gravar-nome]').focus(), 60);
      anunciar((venceu ? 'Você venceu o jogo! ' : 'Fim da aventura! ') + 'Pontuação final: ' + estado.pontos + '. Grave seu nome no ranking.');
    }

    // ============================================================
    //  RANKING ARCADE
    // ============================================================
    function lerRanking() {
      try { return JSON.parse(localStorage.getItem(RANKING_KEY) || '[]'); }
      catch (_) { return []; }
    }
    function salvarRanking(lista) {
      try { localStorage.setItem(RANKING_KEY, JSON.stringify(lista)); } catch (_) {}
    }

    function atualizarSlots() {
      const slots = [];
      for (let i = 0; i < CFG.nomeMax; i++) slots.push(estado.nome[i] || '_');
      $('[data-nome-slots]').textContent = slots.join(' ');
    }

    $('[data-gravar-nome]').addEventListener('click', () => {
      fimRunModal.hidden = true;
      estado.fase = 'nome';
      estado.nome = '';
      atualizarSlots();
      nomeModal.hidden = false;
      setTimeout(() => $('[data-letra="A"]').focus(), 60);
      anunciar('Digite seu nome usando as letras da tela. De ' + CFG.nomeMin + ' a ' + CFG.nomeMax + ' letras. Depois aperte o botão de confirmar.');
    });

    function digitarLetra(l) {
      if (estado.fase !== 'nome') return;
      if (estado.nome.length >= CFG.nomeMax) return;
      estado.nome += l;
      somPulo();
      atualizarSlots();
    }
    function apagarLetra() {
      if (estado.fase !== 'nome' || !estado.nome) return;
      estado.nome = estado.nome.slice(0, -1);
      somPuloTras();
      atualizarSlots();
    }
    function confirmarNome() {
      if (estado.fase !== 'nome') return;
      if (estado.nome.length < CFG.nomeMin) {
        mostrarToast('Escreva pelo menos ' + CFG.nomeMin + ' letras!', 'info', 1800);
        return;
      }
      const lista = lerRanking();
      const entrada = {
        nome: estado.nome,
        pontos: estado.pontos,
        fase: estado.faseIdx + 1,
        modo: estado.modo,
        data: new Date().toISOString().slice(0, 10),
      };
      lista.push(entrada);
      lista.sort((a, b) => b.pontos - a.pontos);
      const corte = lista.slice(0, CFG.rankingMax);
      salvarRanking(corte);
      nomeModal.hidden = true;
      somNivel();
      mostrarRecordes(corte.indexOf(entrada));
    }
    document.querySelectorAll('[data-letra]').forEach((btn) => {
      btn.addEventListener('click', () => digitarLetra(btn.dataset.letra));
    });
    $('[data-nome-apagar]').addEventListener('click', apagarLetra);
    $('[data-nome-ok]').addEventListener('click', confirmarNome);

    function mostrarRecordes(destaque) {
      estado.fase = 'recordes';
      const lista = lerRanking();
      const tabela = $('[data-tabela]');
      tabela.innerHTML = '';
      $('[data-recordes-vazio]').hidden = lista.length > 0;
      lista.forEach((r, i) => {
        const li = document.createElement('li');
        if (i === destaque) li.className = 'novo';
        li.innerHTML =
          '<span class="pos">' + (i + 1) + 'º</span>' +
          '<span class="nome">' + r.nome + '</span>' +
          '<span class="det">fase ' + r.fase + ' · ' + (r.modo === 'vidas' ? '❤️' : '🛸') + '</span>' +
          '<span class="pts">' + r.pontos + '</span>';
        tabela.appendChild(li);
      });
      // veio da intro (consulta) → botão voltar; veio de run → jogar de novo
      const consulta = destaque === undefined;
      $('[data-voltar-intro]').hidden = !consulta;
      $('[data-replay]').hidden = consulta;
      recordesModal.hidden = false;
      setTimeout(() => (consulta ? $('[data-voltar-intro]') : $('[data-replay]')).focus(), 60);
    }
    $('[data-ver-recordes]').addEventListener('click', () => {
      introModal.hidden = true;
      mostrarRecordes(undefined);
    });
    $('[data-voltar-intro]').addEventListener('click', () => {
      recordesModal.hidden = true;
      estado.fase = 'inicio';
      introModal.hidden = false;
      setTimeout(() => $('[data-modo="vidas"]').focus(), 60);
    });
    $('[data-replay]').addEventListener('click', () => {
      recordesModal.hidden = true;
      reiniciar();
    });

    function reiniciar() {
      estado.fase = 'inicio';
      estado.pontos = 0;
      estado.moedas = 0;
      estado.continhasResolvidas = 0;
      estado.floresFase = 0;
      $('[data-pontos]').textContent = '0';
      $('[data-moedas]').textContent = '0';
      $('[data-flores]').textContent = '0';
      vidasWrapEl.hidden = true;
      introModal.hidden = false;
      setTimeout(() => $('[data-modo="vidas"]').focus(), 60);
    }

    // ============================================================
    //  FLUXO / ENTRADA
    // ============================================================
    document.querySelectorAll('[data-modo]').forEach((btn) => {
      btn.addEventListener('click', () => {
        initAudio();
        if (actx && actx.state === 'suspended') actx.resume();
        estado.modo = btn.dataset.modo;
        estado.coracoes = estado.modo === 'vidas' ? CFG.coracoesIniciais : 0;
        vidasWrapEl.hidden = estado.modo !== 'vidas';
        if (estado.modo === 'vidas') atualizarVidas();
        introModal.hidden = true;
        montarFase(0);
      });
    });

    window.addEventListener('keydown', (e) => {
      if (e.repeat || e.ctrlKey || e.altKey || e.metaKey) return;
      if (estado.fase === 'resolvendo') {
        if (e.key === 'ArrowRight') { e.preventDefault(); pularCasa(1); }
        else if (e.key === 'ArrowLeft') { e.preventDefault(); pularCasa(-1); }
        else if (e.key === 'Enter' || e.key === ' ') {
          if (document.activeElement && document.activeElement.tagName === 'BUTTON') return;
          e.preventDefault();
          confirmar();
        }
      } else if (estado.fase === 'escolhendo') {
        const linha = estado.linhas[estado.sapoLinha + 1];
        if (!linha || linha.pads.length !== 2) return;
        if (e.key === 'ArrowLeft') { e.preventDefault(); escolherPad(estado.sapoLinha + 1, 0); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); escolherPad(estado.sapoLinha + 1, 1); }
      } else if (estado.fase === 'nome') {
        const l = e.key.toUpperCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
        if (/^[A-Z]$/.test(l)) { e.preventDefault(); digitarLetra(l); }
        else if (e.key === 'Backspace') { e.preventDefault(); apagarLetra(); }
        else if (e.key === 'Enter') {
          if (document.activeElement && document.activeElement.tagName === 'BUTTON' && document.activeElement.dataset.letra) return;
          e.preventDefault();
          confirmarNome();
        }
      }
    });

    window.addEventListener('resize', () => {
      if (!estado.linhas.length) return;
      renderMapa();
      if (estado.fase === 'escolhendo') {
        const linha = estado.linhas[estado.sapoLinha + 1];
        linha && linha.pads.forEach((pad) => { pad.el.classList.add('pad--escolha'); pad.el.tabIndex = 0; });
      }
      if (estado.continha) posicionarSapoReta(estado.pedraAtual, 'teleporte');
    });

    // ===== Boot =====
    document.body.classList.add('is-game');
    introModal.hidden = false;
    setTimeout(() => $('[data-modo="vidas"]').focus(), 60);
  </script>
</Layout>
