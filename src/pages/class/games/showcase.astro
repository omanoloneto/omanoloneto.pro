---
import Layout from '../../../layouts/Layout.astro';
const title = 'Showcase 3D — Three.js | Manolo Neto';
const description = 'Teste de qualidade 3D com Three.js: carro e rua com PBR, IBL, sombras e pós-processamento.';
---

<Layout title={title} description={description}>
  <main class="sc">
    <div class="sc__cena" data-cena></div>
    <div class="sc__info">
      <strong>Three.js · crepúsculo NFS-style</strong>
      <span>modelo glTF CC0 (clearcoat + vidro) · asfalto molhado (Reflector + poças) · luzes de sódio · IBL do céu · GTAO + Bloom · color grade cinematográfico (split-tone + vinheta + grain)</span>
      <em>arraste pra girar · roda dá zoom</em>
    </div>
  </main>
</Layout>

<style is:global>
  body { margin: 0; }
  .sc { position: fixed; inset: 0; background: #0a0c12; overflow: hidden; font-family: 'Oxanium', Verdana, sans-serif; }
  .sc__cena { position: absolute; inset: 0; }
  .sc__cena canvas { display: block; width: 100%; height: 100%; }
  .sc__info {
    position: absolute; left: 14px; bottom: 14px; z-index: 5;
    display: flex; flex-direction: column; gap: 3px;
    padding: 10px 14px; border-radius: 12px;
    background: rgba(8, 12, 20, 0.55); color: #eaf0ff; backdrop-filter: blur(6px);
    max-width: min(92vw, 560px);
  }
  .sc__info strong { font-size: 0.95rem; }
  .sc__info span { font-size: 0.76rem; opacity: 0.8; line-height: 1.4; }
  .sc__info em { font-size: 0.74rem; opacity: 0.6; font-style: normal; }
</style>

<script>
  import { iniciarShowcase } from '../../../games/showcase/main';
  iniciarShowcase();
</script>
