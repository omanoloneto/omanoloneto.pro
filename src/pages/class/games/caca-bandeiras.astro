    const muteIcon = $('[data-mute-icon]');
    function aplicarMudo() {
      muteBtn.setAttribute('aria-pressed', String(estado.mudo));
      muteIcon.textContent = estado.mudo ? '🔈' : '🔊';
      muteBtn.setAttribute('aria-label', estado.mudo ? 'Ligar o som' : 'Desligar o som');
    }
    (function initMudo() {
      const salvo = localStorage.getItem('caca-bandeiras:mudo');
      estado.mudo = salvo === null ? !CFG.somLigadoInicial : salvo === '1';
      aplicarMudo();
    })();
    muteBtn.addEventListener('click', () => {
      estado.mudo = !estado.mudo;
      localStorage.setItem('caca-bandeiras:mudo', estado.mudo ? '1' : '0');
      aplicarMudo();
    });

    // ===== Utilidades =====
    function anunciar(msg) { anuncioEl.textContent = ''; requestAnimationFrame(() => { anuncioEl.textContent = msg; }); }

    let toastTimer = null;
    function mostrarToast(html, tipo, ms) {
      toastEl.innerHTML = html;
      toastEl.className = 'toast ' + tipo;
      toastEl.hidden = false;
      requestAnimationFrame(() => toastEl.classList.add('show'));
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => {
        toastEl.classList.remove('show');
        setTimeout(() => { toastEl.hidden = true; }, 250);
      }, ms || 2200);
    }

    function atualizarPlacar() {
      const el = $('[data-pontos]');
      el.textContent = String(estado.pontos);
      el.classList.add('pop');
      setTimeout(() => el.classList.remove('pop'), 200);
    }

    function atualizarVidas(pop) {
      let html = '';
      for (let i = 0; i < CFG.vidasMaximas; i++) {
        const cheio = i < estado.vidas;
        html += '<span class="vida' + (cheio ? '' : ' vida--vazia') + (pop && i === estado.vidas - 1 ? ' vida--pop' : '') + '">❤️</span>';
      }
      vidasEl.innerHTML = html;
      vidasWrapEl.setAttribute('aria-label', 'Vidas: ' + estado.vidas + ' de ' + CFG.vidasMaximas);
    }

    // Frases com artigo: "Era o Japão!" / "Era Portugal!" / "no Japão" / "em Cuba"
    function fraseEra(pais) {
      return 'Era ' + (pais.artigo ? pais.artigo + ' ' : '') + pais.nome + '!';
    }
    function fraseEm(iso, nomeFallback) {
      const p = POR_ISO.get(iso);
      if (!p) return 'em ' + nomeFallback;
      const em = { o: 'no', a: 'na', os: 'nos', as: 'nas', '': 'em' }[p.artigo];
      return em + ' ' + p.nome;
    }
    function flagUrl(iso) { return '/class/img/flags/' + iso + '.svg'; }

    // ===== Mapa: viewBox, seleção, pintura =====
    function pathDe(iso) { return svgMapa.querySelector('path[data-iso="' + iso + '"]'); }

    let vbRaf = 0;
    function vbAtual() { return svgMapa.getAttribute('viewBox').split(' ').map(Number); }
    function setVb(a) { svgMapa.setAttribute('viewBox', a.map((n) => n.toFixed(1)).join(' ')); }
    function irPara(alvo, dur) {
      cancelAnimationFrame(vbRaf);
      if (MOTION_REDUZIDO) { setVb(alvo); return; }
      const de = vbAtual();
      const t0 = performance.now();
      dur = dur || 450;
      const passo = (ts) => {
        const k = Math.min(1, (ts - t0) / dur);
        const e = 1 - Math.pow(1 - k, 3);
        setVb(de.map((v, i) => v + (alvo[i] - v) * e));
        if (k < 1) vbRaf = requestAnimationFrame(passo);
      };
      vbRaf = requestAnimationFrame(passo);
    }
    function marcarChip(nome) {
      zoomEl.querySelectorAll('.chip').forEach((c) => c.classList.toggle('chip--on', c.dataset.vb === nome));
    }
    function irParaNome(nome) {
      const vb = VIEWBOXES[nome];
      if (!vb) return;
      irPara(vb.split(' ').map(Number));
      marcarChip(nome);
    }
    zoomEl.querySelectorAll('.chip').forEach((c) => {
      c.addEventListener('click', () => { somClique(); irParaNome(c.dataset.vb); });
    });

    // viewBox que enquadra um conjunto de países (revelação do erro)
    function vbDePaths(els) {
      let x0 = Infinity, y0 = Infinity, x1 = -Infinity, y1 = -Infinity;
      els.forEach((el) => {
        const b = el.getBBox();
        x0 = Math.min(x0, b.x); y0 = Math.min(y0, b.y);
        x1 = Math.max(x1, b.x + b.width); y1 = Math.max(y1, b.y + b.height);
      });
      let w = x1 - x0, h = y1 - y0;
      const pad = 0.45;
      x0 -= w * pad; y0 -= h * pad; w *= 1 + 2 * pad; h *= 1 + 2 * pad;
      if (w < 170) { x0 -= (170 - w) / 2; w = 170; }
      if (h < 100) { y0 -= (100 - h) / 2; h = 100; }
      return [x0, y0, w, h];
    }

    let selecionado = null;
    function podeSelecionar() {
      return estado.fase === 'jogando' || (estado.fase === 'salaRodada' && !sala.respondi);
    }
    function limparSelecao() {
      if (selecionado) selecionado.classList.remove('pais--sel');
      selecionado = null;
      cartuchoEl.hidden = true;
      confirmarBtn.hidden = true;
    }
    function limparPintura() {
      svgMapa.querySelectorAll('.pais--acerto, .pais--erro, .pais--pisca').forEach((p) => {
        p.classList.remove('pais--acerto', 'pais--erro', 'pais--pisca');
      });
      limparSelecao();
    }
    function selecionar(path) {
      if (selecionado) selecionado.classList.remove('pais--sel');
      selecionado = path;
      path.classList.add('pais--sel');
      somClique();
      cartuchoTxtEl.textContent = '📍 ' + path.dataset.nome + ' — é esse?';
      confirmarBtn.hidden = false;
      cartuchoEl.hidden = false;
      anunciar(path.dataset.nome + ' selecionado. Toque de novo pra confirmar.');
    }
    function mostrarCartuchoInfo(txt) {
      cartuchoTxtEl.textContent = txt;
      confirmarBtn.hidden = true;
      cartuchoEl.hidden = false;
    }
    mapaWrap.addEventListener('click', (e) => {
      if (!podeSelecionar()) return;
      const path = e.target.closest && e.target.closest('path[data-iso]');
      if (!path) { limparSelecao(); return; }
      if (path === selecionado) { confirmarResposta(); return; }
      selecionar(path);
    });
    confirmarBtn.addEventListener('click', confirmarResposta);

    function confirmarResposta() {
      if (!selecionado) return;
      const iso = selecionado.dataset.iso;
      if (estado.fase === 'jogando') resolverTreino(iso);
      else if (estado.fase === 'salaRodada') enviarRespostaSala(iso);
    }

    // mini-confete (12 partículas CSS, sem lib)
    function confete() {
      if (MOTION_REDUZIDO) return;
      const cores = ['#22e0ff', '#2ee08a', '#ffd23f', '#ff3d81'];
      for (let i = 0; i < 12; i++) {
        const p = document.createElement('span');
        p.style.cssText =
          'position:absolute;z-index:55;width:8px;height:8px;border-radius:2px;pointer-events:none;' +
          'left:' + (35 + Math.random() * 30) + '%;top:30%;background:' + cores[i % 4] + ';' +
          'transition:transform 0.9s ease-out, opacity 0.9s ease-out;';
        $('.mapa-area').appendChild(p);
        requestAnimationFrame(() => {
          p.style.transform = 'translate(' + (Math.random() * 220 - 110) + 'px,' + (120 + Math.random() * 160) + 'px) rotate(' + (Math.random() * 500 - 250) + 'deg)';
          p.style.opacity = '0';
        });
        setTimeout(() => p.remove(), 950);
      }
    }

    // ===== Bandeira da vez =====
    function setBandeira(iso) {
      bandeiraEl.src = flagUrl(iso);
      alvoEl.hidden = false;
    }

    // ===== TREINO =====
    function sortearFila(nivel) {
      const pool = PAISES.filter((p) => p.dificuldade <= nivel.dificuldadeMax);
      const novatos = pool.filter((p) => p.dificuldade === nivel.dificuldadeMax);
      const resto = pool.filter((p) => p.dificuldade < nivel.dificuldadeMax);
      const fila = [];
      for (let n = 0; n < nivel.quantas; n++) {
        const deNovato = novatos.length && (Math.random() < nivel.pesoNovato || !resto.length);
        const origem = deNovato ? novatos : resto;
        fila.push(origem.splice(Math.floor(Math.random() * origem.length), 1)[0]);
      }
      return fila;
    }

    function prepararNivel(idx) {
      estado.nivelIdx = idx;
      estado.acertosNoNivel = 0;
      estado.fila = sortearFila(NIVEIS[idx]);
      $('[data-nivel]').textContent = String(idx + 1);
      anunciar('Nível ' + (idx + 1) + ': ' + NIVEIS[idx].nome + '.');
    }

    let bannerTimer = null;
    function mostrarBannerNivel(titulo, sub) {
      $('[data-banner-titulo]').textContent = titulo;
      $('[data-banner-sub]').textContent = sub;
      bannerEl.hidden = false;
      bannerEl.classList.remove('show');
      void bannerEl.offsetWidth;
      bannerEl.classList.add('show');
      clearTimeout(bannerTimer);
      bannerTimer = setTimeout(() => { bannerEl.hidden = true; }, CFG.bannerNivelMs);
    }

    function proximaBandeira() {
      if (estado.modo === 'sala') return;
      limparPintura();
      estado.fase = 'jogando';
      estado.alvo = estado.fila[0];
      estado.fila.shift();
      estado.bandeiraInicio = performance.now();
      estado.pausaAcum = 0;
      setBandeira(estado.alvo.iso);
      statusEl.textContent = 'Acertos no nível: ' + estado.acertosNoNivel + ' de ' + NIVEIS[estado.nivelIdx].quantas;
      const nivel = NIVEIS[estado.nivelIdx];
      irParaNome(nivel.zoomAjuda ? estado.alvo.continente : 'mundo');
      // pré-carrega a próxima bandeira
      if (estado.fila[0]) { const img = new Image(); img.src = flagUrl(estado.fila[0].iso); }
      anunciar('Nova bandeira! Encontre o país no mapa.');
    }

    function resolverTreino(iso) {
      const alvo = estado.alvo;
      const certoEl = pathDe(alvo.iso);
      const clicadoEl = selecionado;
      const acertou = iso === alvo.iso;
      estado.fase = 'revelando';
      clicadoEl.classList.remove('pais--sel');
      selecionado = null;
      confirmarBtn.hidden = true;

      if (acertou) {
        const decorrido = performance.now() - estado.bandeiraInicio - estado.pausaAcum;
        const bonus = Math.round(CFG.bonusVelocidadeMax * Math.max(0, 1 - decorrido / CFG.tempoBonusMs));
        const ganho = CFG.pontosAcerto + bonus;
        estado.pontos += ganho;
        atualizarPlacar();
        estado.streak++;
        estado.acertosNoNivel++;
        statusEl.textContent = 'Acertos no nível: ' + estado.acertosNoNivel + ' de ' + NIVEIS[estado.nivelIdx].quantas;
        certoEl.classList.add('pais--acerto');
        somAcertoJogo();
        confete();
        mostrarCartuchoInfo('🎉 ' + fraseEra(alvo) + ' +' + ganho + ' pontos');
        anunciar('Acertou! ' + fraseEra(alvo) + ' Mais ' + ganho + ' pontos.');
        if (estado.modo === 'vidas' && estado.streak % CFG.acertosPraRecuperarVida === 0 && estado.vidas < CFG.vidasMaximas) {
          estado.vidas++;
          atualizarVidas(true);
          mostrarToast('💖 ' + CFG.acertosPraRecuperarVida + ' seguidos — coração recuperado!', 'ok', 1800);
        }
      } else {
        estado.streak = 0;
        estado.fila.push(alvo); // a bandeira errada volta mais tarde
        clicadoEl.classList.add('pais--erro');
        certoEl.classList.add('pais--acerto', 'pais--pisca');
        irPara(vbDePaths([clicadoEl, certoEl]));
        somErroJogo();
        const frase = 'Você clicou ' + fraseEm(iso, clicadoEl.dataset.nome) + '. ' + fraseEra(alvo);
        mostrarCartuchoInfo('💫 ' + frase);
        anunciar(frase);
        if (estado.modo === 'vidas') {
          estado.vidas--;
          atualizarVidas(false);
        }
      }
      setTimeout(() => posRevelacao(acertou), CFG.revelacaoMs);
    }

    function posRevelacao(acertou) {
      if (estado.modo === 'sala') return;
      if (estado.modo === 'vidas' && estado.vidas <= 0) { fimDeJogo(); return; }
      if (acertou && estado.acertosNoNivel >= NIVEIS[estado.nivelIdx].quantas) {
        estado.pontos += CFG.bonusNivel;
        atualizarPlacar();
        if (estado.nivelIdx >= NIVEIS.length - 1) { venceu(); return; }
        prepararNivel(estado.nivelIdx + 1);
        somNivel();
        mostrarBannerNivel('NÍVEL ' + (estado.nivelIdx + 1), NIVEIS[estado.nivelIdx].nome);
        mostrarToast('⭐ Nível completo! +' + CFG.bonusNivel + ' pontos', 'ok', 1800);
        setTimeout(proximaBandeira, CFG.respiroEntreNiveisMs);
        return;
      }
      proximaBandeira();
    }

    function comecarTreino(modo) {
      initAudio();
      if (actx && actx.state === 'suspended') actx.resume();
      estado.modo = modo;
      estado.pontos = 0;
      estado.streak = 0;
      estado.vidas = modo === 'vidas' ? CFG.vidasIniciais : 0;
      vidasWrapEl.hidden = modo !== 'vidas';
      if (modo === 'vidas') atualizarVidas(false);
      atualizarPlacar();
      $('[data-hud-nivel]').hidden = false;
      $('[data-hud-rodada]').hidden = true;
      $('[data-pause]').hidden = false;
      zoomEl.hidden = false;
      tempoWrapEl.hidden = true;
      introModal.hidden = true;
      prepararNivel(0);
      proximaBandeira();
    }
    document.querySelectorAll('[data-modo]').forEach((btn) => {
      btn.addEventListener('click', () => comecarTreino(btn.dataset.modo));
    });

    function venceu() {
      estado.fase = 'vitoria';
      somNivel();
      $('[data-final-score]').textContent = String(estado.pontos);
      $('[data-final-msg]').textContent = 'Você encontrou países nos 6 continentes! 🗺️';
      const gravar = winModal.querySelector('[data-gravar-nome]');
      gravar.hidden = estado.modo !== 'vidas';
      winModal.hidden = false;
      setTimeout(() => (gravar.hidden ? $('[data-replay]') : gravar).focus(), 60);
      anunciar('Parabéns! Você venceu com ' + estado.pontos + ' pontos.');
    }

    function fimDeJogo() {
      estado.fase = 'fim';
      somFimGentil();
      $('[data-fim-msg]').textContent = 'Você chegou ao nível ' + (estado.nivelIdx + 1) + ' — ' + NIVEIS[estado.nivelIdx].nome + '!';
      $('[data-fim-score]').textContent = String(estado.pontos);
      const gravar = fimModal.querySelector('[data-gravar-nome]');
      gravar.hidden = estado.modo !== 'vidas';
      fimModal.hidden = false;
      setTimeout(() => (gravar.hidden ? $('[data-replay-fim]') : gravar).focus(), 60);
      anunciar('Fim da viagem! Você fez ' + estado.pontos + ' pontos.');
    }

    function reiniciar() {
      estado.fase = 'inicio';
      estado.modo = null;
      limparPintura();
      [pausaModal, winModal, fimModal, entradaModal, recordesModal,
        salaMenuModal, salaCriarModal, salaLobbyModal, salaFimModal].forEach((m) => { m.hidden = true; });
      alvoEl.hidden = true;
      zoomEl.hidden = true;
      cartuchoEl.hidden = true;
      seloEl.hidden = true;
      painelRevEl.hidden = true;
      contagemEl.hidden = true;
      bannerEl.hidden = true;
      vidasWrapEl.hidden = true;
      $('[data-hud-nivel]').hidden = true;
      $('[data-hud-rodada]').hidden = true;
      $('[data-hud-nome]').textContent = '';
      $('[data-pause]').hidden = true;
      raizEl.classList.remove('cb--telao');
      estado.pontos = 0;
      atualizarPlacar();
      irParaNome('mundo');
      introModal.hidden = false;
      setTimeout(() => $('[data-modo="vidas"]').focus(), 60);
    }
    $('[data-replay]').addEventListener('click', reiniciar);
    $('[data-replay-fim]').addEventListener('click', reiniciar);

    // ===== Pausa (só treino — a sala corre no relógio do servidor) =====
    function pausar() {
      if (estado.fase !== 'jogando') return;
      estado.fase = 'pausado';
      estado.pausaDesde = performance.now();
      pausaModal.hidden = false;
      setTimeout(() => $('[data-continuar]').focus(), 60);
      anunciar('Jogo pausado.');
    }
    function continuarJogo() {
      if (estado.fase !== 'pausado') return;
      estado.pausaAcum += performance.now() - estado.pausaDesde;
      pausaModal.hidden = true;
      estado.fase = 'jogando';
      anunciar('Jogo continuando!');
    }
    $('[data-pause]').addEventListener('click', pausar);
    $('[data-continuar]').addEventListener('click', continuarJogo);
    $('[data-recomecar]').addEventListener('click', () => { pausaModal.hidden = true; reiniciar(); });

    // ===== Entrada arcade (nome do ranking / nome da sala / código da sala) =====
    let entradaCtx = null; // {titulo, min, max, valor, aoConfirmar(valor), aoVoltar()}
    function abrirEntrada(ctx) {
      entradaCtx = Object.assign({ valor: '' }, ctx);
      estado.fase = 'entrada';
      $('[data-entrada-titulo]').textContent = ctx.titulo;
      atualizarSlots();
      [winModal, fimModal, salaMenuModal, salaCriarModal].forEach((m) => { m.hidden = true; });
      entradaModal.hidden = false;
      setTimeout(() => $('[data-tecla-nome="A"]').focus(), 60);
      anunciar(ctx.titulo + '. Use as letras da tela: de ' + ctx.min + ' a ' + ctx.max + ' letras.');
    }
    function atualizarSlots() {
      const slots = [];
      for (let i = 0; i < entradaCtx.max; i++) slots.push(entradaCtx.valor[i] || '_');
      $('[data-entrada-slots]').textContent = slots.join(' ');
    }
    function digitarLetra(l) {
      if (estado.fase !== 'entrada' || entradaCtx.valor.length >= entradaCtx.max) return;
      entradaCtx.valor += l;
      somClique();
      atualizarSlots();
    }
    function apagarLetra() {
      if (estado.fase !== 'entrada' || !entradaCtx.valor) return;
      entradaCtx.valor = entradaCtx.valor.slice(0, -1);
      somClique();
      atualizarSlots();
    }
    function confirmarEntrada() {
      if (estado.fase !== 'entrada') return;
      if (entradaCtx.valor.length < entradaCtx.min) {
        mostrarToast('Escreva pelo menos ' + entradaCtx.min + ' letras!', 'info', 1800);
        return;
      }
      entradaModal.hidden = true;
      entradaCtx.aoConfirmar(entradaCtx.valor);
    }
    document.querySelectorAll('[data-tecla-nome]').forEach((btn) => {
      btn.addEventListener('click', () => digitarLetra(btn.dataset.teclaNome));
    });
    $('[data-nome-apagar]').addEventListener('click', apagarLetra);
    $('[data-nome-ok]').addEventListener('click', confirmarEntrada);
    $('[data-entrada-voltar]').addEventListener('click', () => {
      entradaModal.hidden = true;
      if (entradaCtx && entradaCtx.aoVoltar) entradaCtx.aoVoltar();
      else reiniciar();
    });

    // ===== Ranking online (padrão do site: online + cache/fallback local) =====
    function lerRanking() {
      try { return JSON.parse(localStorage.getItem(RANKING_KEY) || '[]'); }
      catch (_) { return []; }
    }
    function salvarRanking(lista) {
      try { localStorage.setItem(RANKING_KEY, JSON.stringify(lista)); } catch (_) {}
    }
    function fetchRanking(opts) {
      const ctl = new AbortController();
      const timer = setTimeout(() => ctl.abort(), 4000);
      const url = opts ? API_RANKING : API_RANKING + '?jogo=' + JOGO_ID;
      return fetch(url, Object.assign({ signal: ctl.signal }, opts || {}))
        .then((r) => (r.ok ? r.json() : null))
        .then((lista) => (Array.isArray(lista) ? lista : null))
        .catch(() => null)
        .finally(() => clearTimeout(timer));
    }
    function enviarRankingOnline(entrada) {
      return fetchRanking({
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ jogo: JOGO_ID, nome: entrada.nome, pontos: entrada.pontos, nivel: entrada.nivel }),
      });
    }
    function indiceDe(lista, entrada) {
      return lista.findIndex((r) => r.nome === entrada.nome && r.pontos === entrada.pontos && r.data === entrada.data);
    }
    function renderRecordes(lista, destaque, consulta, fonte) {
      const tabela = $('[data-tabela]');
      tabela.innerHTML = '';
      $('[data-recordes-vazio]').hidden = lista.length > 0;
      lista.forEach((r, i) => {
        const li = document.createElement('li');
        if (i === destaque) li.className = 'novo';
        li.innerHTML =
          '<span class="pos">' + (i + 1) + 'º</span>' +
          '<span class="nome">' + r.nome + '</span>' +
          '<span class="det">nível ' + r.nivel + '</span>' +
          '<span class="pts">' + r.pontos + '</span>';
        tabela.appendChild(li);
      });
      const fonteEl = $('[data-recordes-fonte]');
      if (fonte === 'online') fonteEl.textContent = '🌐 Ranking online — vale pra turma toda!';
      else if (fonte === 'offline') fonteEl.textContent = '📴 Sem internet agora: mostrando o ranking deste aparelho.';
      else fonteEl.textContent = 'Buscando o ranking online…';
      $('[data-voltar-intro]').hidden = !consulta;
      $('[data-recordes-replay]').hidden = consulta;
    }
    function abrirRecordes(consulta, entrada) {
      estado.fase = 'recordes';
      const local = lerRanking();
      const idxLocal = entrada ? indiceDe(local, entrada) : -1;
      renderRecordes(local, idxLocal, consulta, 'buscando');
      recordesModal.hidden = false;
      setTimeout(() => (consulta ? $('[data-voltar-intro]') : $('[data-recordes-replay]')).focus(), 60);
      const pedido = entrada ? enviarRankingOnline(entrada) : fetchRanking(null);
      pedido.then((listaOnline) => {
        if (estado.fase !== 'recordes') return;
        if (listaOnline) {
          salvarRanking(listaOnline);
          renderRecordes(listaOnline, entrada ? indiceDe(listaOnline, entrada) : -1, consulta, 'online');
        } else {
          renderRecordes(local, idxLocal, consulta, 'offline');
        }
      });
    }
    document.querySelectorAll('[data-gravar-nome]').forEach((btn) => {
      btn.addEventListener('click', () => {
        abrirEntrada({
          titulo: 'Digite seu nome, explorador!',
          min: CFG.nomeMin, max: CFG.nomeMax,
          aoConfirmar: (nome) => {
            const entrada = {
              nome: nome.toUpperCase(),
              pontos: estado.pontos,
              nivel: estado.nivelIdx + 1,
              data: new Date().toISOString().slice(0, 10),
            };
            const local = lerRanking();
            local.push(entrada);
            local.sort((a, b) => b.pontos - a.pontos);
            salvarRanking(local.slice(0, CFG.rankingMax));
            somNivel();
            abrirRecordes(false, entrada);
          },
          aoVoltar: () => { (estado.modo === 'vidas' && estado.vidas <= 0 ? fimModal : winModal).hidden = false; estado.fase = estado.vidas <= 0 ? 'fim' : 'vitoria'; },
        });
      });
    });
    $('[data-ver-recordes]').addEventListener('click', () => {
      introModal.hidden = true;
      abrirRecordes(true, null);
    });
    $('[data-voltar-intro]').addEventListener('click', () => {
      recordesModal.hidden = true;
      estado.fase = 'inicio';
      introModal.hidden = false;
      setTimeout(() => $('[data-modo="vidas"]').focus(), 60);
    });
    $('[data-recordes-replay]').addEventListener('click', () => {
      recordesModal.hidden = true;
      reiniciar();
    });

    // ===== SALA (multiplayer via polling) =====
    async function apiSalas(body) {
      const ctl = new AbortController();
      const timer = setTimeout(() => ctl.abort(), 6000);
      try {
        const r = await fetch(API_SALAS, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
          signal: ctl.signal,
        });
        return await r.json();
      } catch (_) {
        return null;
      } finally {
        clearTimeout(timer);
      }
    }
    async function apiEstado() {
      const ctl = new AbortController();
      const timer = setTimeout(() => ctl.abort(), 6000);
      try {
        const r = await fetch(API_SALAS + '?codigo=' + sala.codigo + '&token=' + sala.token, { signal: ctl.signal });
        return await r.json();
      } catch (_) {
        return null;
      } finally {
        clearTimeout(timer);
      }
    }

    function guardarSessao() {
      try {
        sessionStorage.setItem(SESSAO_SALA_KEY, JSON.stringify({
          codigo: sala.codigo, token: sala.token, nome: sala.nome, telao: sala.telao,
        }));
      } catch (_) {}
    }
    function limparSessao() {
      try { sessionStorage.removeItem(SESSAO_SALA_KEY); } catch (_) {}
    }

    function iniciarPoll() {
      sala.pollAtivo = true;
      loopPoll();
    }
    function pararPoll() {
      sala.pollAtivo = false;
      clearTimeout(sala.pollTimer);
    }
    async function loopPoll() {
      if (!sala.pollAtivo) return;
      const r = await apiEstado();
      if (!sala.pollAtivo) return;
      tratarEstadoSala(r);
      const base = r && r.fase === 'lobby' ? CFG.salaPollLobbyMs : CFG.salaPollMs;
      const jitter = (Math.random() * 2 - 1) * CFG.salaJitterMs;
      sala.pollTimer = setTimeout(loopPoll, base + jitter);
    }
    function pollAgora() {
      clearTimeout(sala.pollTimer);
      sala.pollTimer = setTimeout(loopPoll, 150);
    }

    function tratarEstadoSala(r) {
      if (!r) {
        sala.falhas++;
        conexaoEl.hidden = sala.falhas < 3;
        return;
      }
      sala.falhas = 0;
      conexaoEl.hidden = true;
      if (r.erro) { sairDaSala('A sala fechou: ' + r.erro); return; }
      switch (r.fase) {
        case 'lobby': renderLobby(r); break;
        case 'contagem': renderContagem(r); break;
        case 'rodada': renderRodadaSala(r); break;
        case 'revelacao': renderRevelacaoSala(r); break;
        case 'fim': pararPoll(); renderPodio(r); break;
      }
    }

    function entrarModoSala() {
      estado.modo = 'sala';
      estado.pontos = 0;
      atualizarPlacar();
      introModal.hidden = true;
      $('[data-hud-nivel]').hidden = true;
      $('[data-hud-rodada]').hidden = false;
      $('[data-pause]').hidden = true;
      vidasWrapEl.hidden = true;
      $('[data-hud-nome]').textContent = sala.nome ? '🧑‍🚀 ' + sala.nome : '';
      raizEl.classList.toggle('cb--telao', sala.telao);
    }

    function sairDaSala(msg) {
      pararPoll();
      limparSessao();
      if (msg) mostrarToast(msg, 'info', 2600);
      reiniciar();
    }
    document.querySelectorAll('[data-sala-sair]').forEach((b) => b.addEventListener('click', () => sairDaSala()));

    // --- fluxo de criação/entrada ---
    $('[data-abrir-sala]').addEventListener('click', () => {
      initAudio();
      if (actx && actx.state === 'suspended') actx.resume();
      estado.fase = 'salaMenu';
      introModal.hidden = true;
      salaMenuModal.hidden = false;
    });
    $('[data-sala-menu-voltar]').addEventListener('click', () => {
      salaMenuModal.hidden = true;
      estado.fase = 'inicio';
      introModal.hidden = false;
    });
    $('[data-sala-criar-btn]').addEventListener('click', () => {
      estado.fase = 'salaCriar';
      salaMenuModal.hidden = true;
      salaCriarModal.hidden = false;
    });
    $('[data-sala-criar-voltar]').addEventListener('click', () => {
      salaCriarModal.hidden = true;
      estado.fase = 'salaMenu';
      salaMenuModal.hidden = false;
    });
    // grupos de opções (chips exclusivos)
    [['data-op-dificuldade', 'dificuldade', String], ['data-op-rodadas', 'rodadas', Number], ['data-op-tempo', 'rodadaMs', Number]].forEach(([attr, chave, conv]) => {
      const grupo = $('[' + attr + ']');
      grupo.querySelectorAll('.chip--op').forEach((c) => {
        c.addEventListener('click', () => {
          grupo.querySelectorAll('.chip--op').forEach((x) => x.classList.remove('chip--on'));
          c.classList.add('chip--on');
          sala.opcoes[chave] = conv(c.dataset.op);
          somClique();
        });
      });
    });
    $('[data-sala-criar-ok]').addEventListener('click', () => {
      sala.opcoes.telao = $('[data-op-telao]').checked;
      salaCriarModal.hidden = true;
      abrirEntrada({
        titulo: sala.opcoes.telao ? 'Nome do professor' : 'Digite seu nome!',
        min: CFG.nomeMin, max: CFG.nomeMax,
        aoConfirmar: async (nome) => {
          const r = await apiSalas({
            acao: 'criar',
            dificuldade: sala.opcoes.dificuldade,
            rodadas: sala.opcoes.rodadas,
            rodadaMs: sala.opcoes.rodadaMs,
            nome,
            telao: sala.opcoes.telao,
          });
          if (!r || r.erro) { mostrarToast(r && r.erro ? r.erro : 'Sem conexão — tente de novo.', 'info', 2600); reiniciar(); return; }
          sala.codigo = r.codigo;
          sala.token = r.token;
          sala.nome = nome;
          sala.telao = sala.opcoes.telao;
          sala.souHost = true;
          sala.rodadaVista = -1;
          sala.revelacaoVista = -1;
          guardarSessao();
          entrarModoSala();
          estado.fase = 'salaLobby';
          $('[data-lobby-codigo]').textContent = r.codigo; // sem esperar o 1º poll
          salaLobbyModal.hidden = false;
          iniciarPoll();
        },
        aoVoltar: () => { estado.fase = 'salaCriar'; salaCriarModal.hidden = false; },
      });
    });
    $('[data-sala-entrar-btn]').addEventListener('click', () => {
      salaMenuModal.hidden = true;
      abrirEntrada({
        titulo: 'Código da sala',
        min: 4, max: 4,
        aoConfirmar: (codigo) => {
          abrirEntrada({
            titulo: 'Digite seu nome!',
            min: CFG.nomeMin, max: CFG.nomeMax,
            aoConfirmar: async (nome) => {
              const r = await apiSalas({ acao: 'entrar', codigo, nome });
              if (!r || r.erro) {
                mostrarToast(r && r.erro ? r.erro : 'Sem conexão — tente de novo.', 'info', 2600);
                estado.fase = 'salaMenu';
                salaMenuModal.hidden = false;
                return;
              }
              sala.codigo = codigo;
              sala.token = r.token;
              sala.nome = nome;
              sala.telao = false;
              sala.souHost = false;
              sala.rodadaVista = -1;
              sala.revelacaoVista = -1;
              guardarSessao();
              entrarModoSala();
              estado.fase = 'salaLobby';
              $('[data-lobby-codigo]').textContent = codigo;
              salaLobbyModal.hidden = false;
              iniciarPoll();
            },
            aoVoltar: () => { estado.fase = 'salaMenu'; salaMenuModal.hidden = false; },
          });
        },
        aoVoltar: () => { estado.fase = 'salaMenu'; salaMenuModal.hidden = false; },
      });
    });
    $('[data-sala-comecar]').addEventListener('click', async () => {
      const r = await apiSalas({ acao: 'comecar', codigo: sala.codigo, token: sala.token });
      if (r && r.erro) mostrarToast(r.erro, 'info', 2200);
      pollAgora();
    });

    // --- renders por fase ---
    function fecharModaisSala() {
      salaLobbyModal.hidden = true;
      salaFimModal.hidden = true;
      contagemEl.hidden = true;
    }

    function renderLobby(r) {
      estado.fase = 'salaLobby';
      sala.souHost = r.souHost;
      sala.cfgSala = r.cfg;
      salaLobbyModal.hidden = false;
      $('[data-lobby-codigo]').textContent = r.codigo;
      $('[data-lobby-chame]').textContent = sala.souHost ? 'Chame a turma com o código:' : 'Você está dentro! Código:';
      const tempos = { 15000: '15s', 20000: '20s', 30000: '30s' };
      const dif = { facil: '😀 Fácil', medio: '🙂 Médio', dificil: '🤓 Difícil' };
      $('[data-lobby-info]').textContent =
        (dif[r.cfg.dificuldade] || r.cfg.dificuldade) + ' · ' + r.cfg.rodadas + ' rodadas · ' + (tempos[r.cfg.rodadaMs] || r.cfg.rodadaMs + 'ms') +
        ' — ' + r.jogadores.length + (r.jogadores.length === 1 ? ' explorador' : ' exploradores');
      const nomesEl = $('[data-lobby-nomes]');
      nomesEl.innerHTML = '';
      r.jogadores.forEach((n) => {
        const s = document.createElement('span');
        s.textContent = n;
        nomesEl.appendChild(s);
      });
      const comecarBtn = $('[data-sala-comecar]');
      comecarBtn.hidden = !sala.souHost;
      comecarBtn.disabled = r.jogadores.length < 1;
      if (!sala.souHost) anunciarUmaVez('lobby', 'Você entrou na sala. Espere o professor começar.');
    }

    const anunciados = new Set();
    function anunciarUmaVez(chave, msg) {
      if (anunciados.has(chave)) return;
      anunciados.add(chave);
      anunciar(msg);
    }

    let ultimaContagem = -1;
    function renderContagem(r) {
      fecharModaisSala();
      estado.fase = 'salaContagem';
      alvoEl.hidden = true;
      contagemEl.hidden = false;
      const n = Math.max(1, Math.ceil(r.restanteMs / 1000));
      $('[data-contagem-num]').textContent = String(n);
      if (n !== ultimaContagem) { ultimaContagem = n; somTic(); }
      anunciarUmaVez('contagem', 'A partida vai começar!');
    }

    function setTimerBase(restanteMs, totalMs) {
      sala.timerBase = { restanteMs, em: performance.now(), totalMs };
      cancelAnimationFrame(sala.timerRaf);
      const passo = () => {
        if (!sala.timerBase) return;
        const passado = performance.now() - sala.timerBase.em;
        const resta = Math.max(0, sala.timerBase.restanteMs - passado);
        tempoFillEl.style.transform = 'scaleX(' + (resta / sala.timerBase.totalMs) + ')';
        if (resta > 0 && (estado.fase === 'salaRodada' || estado.fase === 'salaRevelacao')) {
          sala.timerRaf = requestAnimationFrame(passo);
        }
      };
      sala.timerRaf = requestAnimationFrame(passo);
    }

    function renderRodadaSala(r) {
      if (sala.rodadaVista !== r.rodada) {
        sala.rodadaVista = r.rodada;
        sala.respondi = r.respondi;
        fecharModaisSala();
        limparPintura();
        painelRevEl.hidden = true;
        seloEl.hidden = r.respondi ? false : true;
        estado.fase = 'salaRodada';
        alvoEl.hidden = false;
        zoomEl.hidden = sala.telao;
        tempoWrapEl.hidden = false;
        setBandeira(r.bandeira);
        $('[data-rodada]').textContent = String(r.rodada + 1);
        $('[data-rodada-total]').textContent = 'de ' + r.total;
        const pais = POR_ISO.get(r.bandeira);
        if (!sala.telao) {
          irParaNome(sala.cfgSala && sala.cfgSala.dificuldade === 'facil' && pais ? pais.continente : 'mundo');
        }
        somLargada();
        anunciar('Rodada ' + (r.rodada + 1) + ' de ' + r.total + '! Encontre o país da bandeira.');
      }
      estado.fase = sala.respondi || r.respondi ? estado.fase : 'salaRodada';
      if (r.respondi && !sala.respondi) { sala.respondi = true; seloEl.hidden = false; }
      setTimerBase(r.restanteMs, r.rodadaMs);
      statusEl.textContent = 'Rodada ' + (r.rodada + 1) + ' de ' + r.total + ' · já responderam: ' + r.responderam + ' 🙋';
    }

    function enviarRespostaSala(iso) {
      if (sala.respondi) return;
      sala.respondi = true;
      limparSelecao();
      seloEl.hidden = false;
      somClique();
      anunciar('Resposta enviada! Espere a revelação.');
      apiSalas({ acao: 'responder', codigo: sala.codigo, token: sala.token, rodada: sala.rodadaVista, iso })
        .then(() => pollAgora());
    }

    function renderRevelacaoSala(r) {
      setTimerBase(r.restanteMs, 7000);
      if (sala.revelacaoVista === r.rodada) return;
      sala.revelacaoVista = r.rodada;
      estado.fase = 'salaRevelacao';
      seloEl.hidden = true;
      limparPintura();
      const certoPais = POR_ISO.get(r.certo);
      const certoEl = pathDe(r.certo);
      if (certoEl) certoEl.classList.add('pais--acerto', 'pais--pisca');
      const minhaEl = r.minha && !r.minha.acertou ? pathDe(r.minha.iso) : null;
      if (minhaEl) minhaEl.classList.add('pais--erro');
      if (!sala.telao && certoEl) irPara(vbDePaths(minhaEl ? [certoEl, minhaEl] : [certoEl]));

      const minhaTxt = $('[data-rev-minha]');
      if (sala.telao) {
        minhaTxt.textContent = '🗺️ ' + (certoPais ? fraseEra(certoPais) : 'Era ' + r.certo.toUpperCase() + '!');
      } else if (!r.minha) {
        minhaTxt.textContent = '⏰ Tempo esgotado! ' + (certoPais ? fraseEra(certoPais) : '');
        somErroJogo();
      } else if (r.minha.acertou) {
        minhaTxt.textContent = '🎉 Acertou! +' + r.minha.pontos + ' pontos';
        somAcertoJogo();
        confete();
      } else {
        minhaTxt.textContent = '💫 ' + (certoPais ? fraseEra(certoPais) : '');
        somErroJogo();
      }
      $('[data-rev-stats]').textContent = r.acertaram + ' de ' + r.jogando + ' acertaram · seus pontos: ' + r.meusPontos;
      estado.pontos = r.meusPontos;
      atualizarPlacar();
      const top = $('[data-rev-top]');
      top.innerHTML = '';
      (r.top5 || []).forEach((j, i) => {
        const li = document.createElement('li');
        li.innerHTML = '<span>' + ['🥇', '🥈', '🥉', '4º', '5º'][i] + '</span><span class="nome">' + j.nome + '</span><span class="pts">' + j.pontos + '</span>';
        top.appendChild(li);
      });
      painelRevEl.hidden = false;
      anunciar(minhaTxt.textContent + '. ' + r.acertaram + ' de ' + r.jogando + ' acertaram.');
    }

    function renderPodio(r) {
      estado.fase = 'salaFim';
      fecharModaisSala();
      painelRevEl.hidden = true;
      tempoWrapEl.hidden = true;
      limparPintura();
      limparSessao();
      somNivel();
      const podio = $('[data-podio]');
      podio.innerHTML = '';
      const medalhas = ['🥇', '🥈', '🥉'];
      const ordem = [1, 0, 2]; // 2º, 1º, 3º (visual de pódio)
      ordem.forEach((pos) => {
        const j = r.placar[pos];
        if (!j) return;
        const d = document.createElement('div');
        d.className = 'podio__lugar podio__lugar--' + (pos + 1);
        d.innerHTML =
          '<span class="podio__nome">' + j.nome + '</span>' +
          '<span class="podio__pts">' + j.pontos + ' pts</span>' +
          '<div class="podio__bloco">' + medalhas[pos] + '</div>';
        podio.appendChild(d);
      });
      const lista = $('[data-podio-lista]');
      lista.innerHTML = '';
      r.placar.forEach((j, i) => {
        const li = document.createElement('li');
        li.innerHTML =
          '<span class="pos">' + (i + 1) + 'º</span>' +
          '<span class="nome">' + j.nome + '</span>' +
          '<span class="det">' + j.acertos + ' acertos</span>' +
          '<span class="pts">' + j.pontos + '</span>';
        lista.appendChild(li);
      });
      salaFimModal.hidden = false;
      const campeao = r.placar[0];
      anunciar('Fim de jogo! ' + (campeao ? 'Campeão: ' + campeao.nome + ' com ' + campeao.pontos + ' pontos.' : ''));
    }
    $('[data-sala-denovo]').addEventListener('click', () => {
      salaFimModal.hidden = true;
      limparSessao();
      pararPoll();
      estado.fase = 'salaMenu';
      salaMenuModal.hidden = false;
    });
    $('[data-sala-fim-menu]').addEventListener('click', () => sairDaSala());

    // reconexão: recarregou a página no meio da partida? volta pra sala
    (function tentarReconectar() {
      let sessao = null;
      try { sessao = JSON.parse(sessionStorage.getItem(SESSAO_SALA_KEY) || 'null'); } catch (_) {}
      if (!sessao || !sessao.codigo) return;
      sala.codigo = sessao.codigo;
      sala.token = sessao.token;
      sala.nome = sessao.nome;
      sala.telao = !!sessao.telao;
      apiEstado().then((r) => {
        if (!r || r.erro || r.fase === 'fim') { limparSessao(); return; }
        entrarModoSala();
        iniciarPoll();
      });
    })();

    // ===== Entrada: teclado físico =====
    window.addEventListener('keydown', (e) => {
      if (e.repeat || e.ctrlKey || e.altKey || e.metaKey) return;
      if (e.key === 'Escape') {
        if (estado.fase === 'jogando') { e.preventDefault(); pausar(); }
        else if (estado.fase === 'pausado') { e.preventDefault(); continuarJogo(); }
        return;
      }
      if (estado.fase === 'entrada') {
        const l = e.key.length === 1 ? e.key.toUpperCase().normalize('NFD').replace(/[̀-ͯ]/g, '') : '';
        if (/^[A-Z]$/.test(l)) { e.preventDefault(); digitarLetra(l); }
        else if (e.key === 'Backspace') { e.preventDefault(); apagarLetra(); }
        else if (e.key === 'Enter') {
          if (document.activeElement && document.activeElement.tagName === 'BUTTON' && document.activeElement.dataset.teclaNome) return;
          e.preventDefault();
          confirmarEntrada();
        }
        return;
      }
    });

    // Treino pausa ao trocar de aba; a sala segue no relógio do servidor
    document.addEventListener('visibilitychange', () => {
      if (document.hidden && estado.fase === 'jogando') pausar();
    });

    // ===== Boot =====
    document.body.classList.add('is-game');
    irParaNome('mundo');
    setTimeout(() => $('[data-modo="vidas"]').focus(), 60);
  </script>
</Layout>
