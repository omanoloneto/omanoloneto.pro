---
import Layout from '../../../layouts/Layout.astro';
import { paises, config, niveis } from '../../../data/caca-bandeiras';
import mapaMeta from '../../../data/mapa-mundi-meta.json';
import mapaSvg from '../../../data/mapa-mundi.svg?raw';

const dadosJson = JSON.stringify({ paises, config, niveis, viewBoxes: mapaMeta.viewBoxes });
const letrasNome = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');

const title = 'Caça-Bandeiras — ache o país da bandeira no mapa! | Manolo Neto';
const description =
  'Jogo educativo de geografia para crianças: a bandeira aparece e você encontra o país no mapa-múndi. Treinamento com níveis progressivos e modo turma com código de sala para jogar todo mundo junto. Em português.';
---

<Layout title={title} description={description}>
  <script type="application/json" data-dados set:html={dadosJson}></script>

  <main id="conteudo" class="cb" data-game role="application" aria-label="Jogo: encontre no mapa o país da bandeira">
    <!-- HUD -->
    <header class="hud" role="status" aria-live="polite">
      <div class="hud__bloco">
        <span class="hud__label">Pontos</span>
        <strong data-pontos>0</strong>
      </div>
      <div class="hud__bloco" data-hud-nivel hidden>
        <span class="hud__label">Nível</span>
        <strong data-nivel>1</strong>
        <span class="hud__sub">de {niveis.length}</span>
      </div>
      <div class="hud__bloco" data-hud-rodada hidden>
        <span class="hud__label">Rodada</span>
        <strong data-rodada>1</strong>
        <span class="hud__sub" data-rodada-total>de 10</span>
      </div>
      <div class="hud__bloco hud__bloco--vidas" data-vidas-wrap hidden>
        <span class="hud__label">Vidas</span>
        <span class="vidas" data-vidas></span>
      </div>
      <div class="hud__bloco hud__bloco--nome" data-hud-nome aria-hidden="true"></div>
      <button class="hud__mute" type="button" data-pause aria-label="Pausar o jogo" hidden>⏸</button>
      <button class="hud__mute" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
        <span data-mute-icon>🔊</span>
      </button>
    </header>

    <!-- Cartão da bandeira -->
    <section class="alvo" data-alvo hidden aria-label="Bandeira da vez">
      <img class="alvo__bandeira" data-bandeira src="" alt="Bandeira misteriosa — que país é esse?" />
      <div class="alvo__info">
        <p class="alvo__pergunta">Que país é esse?</p>
        <div class="tempo" data-tempo-wrap hidden><div class="tempo__fill" data-tempo-fill></div></div>
        <p class="alvo__status" data-alvo-status></p>
      </div>
    </section>

    <!-- Chips de zoom -->
    <nav class="zoom" data-zoom aria-label="Zoom do mapa" hidden>
      <button class="chip" type="button" data-vb="mundo">🌐 Mundo</button>
      <button class="chip" type="button" data-vb="americaNorte">🦅 Am. Norte</button>
      <button class="chip" type="button" data-vb="americaSul">🦜 Am. Sul</button>
      <button class="chip" type="button" data-vb="europa">🏰 Europa</button>
      <button class="chip" type="button" data-vb="africa">🦁 África</button>
      <button class="chip" type="button" data-vb="asia">🐼 Ásia</button>
      <button class="chip" type="button" data-vb="oceania">🐨 Oceania</button>
    </nav>

    <!-- Mapa -->
    <div class="mapa-area">
      <div class="mapa-wrap" data-mapa set:html={mapaSvg}></div>

      <!-- Cartucho: seleção/confirmação e frases de revelação -->
      <div class="cartucho" data-cartucho hidden>
        <span class="cartucho__txt" data-cartucho-txt></span>
        <button class="botao botao--mini" type="button" data-confirmar hidden>✓ É esse!</button>
      </div>

      <!-- Selo "resposta enviada" (sala) -->
      <div class="selo" data-selo hidden>Resposta enviada! 🔒</div>

      <!-- Painel de revelação (sala) -->
      <div class="painel-rev" data-painel-rev hidden>
        <p class="painel-rev__minha" data-rev-minha></p>
        <p class="painel-rev__stats" data-rev-stats></p>
        <ol class="painel-rev__top" data-rev-top></ol>
      </div>

      <!-- Banner de nível (treino) -->
      <div class="banner-nivel" data-banner-nivel aria-hidden="true" hidden>
        <strong data-banner-titulo></strong>
        <span data-banner-sub></span>
      </div>

      <!-- Contagem regressiva (sala) -->
      <div class="contagem" data-contagem hidden><span data-contagem-num>3</span></div>

      <!-- Aviso de conexão (sala) -->
      <div class="conexao" data-conexao hidden>📡 Reconectando…</div>
    </div>

    <!-- Toast + anúncios pra leitor de tela -->
    <div class="toast" data-toast aria-live="polite" hidden></div>
    <p class="sr-only" data-anuncio aria-live="assertive"></p>

    <!-- Modal: intro -->
    <div class="modal" data-intro>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="intro-title">
        <div class="placa__topo" id="intro-title">🌍 Caça-Bandeiras</div>
        <div class="placa__corpo">
          <ol class="regras">
            <li>Uma <b>bandeira</b> aparece lá em cima. 🏁</li>
            <li><b>Toque no país</b> dela no mapa-múndi.</li>
            <li>Toque <b>de novo</b> (ou no ✓) pra confirmar!</li>
            <li>Use os botões de <b>continente</b> pra dar zoom. 🔍</li>
          </ol>
          <p class="escolha__titulo">Como você quer jogar?</p>
          <div class="escolha">
            <button class="botao-modo botao-modo--vidas" type="button" data-modo="vidas">
              <span class="botao-modo__titulo">❤️❤️❤️ Com vidas</span>
              <small>Errou, perde um coração. 6 acertos seguidos recuperam! Vale ranking.</small>
            </button>
            <button class="botao-modo botao-modo--tranquilo" type="button" data-modo="tranquilo">
              <span class="botao-modo__titulo">🛸 Tranquilo</span>
              <small>Sem pressa e sem perder: errou, aprende e segue viajando.</small>
            </button>
            <button class="botao-modo botao-modo--turma" type="button" data-abrir-sala>
              <span class="botao-modo__titulo">🏫 Jogar com a turma</span>
              <small>Crie uma sala ou entre com o código — todo mundo joga junto!</small>
            </button>
          </div>
          <button class="recordes-btn" type="button" data-ver-recordes>🏆 Recordes</button>
        </div>
      </div>
    </div>

    <!-- Modal: pausa (treino) -->
    <div class="modal" data-pausa hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="pausa-title">
        <div class="placa__topo" id="pausa-title">⏸ Pausa</div>
        <div class="placa__corpo center">
          <div class="pausa-acoes">
            <button class="botao botao--go" type="button" data-continuar>▶ Continuar</button>
            <button class="botao botao--sec" type="button" data-recomecar>🔄 Recomeçar</button>
            <a class="botao botao--sec" href="/class/games/">🚪 Sair do jogo</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: vitória (treino) -->
    <div class="modal" data-win hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="win-title">
        <div class="placa__topo" id="win-title">Parabéns, explorador! 🌍🎉</div>
        <div class="placa__corpo center">
          <p class="grande">Você caçou bandeiras no mundo inteiro!</p>
          <p class="placar">Sua pontuação: <strong data-final-score>0</strong></p>
          <p class="aviso" data-final-msg></p>
          <div class="fim-acoes">
            <button class="botao botao--go" type="button" data-gravar-nome hidden>🏆 Gravar meu nome</button>
            <button class="botao botao--sec" type="button" data-replay>Jogar de novo</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: fim gentil (treino, modo vidas) -->
    <div class="modal" data-fim hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="fim-title">
        <div class="placa__topo" id="fim-title">Que viagem incrível! 🌟</div>
        <div class="placa__corpo center">
          <p class="grande" data-fim-msg></p>
          <p class="placar">Seus pontos: <strong data-fim-score>0</strong></p>
          <p class="aviso">Cada tentativa ensina um país novo. Bora explorar de novo?</p>
          <div class="fim-acoes">
            <button class="botao botao--go" type="button" data-gravar-nome hidden>🏆 Gravar meu nome</button>
            <button class="botao botao--sec" type="button" data-replay-fim>Jogar de novo</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: entrada arcade (nome do ranking, nome da sala, código da sala) -->
    <div class="modal" data-entrada hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="entrada-title">
        <div class="placa__topo" id="entrada-title" data-entrada-titulo>Digite</div>
        <div class="placa__corpo center">
          <p class="nome-slots" data-entrada-slots aria-live="polite">_ _ _</p>
          <div class="grade-letras" role="group" aria-label="Letras">
            {letrasNome.map((l) => (
              <button class="letra" type="button" data-tecla-nome={l}>{l}</button>
            ))}
            <button class="letra letra--apagar" type="button" data-nome-apagar aria-label="Apagar letra">⌫</button>
            <button class="letra letra--ok" type="button" data-nome-ok aria-label="Confirmar">✓</button>
          </div>
          <button class="botao botao--sec botao--mini" type="button" data-entrada-voltar>← Voltar</button>
        </div>
      </div>
    </div>

    <!-- Modal: recordes -->
    <div class="modal" data-recordes hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="recordes-title">
        <div class="placa__topo" id="recordes-title">🏆 Recordes dos Exploradores</div>
        <div class="placa__corpo center">
          <ol class="tabela" data-tabela></ol>
          <p class="aviso" data-recordes-vazio hidden>Ninguém gravou o nome ainda. Seja o primeiro! 🌍</p>
          <p class="aviso aviso--fonte" data-recordes-fonte></p>
          <div class="recordes-acoes">
            <button class="botao botao--go" type="button" data-recordes-replay>Jogar de novo</button>
            <button class="botao botao--sec" type="button" data-voltar-intro hidden>Voltar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: menu da sala -->
    <div class="modal" data-sala-menu hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="sala-menu-title">
        <div class="placa__topo" id="sala-menu-title">🏫 Jogar com a turma</div>
        <div class="placa__corpo center">
          <div class="pausa-acoes">
            <button class="botao botao--go" type="button" data-sala-criar-btn>✨ Criar uma sala</button>
            <button class="botao botao--go" type="button" data-sala-entrar-btn>🔑 Entrar com código</button>
            <button class="botao botao--sec" type="button" data-sala-menu-voltar>← Voltar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: criar sala (opções) -->
    <div class="modal" data-sala-criar hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="sala-criar-title">
        <div class="placa__topo" id="sala-criar-title">✨ Criar sala</div>
        <div class="placa__corpo">
          <p class="opcao__titulo">Dificuldade das bandeiras</p>
          <div class="opcoes" data-op-dificuldade>
            <button class="chip chip--op chip--on" type="button" data-op="facil">😀 Fácil</button>
            <button class="chip chip--op" type="button" data-op="medio">🙂 Médio</button>
            <button class="chip chip--op" type="button" data-op="dificil">🤓 Difícil</button>
          </div>
          <p class="opcao__titulo">Quantas rodadas</p>
          <div class="opcoes" data-op-rodadas>
            <button class="chip chip--op" type="button" data-op="5">5</button>
            <button class="chip chip--op chip--on" type="button" data-op="10">10</button>
          </div>
          <p class="opcao__titulo">Tempo por rodada</p>
          <div class="opcoes" data-op-tempo>
            <button class="chip chip--op" type="button" data-op="15000">15s</button>
            <button class="chip chip--op chip--on" type="button" data-op="20000">20s</button>
            <button class="chip chip--op" type="button" data-op="30000">30s</button>
          </div>
          <label class="telao-check"><input type="checkbox" data-op-telao /> 👁 Só projetar (eu não jogo — modo telão)</label>
          <div class="pausa-acoes" style="margin-top:16px">
            <button class="botao botao--go" type="button" data-sala-criar-ok>Continuar →</button>
            <button class="botao botao--sec" type="button" data-sala-criar-voltar>← Voltar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: lobby -->
    <div class="modal" data-sala-lobby hidden>
      <div class="placa placa--lobby" role="dialog" aria-modal="true" aria-labelledby="lobby-title">
        <div class="placa__topo" id="lobby-title">🚪 Sala aberta!</div>
        <div class="placa__corpo center">
          <p class="lobby__chame" data-lobby-chame>Chame a turma com o código:</p>
          <p class="lobby__codigo" data-lobby-codigo>····</p>
          <p class="lobby__info" data-lobby-info></p>
          <div class="lobby__nomes" data-lobby-nomes></div>
          <div class="pausa-acoes" style="margin-top:14px">
            <button class="botao botao--go" type="button" data-sala-comecar hidden disabled>▶ COMEÇAR</button>
            <button class="botao botao--sec" type="button" data-sala-sair>🚪 Sair da sala</button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: pódio (fim da sala) -->
    <div class="modal" data-sala-fim hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="sala-fim-title">
        <div class="placa__topo" id="sala-fim-title">🏁 Fim de jogo!</div>
        <div class="placa__corpo center">
          <div class="podio" data-podio></div>
          <ol class="tabela" data-podio-lista></ol>
          <div class="recordes-acoes">
            <button class="botao botao--go" type="button" data-sala-denovo>🏫 Jogar com a turma de novo</button>
            <button class="botao botao--sec" type="button" data-sala-fim-menu>Menu</button>
          </div>
        </div>
      </div>
    </div>
  </main>

  <style is:global>
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-Regular.ttf') format('truetype');
      font-weight: 400;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-SemiBold.ttf') format('truetype');
      font-weight: 600;
      font-display: swap;
    }
    @font-face {
      font-family: 'Oxanium';
      src: url('/class/fonts/oxanium/Oxanium-ExtraBold.ttf') format('truetype');
      font-weight: 800;
      font-display: swap;
    }

    body.is-game { background: #081426; overflow: hidden; }
    body.is-game::before { display: none !important; }

    .sr-only {
      position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; border: 0;
    }

    .cb {
      position: fixed;
      inset: 0;
      /* clip (não hidden): impede o browser de scrollar o jogo pra fora da tela */
      overflow: clip;
      font-family: 'Oxanium', Verdana, Tahoma, 'Segoe UI', Geneva, sans-serif;
      user-select: none;
      -webkit-user-select: none;
      color: var(--texto);
      display: flex;
      flex-direction: column;
      /* tema "atlas noturno neon" */
      --oceano: #081426;
      --terra: #1c2f4f;
      --ciano: #22e0ff;
      --magenta: #ff3d81;
      --verde: #2ee08a;
      --texto: #eaf6ff;
      background: var(--oceano);
    }

    /* ===== HUD ===== */
    .hud {
      position: relative; z-index: 30;
      display: flex; align-items: center; gap: 16px;
      padding: 8px 16px;
      background: rgba(10, 22, 44, 0.6);
      border-bottom: 1px solid rgba(34, 224, 255, 0.35);
      box-shadow: 0 2px 18px rgba(34, 224, 255, 0.1);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
    }
    .hud__bloco { display: flex; align-items: baseline; gap: 7px; }
    .hud__bloco[hidden] { display: none; }
    .hud__label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.85; }
    .hud__bloco strong { font-size: 1.5rem; line-height: 1; text-shadow: 0 0 8px rgba(34, 224, 255, 0.55); transition: transform 0.18s ease; }
    .hud__bloco strong.pop { transform: scale(1.4); color: var(--verde); text-shadow: 0 0 10px rgba(46, 224, 138, 0.7); }
    .hud__sub { font-size: 0.75rem; opacity: 0.85; }
    .hud__bloco--nome { flex: 1; justify-content: center; font-weight: 700; font-size: 0.95rem; opacity: 0.9; }
    .hud__bloco--vidas { align-items: center; }
    .vidas { display: inline-flex; gap: 4px; font-size: 1.1rem; }
    .vida--vazia { opacity: 0.25; filter: grayscale(1); }
    .vida--pop { animation: vida-pop 0.45s ease; display: inline-block; }
    @keyframes vida-pop { 0% { transform: scale(0.4); } 55% { transform: scale(1.5); } 100% { transform: scale(1); } }
    .hud__mute {
      width: 42px; height: 42px; border-radius: 10px; cursor: pointer;
      border: 1px solid rgba(34, 224, 255, 0.45); background: rgba(10, 22, 44, 0.55);
      box-shadow: 0 0 10px rgba(34, 224, 255, 0.18);
      font-size: 1.15rem; display: grid; place-items: center; color: var(--texto);
    }
    .hud__mute:hover { background: rgba(34, 224, 255, 0.18); }
    .hud__mute[hidden] { display: none; }

    /* ===== Cartão da bandeira ===== */
    .alvo {
      position: relative; z-index: 25;
      display: flex; align-items: center; justify-content: center; gap: 16px;
      padding: 10px 14px 6px;
    }
    .alvo[hidden] { display: none; }
    /* dimensões explícitas: o reset global img{max-width:100%} colapsa sem isso */
    .alvo__bandeira {
      height: 72px; width: auto; max-width: 150px;
      border-radius: 8px;
      border: 2px solid rgba(34, 224, 255, 0.55);
      box-shadow: 0 0 16px rgba(34, 224, 255, 0.35), 0 6px 16px rgba(0, 0, 0, 0.5);
      background: #fff;
    }
    .alvo__info { display: grid; gap: 4px; min-width: 150px; }
    .alvo__pergunta { font-weight: 800; font-size: 1.1rem; text-shadow: 0 0 10px rgba(34, 224, 255, 0.5); }
    .alvo__status { font-size: 0.85rem; opacity: 0.85; min-height: 1.1em; }
    .tempo {
      width: 100%; max-width: 220px; height: 10px; border-radius: 999px;
      background: rgba(6, 12, 26, 0.9);
      border: 1px solid rgba(34, 224, 255, 0.4);
      overflow: hidden;
    }
    .tempo[hidden] { display: none; }
    .tempo__fill {
      height: 100%; width: 100%;
      transform-origin: left center;
      border-radius: inherit;
      background: linear-gradient(90deg, var(--verde), #ffd23f 65%, var(--magenta));
    }

    /* ===== Chips de zoom ===== */
    .zoom {
      position: relative; z-index: 25;
      display: flex; gap: 8px;
      padding: 4px 12px 8px;
      overflow-x: auto;
      scrollbar-width: none;
    }
    .zoom[hidden] { display: none; }
    .zoom::-webkit-scrollbar { display: none; }
    .chip {
      flex-shrink: 0;
      font-family: inherit; font-weight: 700; font-size: 0.85rem;
      color: var(--texto); background: rgba(10, 22, 44, 0.7);
      border: 1px solid rgba(34, 224, 255, 0.4); border-radius: 999px;
      padding: 7px 14px; cursor: pointer;
      touch-action: manipulation;
    }
    .chip--on, .chip:hover { background: rgba(34, 224, 255, 0.2); border-color: var(--ciano); }
    .chip:focus-visible { outline: 3px solid var(--magenta); outline-offset: 2px; }

    /* ===== Mapa ===== */
    .mapa-area { position: relative; z-index: 10; flex: 1; min-height: 0; overflow: hidden; }
    .mapa-wrap, .mapa-wrap svg.mapa { width: 100%; height: 100%; display: block; }
    .mapa path {
      fill: var(--terra);
      stroke: rgba(34, 224, 255, 0.33);
      stroke-width: 0.75px;
      vector-effect: non-scaling-stroke;
      cursor: pointer;
      transition: fill 0.15s ease;
    }
    @media (hover: hover) {
      .mapa path[data-iso]:hover { fill: #2c4a78; }
    }
    .mapa .terra-neutra { fill: #131f36; pointer-events: none; cursor: default; }
    .mapa path.pais--sel {
      fill: #2a6b9e;
      stroke: var(--ciano); stroke-width: 2px;
      filter: drop-shadow(0 0 6px rgba(34, 224, 255, 0.8));
      animation: sel-pulsa 0.8s ease-in-out infinite alternate;
    }
    @keyframes sel-pulsa { from { fill: #2a6b9e; } to { fill: #3585c4; } }
    .mapa path.pais--acerto {
      fill: #17a866 !important;
      stroke: var(--verde); stroke-width: 2px;
      filter: drop-shadow(0 0 8px rgba(46, 224, 138, 0.8));
      animation: none;
    }
    .mapa path.pais--erro {
      fill: #b02050 !important;
      stroke: var(--magenta); stroke-width: 2px;
      filter: drop-shadow(0 0 8px rgba(255, 61, 129, 0.7));
      animation: none;
    }
    .mapa path.pais--pisca { animation: pais-pisca 0.55s step-end infinite alternate; }
    @keyframes pais-pisca { from { fill-opacity: 1; } to { fill-opacity: 0.45; } }

    /* ===== Cartucho ===== */
    .cartucho {
