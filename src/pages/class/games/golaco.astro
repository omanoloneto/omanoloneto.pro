---
import Layout from '../../../layouts/Layout.astro';
import { config, narrador } from '../../../data/golaco';

const dadosJson = JSON.stringify({ config, narrador });

const title = 'Golaço! — futebol com câmera de TV, 11 contra 11 | Manolo Neto';
const description =
  'Futebol arcade no navegador com cara de videogame de futebol clássico: câmera de TV acompanhando a bola, 11 contra 11, radar, passes e chutes no canto. Felinos FC contra Robôs FC — em português e grátis.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['VideoGame', 'LearningResource'],
  name: 'Golaço!',
  url: 'https://omanoloneto.pro/class/games/golaco/',
  description,
  inLanguage: 'pt-BR',
  isAccessibleForFree: true,
  learningResourceType: 'Game',
  educationalLevel: 'Ensino Fundamental',
  teaches: 'Coordenação motora, lateralidade, noção espacial e decisão rápida (passar, driblar ou chutar)',
  audience: { '@type': 'EducationalAudience', educationalRole: 'student' },
  gamePlatform: 'Navegador web',
  author: { '@type': 'Person', name: 'Manolo Neto', url: 'https://omanoloneto.pro' },
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'BRL' },
};
---

<Layout
  title={title}
  description={description}
  ogImage="/og/class.png"
  ogImageAlt="Sala do Professor Manolo — jogos educativos gratuitos pra sala de aula"
  jsonLd={jsonLd}
  fontes={false}
  manifest="/class/manifest.webmanifest"
  sw="/class/sw.js"
  themeColor="#ffffff"
>
  <script type="application/json" data-dados set:html={dadosJson}></script>

  <main id="conteudo" class="gl" data-game role="application" aria-label="Jogo de futebol: mova com as setas, passe com X e chute com espaço">
    <!-- HUD -->
    <header class="hud" role="status" aria-live="polite">
      <div class="hud__bloco hud__bloco--placar">
        <span class="placar__time placar__time--a">{config.timeJogador.emoji} {config.timeJogador.curto}</span>
        <strong data-gols-a>0</strong>
        <span class="placar__x">×</span>
        <strong data-gols-b>0</strong>
        <span class="placar__time placar__time--b">{config.timeCpu.curto} {config.timeCpu.emoji}</span>
      </div>
      <div class="hud__bloco">
        <span class="hud__label">Tempo</span>
        <strong data-relogio>0:00</strong>
        <span class="hud__sub" data-etapa>1º</span>
      </div>
      <div class="hud__bloco hud__bloco--nome" aria-hidden="true">⚽ Golaço!</div>
      <button class="hud__mute" type="button" data-mute aria-pressed="false" aria-label="Ligar ou desligar o som">
        <span data-mute-icon>🔊</span>
      </button>
      <button class="hud__mute" type="button" data-fullscreen aria-pressed="false" aria-label="Entrar em tela cheia">
        <span data-fullscreen-icon>⛶</span>
      </button>
    </header>

    <!-- Palco -->
    <div class="palco">
      <canvas class="tela" data-tela width={config.canvasL} height={config.canvasA} aria-hidden="true"></canvas>
      <p class="toast" data-toast hidden></p>

      <!-- Controles de toque -->
      <div class="controles" aria-hidden="true">
        <div class="dpad">
          <button class="ctl dpad__cima" type="button" data-ctl="cima">▲</button>
          <button class="ctl dpad__esq" type="button" data-ctl="esq">◀</button>
          <button class="ctl dpad__dir" type="button" data-ctl="dir">▶</button>
          <button class="ctl dpad__baixo" type="button" data-ctl="baixo">▼</button>
        </div>
        <div class="acoes-toque">
          <button class="ctl ctl--acao" type="button" data-ctl="passe">PASSE</button>
          <button class="ctl ctl--acao ctl--chute" type="button" data-ctl="chute">CHUTE</button>
        </div>
      </div>
    </div>

    <!-- Modal: introdução + escolha de modo -->
    <div class="modal" data-intro>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="intro-title">
        <div class="placa__topo" id="intro-title">⚽ Golaço!</div>
        <div class="placa__corpo">
          <ol class="regras">
            <li>É o <b>{config.timeJogador.nome} {config.timeJogador.emoji}</b> contra o <b>{config.timeCpu.nome} {config.timeCpu.emoji}</b>: <b>11 contra 11</b>, câmera de TV e radar embaixo mostrando o campo inteiro.</li>
            <li><b>Setas</b> movem — você controla quem está com a setinha amarela (troca sozinho pro mais perto da bola).</li>
            <li><b>X</b> (ou Z) faz o <b>passe</b> pro companheiro na direção em que você aponta. Tabelinha é vida! 🔄</li>
            <li><b>Espaço</b> é o <b>chute</b> — perto do gol, ele sai no canto longe do goleiro. 🥅</li>
          </ol>
          <p class="regras__teclas">🎮 Setas/WASD correm · <b>X</b> passa · <b>Espaço</b> chuta · No tablet, botões na tela</p>
          <p class="escolha__titulo">Que jogo vai ser?</p>
          <div class="escolha">
            <button class="botao-modo botao-modo--amistoso" type="button" data-modo="amistoso">
              <span class="botao-modo__titulo">⚽ Amistoso</span>
              <small>Os Robôs jogam devagarzinho. Bom pra aprender a passar e chutar no canto.</small>
            </button>
            <button class="botao-modo botao-modo--decisao" type="button" data-modo="decisao">
              <span class="botao-modo__titulo">🏆 Decisão</span>
              <small>Os Robôs vieram pra ganhar: pressionam, tabelam e chutam forte. Final de campeonato!</small>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Modal: fim de jogo -->
    <div class="modal" data-fim hidden>
      <div class="placa" role="dialog" aria-modal="true" aria-labelledby="fim-title">
        <div class="placa__topo" id="fim-title" data-fim-title>Fim de jogo!</div>
        <div class="placa__corpo center">
          <p class="grande" data-fim-msg></p>
          <p class="placar-final" data-fim-placar></p>
          <button class="botao botao--go" type="button" data-restart>🔄 Revanche!</button>
        </div>
      </div>
    </div>

    <p class="sr-only" data-anuncio aria-live="polite"></p>
  </main>
</Layout>

<style is:global>
  body.is-class { background: #fff; overflow-x: hidden; }
  body.is-class::before { display: none !important; }
</style>

<style>
  .gl {
    height: 100svh;
    display: flex;
    flex-direction: column;
    font-family: Verdana, Tahoma, 'Segoe UI', Geneva, sans-serif;
    background: #123a1d;
    color: #fff;
    overflow: hidden;
    touch-action: manipulation;
  }

  /* ===== HUD ===== */
  .hud {
    display: flex;
    align-items: center;
    gap: clamp(12px, 3vw, 28px);
    padding: 10px clamp(12px, 3vw, 24px);
    background: rgba(10, 40, 18, 0.92);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.3);
    z-index: 5;
  }
  .hud__bloco { display: flex; align-items: baseline; gap: 7px; }
  .hud__label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; opacity: 0.85; }
  .hud__bloco strong { font-size: 1.55rem; line-height: 1; transition: transform 0.18s ease; }
  .hud__bloco strong.pop { transform: scale(1.4); color: #ffe8a3; }
  .hud__sub { font-size: 0.75rem; opacity: 0.85; }
  .hud__bloco--nome { flex: 1; font-size: 0.95rem; font-weight: 700; opacity: 0.95; justify-content: center; }
  .hud__bloco--placar { align-items: center; gap: 9px; }
  .placar__time { font-size: 0.82rem; font-weight: 800; letter-spacing: 0.03em; }
  .placar__time--a { color: #9cc0f0; }
  .placar__time--b { color: #f0a89c; }
  .placar__x { opacity: 0.7; }
  .hud__mute {
    width: 42px; height: 42px; border-radius: 10px; cursor: pointer;
    border: 1px solid rgba(255, 255, 255, 0.55); background: rgba(255, 255, 255, 0.16);
    font-size: 1.15rem; display: grid; place-items: center; color: #fff;
    flex-shrink: 0;
  }
  .hud__mute:hover { background: rgba(255, 255, 255, 0.3); }
  .hud__mute[hidden] { display: none; }

  /* ===== Palco ===== */
  .palco {
    position: relative;
    flex: 1;
    min-height: 0;
    display: grid;
    place-items: center;
    padding: clamp(4px, 1.5vh, 14px);
  }
  .tela {
    max-width: 100%;
    max-height: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    background: #2e7d3f;
  }

  .toast {
    position: absolute;
    left: 50%;
    top: clamp(14px, 8vh, 60px);
    transform: translateX(-50%);
    max-width: 90%;
    padding: 10px 24px;
    border-radius: 999px;
    background: rgba(10, 40, 18, 0.94);
    color: #ffe8a3;
    font-weight: 800;
    font-size: clamp(1rem, 3vw, 1.4rem);
    text-align: center;
    pointer-events: none;
    animation: sobe 0.25s ease;
    z-index: 6;
  }
  .toast[hidden] { display: none; }
  @keyframes sobe {
    from { opacity: 0; transform: translateX(-50%) translateY(10px); }
    to { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  /* ===== Controles de toque ===== */
  .controles {
    position: absolute;
    inset: auto 0 0 0;
    display: none;
    justify-content: space-between;
    align-items: flex-end;
    padding: 0 18px 14px;
    pointer-events: none;
    z-index: 7;
  }
  @media (pointer: coarse) {
    .controles { display: flex; }
  }
  .dpad {
    display: grid;
    grid-template-columns: 56px 56px 56px;
    grid-template-rows: 56px 56px;
    gap: 4px;
  }
  .dpad__cima { grid-column: 2; grid-row: 1; }
  .dpad__esq { grid-column: 1; grid-row: 2; }
  .dpad__dir { grid-column: 3; grid-row: 2; }
  .dpad__baixo { grid-column: 2; grid-row: 2; }
  .acoes-toque { display: flex; gap: 10px; align-items: flex-end; }
  .ctl {
    pointer-events: auto;
    width: 56px;
    height: 56px;
    border-radius: 14px;
    border: 2px solid rgba(255, 255, 255, 0.7);
    background: rgba(10, 40, 18, 0.6);
    color: #fff;
    font-size: 1.25rem;
    font-weight: 800;
    display: grid;
    place-items: center;
    user-select: none;
    -webkit-user-select: none;
    touch-action: none;
  }
  .ctl:active { background: rgba(10, 40, 18, 0.9); }
  .ctl--acao { width: 92px; height: 66px; font-size: 0.9rem; letter-spacing: 0.04em; border-radius: 18px; }
  .ctl--chute { height: 78px; }

  /* ===== Modais (padrão da sala) ===== */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: grid;
    place-items: center;
    padding: 18px;
    background: rgba(6, 26, 12, 0.6);
    backdrop-filter: blur(3px);
  }
  .modal[hidden] { display: none; }
  .placa {
    width: min(94vw, 560px);
    max-height: 92svh;
    overflow: auto;
    border-radius: 18px;
    background: #fffdf5;
    color: #333;
    border: 3px solid #0a2812;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
  }
  .placa__topo {
    padding: 14px 20px;
    font-size: 1.15rem;
    font-weight: 800;
    color: #fff;
    background: linear-gradient(90deg, #2e7d3f, #0a2812);
  }
  .placa__corpo { padding: 18px 20px 20px; }
  .placa__corpo.center { text-align: center; }
  .regras { padding-left: 22px; display: grid; gap: 9px; font-size: 0.94rem; line-height: 1.5; }
  .regras__teclas {
    margin-top: 12px;
    padding: 8px 12px;
    border-radius: 10px;
    background: #eef7ef;
    font-size: 0.82rem;
    color: #55555c;
  }
  .escolha__titulo { margin: 14px 0 10px; font-weight: 800; font-size: 0.98rem; }
  .escolha { display: grid; gap: 10px; }
  .botao-modo {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 12px 16px;
    border-radius: 14px;
    border: 2px solid #cfe0d0;
    background: #fff;
    font-family: inherit;
    text-align: left;
    cursor: pointer;
    transition: transform 0.12s ease, border-color 0.12s ease, box-shadow 0.12s ease;
  }
  .botao-modo:hover { transform: translateY(-2px); box-shadow: 0 6px 16px rgba(0, 0, 0, 0.12); }
  .botao-modo--amistoso:hover { border-color: #2e7d3f; }
  .botao-modo--decisao:hover { border-color: #d99e1b; }
  .botao-modo__titulo { font-weight: 800; font-size: 1rem; color: #0a2812; }
  .botao-modo small { font-size: 0.8rem; color: #6b6b70; line-height: 1.4; }
  .grande { font-size: 1.15rem; font-weight: 800; color: #0a2812; }
  .placar-final { margin-top: 12px; font-size: 1.35rem; font-weight: 800; color: #2e7d3f; }
  .botao {
    margin-top: 16px;
    padding: 12px 26px;
    border-radius: 14px;
    border: 0;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 800;
    cursor: pointer;
    color: #fff;
    background: linear-gradient(180deg, #46a55b 0%, #2e7d3f 55%, #1c5229 100%);
    box-shadow: 0 3px 0 #143d1e;
    transition: transform 0.12s ease, filter 0.12s ease;
  }
  .botao:hover { filter: brightness(1.08); }
  .botao:active { transform: translateY(2px); box-shadow: none; }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    margin: -1px; padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 560px) {
    .hud { flex-wrap: wrap; gap: 8px 14px; padding: 8px 12px; }
    .hud__bloco strong { font-size: 1.2rem; }
    .hud__bloco--nome { display: none; }
    .hud__mute { width: 36px; height: 36px; }
  }
</style>

<script>
  document.body.classList.add('is-class');

  (() => {
    const $ = (s) => document.querySelector(s);
    const dados = JSON.parse($('[data-dados]').textContent);
    const CFG = dados.config;
    const NARRA = dados.narrador;

    const canvas = $('[data-tela]');
    const ctx = canvas.getContext('2d');
    const TL = CFG.canvasL, TA = CFG.canvasA;       // tela
    const W = CFG.campoL, H = CFG.campoA, M = CFG.margem; // mundo
    const CY = H / 2;
    const golY0 = CY - CFG.bocaGol / 2, golY1 = CY + CFG.bocaGol / 2;

    const golsAEl = $('[data-gols-a]');
    const golsBEl = $('[data-gols-b]');
    const relogioEl = $('[data-relogio]');
    const etapaEl = $('[data-etapa]');
    const toastEl = $('[data-toast]');
    const anuncioEl = $('[data-anuncio]');

    const estado = {
      modo: 'amistoso',
      mudo: false,
      rodando: false,
      golsA: 0,
      golsB: 0,
      etapa: 1,
      segundos: 0,
      frames: 0,
      festejo: 0,
      dono: null,
      controlado: null,
      passeAlvo: null,  // recebedor do passe em voo (trava a troca automática)
      passeTimer: 0,
      tempo: 0, // contador de quadros (animação)
    };
    const dif = () => CFG.modos[estado.modo];

    // ===== Câmera de TV =====
    const zoom = TL / CFG.camJanela;
    const SQ = CFG.camSquash;
    const cam = { x: W / 2, y: CY };
    const visMeiaAltura = TA / 2 / (zoom * SQ);
    function passoCamera(suave) {
      const ax = Math.max(M + 470, Math.min(W - M - 470, bola.x));
      const ay = Math.max(M + visMeiaAltura - 120, Math.min(H - M - visMeiaAltura + 120, bola.y));
      const k = suave ? 0.06 : 1;
      cam.x += (ax - cam.x) * k;
      cam.y += (ay - cam.y) * k;
    }
    const px = (wx) => (wx - cam.x) * zoom + TL / 2;
    const py = (wy) => (wy - cam.y) * zoom * SQ + TA / 2;
    const escala = (wy) => 0.8 + 0.45 * ((wy - M) / (H - 2 * M));

    // ===== Áudio =====
    let actx = null;
    function initAudio() {
      if (actx) return;
      const AC = window.AudioContext || window.webkitAudioContext;
      if (AC) actx = new AC();
    }
    function tom(freq, inicio, dur, tipo, vol) {
      if (!actx) return;
      const o = actx.createOscillator();
      const g = actx.createGain();
      o.type = tipo; o.frequency.value = freq;
      o.connect(g); g.connect(actx.destination);
      const t = actx.currentTime + inicio;
      g.gain.setValueAtTime(0.0001, t);
      g.gain.linearRampToValueAtTime(vol, t + 0.02);
      g.gain.exponentialRampToValueAtTime(0.0001, t + dur);
      o.start(t); o.stop(t + dur + 0.03);
    }
    function somChute() { if (estado.mudo) return; tom(220, 0, 0.06, 'square', 0.1); }
    function somPasse() { if (estado.mudo) return; tom(320, 0, 0.04, 'square', 0.07); }
    function somApito() { if (estado.mudo) return; tom(2200, 0, 0.18, 'square', 0.06); tom(2200, 0.25, 0.3, 'square', 0.06); }
    function somRoubo() { if (estado.mudo) return; tom(340, 0, 0.05, 'triangle', 0.1); }
    function somTorcida() {
      if (estado.mudo || !actx) return;
      const dur = 1.4;
      const buf = actx.createBuffer(1, actx.sampleRate * dur, actx.sampleRate);
      const d = buf.getChannelData(0);
      for (let i = 0; i < d.length; i++) d[i] = (Math.random() * 2 - 1) * (1 - i / d.length);
      const src = actx.createBufferSource();
      src.buffer = buf;
      const filtro = actx.createBiquadFilter();
      filtro.type = 'bandpass'; filtro.frequency.value = 900; filtro.Q.value = 0.6;
      const g = actx.createGain();
      g.gain.value = 0.25;
      src.connect(filtro); filtro.connect(g); g.connect(actx.destination);
      src.start();
      tom(880, 0, 0.5, 'triangle', 0.1);
      tom(1100, 0.2, 0.5, 'triangle', 0.1);
    }

    // ===== Mudo / tela cheia (padrão da sala) =====
    const muteBtn = $('[data-mute]');
    const muteIcon = $('[data-mute-icon]');
    function aplicarMudo() {
      muteBtn.setAttribute('aria-pressed', String(estado.mudo));
      muteIcon.textContent = estado.mudo ? '🔈' : '🔊';
      muteBtn.setAttribute('aria-label', estado.mudo ? 'Ligar o som' : 'Desligar o som');
    }
    estado.mudo = localStorage.getItem('golaco:mudo') === '1';
    aplicarMudo();
    muteBtn.addEventListener('click', () => {
      estado.mudo = !estado.mudo;
      localStorage.setItem('golaco:mudo', estado.mudo ? '1' : '0');
      aplicarMudo();
    });

    const fsBtn = $('[data-fullscreen]');
    if (!document.fullscreenEnabled) {
      fsBtn.hidden = true;
    } else {
      fsBtn.addEventListener('click', () => {
        if (document.fullscreenElement) document.exitFullscreen();
        else document.documentElement.requestFullscreen();
      });
      document.addEventListener('fullscreenchange', () => {
        const cheio = !!document.fullscreenElement;
        fsBtn.setAttribute('aria-pressed', String(cheio));
        fsBtn.setAttribute('aria-label', cheio ? 'Sair da tela cheia' : 'Entrar em tela cheia');
        $('[data-fullscreen-icon]').textContent = cheio ? '⊡' : '⛶';
      });
    }

    // ===== Toast =====
    let toastTimer = 0;
    function toast(txt, ms) {
      toastEl.textContent = txt;
      toastEl.hidden = false;
      clearTimeout(toastTimer);
      toastTimer = setTimeout(() => { toastEl.hidden = true; }, ms || 2000);
      anuncioEl.textContent = txt;
    }
    const sorteia = (arr) => arr[Math.floor(Math.random() * arr.length)];

    // ===== Times (11 contra 11) =====
    // Time A (humano) defende a ESQUERDA e ataca a DIREITA.
    function fazTime(time) {
      const larg = W - 2 * M;
      const meiaAlt = (H - 2 * M) / 2 - 60;
      const lista = [];
      const gx = time === 'A' ? M + 22 : W - M - 22;
      lista.push({ time, papel: 'goleiro', x: gx, y: CY, baseX: gx, baseY: CY, cd: 0, segura: 0, dirX: time === 'A' ? 1 : -1, dirY: 0, anda: false });
      for (const [fx, fy] of CFG.formacao) {
        const x = time === 'A' ? M + fx * larg : W - M - fx * larg;
        const y = CY + fy * meiaAlt;
        lista.push({ time, papel: 'linha', x, y, baseX: x, baseY: y, cd: 0, dirX: time === 'A' ? 1 : -1, dirY: 0, anda: false });
      }
      return lista;
    }
    let jogadores = [];
    const bola = { x: W / 2, y: CY, vx: 0, vy: 0, z: 0, vz: 0, giro: 0 };

    function armarKickoff() {
      jogadores = [...fazTime('A'), ...fazTime('B')];
      bola.x = W / 2; bola.y = CY; bola.vx = 0; bola.vy = 0; bola.z = 0; bola.vz = 0;
      estado.dono = null;
      estado.controlado = jogadores.find((j) => j.time === 'A' && j.papel === 'linha' && Math.abs(j.baseY - CY) < 80);
      cam.x = W / 2; cam.y = CY;
    }

    // ===== Entrada =====
    // chuteTap/passeTap são "trincos": um toque mais curto que um quadro da
    // simulação não pode se perder (teclado rápido ou aba lenta).
    const input = { esq: false, dir: false, cima: false, baixo: false, chute: false, chuteTap: false, passe: false, passeTap: false };
    const mapaTeclas = {
      ArrowLeft: 'esq', a: 'esq', A: 'esq',
      ArrowRight: 'dir', d: 'dir', D: 'dir',
      ArrowUp: 'cima', w: 'cima', W: 'cima',
      ArrowDown: 'baixo', s: 'baixo', S: 'baixo',
      ' ': 'chute',
      x: 'passe', X: 'passe', z: 'passe', Z: 'passe',
    };
    document.addEventListener('keydown', (e) => {
      const acao = mapaTeclas[e.key];
      if (!acao) return;
      e.preventDefault();
      if (!e.repeat && (acao === 'passe' || acao === 'chute')) input[acao + 'Tap'] = true;
      input[acao] = true;
    });
    document.addEventListener('keyup', (e) => {
      const acao = mapaTeclas[e.key];
      if (acao) input[acao] = false;
    });
    document.querySelectorAll('[data-ctl]').forEach((btn) => {
      const acao = btn.dataset.ctl;
      const liga = (v) => (e) => {
        e.preventDefault();
        if (v && (acao === 'passe' || acao === 'chute')) input[acao + 'Tap'] = true;
        input[acao] = v;
      };
      btn.addEventListener('pointerdown', liga(true));
      btn.addEventListener('pointerup', liga(false));
      btn.addEventListener('pointercancel', liga(false));
      btn.addEventListener('pointerleave', liga(false));
    });

    // ===== Utilidades =====
    const dist = (a, b) => Math.hypot(a.x - b.x, a.y - b.y);
    function andaPara(j, tx, ty, vel) {
      const dx = tx - j.x, dy = ty - j.y;
      const d = Math.hypot(dx, dy);
      j.anda = d > 3;
      if (d < 2) return;
      j.x += (dx / d) * Math.min(vel, d);
      j.y += (dy / d) * Math.min(vel, d);
      j.dirX = dx / d; j.dirY = dy / d;
    }
    function dentroDoCampo(j) {
      j.x = Math.max(M + 8, Math.min(W - M - 8, j.x));
      j.y = Math.max(M + 8, Math.min(H - M - 8, j.y));
    }
    function pop(el) { el.classList.remove('pop'); void el.offsetWidth; el.classList.add('pop'); }
    const goleiroDe = (time) => jogadores.find((g) => g.time === time && g.papel === 'goleiro');

    // ===== Posse, passe e chute =====
    function chuta(j, dx, dy, forca, vz) {
      const d = Math.hypot(dx, dy) || 1;
      bola.vx = (dx / d) * forca;
      bola.vy = (dy / d) * forca;
      bola.vz = vz || 0;
      estado.dono = null;
      j.cd = 18;
    }

    function passar(j, dirx, diry) {
      // 1ª escolha: companheiro no cone de ~±75° da direção apontada.
      // Sem ninguém lá, vale qualquer companheiro razoável (criança apertou
      // PASSE, a bola tem que ir pra ALGUÉM) — só não passa pra trás demais.
      let melhor = null, melhorNota = -1;
      for (const cone of [0.25, -0.5]) {
        for (const t of jogadores) {
          if (t.time !== j.time || t === j || t.papel === 'goleiro') continue;
          const vx = t.x - j.x, vy = t.y - j.y;
          const d = Math.hypot(vx, vy);
          if (d < 60 || d > 750) continue;
          const cos = (vx * dirx + vy * diry) / d;
          if (cos < cone) continue;
          const frente = j.time === 'A' ? (t.x - j.x) / 750 : (j.x - t.x) / 750;
          const nota = cos * 2 + frente;
          if (nota > melhorNota) { melhorNota = nota; melhor = t; }
        }
        if (melhor) break;
      }
      if (melhor) {
        const lead = j.time === 'A' ? 34 : -34;
        const dx = melhor.x + lead - j.x, dy = melhor.y - j.y;
        const d = Math.hypot(dx, dy);
        chuta(j, dx, dy, Math.min(CFG.forcaPasseMax, CFG.forcaPasseBase + d * CFG.forcaPassePorDist), 0);
        somPasse();
        if (j.time === 'A') {
          // controle já vai pro recebedor e fica com ele até a bola chegar
          estado.controlado = melhor;
          estado.passeAlvo = melhor;
          estado.passeTimer = 80;
        }
        return true;
      }
      // ninguém no cone: toco curto pra frente
      chuta(j, dirx, diry, 6.2, 0);
      somPasse();
      return false;
    }

    function passoPosse() {
      const dono = estado.dono;
      if (dono) {
        bola.x = dono.x + dono.dirX * 18;
        bola.y = dono.y + dono.dirY * 18;
        bola.vx = 0; bola.vy = 0; bola.z = 0; bola.vz = 0;
        for (const j of jogadores) {
          if (j.time === dono.time || j.cd > 0 || j.papel === 'goleiro') continue;
          if (dist(j, bola) < CFG.distRoubo) {
            dono.cd = 40;
            estado.dono = j;
            j.segura = 0;
            somRoubo();
            break;
          }
        }
      } else {
        // bola alta ou rápida, jogador de linha não domina; só o goleiro pega
        if (bola.z > CFG.alturaDominio) return;
        const velBola = Math.hypot(bola.vx, bola.vy);
        if (velBola > CFG.velDominio) return;
        let melhor = null, melhorD = CFG.distDominio;
        for (const j of jogadores) {
          if (j.cd > 0) continue;
          const d = dist(j, bola);
          if (d < melhorD) { melhorD = d; melhor = j; }
        }
        if (melhor) { estado.dono = melhor; melhor.segura = 0; }
      }
    }

    // ===== Cérebros =====
    function escolheControlado() {
      // passe em voo: controle preso no recebedor
      if (estado.passeAlvo) {
        if (estado.dono || estado.passeTimer-- <= 0) estado.passeAlvo = null;
        else {
          estado.controlado = estado.passeAlvo;
          return;
        }
      }
      let melhor = null, melhorD = 1e9;
      for (const j of jogadores) {
        if (j.time !== 'A' || j.papel === 'goleiro') continue;
        const d = dist(j, bola);
        if (d < melhorD) { melhorD = d; melhor = j; }
      }
      const atual = estado.controlado;
      if (!atual || atual.papel === 'goleiro') estado.controlado = melhor;
      else if (melhor !== atual && atual !== estado.dono && melhorD < dist(atual, bola) * 0.8) estado.controlado = melhor;
    }

    function anchor(j) {
      const ax = j.baseX + (bola.x - W / 2) * 0.4;
      const ay = j.baseY + (bola.y - CY) * 0.3;
      return [Math.max(M + 20, Math.min(W - M - 20, ax)), Math.max(M + 20, Math.min(H - M - 20, ay))];
    }

    function passoHumano() {
      const j = estado.controlado;
      if (!j) return;
      let dx = (input.dir ? 1 : 0) - (input.esq ? 1 : 0);
      let dy = (input.baixo ? 1 : 0) - (input.cima ? 1 : 0);
      const vel = estado.dono === j ? CFG.velComBola : CFG.velJogador;
      if (dx || dy) {
        const d = Math.hypot(dx, dy);
        j.x += (dx / d) * vel;
        j.y += (dy / d) * vel;
        j.dirX = dx / d; j.dirY = dy / d;
        j.anda = true;
      } else j.anda = false;

      // PASSE (trinco do toque)
      if (input.passeTap && estado.dono === j) {
        passar(j, dx || j.dirX, dy || j.dirY);
      }
      input.passeTap = false;

      // CHUTE (trinco do toque)
      if (input.chuteTap && estado.dono === j) {
        let cx = dx, cy = dy;
        if (!cx && !cy) { cx = j.dirX; cy = j.dirY; }
        // na frente do ataque, mira assistida na trave mais longe do goleiro
        if (j.x > W - M - 700 && cx >= 0) {
          const golB = goleiroDe('B');
          const canto = golB && golB.y > CY ? golY0 + 18 : golY1 - 18;
          cx = W - M - j.x;
          cy = canto - j.y;
        }
        chuta(j, cx, cy, CFG.forcaChute, 2.4);
        somChute();
      }
      input.chuteTap = false;

      // companheiros: formação; se os robôs têm a bola, o mais perto ajuda a marcar
      let marcador = null;
      if (estado.dono && estado.dono.time === 'B') {
        let melhorD = 1e9;
        for (const t of jogadores) {
          if (t.time !== 'A' || t.papel === 'goleiro' || t === j) continue;
          const d = dist(t, bola);
          if (d < melhorD) { melhorD = d; marcador = t; }
        }
      }
      for (const t of jogadores) {
        if (t.time !== 'A' || t === j || t.papel === 'goleiro') continue;
        if (t === marcador) andaPara(t, bola.x, bola.y, CFG.velJogador * 0.9);
        else {
          const [ax, ay] = anchor(t);
          andaPara(t, ax, ay, CFG.velJogador * 0.85);
        }
      }
    }

    function passoCpu() {
      const D = dif();
      const dono = estado.dono;
      // os dois robôs mais perto da bola pressionam
      const linha = jogadores.filter((j) => j.time === 'B' && j.papel === 'linha');
      const porPerto = [...linha].sort((a, b) => dist(a, bola) - dist(b, bola));
      const cacadores = new Set([porPerto[0], porPerto[1]]);

      for (const j of linha) {
        if (dono === j) {
          // carrega pela própria ala em direção ao gol esquerdo
          andaPara(j, M + 40, j.y + (Math.random() * 24 - 12), D.velCpu * 0.88);
          const pressionado = jogadores.some((h) => h.time === 'A' && h.papel === 'linha' && dist(h, j) < 45);
          // pressionado? tenta tabela com companheiro mais livre
          if (pressionado && Math.random() < D.passeCpu) {
            passar(j, -1, Math.random() * 1.6 - 0.8);
            continue;
          }
          const pertoDoGol = j.x < M + 320;
          if ((pertoDoGol || (pressionado && j.x < W / 2)) && Math.random() < D.reacaoCpu) {
            const golA = goleiroDe('A');
            const alvo = golA && golA.y > CY ? golY0 + 18 : golY1 - 18;
            chuta(j, M - j.x, alvo - j.y, D.chuteCpu, 2.2);
            somChute();
          }
        } else if (cacadores.has(j) && (!dono || dono.time === 'A')) {
          andaPara(j, bola.x, bola.y, D.velCpu);
        } else {
          const [ax, ay] = anchor(j);
          andaPara(j, ax, ay, D.velCpu * 0.85);
        }
      }
    }

    function passoGoleiros() {
      for (const g of jogadores) {
        if (g.papel !== 'goleiro') continue;
        if (estado.dono === g) {
          g.segura++;
          if (g.segura > 40) {
            // reposição alta pro meio-campo (a bola voa por cima de todo mundo)
            const alvoX = W / 2 + (g.time === 'A' ? 260 : -260);
            chuta(g, alvoX - g.x, Math.random() * 500 - 250, 12, 5);
            somChute();
          }
          continue;
        }
        const alvoY = Math.max(golY0 + 16, Math.min(golY1 - 16, bola.y));
        andaPara(g, g.baseX, alvoY, dif().velGoleiro);
        // defesa: o goleiro pega em qualquer altura (ele pula)
        if (g.cd === 0 && dist(g, bola) < 24 && estado.dono?.papel !== 'goleiro' && !estado.dono) {
          const veio = Math.hypot(bola.vx, bola.vy);
          estado.dono = g;
          g.segura = 0;
          if (veio > 6) toast(sorteia(NARRA.defesa), 1300);
        }
      }
    }

    function separa() {
      for (let i = 0; i < jogadores.length; i++)
        for (let k = i + 1; k < jogadores.length; k++) {
          const a = jogadores[i], b = jogadores[k];
          const d = dist(a, b);
          if (d > 0 && d < 26) {
            const sx = (a.x - b.x) / d, sy = (a.y - b.y) / d;
            a.x += sx; a.y += sy;
            b.x -= sx; b.y -= sy;
          }
        }
    }

    // ===== Bola =====
    function passoBola() {
      if (estado.dono) return;
      bola.x += bola.vx;
      bola.y += bola.vy;
      bola.vx *= CFG.atritoBola;
      bola.vy *= CFG.atritoBola;
      bola.giro += Math.hypot(bola.vx, bola.vy) * 0.06;
      // altura
      if (bola.z > 0 || bola.vz > 0) {
        bola.z += bola.vz;
        bola.vz -= 0.35;
        if (bola.z <= 0) {
          bola.z = 0;
          bola.vz = bola.vz < -1.2 ? -bola.vz * 0.45 : 0;
        }
      }
      const r = CFG.raioBola;
      if (bola.y < M + r) { bola.y = M + r; bola.vy *= -0.8; }
      if (bola.y > H - M - r) { bola.y = H - M - r; bola.vy *= -0.8; }
      const naBoca = bola.y > golY0 && bola.y < golY1;
      if (naBoca && bola.x < M - r) { gol('B'); return; }
      if (naBoca && bola.x > W - M + r) { gol('A'); return; }
      if (!naBoca && bola.x < M + r) { bola.x = M + r; bola.vx *= -0.8; }
      if (!naBoca && bola.x > W - M - r) { bola.x = W - M - r; bola.vx *= -0.8; }
      if (bola.x < M - CFG.fundoGol + r) { bola.x = M - CFG.fundoGol + r; bola.vx = 0; }
      if (bola.x > W - M + CFG.fundoGol - r) { bola.x = W - M + CFG.fundoGol - r; bola.vx = 0; }
    }

    function gol(time) {
      estado.festejo = 140;
      if (time === 'A') {
        estado.golsA++;
        toast(sorteia(NARRA.gol), 2300);
        pop(golsAEl);
      } else {
        estado.golsB++;
        toast(sorteia(NARRA.golSofrido), 2300);
        pop(golsBEl);
      }
      somTorcida();
      atualizarHud();
    }

    // ===== Relógio =====
    function atualizarHud() {
      golsAEl.textContent = estado.golsA;
      golsBEl.textContent = estado.golsB;
      const s = estado.segundos;
      relogioEl.textContent = Math.floor(s / 60) + ':' + String(s % 60).padStart(2, '0');
      etapaEl.textContent = estado.etapa + 'º';
    }

    function passoRelogio() {
      estado.frames++;
      if (estado.frames < 60) return;
      estado.frames = 0;
      estado.segundos++;
      atualizarHud();
      const fimEtapa = CFG.minutosPorTempo * 60;
      if (estado.etapa === 1 && estado.segundos >= fimEtapa) {
        estado.etapa = 2;
        estado.segundos = 0;
        somApito();
        toast(NARRA.intervalo, 2400);
        armarKickoff();
        atualizarHud();
      } else if (estado.etapa === 2 && estado.segundos >= fimEtapa) {
        fimDeJogo();
      }
    }

    function fimDeJogo() {
      estado.rodando = false;
      somApito();
      const a = estado.golsA, b = estado.golsB;
      const msg = a > b ? NARRA.fimVitoria : a < b ? NARRA.fimDerrota : NARRA.fimEmpate;
      $('[data-fim-title]').textContent = a > b ? '🏆 Fim de jogo!' : '⚽ Fim de jogo!';
      $('[data-fim-msg]').textContent = msg;
      $('[data-fim-placar]').textContent =
        CFG.timeJogador.emoji + ' ' + CFG.timeJogador.curto + ' ' + a + ' × ' + b + ' ' + CFG.timeCpu.curto + ' ' + CFG.timeCpu.emoji;
      $('[data-fim]').hidden = false;
      anuncioEl.textContent = msg + ' Placar final: ' + a + ' a ' + b + '.';
    }

    function reiniciar() {
      estado.golsA = 0; estado.golsB = 0;
      estado.etapa = 1; estado.segundos = 0; estado.frames = 0;
      $('[data-fim]').hidden = true;
      armarKickoff();
      atualizarHud();
      estado.rodando = true;
      somApito();
    }

    // ===== Desenho =====
    function desenhaCampo() {
      // gramado cobre a tela toda (faixas em coordenadas de mundo)
      const faixa = 137.5;
      const i0 = Math.floor((cam.x - CFG.camJanela / 2) / faixa) - 1;
      const i1 = Math.ceil((cam.x + CFG.camJanela / 2) / faixa) + 1;
      for (let i = i0; i <= i1; i++) {
        ctx.fillStyle = ((i % 2) + 2) % 2 ? '#2e7d3f' : '#2a7339';
        ctx.fillRect(px(i * faixa), 0, faixa * zoom + 1, TA);
      }
      const linha = (x0, y0, x1, y1) => {
        ctx.beginPath();
        ctx.moveTo(px(x0), py(y0));
        ctx.lineTo(px(x1), py(y1));
        ctx.stroke();
      };
      ctx.strokeStyle = 'rgba(255,255,255,0.85)';
      ctx.lineWidth = 3;
      // contorno, meio, círculo central
      ctx.strokeRect(px(M), py(M), (W - 2 * M) * zoom, (H - 2 * M) * zoom * SQ);
      linha(W / 2, M, W / 2, H - M);
      ctx.beginPath();
      ctx.ellipse(px(W / 2), py(CY), 130 * zoom, 130 * zoom * SQ, 0, 0, Math.PI * 2);
      ctx.stroke();
      // grandes áreas e pequenas áreas
      for (const lado of [0, 1]) {
        const x0 = lado === 0 ? M : W - M - 300;
        ctx.strokeRect(px(x0), py(CY - 330), 300 * zoom, 660 * zoom * SQ);
        const x1 = lado === 0 ? M : W - M - 120;
        ctx.strokeRect(px(x1), py(CY - 170), 120 * zoom, 340 * zoom * SQ);
        // marca do pênalti
        ctx.beginPath();
        ctx.arc(px(lado === 0 ? M + 220 : W - M - 220), py(CY), 3, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.85)';
        ctx.fill();
      }
      // gols (rede + traves)
      ctx.fillStyle = 'rgba(255,255,255,0.22)';
      ctx.fillRect(px(M - CFG.fundoGol), py(golY0), CFG.fundoGol * zoom, CFG.bocaGol * zoom * SQ);
      ctx.fillRect(px(W - M), py(golY0), CFG.fundoGol * zoom, CFG.bocaGol * zoom * SQ);
      ctx.strokeStyle = '#fff';
      ctx.lineWidth = 4;
      ctx.strokeRect(px(M - CFG.fundoGol), py(golY0), CFG.fundoGol * zoom, CFG.bocaGol * zoom * SQ);
      ctx.strokeRect(px(W - M), py(golY0), CFG.fundoGol * zoom, CFG.bocaGol * zoom * SQ);
    }

    function desenhaJogador(j) {
      const cor = j.time === 'A' ? CFG.timeJogador : CFG.timeCpu;
      const e = escala(j.y);
      const sx = px(j.x), sy = py(j.y);
      if (sx < -40 || sx > TL + 40) return;
      // sombra
      ctx.fillStyle = 'rgba(0,0,0,0.3)';
      ctx.beginPath();
      ctx.ellipse(sx, sy, 8 * e, 3 * e, 0, 0, Math.PI * 2);
      ctx.fill();
      // marcador do controlado (embaixo, estilo PES)
      if (j === estado.controlado) {
        ctx.strokeStyle = '#ffe14d';
        ctx.lineWidth = 2.5;
        ctx.beginPath();
        ctx.ellipse(sx, sy, 13 * e, 5.5 * e, 0, 0, Math.PI * 2);
        ctx.stroke();
      }
      // perninhas (2 quadros de corrida)
      const passo = j.anda ? (Math.floor(estado.tempo / 6) % 2 ? 2.2 : -2.2) * e : 0;
      ctx.fillStyle = cor.pele;
      ctx.fillRect(sx - 4 * e, sy - 8 * e + passo, 3 * e, 8 * e - passo);
      ctx.fillRect(sx + 1 * e, sy - 8 * e - passo, 3 * e, 8 * e + passo);
      // calção
      ctx.fillStyle = j.time === 'A' ? '#fff' : '#222';
      ctx.fillRect(sx - 5 * e, sy - 13 * e, 10 * e, 6 * e);
      // camisa (goleiro em cor alternativa)
      ctx.fillStyle = j.papel === 'goleiro' ? cor.corClara : cor.cor;
      ctx.fillRect(sx - 5.5 * e, sy - 21 * e, 11 * e, 9 * e);
      // braços
      ctx.fillRect(sx - 7.5 * e, sy - 20 * e, 2 * e, 6 * e);
      ctx.fillRect(sx + 5.5 * e, sy - 20 * e, 2 * e, 6 * e);
      // cabeça + cabelo
      ctx.fillStyle = cor.pele;
      ctx.beginPath();
      ctx.arc(sx, sy - 25 * e, 4 * e, 0, Math.PI * 2);
      ctx.fill();
      ctx.fillStyle = j.time === 'A' ? '#3a2a1a' : '#4a5560';
      ctx.beginPath();
      ctx.arc(sx, sy - 26 * e, 4 * e, Math.PI, 2 * Math.PI);
      ctx.fill();
      // setinha em cima do controlado
      if (j === estado.controlado) {
        ctx.fillStyle = '#ffe14d';
        ctx.beginPath();
        ctx.moveTo(sx - 5, sy - 38 * e);
        ctx.lineTo(sx + 5, sy - 38 * e);
        ctx.lineTo(sx, sy - 32 * e);
        ctx.fill();
      }
    }

    function desenhaBola() {
      const e = escala(bola.y);
      const sx = px(bola.x), syChao = py(bola.y);
      // sombra no chão
      ctx.fillStyle = 'rgba(0,0,0,0.3)';
      ctx.beginPath();
      ctx.ellipse(sx, syChao, 5.5 * e, 2.2 * e, 0, 0, Math.PI * 2);
      ctx.fill();
      // bola (sobe com a altura z)
      const sy = syChao - bola.z * zoom * 0.9;
      ctx.fillStyle = '#fff';
      ctx.beginPath();
      ctx.arc(sx, sy - 3 * e, 5.5 * e, 0, Math.PI * 2);
      ctx.fill();
      ctx.strokeStyle = '#333';
      ctx.lineWidth = 1.2;
      ctx.stroke();
      ctx.fillStyle = '#333';
      ctx.beginPath();
      ctx.arc(sx + Math.cos(bola.giro) * 2.5 * e, sy - 3 * e + Math.sin(bola.giro) * 2.5 * e, 1.6 * e, 0, Math.PI * 2);
      ctx.fill();
    }

    function desenhaRadar() {
      const rw = 200, rh = 92;
      const rx = TL / 2 - rw / 2, ry = TA - rh - 12;
      ctx.fillStyle = 'rgba(6, 26, 12, 0.55)';
      ctx.strokeStyle = 'rgba(255,255,255,0.5)';
      ctx.lineWidth = 1.5;
      ctx.fillRect(rx, ry, rw, rh);
      ctx.strokeRect(rx, ry, rw, rh);
      ctx.beginPath();
      ctx.moveTo(rx + rw / 2, ry);
      ctx.lineTo(rx + rw / 2, ry + rh);
      ctx.stroke();
      const mx = (wx) => rx + (wx / W) * rw;
      const my = (wy) => ry + (wy / H) * rh;
      for (const j of jogadores) {
        ctx.fillStyle = j.time === 'A' ? '#6fa8ff' : '#ff8a75';
        ctx.fillRect(mx(j.x) - 1.5, my(j.y) - 1.5, 3, 3);
      }
      ctx.fillStyle = '#fff';
      ctx.beginPath();
      ctx.arc(mx(bola.x), my(bola.y), 2.4, 0, Math.PI * 2);
      ctx.fill();
    }

    function desenhar() {
      desenhaCampo();
      const todos = [...jogadores].sort((a, b) => a.y - b.y);
      let bolaDesenhada = false;
      for (const j of todos) {
        if (!bolaDesenhada && bola.y < j.y) { desenhaBola(); bolaDesenhada = true; }
        desenhaJogador(j);
      }
      if (!bolaDesenhada) desenhaBola();
      desenhaRadar();
    }

    // ===== Loop =====
    let ultimo = 0, acum = 0;
    function quadro(t) {
      requestAnimationFrame(quadro);
      const dt = Math.min(50, t - ultimo);
      ultimo = t;
      if (!estado.rodando) { desenhar(); return; }
      acum += dt;
      while (acum >= 1000 / 60) {
        acum -= 1000 / 60;
        estado.tempo++;
        if (estado.festejo) {
          estado.festejo--;
          if (estado.festejo === 0) { armarKickoff(); somApito(); }
          continue;
        }
        escolheControlado();
        passoHumano();
        passoCpu();
        passoGoleiros();
        for (const j of jogadores) { if (j.cd > 0) j.cd--; dentroDoCampo(j); }
        separa();
        passoPosse();
        passoBola();
        passoCamera(true);
        passoRelogio();
      }
      desenhar();
    }

    // ===== Botões =====
    document.querySelectorAll('[data-modo]').forEach((btn) =>
      btn.addEventListener('click', () => {
        initAudio();
        estado.modo = btn.dataset.modo;
        $('[data-intro]').hidden = true;
        reiniciar();
        anuncioEl.textContent = 'Começou o jogo! Setas correm, X passa, espaço chuta.';
      })
    );
    $('[data-restart]').addEventListener('click', () => { initAudio(); reiniciar(); });

    armarKickoff();
    passoCamera(false);
    atualizarHud();
    desenhar();
    requestAnimationFrame(quadro);

    // Handle de depuração/afinação (usado também pelos testes automatizados).
    window.__gl = { estado, bola, cam, get jogadores() { return jogadores; } };
  })();
</script>
