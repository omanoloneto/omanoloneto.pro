---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

const title = 'Página não encontrada — Manolo Neto';
const description = 'Essa página não existe (ou foi pra outra fase). Volte pro início ou visite a sala de aula.';
---

<Layout title={title} description={description}>
  <main class="cartao" id="conteudo">
    <div class="cartao__miolo">
      <p class="eyebrow">Erro 404</p>

      <h1 class="statement">
        <span class="statement__destaque">Game over.</span><br />
        Essa página não existe.
      </h1>

      <p class="contexto">
        Ou o link mudou, ou você digitou errado, ou ela foi pra outra fase.
        Sem problema: é só voltar pro começo.
      </p>

      <div class="acoes">
        <a href="/" class="btn">
          Voltar pro início <Icon name="arrow" size={18} />
        </a>
        <a href="/class/" class="btn btn--ghost">Ir pra sala de aula</a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .cartao {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 48px 24px 28px;
  }

  .cartao__miolo {
    width: min(92vw, 660px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .statement {
    margin-block: 22px 18px;
    font-size: clamp(2.3rem, 7.2vw, 4.1rem);
    line-height: 1.08;
    letter-spacing: -0.025em;
    font-weight: 800;
    color: var(--text);
    text-wrap: balance;
  }
  .statement__destaque {
    color: var(--accent);
  }

  .contexto {
    color: var(--text-soft);
    font-size: clamp(1rem, 2.6vw, 1.13rem);
    line-height: 1.65;
    max-width: 46ch;
  }

  .acoes {
    margin-top: 30px;
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  @media (max-width: 480px) {
    .acoes :global(.btn) {
      width: 100%;
      justify-content: center;
    }
  }
</style>
